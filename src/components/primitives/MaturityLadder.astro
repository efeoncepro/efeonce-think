---
/**
 * MaturityLadder — PRIMITIVA CANÓNICA del hub (la "escalera").
 *
 * Escalera de peldaños de madurez que se suben en orden. Presentación pura + self-contained
 * (estilos + motion propios). Contrato en `@lib/primitives/ladder` (`LadderRung`).
 *
 * Cada peldaño es UNA pieza (card + líquido como base, sin costura):
 *  - altura del pedestal-líquido = posición en la escalera (ordinal)
 *  - color del líquido + chip = severidad ('critico'|'atencion'|'optimo'|'sin_dato')
 *  - score = número; null = "En cobertura" (pedestal con hatch)
 *  - isNext = marcador "Empieza aquí" + anillo de acento
 *
 * Uso:  <MaturityLadder rungs={rungs} />   (rungs ordenados 01→N con isNext resuelto)
 */
import { axis, LEVEL_COPY, severityMeta } from '@lib/report-tokens'
import type { MaturityLadderProps } from '@lib/primitives/ladder'

const { rungs, animate = true, nextLabel = 'Empieza aquí', coverageLabel = 'En cobertura' } =
  Astro.props as MaturityLadderProps

const liquid = (measured: boolean, sevBorder: string) =>
  measured
    ? `linear-gradient(180deg, ${sevBorder}cc 0%, ${sevBorder}30 100%)`
    : `repeating-linear-gradient(135deg, ${axis.gray[100]} 0 10px, ${axis.gray[50]} 10px 20px)`

const rungDefinitions = {
  '01': {
    axis: 'Percepción',
    definition: 'La IA puede descubrir e indexar tu marca. Sin este piso, no hay citas ni recomendaciones.',
  },
  '02': {
    axis: 'Percepción',
    definition: 'Entidad, oferta y contexto quedan claros para la IA: estructura, schema y contenido sin ambigüedad.',
  },
  '03': {
    axis: 'Percepción',
    definition: 'La IA describe tu marca con precisión, sin inventar claims ni confundirte con competidores.',
  },
  '04': {
    axis: 'Operabilidad',
    definition: 'Los agentes pueden operar tu sitio: comparar, consultar, reservar o comprar con menos fricción.',
  },
  '05': {
    axis: 'Percepción',
    definition: 'Tu marca gana preferencia en la categoría por autoridad, consistencia y share of voice sostenido.',
  },
} as const
---

<div class="mladder" data-animate={animate ? '' : undefined} style={`--n:${rungs.length}`}>
  {rungs.map((r, i) => {
    const measured = r.score !== null
    const s = severityMeta(measured ? r.severity : 'sin_dato')
    const level = Object.values(LEVEL_COPY).find((item) => item.ordinal === r.ordinal || item.labelEn === r.eyebrow)
    const definition = rungDefinitions[r.ordinal as keyof typeof rungDefinitions]
    const tooltipId = `maturity-rung-tip-${i}`
    return (
      <div class={`col${r.isNext ? ' is-next' : ''}`}>
        <div class="card">
          {r.isNext && <p class="next" style={`color:${axis.accent[700]}`}>{nextLabel}</p>}
          <div class="card-top">
            <span class="ord" style={`color:${axis.gray[200]}`}>{r.ordinal}</span>
            {measured ? (
              <span class="score" data-rung-score={Math.round(r.score as number)} style={`color:${axis.gray[900]}`}>{Math.round(r.score as number)}</span>
            ) : (
              <span class="cover" style={`background:${axis.gray[100]};color:${axis.gray[600]}`}>{coverageLabel}</span>
            )}
          </div>
          {r.eyebrow && (
            <div class="bex-row">
              <p class="bex" style={`color:${axis.accent[500]}`}>{r.eyebrow}</p>
              {level && definition && (
                <span class="info-wrap">
                  <button
                    class="info-trigger"
                    type="button"
                    aria-label={`Qué significa ${level.labelEn}`}
                    aria-describedby={tooltipId}
                    aria-expanded="false"
                  >
                    i
                  </button>
                  <span class="info-tip" id={tooltipId} role="tooltip">
                    <span class="tip-meta">{definition.axis} · {level.ordinal}</span>
                    <span class="tip-title">{level.labelEn} · {level.label}</span>
                    <span class="tip-body">{definition.definition}</span>
                    <span class="tip-question">{level.question}</span>
                  </span>
                </span>
              )}
            </div>
          )}
          <p class="label" style={`color:${axis.gray[900]}`}>{r.label}</p>
          {r.caption && <p class="q" style={`color:${axis.gray[600]}`}>{r.caption}</p>}
          {measured && <span class="sev" style={`background:${s.bg};color:${s.fg}`}>{s.label}</span>}
        </div>
        <div class={`riser${measured ? ' measured' : ''}`} style={`--i:${i};--liquid:${s.border};background:${measured ? 'transparent' : liquid(measured, s.border)}`}>
          {measured && (
            <svg class="liquid-svg" viewBox="0 0 260 72" preserveAspectRatio="none" aria-hidden="true" focusable="false">
              <path
                class="liquid-body liquid-mass"
                data-calm="M -28 15 C 20 13 54 17 92 15 S 152 12 190 15 S 236 19 288 15 V 86 H -28 Z"
                data-right="M -28 18 C 19 16 55 20 92 18 S 151 12 190 11 S 236 12 288 9 V 86 H -28 Z"
                data-left="M -28 9 C 20 12 54 12 92 14 S 152 19 190 18 S 236 16 288 19 V 86 H -28 Z"
                d="M -28 15 C 20 13 54 17 92 15 S 152 12 190 15 S 236 19 288 15 V 86 H -28 Z"
              ></path>
              <path
                class="liquid-shade liquid-mass"
                data-calm="M -28 34 C 28 31 70 36 112 34 S 176 30 218 34 S 252 38 288 34 V 86 H -28 Z"
                data-right="M -28 38 C 26 34 72 39 113 36 S 176 29 219 31 S 254 34 288 28 V 86 H -28 Z"
                data-left="M -28 28 C 28 30 70 32 112 35 S 176 39 218 37 S 252 34 288 39 V 86 H -28 Z"
                d="M -28 34 C 28 31 70 36 112 34 S 176 30 218 34 S 252 38 288 34 V 86 H -28 Z"
              ></path>
              <ellipse class="liquid-caustic caustic-a" cx="64" cy="42" rx="58" ry="7"></ellipse>
              <ellipse class="liquid-caustic caustic-b" cx="174" cy="56" rx="82" ry="8"></ellipse>
              <path
                class="liquid-rim liquid-mass"
                data-calm="M -28 15 C 20 13 54 17 92 15 S 152 12 190 15 S 236 19 288 15"
                data-right="M -28 18 C 19 16 55 20 92 18 S 151 12 190 11 S 236 12 288 9"
                data-left="M -28 9 C 20 12 54 12 92 14 S 152 19 190 18 S 236 16 288 19"
                d="M -28 15 C 20 13 54 17 92 15 S 152 12 190 15 S 236 19 288 15"
              ></path>
              <path class="liquid-glint" d="M 18 23 C 58 19 88 22 126 20 S 178 19 222 22"></path>
            </svg>
          )}
        </div>
      </div>
    )
  })}
</div>

<style>
  .mladder { margin-top: 1.75rem; display: grid; grid-template-columns: repeat(var(--n), 1fr); align-items: end; gap: 0.75rem; }
  .col {
    position: relative;
    display: flex; flex-direction: column;
    border: 1px solid rgba(0,0,0,0.07); border-radius: 16px; overflow: visible; background: #fff;
    box-shadow: 0 1px 2px rgba(0,0,0,0.04);
    transition: box-shadow 0.18s cubic-bezier(0.2,0,0,1), transform 0.18s cubic-bezier(0.2,0,0,1);
  }
  .col:hover,
  .col:focus-within,
  .col.is-tip-open { z-index: 40; }
  @media (hover: hover) { .col:hover { transform: translateY(-3px); box-shadow: 0 14px 30px -14px rgba(2,60,112,0.3); } }
  .col.is-next {
    border-color: transparent;
    box-shadow: 0 0 0 2px #0375db, 0 10px 26px -12px rgba(3,117,219,0.42);
    background: linear-gradient(180deg, rgba(3,117,219,0.06), #fff 42%);
  }
  .card { position: relative; display: flex; flex-direction: column; gap: 0.12rem; padding: 1rem 1.05rem 1.15rem; border-radius: 16px 16px 0 0; background: inherit; }
  .next { display: inline-flex; align-items: center; gap: 0.28rem; font-size: 0.6875rem; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 0.35rem; }
  .next::before { content: '↑'; font-size: 0.72rem; }
  .card-top { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 0.5rem; }
  .ord { font-size: 1.9rem; font-weight: 700; font-variant-numeric: tabular-nums; line-height: 1; }
  .score { font-size: 1.9rem; font-weight: 600; font-variant-numeric: tabular-nums; line-height: 1; }
  .cover { font-size: 0.6875rem; font-weight: 500; border-radius: 999px; padding: 0.2rem 0.5rem; white-space: nowrap; }
  .bex-row { position: relative; display: inline-flex; align-items: center; gap: 0.35rem; align-self: flex-start; max-width: 100%; }
  .bex { font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; }
  .info-wrap { position: relative; display: inline-flex; align-items: center; z-index: 20; }
  .info-trigger {
    appearance: none; display: inline-grid; place-items: center; width: 0.98rem; height: 0.98rem;
    border: 1px solid rgba(46,38,61,0.1); border-radius: 999px; padding: 0;
    background: linear-gradient(180deg, #433c50, #2e263d);
    color: #fff; font: 750 0.62rem/1 ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    cursor: pointer;
    box-shadow: 0 5px 12px -8px rgba(46,38,61,0.72);
    transition: transform 0.16s cubic-bezier(0.2,0,0,1), box-shadow 0.16s cubic-bezier(0.2,0,0,1), border-color 0.16s cubic-bezier(0.2,0,0,1);
  }
  .info-trigger:hover,
  .info-trigger:focus-visible,
  .info-wrap.is-open .info-trigger {
    transform: translateY(-1px);
    border-color: rgba(46,38,61,0.2);
    box-shadow: 0 12px 24px -16px rgba(46,38,61,0.72);
    outline: none;
  }
  .info-tip {
    position: absolute; left: 50%; top: calc(100% + 0.5rem); width: min(15.75rem, 78vw);
    display: grid; gap: 0.28rem; padding: 0.68rem 0.72rem 0.72rem;
    border: 1px solid rgba(46,38,61,0.1); border-radius: 12px;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.98), rgba(250,250,251,0.96)),
      radial-gradient(90% 130% at 12% 0%, rgba(46,38,61,0.045), transparent 62%);
    color: #2e263d;
    box-shadow: 0 18px 38px -28px rgba(46,38,61,0.42), 0 1px 5px rgba(46,38,61,0.06);
    opacity: 0; pointer-events: none;
    transform: translateX(-50%) translateY(-5px) scale(0.98);
    transform-origin: 50% 0;
    transition: opacity 0.16s cubic-bezier(0.2,0,0,1), transform 0.16s cubic-bezier(0.2,0,0,1);
  }
  .info-tip::before {
    content: ''; position: absolute; left: 50%; top: -6px; width: 10px; height: 10px;
    border-left: 1px solid rgba(46,38,61,0.1); border-top: 1px solid rgba(46,38,61,0.1);
    background: rgba(255,255,255,0.98);
    transform: translateX(-50%) rotate(45deg);
  }
  .info-wrap:hover .info-tip,
  .info-wrap:focus-within .info-tip,
  .info-wrap.is-open .info-tip {
    opacity: 1; pointer-events: auto;
    transform: translateX(-50%) translateY(0) scale(1);
  }
  .col:nth-last-child(-n+2) .info-tip {
    left: auto; right: 0;
    transform: translateY(-5px) scale(0.98);
    transform-origin: 90% 0;
  }
  .col:nth-last-child(-n+2) .info-tip::before {
    left: auto; right: 0.48rem;
    transform: rotate(45deg);
  }
  .col:nth-last-child(-n+2) .info-wrap:hover .info-tip,
  .col:nth-last-child(-n+2) .info-wrap:focus-within .info-tip,
  .col:nth-last-child(-n+2) .info-wrap.is-open .info-tip {
    transform: translateY(0) scale(1);
  }
  .tip-meta { color: #6d6777; font-size: 0.58rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; }
  .tip-title { color: #2e263d; font-size: 0.76rem; font-weight: 760; line-height: 1.2; }
  .tip-body { color: #625c6b; font-size: 0.7rem; font-weight: 500; line-height: 1.38; }
  .tip-question {
    margin-top: 0.04rem; color: #433c50; font-size: 0.68rem; font-weight: 720; line-height: 1.28;
  }
  .tip-question::before { content: 'Guía: '; color: #8a8591; font-weight: 650; }
  .label { margin-top: 0.12rem; font-weight: 600; font-size: 0.92rem; line-height: 1.2; }
  .q { margin-top: 0.2rem; font-size: 0.76rem; line-height: 1.3; }
  .sev { align-self: flex-start; margin-top: 0.55rem; border-radius: 999px; padding: 0.12rem 0.5rem; font-size: 0.6875rem; font-weight: 600; }
  .riser {
    position: relative; height: calc(10px + var(--i, 0) * 18px); overflow: hidden; isolation: isolate;
    border-radius: 0 0 16px 16px;
    --liquid-depth: 1;
  }
  .riser.measured {
    background: color-mix(in srgb, var(--liquid) 18%, #fff 82%);
    box-shadow:
      inset 0 8px 14px rgba(255,255,255,0.26),
      inset 0 -12px 18px rgba(0,0,0,0.1);
  }
  .riser.measured::before {
    content: ''; position: absolute; z-index: 1; inset: 0;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.38), transparent 34%),
      radial-gradient(80% 120% at 50% 110%, color-mix(in srgb, var(--liquid) 32%, transparent), transparent 70%);
    pointer-events: none;
  }
  .riser.measured::after {
    content: ''; position: absolute; z-index: 2; inset: 0;
    background: linear-gradient(100deg, transparent 35%, rgba(255,255,255,0.28) 50%, transparent 65%);
    transform: translateX(-120%); animation: mladder-sheen 4.5s ease-in-out infinite;
  }
  .liquid-svg {
    position: absolute; z-index: 3; inset: -10px -10% -3px;
    width: 120%; height: calc(100% + 18px); overflow: visible;
    transform-origin: 50% 14px;
    will-change: transform;
    pointer-events: none;
  }
  .liquid-body,
  .liquid-shade {
    fill: var(--liquid); transform-box: fill-box; transform-origin: center top;
  }
  .liquid-body {
    opacity: 0.82;
    filter: drop-shadow(0 -1px 0 rgba(255,255,255,0.2));
  }
  .liquid-shade {
    opacity: 0.14;
    mix-blend-mode: multiply;
    filter: blur(2.5px);
  }
  .liquid-rim {
    fill: none; stroke: color-mix(in srgb, var(--liquid) 88%, #fff 12%); stroke-width: 2.8; stroke-linecap: round;
    opacity: 0.88; filter: drop-shadow(0 3px 6px rgba(0,0,0,0.08));
    transform-box: fill-box; transform-origin: center;
  }
  .liquid-glint {
    fill: none; stroke: rgba(255,255,255,0.48); stroke-width: 1.4; stroke-linecap: round;
    opacity: 0.42; mix-blend-mode: screen;
    transform-box: fill-box; transform-origin: center;
  }
  .liquid-caustic {
    fill: rgba(255,255,255,0.24);
    opacity: 0.22;
    filter: blur(5px);
    mix-blend-mode: screen;
    transform-box: fill-box; transform-origin: center;
  }
  .caustic-b { opacity: 0.14; }
  @keyframes mladder-sheen { 0%, 60%, 100% { transform: translateX(-120%); } 80% { transform: translateX(120%); } }
  @media (max-width: 720px) {
    .mladder { grid-template-columns: 1fr; gap: 0.55rem; align-items: stretch; }
    .riser { height: 10px !important; }
    .col:nth-last-child(-n+2) .info-tip,
    .info-tip { left: 50%; right: auto; width: min(18rem, calc(100vw - 2.5rem)); transform: translateX(-36%) translateY(-5px) scale(0.98); }
    .col:nth-last-child(-n+2) .info-tip::before,
    .info-tip::before { left: 36%; right: auto; transform: translateX(-50%) rotate(45deg); }
    .col:nth-last-child(-n+2) .info-wrap:hover .info-tip,
    .col:nth-last-child(-n+2) .info-wrap:focus-within .info-tip,
    .col:nth-last-child(-n+2) .info-wrap.is-open .info-tip,
    .info-wrap:hover .info-tip,
    .info-wrap:focus-within .info-tip,
    .info-wrap.is-open .info-tip { transform: translateX(-36%) translateY(0) scale(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .liquid-svg { will-change: auto; }
    .riser.measured::after { animation: none; opacity: 0; }
  }
</style>

<script>
  // Motion self-contained de la primitiva: los peldaños suben en secuencia + count-up.
  // El pedestal-líquido NO se anima (estático/lleno siempre → nunca colapsa). Robusto:
  // fail-safe global + reduced-motion + bien bajo el fold. Soporta múltiples instancias.
  import gsap from 'gsap'
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
  document.querySelectorAll<HTMLElement>('.mladder[data-animate]').forEach((ladder) => {
    const cols = Array.from(ladder.querySelectorAll<HTMLElement>('.col'))
    if (!cols.length) return
    const tooltipWraps = Array.from(ladder.querySelectorAll<HTMLElement>('.info-wrap'))
    const closeTooltips = () => {
      tooltipWraps.forEach((wrap) => {
        wrap.classList.remove('is-open')
        wrap.closest<HTMLElement>('.col')?.classList.remove('is-tip-open')
        wrap.querySelector<HTMLButtonElement>('.info-trigger')?.setAttribute('aria-expanded', 'false')
      })
    }
    tooltipWraps.forEach((wrap) => {
      const trigger = wrap.querySelector<HTMLButtonElement>('.info-trigger')
      if (!trigger) return
      trigger.addEventListener('click', (event) => {
        event.stopPropagation()
        const willOpen = !wrap.classList.contains('is-open')
        closeTooltips()
        wrap.classList.toggle('is-open', willOpen)
        wrap.closest<HTMLElement>('.col')?.classList.toggle('is-tip-open', willOpen)
        trigger.setAttribute('aria-expanded', String(willOpen))
      })
    })
    document.addEventListener('click', (event) => {
      if (!ladder.contains(event.target as Node)) closeTooltips()
    })
    ladder.addEventListener('click', (event) => {
      const target = event.target as HTMLElement
      if (!target.closest('.info-wrap')) closeTooltips()
    })
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeTooltips()
    })
    if (reduce) return
    cols.forEach((col) => {
      const riser = col.querySelector<HTMLElement>('.riser.measured')
      const liquid = col.querySelector<SVGElement>('.liquid-svg')
      const masses = Array.from(col.querySelectorAll<SVGPathElement>('.liquid-mass'))
      const caustics = Array.from(col.querySelectorAll<SVGElement>('.liquid-caustic, .liquid-glint'))
      if (!riser) return
      const morphTo = (nodes: SVGPathElement[], state: 'calm' | 'right' | 'left', vars = {}) => {
        nodes.forEach((node) => {
          const value = node.dataset[state]
          if (value) gsap.to(node, { attr: { d: value }, overwrite: 'auto', ...vars })
        })
      }
      col.addEventListener('pointerenter', () => {
        gsap.killTweensOf([liquid, masses, caustics])
        const tl = gsap.timeline({ defaults: { overwrite: 'auto' } })
        if (liquid) {
          tl.add(() => morphTo(masses, 'right', { duration: 0.2, ease: 'sine.out' }), 0)
            .to(liquid, { xPercent: 6, y: -1.5, rotation: -2.8, scaleX: 1.035, duration: 0.2, ease: 'sine.out' }, 0)
            .to(caustics, { xPercent: -10, opacity: 0.34, duration: 0.2, stagger: 0.025, ease: 'sine.out' }, 0)
            .add(() => morphTo(masses, 'left', { duration: 0.34, ease: 'sine.inOut' }), 0.2)
            .to(liquid, { xPercent: -4, y: 0.5, rotation: 2.1, scaleX: 1.018, duration: 0.34, ease: 'sine.inOut' }, 0.2)
            .to(caustics, { xPercent: 8, opacity: 0.22, duration: 0.34, stagger: 0.025, ease: 'sine.inOut' }, 0.2)
            .add(() => morphTo(masses, 'calm', { duration: 0.76, ease: 'elastic.out(1,0.55)' }), 0.54)
            .to(liquid, { xPercent: 0, y: 0, rotation: 0, scaleX: 1, duration: 0.76, ease: 'elastic.out(1,0.55)' }, 0.54)
            .to(caustics, { xPercent: 0, opacity: 0.22, duration: 0.76, stagger: 0.025, ease: 'elastic.out(1,0.55)' }, 0.54)
        }
      })
      col.addEventListener('pointermove', (event) => {
        const e = event as PointerEvent
        const rect = col.getBoundingClientRect()
        const ratio = Math.max(-0.5, Math.min(0.5, (e.clientX - rect.left) / rect.width - 0.5))
        if (liquid) {
          morphTo(masses, ratio > 0.04 ? 'left' : ratio < -0.04 ? 'right' : 'calm', { duration: 0.28, ease: 'sine.out' })
          gsap.to(liquid, { xPercent: ratio * -11, y: Math.abs(ratio) * -1.3, rotation: ratio * 5.2, scaleX: 1 + Math.abs(ratio) * 0.045, duration: 0.24, ease: 'sine.out', overwrite: 'auto' })
          gsap.to(caustics, { xPercent: ratio * 18, opacity: 0.18 + Math.abs(ratio) * 0.28, duration: 0.3, ease: 'sine.out', overwrite: 'auto' })
        }
      })
      col.addEventListener('pointerleave', () => {
        if (liquid) gsap.to(liquid, { xPercent: 0, y: 0, rotation: 0, scaleX: 1, duration: 0.9, ease: 'elastic.out(1,0.5)', overwrite: 'auto' })
        morphTo(masses, 'calm', { duration: 0.9, ease: 'elastic.out(1,0.5)' })
        gsap.to(caustics, { xPercent: 0, opacity: 0.22, duration: 0.9, ease: 'elastic.out(1,0.5)', overwrite: 'auto' })
      })
    })
    let played = false
    gsap.set(cols, { opacity: 0, y: 26 })
    const play = () => {
      if (played) return
      played = true
      gsap.to(cols, { opacity: 1, y: 0, duration: 0.55, stagger: 0.13, ease: 'power3.out' })
      ladder.querySelectorAll<HTMLElement>('[data-rung-score]').forEach((el, i) => {
        const t = parseFloat(el.dataset.rungScore || '0')
        const o = { v: 0 }
        gsap.to(o, { v: t, duration: 0.8, delay: 0.2 + i * 0.13, ease: 'power2.out', onUpdate: () => { el.textContent = String(Math.round(o.v)) } })
      })
      const risers = Array.from(ladder.querySelectorAll<HTMLElement>('.riser.measured'))
      const liquids = risers
        .map((r) => r.querySelector<SVGElement>('.liquid-svg'))
        .filter((el): el is SVGElement => Boolean(el))
      const masses = Array.from(ladder.querySelectorAll<SVGPathElement>('.liquid-mass'))
      const caustics = Array.from(ladder.querySelectorAll<SVGElement>('.liquid-caustic, .liquid-glint'))
      gsap.fromTo(
        liquids,
        { xPercent: -12, y: -2, rotation: -3.6, scaleX: 1.05 },
        { xPercent: 0, y: 0, rotation: 0, scaleX: 1, duration: 1.18, delay: 0.2, stagger: 0.12, ease: 'elastic.out(1,0.52)' },
      )
      masses.forEach((node, i) => {
        gsap.fromTo(
          node,
          { xPercent: 8, attr: { d: node.dataset.left || node.getAttribute('d') || '' } },
          { xPercent: 0, attr: { d: node.dataset.calm || node.getAttribute('d') || '' }, duration: 1.18, delay: 0.2 + i * 0.014, ease: 'elastic.out(1,0.52)' },
        )
      })
      gsap.fromTo(
        caustics,
        { xPercent: -18, opacity: 0.08 },
        { xPercent: 0, opacity: 0.22, duration: 1.18, delay: 0.2, stagger: 0.02, ease: 'elastic.out(1,0.52)' },
      )
    }
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) { play(); io.disconnect() } })
    }, { threshold: 0.15 })
    io.observe(ladder)
    window.setTimeout(() => { if (!played) gsap.set(cols, { clearProps: 'all' }) }, 3500)
  })
</script>
