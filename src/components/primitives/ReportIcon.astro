      <path d="M8.4 13.2l7.2 3.8" />
    </>
  )}

  {name === 'copy' && (
    <>
      <rect x="8.2" y="7.2" width="10.3" height="12" rx="2" />
      <path d="M5.5 16.8V6.5a2 2 0 0 1 2-2h8.3" />
