      <path d="M9.8 13.2a3.1 3.1 0 0 1 0-4.4l2.4-2.4a3.1 3.1 0 0 1 4.4 4.4l-1.1 1.1" />
      <path d="M14.2 10.8a3.1 3.1 0 0 1 0 4.4l-2.4 2.4a3.1 3.1 0 0 1-4.4-4.4l1.1-1.1" />
    </>
  )}

  {name === 'download' && (
    <>
      <path d="M12 4.5v10" />
      <path d="M8.2 10.8L12 14.6l3.8-3.8" />
      <path d="M5.2 18.8h13.6" />
      <path d="M6.8 16.2v2.6" />
      <path d="M17.2 16.2v2.6" />
    </>
  )}
</svg>
