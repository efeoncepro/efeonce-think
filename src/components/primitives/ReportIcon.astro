      <path d="M12 16.8h.01" />
    </>
  )}

  {name === 'read' && (
    <>
      <path d="M5.5 5.5h4.3a3.2 3.2 0 0 1 3.2 3.2v10.1a3.8 3.8 0 0 0-3.2-1.8H5.5Z" />
      <path d="M18.5 5.5h-4.3A3.2 3.2 0 0 0 11 8.7v10.1a3.8 3.8 0 0 1 3.2-1.8h4.3Z" />
