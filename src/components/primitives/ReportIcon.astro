      <path d="M4.8 17.8c.6-2.8 2.2-4.2 4.2-4.2s3.6 1.4 4.2 4.2" />
      <circle cx="16.2" cy="9.4" r="2.1" />
      <path d="M13.9 16.2c.6-1.5 1.8-2.3 3.2-2.3 1.5 0 2.6.8 3.1 2.3" />
    </>
  )}

  {name === 'priority' && (
    <>
      <path d="M12 4.2v15.6" />
      <path d="M7.2 9l4.8-4.8L16.8 9" />
