      <rect x="13.5" y="5" width="6" height="6" rx="1.5" />
      <rect x="4.5" y="14" width="6" height="6" rx="1.5" />
      <path d="M14 16.2h5" />
      <path d="M14 18.8h3.2" />
    </>
  )}

  {name === 'target' && (
    <>
      <circle cx="12" cy="12" r="7.2" />
      <circle cx="12" cy="12" r="3.7" />
      <path d="M12 4.8v2.4" />
      <path d="M12 16.8v2.4" />
      <path d="M4.8 12h2.4" />
      <path d="M16.8 12h2.4" />
    </>
  )}

  {name === 'market' && (
    <>
      <path d="M5.5 19V9.2" />
      <path d="M10 19V5.5" />
      <path d="M14.5 19v-7.2" />
      <path d="M19 19V8" />
      <path d="M4.5 19h16" />
      <path d="M5.5 9.2l4.5-3.7 4.5 6.3L19 8" />
