---
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'

// La tipografía del CLIENTE. La importa el componente que la USA — nunca se hereda
// de un vecino: exactamente el bug que nos costó cuatro pantallas en ExtraBold.
// Variable (eje wght 200–800): un solo archivo cubre el 400 y el 700 de SKY.
import '@fontsource-variable/assistant'

/**
 * El ESPÉCIMEN — el artículo tal como se vería publicado.
 *
 * Es EDITORIAL, no product UI: es el mockup de un blog real (cuerpo 18px, interlineado 1.7,
 * medida 64ch, imágenes que respiran). Aplicarle densidad de producto fue el error que lo
 * dejaba plano — le mostrábamos al comité un wireframe del contenido, no el contenido.
 *
 * `coupled=false` (pantalla ② «El artículo»): se LEE. Sin chips, sin tabindex, sin ruido.
 * `coupled=true`  (pantalla ③ «La radiografía»): cada bloque se acopla con su capa de máquina.
 */

type Sample = CollectionEntry<'aeoXray'>['data']

interface Props {
  d: Sample
  coupled?: boolean
  /** Cuántos datos de máquina produce cada bloque — alimenta el chip direccional. */
  produces?: Map<string, number>
  hero?: string
}

const { d, coupled = false, produces = new Map(), hero } = Astro.props
const { article, ui, machine } = d

type Block = (typeof article.blocks)[number]
type ImageBlock = Extract<Block, { type: 'image' | 'hero-image' }>
const isImage = (b: Block): b is ImageBlock => b.type === 'image' || b.type === 'hero-image'

const articleBlocks: Block[] = (() => {
  if (coupled) return [...article.blocks]

  const blocks = [...article.blocks]
  const heroIndex = blocks.findIndex(b => b.type === 'hero-image')
  const headlineIndex = blocks.findIndex(b => b.type === 'h1')

  // La ② es lectura editorial. Un blog premium abre con titular/firma antes de
  // pedirle al lector que atraviese una foto de 16:9 completa.
  if (heroIndex >= 0 && headlineIndex > heroIndex) {
    const [headline] = blocks.splice(headlineIndex, 1)
    blocks.splice(heroIndex, 0, headline)
  }

  return blocks
})()

/**
 * La FIRMA (categoría · autor · fecha · lectura). No es adorno: el `BlogPosting` declara
 * `author`, `datePublished` y `articleSection`, y el schema SOLO puede marcar contenido
 * VISIBLE. Sin la firma, la muestra violaría su propia tesis.
 */
const words = article.blocks.reduce((n, b) => {
  const t =
    'text' in b ? b.text
    : b.type === 'faq' ? b.items.map(i => `${i.q} ${i.a}`).join(' ')
    : b.type === 'ordered-list' ? b.items.join(' ')
    : b.type === 'table' ? b.rows.flat().join(' ')
    : ''

  return n + t.split(/\s+/).filter(Boolean).length
}, 0)
const readMin = Math.max(1, Math.round(words / 200))
const published = new Date(`${article.publishedAt}T12:00:00Z`).toLocaleDateString('es-CL', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
  timeZone: 'UTC',
})

/**
 * El ÍNDICE se DERIVA de los H2 del propio artículo. No se declara aparte.
 * Un índice declarado a mano se desincroniza el día que alguien renombra un título —
 * y no falla nada, solo miente. Acá el drift es imposible por construcción.
 *
 * Nota: el H2 es una PREGUNTA (así lo recupera un motor de respuesta: por pasaje).
 * El índice es un MAPA (así lo escanea un humano en dos segundos). No son el mismo
 * texto, y por eso el H2 lleva `short` además de `text`.
 */
/* El índice se DERIVA de las secciones — nunca se escribe a mano (el drift sería inevitable).
   El FAQ es una sección más: el árbol de encabezados lo declara como H2 y cubre dos preguntas
   del fan-out. Dejarlo fuera lo volvía la única sección sin ancla y sin entrada en el índice. */
const tocItems = article.blocks.flatMap(b =>
  b.type === 'h2' || b.type === 'faq' ? [{ anchor: b.anchor, short: b.short }] : [],
)

/**
 * 🔴 EL BLOQUE NO ES UN CONTROL. EL BOTÓN DENTRO DE ÉL, SÍ.
 *
 * Antes cada bloque acoplable era un `<div tabindex="0">` **sin rol, sin nombre accesible y sin
 * relación ARIA con el panel**. Tres consecuencias:
 *   · Al lector de pantalla se le presentaba como contenido plano que casualmente recibe foco: nada
 *     le decía que ese bloque CONTROLA un panel remoto, ni dónde aterriza el resultado. El eje entero
 *     de la pieza —la correspondencia artículo ↔ capa de máquina— le era invisible.
 *   · Un `div[tabindex=0]` **no dispara `click` con Enter ni Space** → fijar/soltar el acoplamiento
 *     era una función EXCLUSIVA DEL MOUSE (WCAG 2.1.1).
 *   · Y 22 tab-stops que sin JS no hacían absolutamente nada.
 *
 * No se convierte el bloque en `role="button"`: un `<h2>` dentro de un botón es peor semántica que
 * el problema. El patrón correcto es el **disclosure remoto** — el punto que era un `::before`
 * decorativo pasa a ser un `<button>` de verdad, con `aria-controls` al panel y `aria-expanded`.
 * El botón hereda foco, rol, nombre y Enter/Space **gratis**.
 */
const attrsFor = (id: string) => {
  if (!coupled) return {}
  const n = produces.get(id) ?? 0

  return {
    'data-couple': id,
    'data-on': id === hero ? true : undefined,
    'data-n': n > 0 ? `${n} ${n === 1 ? ui.producesLabelOne : ui.producesLabel}` : undefined,
  }
}

/** El nombre accesible del botón: sale del copy que ya existe en el payload. */
const probeFor = (id: string) => {
  const n = produces.get(id) ?? 0

  return coupled && n > 0 ? ui.srProduces.replace('{n}', String(n)) : null
}
---

<section class={`sp ${coupled ? 'sp-split' : 'sp-read'}`} aria-labelledby="sp-t">
  <div class="sp-head">
    <div>
      <h2 id="sp-t">{ui.paneArticleTitle}</h2>
      <p>{ui.paneArticleSubtitle}</p>
    </div>
    {/* La URL propuesta, en su contexto: es el mismo valor que el instrumento declara canónico. */}
    <span class="urlbar" title={article.proposedUrl}>
      <span class="lock" aria-hidden="true">🔒</span>
      <span class="url">{article.proposedUrl.replace('https://', '')}</span>
    </span>
  </div>

  <article class="post xr-article">
    {articleBlocks.map(b => {
      if (!('coupleId' in b)) {
        if (b.type === 'paragraph') return <p class="para">{b.text}</p>

        return null
      }

      const a = attrsFor(b.coupleId)
      const probe = probeFor(b.coupleId)

      if (isImage(b))
        return (
          <figure class={`blk fig ${b.type === 'hero-image' ? 'hero' : ''}`} {...a}>
            {probe && (
              <button class="probe" type="button" data-probe aria-controls="in-body" aria-expanded="false">
                {probe}
              </button>
            )}
            {/* `<Image>` de astro:assets: de acá salen width/height (sin ellos, CLS), el srcset
                (sin él un teléfono baja el hero de escritorio) y AVIF. Una pieza que argumenta
                rigor técnico no puede reprobar su propio PageSpeed. */}
            <Image
              class={b.type === 'hero-image' ? 'xr-hero-img' : ''}
              src={b.src}
              alt={b.alt}
              widths={
                b.type === 'hero-image'
                  ? coupled ? [640, 960, 1400] : [640, 960, 1400, 1600]
                  : coupled ? [480, 720, 1000] : [480, 720, 1000, 1400]
              }
              sizes={
                b.type === 'hero-image'
                  ? coupled ? '(min-width: 1080px) 52vw, 100vw' : '(min-width: 1440px) 1400px, (min-width: 820px) calc(100vw - 4rem), 100vw'
                  : coupled ? '(min-width: 1080px) 46vw, 92vw' : '(min-width: 820px) 980px, 92vw'
              }
              format="avif"
              quality={72}
              loading={b.type === 'hero-image' ? 'eager' : 'lazy'}
              fetchpriority={b.type === 'hero-image' ? 'high' : 'auto'}
            />
            <div class="fig-m">
              {b.caption && <figcaption>{b.caption}</figcaption>}
              <p class="credit">
                Foto: {b.credit.author} · <a href={b.credit.url} rel="nofollow noopener">{b.credit.license}</a>
              </p>
            </div>
          </figure>
        )

      if (b.type === 'h1')
        return (
          <div class="blk head-blk" {...a}>
            {probe && (
              <button class="probe" type="button" data-probe aria-controls="in-body" aria-expanded="false">
                {probe}
              </button>
            )}
            <p class="cat">{article.category}</p>
            <h3 class="p-h1">{b.text}</h3>
            <p class="byline">
              {ui.bylineBy} <b>{article.author}</b>
              <span class="dot" aria-hidden="true">·</span>
              <time datetime={article.publishedAt}>{published}</time>
              <span class="dot" aria-hidden="true">·</span>
              {readMin} {ui.readTime}
            </p>
          </div>
        )
      if (b.type === 'h2')
        return (
          <div class="blk" {...a}>
            {/* `scroll-margin-top` en el CSS: sin él, el ancla deja el título BAJO el
                header pegajoso. Es el mismo WCAG 2.4.11 que ya nos mordió una vez. */}
            <h4 class="p-h2" id={b.anchor}>{b.text}</h4>
            {probe && (
              <button class="probe" type="button" data-probe aria-controls="in-body" aria-expanded="false">
                {probe}
              </button>
            )}
          </div>
        )
      if (b.type === 'toc')
        return (
          <nav class="toc" aria-labelledby="toc-t">
            <p class="toc-t" id="toc-t">{b.title}</p>
            <ol>
              {tocItems.map(h => (
                <li>
                  <a href={`#${h.anchor}`}>{h.short}</a>
                </li>
              ))}
            </ol>
          </nav>
        )
      /* LA CÁPSULA. En la ③ va con su aparato (recuadro + rótulo): ahí es donde el trabajo
         DEBE verse. En la ② va como lo que ES para el lector — el primer párrafo de la
         sección, el que responde de una. Seis cajas de color gritan «acá hay una técnica
         aplicada» tan fuerte como el letrero que las nombra, y en un blog real no existen.
         🔴 Y no cuesta NADA en AEO: el valor de la cápsula vive en el TEXTO (answer-first,
         40-60 palabras, bajo su H2). El motor lee el texto, no el CSS. */
      if (b.type === 'answer-capsule')
        return (
          <div class={`blk ${coupled ? 'cap' : 'cap-read'}`} {...a}>
            {coupled && <span class="cap-t">Respuesta directa</span>}
            <p>{b.text}</p>
            {probe && (
              <button class="probe" type="button" data-probe aria-controls="in-body" aria-expanded="false">
                {probe}
              </button>
            )}
          </div>
        )
      if (b.type === 'pull-quote')
        return (
          <blockquote class="blk pull" {...a}>
            <p>{b.text}</p>
            {probe && (
              <button class="probe" type="button" data-probe aria-controls="in-body" aria-expanded="false">
                {probe}
              </button>
            )}
          </blockquote>
        )
      if (b.type === 'table')
        return (
          <div class="blk" {...a}>
            {probe && (
              <button class="probe" type="button" data-probe aria-controls="in-body" aria-expanded="false">
                {probe}
              </button>
            )}
            <div class="tw">
              <table>
                <caption>{b.caption}</caption>
                <thead><tr>{b.headers.map(h => <th scope="col">{h}</th>)}</tr></thead>
                <tbody>{b.rows.map(r => <tr>{r.map(c => <td>{c}</td>)}</tr>)}</tbody>
              </table>
            </div>
          </div>
        )
      if (b.type === 'ordered-list')
        return (
          <div class="blk" {...a}>
            <p class="blk-t">{b.title}</p>
            <ol>{b.items.map(i => <li>{i}</li>)}</ol>
            {probe && (
              <button class="probe" type="button" data-probe aria-controls="in-body" aria-expanded="false">
                {probe}
              </button>
            )}
          </div>
        )
      if (b.type === 'faq')
        return (
          <div class="blk faq" {...a}>
            {/* Encabezado de SECCIÓN, igual que los otros cinco — no un párrafo en negrita.
                El árbol de la capa de máquina lo declara como H2 y aquí cubre dos preguntas
                del fan-out: si renderiza como <p>, el instrumento declara un encabezado que
                la página no tiene. Mismo `p-h2` + ancla que el resto (WCAG 2.4.11 incluido). */}
            <h4 class="p-h2" id={b.anchor}>{b.title}</h4>
            {b.items.map(i => (
              <div class="qa">
                <p class="q">{i.q}</p>
                <p class="a">{i.a}</p>
              </div>
            ))}
            {probe && (
              <button class="probe" type="button" data-probe aria-controls="in-body" aria-expanded="false">
                {probe}
              </button>
            )}
          </div>
        )
      if (b.type === 'internal-links')
        return (
          <div class="blk" {...a}>
            <p class="blk-t">{b.title}</p>
            <ul class="lnks">
              {b.items.map(i => (
                <li>
                  <a href={i.href} rel="nofollow noopener">{i.text}</a>
                  {i.note && <em> — {i.note}</em>}
                </li>
              ))}
            </ul>
            {probe && (
              <button class="probe" type="button" data-probe aria-controls="in-body" aria-expanded="false">
                {probe}
              </button>
            )}
          </div>
        )
      if (b.type === 'sources')
        return (
          <div class="blk srcs" {...a}>
            <p class="blk-t">{b.title}</p>
            <ul>{b.items.map(i => <li><a href={i.href} rel="nofollow noopener">{i.text}</a></li>)}</ul>
            {probe && (
              <button class="probe" type="button" data-probe aria-controls="in-body" aria-expanded="false">
                {probe}
              </button>
            )}
          </div>
        )

      return null
    })}
  </article>

  {/* El pie de licencias ES la demostración del requisito 5 de las bases — pero es NUESTRA
      prueba, no el artículo del lector. Ojo: el crédito de cada foto SÍ se queda dentro del
      artículo (un blog real acredita sus imágenes); lo que sale de la ② es este INVENTARIO
      con la nota de servicio, que es un argumento comercial y no una pieza editorial.
      Enseñarlo en la pantalla que se llama «lo que ve el lector» sería mentir en el rótulo. */}
  {coupled && (
    <footer class="lic" data-testid="licenses">
      <p class="lic-t">{ui.licenseTitle}</p>
      <ul>
        {article.blocks.filter(isImage).map(i => (
          <li>
            <span class="lic-a">{i.alt}</span>
            <span class="lic-c">{i.credit.author} · <a href={i.credit.url} rel="nofollow noopener">{i.credit.license}</a></span>
          </li>
        ))}
      </ul>
      <p class="lic-n">{ui.licenseNote}</p>
    </footer>
  )}
</section>

<style>
  /* El espécimen es EDITORIAL. Ver la nota del frontmatter. */
  .sp {
    --a-body: 1.125rem;
    --a-lead: 1.25rem;
    --a-h1: 2.25rem;
    --a-h2: 1.5rem;
    --read-measure: min(64ch, calc(100% - 3.5rem));
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 12px;
    min-width: 0;
  }
  /* Leyendo (pantalla ②): la medida manda, no el ancho del contenedor. */
  .sp-read {
    --a-h1: 2.56rem;
    --a-body: 1.15rem;
    --a-lead: 1.24rem;
    --read-measure: min(44rem, 100%);
    --read-gutter: clamp(1.5rem, 5vw, 5rem);
    --read-gap: clamp(1.35rem, 3vw, 2.75rem);
    width: min(100%, 86rem);
    max-width: none;
    margin-inline: auto;
    overflow: hidden;
    border-color: color-mix(in srgb, var(--line) 86%, white);
    border-radius: 14px;
    box-shadow:
      0 34px 90px color-mix(in srgb, var(--navy) 11%, transparent),
      0 1px 0 rgb(255 255 255 / 0.9) inset;
  }

  .sp-head {
    display: flex; justify-content: space-between; align-items: center; gap: 1rem;
    padding: 0.9rem 1.1rem; border-bottom: 1px solid var(--line); background: var(--surf);
    border-radius: 12px 12px 0 0;
  }
  .sp-head h2 { font-size: var(--t-body); font-weight: var(--w-label); }
  .sp-head p { font-size: var(--t-meta); color: var(--muted); }
  .urlbar {
    display: flex; gap: 0.4rem; align-items: center; min-width: 0; max-width: 24rem;
    font-size: var(--t-meta); color: var(--muted);
    background: var(--surf-2); border: 1px solid var(--line);
    padding: 0.3rem 0.7rem; border-radius: 999px;
  }
  .lock { font-size: 0.625rem; opacity: 0.6; }
  .url { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .sp-read .sp-head {
    padding: 0.72rem 0.9rem;
    background: linear-gradient(180deg, #fff, var(--surf));
    border-radius: 14px 14px 0 0;
  }
  .sp-read .sp-head h2 {
    color: var(--ink-3);
    font-size: var(--t-meta);
  }
  .sp-read .sp-head p { display: none; }
  .sp-read .urlbar {
    max-width: min(32rem, 62vw);
    background: #fff;
  }

  .xr-article {
    font-family: var(--client-font);
    font-weight: var(--w-client-body);
  }
  .post { padding: 0 0 1.5rem; }
  .post > .para { margin-inline: 1.75rem; }
  .blk { position: relative; padding: 0.5rem 0.75rem; border-radius: 8px; border-left: 3px solid transparent; }
  .post > .blk:not(.fig) { margin-inline: 1rem; }
  @media (max-width: 640px) {
    .post > .para { margin-inline: 1.15rem; }
    .post > .blk:not(.fig) { margin-inline: 0.4rem; }
  }
  .blk.fig { padding: 0; border-left: 0; }

  /* El hero es un HERO: a sangre, 21:9. Era un thumbnail recortado a 150px. */
  .fig { margin: 1.75rem 0; }
  .fig.hero { margin: 0 0 1.5rem; }
  .fig :global(img) { width: 100%; height: auto; display: block; border-radius: 8px; }
  /* TODAS a 16:9, hero incluido. El hero era una franja 21:9 y ése fue el error:
     sacar una franja 21:9 de una foto 3:2 tira el 60% del alto — la composición del
     fotógrafo (el camino, el primer plano) se pierde y queda solo cielo. 16:9 desde
     3:2 recorta ~15% de alto: la foto sobrevive. El formato se elige por la foto,
     no al revés. */
  .fig :global(img) { aspect-ratio: 16 / 9; object-fit: cover; }
  .fig.hero :global(img) { border-radius: 0; }
  .fig-m { padding: 0.55rem 1.75rem 0; }
  .sp-read .post {
    display: grid;
    grid-template-columns:
      minmax(var(--read-gutter), 5rem)
      minmax(0, var(--read-measure))
      minmax(15rem, 1fr);
    column-gap: var(--read-gap);
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }
  .sp-read .post > .para,
  .sp-read .post > .blk:not(.fig),
  .sp-read .fig-m {
    grid-column: 2;
    box-sizing: border-box;
    width: 100%;
    max-width: none;
    margin-inline: 0;
  }
  .sp-read .post > .blk:not(.fig) {
    padding-inline: 0;
  }
  .sp-read .post > .fig {
    grid-column: 2 / 4;
    width: 100%;
  }
  .sp-read .fig {
    display: block;
  }
  .sp-read .fig :global(img) {
    width: 100%;
  }
  .sp-read .fig.hero :global(img) {
    grid-column: auto;
  }
  .sp-read .fig.hero {
    margin-block: 0 clamp(2.4rem, 4.8vw, 3.6rem);
  }
  .sp-read .fig:not(.hero) {
    margin-block: clamp(2.4rem, 5vw, 3.8rem);
  }
  .sp-read .fig-m {
    padding-top: clamp(0.75rem, 1.6vw, 1rem);
    max-width: var(--read-measure);
  }
  .sp-read .head-blk {
    padding-top: clamp(2.3rem, 5vw, 4.25rem);
    padding-bottom: clamp(1.35rem, 3vw, 2.25rem);
  }
  .sp-read .cat {
    margin-bottom: 0.85rem;
  }
  .sp-read .p-h1 {
    max-width: min(36ch, var(--read-measure));
  }
  .sp-read .byline {
    max-width: var(--read-measure);
    margin-top: 1.15rem;
    padding-top: 1.05rem;
    margin-bottom: 0;
  }
  .sp-read .para {
    margin-block: 1.45rem;
    line-height: 1.78;
  }
  .sp-read .cap-read {
    margin-block: 1.65rem 2.25rem;
  }
  .sp-read .p-h2 {
    margin-top: clamp(3rem, 6vw, 4.4rem);
  }
  .sp-read .toc {
    grid-column: 3;
    grid-row: 3 / span 3;
    align-self: start;
    position: sticky;
    top: clamp(5rem, 9vw, 6.5rem);
    width: 100%;
    max-width: none;
    margin-block: clamp(0.2rem, 1vw, 0.5rem) 0;
    padding: clamp(1rem, 2vw, 1.35rem);
  }
  .sp-read .para,
  .sp-read .cap-read p,
  .sp-read .faq .a {
    text-wrap: pretty;
  }
  .sp-read .p-h1,
  .sp-read .p-h2,
  .sp-read .pull p,
  .sp-read .blk-t,
  .sp-read caption {
    letter-spacing: 0;
  }
  figcaption { font-size: 0.9375rem; line-height: 1.5; color: var(--ink-3); }
  /* 🔴 WCAG 1.4.3 — y la ironía ERA el hallazgo.
     El crédito usaba `--faint` (#7c8fa3), que da 3,33:1 sobre blanco. El mínimo es 4,5:1. Y el
     crédito visible ES la demostración del requisito 5 de las bases («imagen apta y libre de
     derechos, con licencia verificable»): un evaluador que le pasa axe a la muestra encontraba su
     fallo AA justo en la línea que existe para probar cumplimiento. En una agencia que vende rigor,
     eso no es un bug: es el titular. `--muted` (#5a6b7d) da 5,5:1 y ya se usa para meta. */
  .credit { margin-top: 0.25rem; font-size: 0.8125rem; color: var(--muted); }
  .credit a { color: inherit; text-decoration: underline; }

  .head-blk { padding-top: 0.25rem; }
  .cat {
    font-size: var(--t-over); font-weight: var(--w-client-title); letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--client); margin-bottom: 0.6rem;
  }
  .p-h1 {
    font-size: var(--a-h1); font-weight: var(--w-client-title);
    line-height: 1.12; letter-spacing: -0.02em; max-width: 20ch; text-wrap: balance;
  }
  .byline {
