---
import type { CollectionEntry } from 'astro:content'

/**
 * EL INSTRUMENTO — navy Efeonce. Nuestro análisis habla con NUESTRA voz.
 *
 * ⚠️ INVARIANTE #1: el JSON-LD se renderiza como TEXTO ESCAPADO, jamás dentro de un
 * <script type="application/ld+json">. Emitirlo declararía, en NUESTRO dominio, que Efeonce
 * publicó un artículo del cliente — un dato estructurado falso, ingerible por crawlers, justo
 * en la pieza cuya tesis es el rigor técnico. `verify-aeo-xray.mjs` falla si aparece uno.
 *
 * Tres niveles de nodo: el 1 mueve un número del diagnóstico (stat grande), el 3 es prueba de
 * completitud —no argumento— y va callado. Sin eso, `og:title` pesa igual que `FAQPage` y todo
 * se aplana.
 */

type Sample = CollectionEntry<'aeoXray'>['data']
interface Props { d: Sample; hero: string }

const { d, hero } = Astro.props
const { ui, machine, evidence } = d

const kpis = evidence.facts.filter(f => f.headline)
const details = evidence.facts.filter(f => !f.headline)

/** Escapa el JSON-LD para mostrarlo como TEXTO. Jamás `set:html`. */
const asText = (code: unknown) =>
  JSON.stringify({ '@context': 'https://schema.org', ...(code as object) }, null, 2)
---

<aside class="inst" aria-labelledby="in-t">
  <div class="in-head">
    {/* `tabindex="-1"`: alcanzable por script, nunca por Tab. Es el destino seguro del foco cuando
        el panel colapsa bajo él, y el ancla del focus-return al salir del enfoque. */}
    <h2 id="in-t" tabindex="-1">{ui.instrumentTitle}</h2>
    {/* Al enfocar, el panel DICE en palabras qué acaba de pasar. El comprador no tiene por qué
        saber SEO: un realce sutil sobre una fila de un árbol de encabezados no le comunica nada. */}
    <p class="in-focus" data-testid="focus-note" aria-hidden="true"></p>
    {/* La salida del enfoque. `Escape` ya funcionaba, pero nadie lo descubre: sin un botón, un
        evaluador que interroga un bloque queda encerrado en esos N datos y no puede volver a ver
        la máquina completa. Es un <button> de verdad (teclado + lector de pantalla gratis).
        Nace `disabled` porque la llegada es el modo MAPA: no hay de qué salir todavía. */}
    <button class="in-all" type="button" data-show-all disabled>Ver toda la capa</button>
    <p class="in-live" role="status" aria-live="polite" data-testid="live"></p>
    {/* Solo móvil: cierra la hoja y devuelve el foco al bloque que la abrió. */}
    <button class="sheet-x" type="button" data-close-sheet aria-label={ui.backToArticle}>✕</button>
  </div>

  {/* El panel es CONTENIDO: se LEE. Sus nodos ya NO son tab-stops — lo eran solo para que el
      `focusin` disparara el acoplamiento desde ESTE lado, y eso se eliminó (el instrumento no
      puede repintarse a sí mismo). Eran 55 paradas de teclado que no hacían nada. Los controles
      viven en el ARTÍCULO (un <button> de sonda por bloque); acá solo quedan los <pre>
      scrolleables (WCAG 2.1.1) y los <summary>, que sí deben ser alcanzables. */}
  <div class="in-body" id="in-body">
    {/* La evidencia ABRE el instrumento: es el argumento, no el apéndice. */}
    <div class="kpis" data-testid="kpis">
      {kpis.map(k => (
        <div class="kpi" data-couple-target={k.coupleId}>
          <p class="kpi-n">{k.big}</p>
          <p class="kpi-u">{k.bigUnit}</p>
          <cite class="kpi-s">{k.source} · {k.asOf}</cite>
        </div>
      ))}
    </div>

    <p class="grp">Cómo está escrito</p>
    {machine.craft.map(c => (
      <div class={`nd t${c.tier}`} data-couple-target={c.coupleId} data-on={c.coupleId === hero ? true : undefined}>
        {/* La cifra va CON su fuente, igual que en la ① y en la ④. La ③ era la única pantalla
            donde los números flotaban — justo la que argumenta el rigor. El schema ya lo obliga
            (superRefine de la raíz); esto lo RENDERIZA: un dato obligatorio que no se pinta no le
            sirve de nada al evaluador que lo quiere comprobar. */}
        {c.stat && <p class="stat">{c.stat} <span>{c.statNote}</span></p>}
        {c.stat && c.source && <cite class="stat-src">{c.source} · {c.asOf}</cite>}
        <p class="nd-l">{c.label} <em>· {c.detail}</em></p>
        <p class="why"><b>{ui.whyLabel}:</b> {c.why}</p>
      </div>
    ))}

    <p class="grp">Datos estructurados <em>· se muestran como texto</em></p>
    <p class="warn">{ui.schemaNote}</p>
    {machine.jsonld.map(n => (
      <div class={`nd t${n.tier} sch`} data-couple-target={n.coupleId}>
        <div class="sch-h">
          <span class="sch-t">{n.type}</span>
          <span class="sch-m">{n.metric}</span>
        </div>
        {n.stat && <p class="stat"><span class="stat-fix">arregla</span>{n.stat} <span>{n.statNote}</span></p>}
        {n.tier < 3 && <p class="why"><b>{ui.whyLabel}:</b> {n.why}</p>}
        <details>
          <summary>Ver el código</summary>
          <pre role="region" tabindex="0" aria-label={`Datos estructurados: ${n.type}`}><code>{asText(n.code)}</code></pre>
        </details>
      </div>
    ))}

    <p class="grp">Metadatos</p>
    {machine.seo.map(s => (
      <div class={`nd t${s.tier}`} data-couple-target={s.coupleId}>
        <p class="nd-l">{s.label} {s.detail && <em>· {s.detail}</em>}</p>
        <p class="nd-v">{s.value}</p>
        {s.tier < 3 && <p class="why"><b>{ui.whyLabel}:</b> {s.why}</p>}
      </div>
    ))}
    <div class="t3wrap">
      {machine.og.map(o => (
        <div class="nd t3" data-couple-target={o.coupleId}>
          <p class="nd-l">{o.label}</p>
          <p class="nd-v mono">{o.value}</p>
        </div>
      ))}
    </div>

    <p class="grp">Estructura</p>
    <div class="nd t2" data-couple-target={machine.headings.coupleId}>
      {machine.headings.tree.map(h => (
        <p class={`hn l${h.level}`} data-couple-target={h.coupleId}>
          <span class="lv">H{h.level}</span> {h.text}
        </p>
      ))}
      <p class="why"><b>{ui.whyLabel}:</b> {machine.headings.why}</p>
    </div>
    {machine.alts.map(a => (
      <div class="nd t2" data-couple-target={a.coupleId}>
        <p class="nd-v">“{a.alt}”</p>
        <p class="why"><b>{ui.whyLabel}:</b> {a.why}</p>
      </div>
    ))}

    <p class="grp">La evidencia <em>· por qué existe este artículo</em></p>
    {details.map(f => (
      <div class="nd t2 fct" data-couple-target={f.coupleId}>
        <p class="nd-l">{f.label}</p>
        <p class="fct-v">{f.value}</p>
        <p class="why">{f.note}</p>
        <cite>{ui.sourceLabel}: {f.source} · {f.asOf}</cite>
      </div>
    ))}
    <div class="nd t2">
      <p class="nd-l">{evidence.fanOut.title}</p>
      <p class="why">{evidence.fanOut.note}</p>
      <ul class="fan">
        {evidence.fanOut.items.map(i => (
          <li data-couple-target={i.coveredBy}>
            <span class="ok" aria-hidden="true">{i.covered ? '✓' : '—'}</span>{i.q}
          </li>
        ))}
      </ul>
    </div>
    <p class="hon">{evidence.honesty}</p>
  </div>
</aside>

<style>
  .inst {
    background: var(--navy); color: var(--ink-d); border: 1px solid var(--navy-3);
    font-weight: var(--w-body-dark);
    border-radius: 12px; min-width: 0;
  }
  /* 🔴 `flex-wrap` NO es cosmético (WCAG 1.4.10 · reflow).
     Sin él, a 390px el header sumaba ~440px de contenido `nowrap` y se recortaba justo lo que el
     invariante 12b declara load-bearing: LA CUENTA en palabras y EL BOTÓN DE SALIDA. En un teléfono,
     la «salida descubrible» quedaba fuera de la pantalla. Y como el panel tiene `overflow-y: auto`
     (lo que fuerza `overflow-x: auto`), el desborde scrolleaba DENTRO del panel → el assert de
     scroll horizontal, que mide el DOCUMENTO, salía verde mientras el usuario veía el header roto. */
  .in-head {
    display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center;
    gap: 0.5rem 1rem;
    padding: 0.9rem 1.1rem; border-bottom: 1px solid var(--line-d); background: var(--navy-2);
    border-radius: 12px 12px 0 0; position: sticky; top: 0; z-index: 2;
  }
  .in-head h2 { font-size: var(--t-body); font-weight: var(--w-label); }
  /* El anuncio para lectores de pantalla. Es SOLO para ellos: la versión visible es `.in-focus`,
     y tener las dos a la vista imprimía la cuenta dos veces en el header. */
  .in-live {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip-path: inset(50%); white-space: nowrap; border: 0;
  }

  /* EL INSTRUMENTO ENFOCA. Colapsa todo lo que el bloque tocado NO produce, para que los N datos
     que el chip promete queden apilados arriba, juntos y sin cacería. Antes el panel solo atenuaba
     y scrolleaba al primer match: de 51 datos prometidos, 44 no se veían NUNCA. */
  .inst [data-hide] { display: none; }

  /* Y lo dice en palabras: el comprador no tiene por qué saber SEO para entender qué pasó.
     Sin `nowrap`: es una FRASE, no un chip — que envuelva en dos líneas es correcto, y es lo que
     impide que se recorte en un teléfono. */
  .in-focus {
    margin-left: auto; font-size: var(--t-meta); font-weight: var(--w-label);
    color: var(--blue-up); min-width: 0;
  }
  .in-focus:empty { display: none; }

  /* La fuente de cada cifra del instrumento. Sobre navy el texto sube un paso (--w-body-dark). */
  .stat-src {
    display: block; margin-top: 0.4rem; font-size: 0.75rem; line-height: 1.45;
    color: var(--dim-d); font-style: normal; font-weight: var(--w-body-dark);
  }

  /* 🔴 UN CONTROL QUE DESAPARECE AL USARSE NUNCA ES LA RESPUESTA.
     Antes este botón solo existía en modo enfoque: al presionarlo salías del enfoque → el CSS lo
     borraba → el foco caía al inicio del documento y el usuario de teclado quedaba perdido en una
     página de 9.000px. Es el mismo bug que el botón vino a arreglar, ahora en la salida.
     Ahora está SIEMPRE: en modo mapa queda `disabled` (no hay de qué salir) y conserva su sitio,
     así el foco sobrevive al clic. Mínimo 24×24 (WCAG 2.2 · 2.5.8). */
  .in-all {
    padding: 0.45rem 0.7rem; min-height: 24px; border-radius: 999px; cursor: pointer;
    border: 1px solid var(--line-d); background: transparent; color: var(--dim-d);
    font: inherit; font-size: var(--t-over); font-weight: var(--w-label);
  }
  .in-all:hover:not(:disabled) { color: #fff; border-color: var(--blue-up); }
  .in-all:focus-visible { outline: 2px solid var(--blue-up); outline-offset: 2px; }
  .in-all:disabled { opacity: 0.35; cursor: default; }

  /* Si la pila enfocada desborda (el H1 produce ONCE datos y en pantalla caben cuatro), se avisa.
     Un degradado al pie dice «hay más abajo» sin robarle una línea al panel. */
  .inst { position: relative; }
  .inst[data-more='true']::after {
    content: ''; position: sticky; bottom: 0; display: block; height: 3.5rem; margin-top: -3.5rem;
    pointer-events: none; border-radius: 0 0 12px 12px;
    background: linear-gradient(to top, var(--navy) 15%, transparent);
  }
  .in-body { padding: 1rem 1rem 1rem 1.3rem; }

  /* Los KPI abren el instrumento. Tabular-nums, NUNCA monoespaciada. */
  .kpis { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.6rem; margin-bottom: 1.4rem; }
  .kpi {
    padding: 0.7rem 0.75rem; background: var(--navy-2); border: 1px solid var(--line-d);
    border-radius: 9px; outline: 2px solid transparent;
  }
  .kpi-n {
    font-family: Poppins, system-ui, sans-serif;
    font-size: var(--t-stat); font-weight: var(--w-display); line-height: 1; color: #fff;
    font-variant-numeric: tabular-nums; letter-spacing: -0.02em;
  }
  .kpi-u { margin-top: 0.3rem; font-size: var(--t-meta); color: var(--ink-d); line-height: 1.35; }
  .kpi-s { display: block; margin-top: 0.4rem; font-size: 0.75rem; color: var(--dim-d); font-style: normal; }
  @media (max-width: 520px) { .kpis { grid-template-columns: 1fr; } }

  .grp {
    font-size: var(--t-over); font-weight: var(--w-label); letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--blue-up); margin: 1.5rem 0 0.6rem; padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--line-d);
  }
  .grp em { font-style: normal; font-weight: var(--w-body-dark); color: var(--dim-d); text-transform: none; letter-spacing: 0.04em; }
  .warn {
    font-size: var(--t-meta); line-height: 1.5; color: var(--amber);
    background: color-mix(in srgb, var(--amber) 10%, var(--navy-2));
    border: 1px solid color-mix(in srgb, var(--amber) 30%, var(--navy-2));
    border-radius: 7px; padding: 0.55rem 0.65rem; margin-bottom: 0.7rem;
  }

  .nd {
    position: relative; margin-bottom: 0.55rem; padding: 0.7rem 0.8rem;
    background: var(--navy-2); border: 1px solid var(--line-d); border-radius: 9px;
    outline: 2px solid transparent; outline-offset: 1px; min-width: 0;
    scroll-margin-top: 4rem; /* Focus Not Obscured (2.4.11): el header pegajoso no lo tapa */
  }
  /* 🔴 WCAG 2.4.7 — TODO lo que recibe foco lo MUESTRA.
     `outline: 2px solid transparent` se usa en varias reglas base como reserva de espacio (para que
     el anillo no mueva el layout al aparecer). El problema: esa regla de AUTOR gana sobre el anillo
     por defecto del navegador. Y el `:focus-visible` solo cubría `.nd` y `.kpi` — así que las ~10
     filas del árbol de encabezados (`.hn`) y los ítems del fan-out (`.fan li`), que SÍ llevan
     `tabindex="0"`, eran tab-stops reales con el foco INVISIBLE. El usuario de teclado tabulaba por
     el instrumento y no sabía dónde estaba. El `--blue-up` da 5,5:1 sobre el navy (cumple 1.4.11). */
  .nd:focus-visible,
  .kpi:focus-visible,
  .hn:focus-visible,
  .fan li:focus-visible { outline: 2px solid var(--blue-up); outline-offset: 1px; }
  .t1 { border-color: color-mix(in srgb, var(--blue-up) 35%, var(--line-d)); background: var(--navy-3); }
  .t3 { padding: 0.4rem 0.6rem; background: transparent; border-color: transparent; margin-bottom: 0.1rem; }
  .t3wrap { padding: 0.3rem 0 0.6rem; border-left: 2px solid var(--line-d); margin-left: 0.2rem; }

  .stat {
    font-family: Poppins, system-ui, sans-serif; font-size: var(--t-stat); font-weight: var(--w-display);
    line-height: 1.05; color: #fff; font-variant-numeric: tabular-nums; letter-spacing: -0.02em;
    margin-bottom: 0.15rem;
  }
  .stat span {
    display: block; font-size: var(--t-meta); font-weight: var(--w-body-dark); line-height: 1.45;
    color: var(--dim-d); letter-spacing: 0; margin-top: 0.25rem;
  }
  .stat-fix {
    display: inline-block !important; margin-right: 0.35rem; font-size: var(--t-over) !important;
    font-weight: var(--w-label) !important; letter-spacing: 0.08em !important; text-transform: uppercase;
    color: var(--blue-up) !important; vertical-align: middle;
  }
  .nd-l { font-size: var(--t-meta); font-weight: var(--w-label); color: var(--ink-d); }
  .nd-l em { font-weight: var(--w-body-dark); color: var(--dim-d); font-style: normal; }
  .nd-v { font-size: var(--t-meta); margin-top: 0.2rem; color: var(--ink-d); word-break: break-word; line-height: 1.5; }
  .nd-v.mono { font-family: ui-monospace, monospace; font-size: 0.6875rem; color: var(--dim-d); }
  .why { font-size: var(--t-meta); line-height: 1.55; color: var(--dim-d); margin-top: 0.4rem; max-width: 62ch; }
  .why b { color: var(--blue-up); font-weight: var(--w-label); }

  /* `flex-wrap` NO es cosmético: sin él, la píldora de métrica (`white-space: nowrap`) empujaba el
     DOCUMENTO 11px a 390px. Y «Claridad de marca — 100/100» ya llegaba a 400px: el assert de scroll
     horizontal venía pasando por UN píxel. Un badge nunca puede decidir el ancho de la página. */
  .sch-h {
    display: flex; flex-wrap: wrap; justify-content: space-between; gap: 0.4rem 0.6rem;
    align-items: center; margin-bottom: 0.35rem;
  }
  .sch-t { font-size: var(--t-meta); font-weight: var(--w-label); font-family: ui-monospace, monospace; color: #fff; min-width: 0; }
  .sch-m {
    font-size: var(--t-over); font-weight: var(--w-label); color: var(--navy); background: var(--blue-up);
    padding: 0.12rem 0.45rem; border-radius: 999px; max-width: 100%;
  }
  .sch details { margin-top: 0.5rem; }
  .sch summary {
    cursor: pointer; font-size: var(--t-over); font-weight: var(--w-label); letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--dim-d); padding: 0.25rem 0; list-style-position: inside;
  }
  .sch summary:hover { color: var(--blue-up); }
  .sch summary:focus-visible { outline: 2px solid var(--blue-up); outline-offset: 2px; border-radius: 4px; }
  .sch pre {
    margin-top: 0.6rem; padding: 0.65rem; background: var(--navy-sunk); color: var(--code-d);
    border: 1px solid var(--line-d); border-radius: 7px; font-size: 0.6875rem; line-height: 1.55;
    overflow-x: auto; max-height: 20rem; max-width: 100%;
  }

  /* `min-height: 24px` — WCAG 2.2 · 2.5.8. Medían ~23px y son tap targets contiguos. */
  .hn { font-size: var(--t-meta); padding: 0.3rem; min-height: 24px; border-radius: 4px; outline: 2px solid transparent; scroll-margin-top: 4rem; }
  .hn.l2 { padding-left: 1.15rem; }
  .lv { display: inline-block; min-width: 1.7rem; font-weight: var(--w-label); color: var(--blue-up); font-size: 0.625rem; }

  .fct-v { font-size: var(--t-node); font-weight: var(--w-label); color: var(--blue-up); margin: 0.15rem 0; font-variant-numeric: tabular-nums; }
  .fct cite { display: block; margin-top: 0.4rem; font-size: 0.75rem; color: var(--dim-d); font-style: normal; }
  .fan li {
    display: flex; gap: 0.45rem; font-size: var(--t-meta); padding: 0.28rem 0.3rem; border-radius: 4px;
    outline: 2px solid transparent; align-items: baseline; color: var(--ink-d); scroll-margin-top: 4rem;
  }
  .ok { color: var(--mint); font-weight: var(--w-label); }
  .hon {
    margin-top: 0.8rem; padding: 0.7rem 0.8rem; font-size: var(--t-meta); line-height: 1.55;
    color: var(--dim-d); background: var(--navy-2); border-radius: 8px; border: 1px dashed var(--line-d);
  }

  /* Solo móvil: la hoja inferior. Ver el CSS global del acoplamiento. */
  .sheet-x { display: none; }
  @media (max-width: 1079px) {
    .sheet-x {
      display: grid; place-items: center; width: 2.25rem; height: 2.25rem; border-radius: 999px;
      border: 1px solid var(--line-d); background: var(--navy-3); color: var(--ink-d);
      font-size: 1rem; cursor: pointer; flex-shrink: 0;
    }
    .sheet-x:focus-visible { outline: 2px solid var(--blue-up); outline-offset: 2px; }
  }
</style>
