const normalizedName = name.replace(/^ti-/, '')
const path = paths[normalizedName] ?? paths.info
const isFilled = normalizedName === 'brand-google-filled'
---
<svg
  class={`ti ti-${normalizedName} ${className}`}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={isFilled ? 'currentColor' : 'none'}
  stroke={isFilled ? 'none' : 'currentColor'}
  stroke-width={isFilled ? undefined : '1.8'}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden={ariaHidden ? 'true' : undefined}
>
  <path d={path} />
</svg>
