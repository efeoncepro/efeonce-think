---
// Benchmark competitivo (Share of Voice): cuánto ocupa tu marca vs competidores en las
// respuestas de IA. Bar chart horizontal (dataviz: comparar categorías) + insight de citas.
import { axis } from '@lib/report-tokens'

interface Competitor { name: string; mentions: number }
interface Props {
  brandName: string
  brandMentions: number
  competitors: Competitor[]
  ownDomainShare: number | null
  findingsWithCitations: number
  findingsCitingOwnDomain: number
}
const { brandName, brandMentions, competitors, ownDomainShare, findingsWithCitations, findingsCitingOwnDomain } = Astro.props

const rows = [
  { name: brandName, mentions: brandMentions, isBrand: true },
  ...competitors.map((c) => ({ name: c.name, mentions: c.mentions, isBrand: false })),
].sort((a, b) => b.mentions - a.mentions)
const max = Math.max(1, ...rows.map((r) => r.mentions))
const totalMentions = rows.reduce((sum, r) => sum + r.mentions, 0)
const brandShare = totalMentions > 0 ? Math.round((brandMentions / totalMentions) * 100) : null
const topCompetitor = competitors.slice().sort((a, b) => b.mentions - a.mentions)[0]
const multiple = topCompetitor && brandMentions > 0 ? (topCompetitor.mentions / brandMentions).toFixed(1) : null
---

<div class="report-panel overflow-hidden rounded-2xl border bg-white" style={`border-color:${axis.gray[100]}`}>
  <div class="grid sm:grid-cols-3">
    <div class="border-b p-5 sm:border-b-0 sm:border-r" style={`border-color:${axis.gray[100]}`}>
      <p class="text-xs font-semibold uppercase tracking-[0.08em]" style={`color:${axis.gray[600]}`}>Share detectado</p>
      <p class="mt-2 text-3xl font-semibold tabular-nums" style={`color:${axis.gray[900]}`}>{brandShare === null ? '—' : `${brandShare}%`}</p>
      <p class="mt-1 text-sm" style={`color:${axis.gray[600]}`}>{brandName} en el set competitivo.</p>
    </div>
    <div class="border-b p-5 sm:border-b-0 sm:border-r" style={`border-color:${axis.gray[100]}`}>
      <p class="text-xs font-semibold uppercase tracking-[0.08em]" style={`color:${axis.gray[600]}`}>Líder detectado</p>
      <p class="mt-2 text-lg font-semibold" style={`color:${axis.gray[900]}`}>{topCompetitor?.name ?? '—'}</p>
      {multiple && <p class="mt-1 text-sm tabular-nums" style={`color:${axis.gray[600]}`}>{multiple}× tus menciones.</p>}
    </div>
    <div class="p-5">
      <p class="text-xs font-semibold uppercase tracking-[0.08em]" style={`color:${axis.gray[600]}`}>Citas propias</p>
      <p class="mt-2 text-3xl font-semibold tabular-nums" style={`color:${axis.gray[900]}`}>{ownDomainShare === null ? '—' : `${ownDomainShare}%`}</p>
      <p class="mt-1 text-sm" style={`color:${axis.gray[600]}`}>{findingsCitingOwnDomain} de {findingsWithCitations} respuestas con fuentes.</p>
    </div>
  </div>

  <div class="border-t p-5" style={`border-color:${axis.gray[100]}`}>
    <div class="flex flex-col gap-1 sm:flex-row sm:items-end sm:justify-between">
      <p class="text-sm font-semibold" style={`color:${axis.gray[900]}`}>Menciones por entidad</p>
      {topCompetitor && multiple && <p class="text-sm" style={`color:${axis.gray[600]}`}><span class="font-semibold" style={`color:${axis.gray[900]}`}>{topCompetitor.name}</span> tiene {multiple}× tus menciones.</p>}
    </div>
    <div class="mt-5 flex flex-col gap-4">
      {rows.map((r) => (
        <div class="data-row rounded-lg px-2 py-1">
          <div class="flex items-baseline justify-between gap-4">
            <span class="text-sm font-semibold" style={`color:${r.isBrand ? axis.accent[700] : axis.gray[900]}`}>{r.name}{r.isBrand && ' · tú'}</span>
            <span class="text-sm font-semibold tabular-nums" style={`color:${axis.gray[600]}`}>{r.mentions}</span>
          </div>
          <div class="mt-1.5 h-2.5 w-full overflow-hidden rounded-full" style={`background:${axis.gray[100]}`}>
            <div data-bar class="h-full rounded-full" style={`width:${Math.max(4, (r.mentions / max) * 100)}%;background:${r.isBrand ? axis.accent[500] : axis.gray[400]}`}></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>
