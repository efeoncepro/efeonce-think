---
// Benchmark competitivo (Share of Voice): cuánto ocupa tu marca vs competidores en las
// respuestas de IA. Bar chart horizontal (dataviz: comparar categorías) + insight de citas.
import { axis } from '@lib/report-tokens'
import ReportIcon from '@/components/primitives/ReportIcon.astro'

interface Competitor { name: string; mentions: number }
interface BenchmarkRow { name: string; mentions: number; rank: number; isBrand: boolean; deltaVsBrand: number; sharePct: number | null }
interface BenchmarkFacts {
  totalMentions?: number
  brandShare?: number | null
  brandRank?: number | null
  leaderName?: string | null
  leaderMentions?: number | null
  leaderGap?: number | null
  nextGap?: number | null
  leaderMultiple?: number | null
  rows?: BenchmarkRow[]
}
interface Props {
  brandName: string
  brandMentions: number
  competitors: Competitor[]
  ownDomainShare: number | null
  findingsWithCitations: number
  findingsCitingOwnDomain: number
  benchmark?: BenchmarkFacts | null
}
const { brandName, brandMentions, competitors, ownDomainShare, findingsWithCitations, findingsCitingOwnDomain, benchmark } = Astro.props

const fallbackRows = [
  { name: brandName, mentions: brandMentions, isBrand: true },
  ...competitors.map((c) => ({ name: c.name, mentions: c.mentions, isBrand: false })),
].sort((a, b) => b.mentions - a.mentions)
const rows = benchmark?.rows?.length ? benchmark.rows : fallbackRows.map((row, index) => ({
  ...row,
  rank: index + 1,
  deltaVsBrand: row.mentions - brandMentions,
  sharePct: null,
}))
const max = Math.max(1, ...rows.map((r) => r.mentions))
const totalMentions = benchmark?.totalMentions ?? rows.reduce((sum, r) => sum + r.mentions, 0)
const brandShare = benchmark?.brandShare ?? (totalMentions > 0 ? Math.round((brandMentions / totalMentions) * 100) : null)
const topCompetitor = competitors.slice().sort((a, b) => b.mentions - a.mentions)[0]
const leader = rows[0]
const brandIndex = rows.findIndex((r) => r.isBrand)
const brandRank = benchmark?.brandRank ?? (brandIndex >= 0 ? brandIndex + 1 : null)
const nextAbove = brandIndex > 0 ? rows[brandIndex - 1] : null
const leaderGap = benchmark?.leaderGap ?? (leader && !leader.isBrand ? Math.max(0, leader.mentions - brandMentions) : 0)
const nextGap = benchmark?.nextGap ?? (nextAbove ? Math.max(0, nextAbove.mentions - brandMentions) : 0)
const multiple = benchmark?.leaderMultiple !== undefined && benchmark?.leaderMultiple !== null
  ? String(benchmark.leaderMultiple)
  : topCompetitor && brandMentions > 0 ? (topCompetitor.mentions / brandMentions).toFixed(1) : null
const normalizedOwnDomainShare =
  ownDomainShare === null
    ? null
    : Math.round((ownDomainShare > 0 && ownDomainShare <= 1 ? ownDomainShare * 100 : ownDomainShare))
const brandPositionCopy =
  brandRank === 1
    ? 'Tu marca lidera el set competitivo medido.'
    : leader
      ? `${benchmark?.leaderName ?? leader.name} lidera con ${leaderGap} mención${leaderGap === 1 ? '' : 'es'} más que tú.`
      : 'No hay líder competitivo suficiente en esta muestra.'
const nextMoveCopy =
  brandRank === 1
    ? 'Defiende la posición con más fuentes propias y consistencia de categoría.'
    : nextAbove
      ? `Te separan ${nextGap} mención${nextGap === 1 ? '' : 'es'} de ${nextAbove.name}.`
      : 'Aumenta presencia propia antes de ampliar autoridad.'
const authorityCopy =
  normalizedOwnDomainShare === null
    ? 'Sin citabilidad propia suficiente para comparar autoridad.'
    : normalizedOwnDomainShare > 0
      ? `Tu sitio sostiene ${normalizedOwnDomainShare}% de las respuestas con fuentes.`
      : 'La autoridad de fuente todavía depende de terceros.'
---

<div class="report-panel overflow-hidden rounded-2xl border bg-white" style={`border-color:${axis.gray[100]}`}>
  <div class="benchmark-brief grid gap-4 border-b p-5 sm:p-6 lg:grid-cols-[minmax(0,1.15fr)_minmax(18rem,0.85fr)]" style={`border-color:${axis.gray[100]};background:linear-gradient(180deg,${axis.gray[50]}cc,#fff)`}>
    <div class="min-w-0">
      <p class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.1em]" style={`color:${axis.accent[700]}`}>
        <ReportIcon name="signal" size={16} />
        Lectura competitiva
      </p>
      <h3 class="mt-2 text-2xl font-semibold leading-tight text-balance" style={`color:${axis.gray[900]}`}>
        {brandPositionCopy}
      </h3>
      <p class="mt-2 max-w-3xl text-sm leading-relaxed" style={`color:${axis.gray[600]}`}>
        {nextMoveCopy} {authorityCopy}
      </p>
    </div>
    <div class="benchmark-status rounded-2xl border bg-white p-4" style={`border-color:${axis.gray[100]}`}>
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.08em]" style={`color:${axis.gray[600]}`}>Tu posición</p>
          <p class="mt-1 text-3xl font-semibold tabular-nums" style={`color:${axis.gray[900]}`}>{brandRank ? `#${brandRank}` : '—'}</p>
        </div>
        <span class="rounded-full px-2.5 py-1 text-xs font-semibold" style={`background:${brandRank === 1 ? axis.success[100] : axis.warning[100]};color:${brandRank === 1 ? axis.success[700] : axis.warning[700]}`}>
          {brandRank === 1 ? 'Líder' : 'En disputa'}
        </span>
      </div>
      <p class="mt-3 text-sm leading-relaxed" style={`color:${axis.gray[600]}`}>
        Set competitivo de {rows.length} entidades · {totalMentions} menciones agregadas.
      </p>
    </div>
  </div>

  <div class="grid sm:grid-cols-3">
    <div class="benchmark-metric border-b p-5 sm:border-b-0 sm:border-r" style={`border-color:${axis.gray[100]}`}>
      <div class="flex items-center justify-between gap-3">
        <p class="text-xs font-semibold uppercase tracking-[0.08em]" style={`color:${axis.gray[600]}`}>Tu SoV en la muestra</p>
        <span class="benchmark-icon" style={`--benchmark-icon:${axis.accent[500]}`}><ReportIcon name="signal" size={16} /></span>
      </div>
      <p class="mt-2 text-3xl font-semibold tabular-nums" style={`color:${axis.gray[900]}`}>{brandShare === null ? '—' : `${brandShare}%`}</p>
      <p class="mt-1 text-sm" style={`color:${axis.gray[600]}`}>{brandMentions} de {totalMentions || '—'} menciones competitivas.</p>
    </div>
    <div class="benchmark-metric border-b p-5 sm:border-b-0 sm:border-r" style={`border-color:${axis.gray[100]}`}>
      <div class="flex items-center justify-between gap-3">
        <p class="text-xs font-semibold uppercase tracking-[0.08em]" style={`color:${axis.gray[600]}`}>Gap vs líder</p>
        <span class="benchmark-icon" style={`--benchmark-icon:${axis.warning[500]}`}><ReportIcon name="priority" size={16} /></span>
      </div>
      <p class="mt-2 text-3xl font-semibold tabular-nums" style={`color:${axis.gray[900]}`}>{leaderGap > 0 ? `-${leaderGap}` : '0'}</p>
      <p class="mt-1 text-sm" style={`color:${axis.gray[600]}`}>
        {leader?.isBrand ? 'Tu marca lidera la muestra.' : `${leader?.name ?? 'El líder'} concentra ${multiple ? `${multiple}×` : 'más'} tus menciones.`}
      </p>
    </div>
    <div class="benchmark-metric p-5">
      <div class="flex items-center justify-between gap-3">
        <p class="text-xs font-semibold uppercase tracking-[0.08em]" style={`color:${axis.gray[600]}`}>Citabilidad propia</p>
        <span class="benchmark-icon" style={`--benchmark-icon:${axis.success[500]}`}><ReportIcon name="citation" size={16} /></span>
      </div>
      <p class="mt-2 text-3xl font-semibold tabular-nums" style={`color:${axis.gray[900]}`}>{normalizedOwnDomainShare === null ? '—' : `${normalizedOwnDomainShare}%`}</p>
      <p class="mt-1 text-sm" style={`color:${axis.gray[600]}`}>{findingsCitingOwnDomain} de {findingsWithCitations} respuestas con fuentes.</p>
    </div>
  </div>

  <div class="border-t p-5" style={`border-color:${axis.gray[100]}`}>
    <div class="flex flex-col gap-1 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-semibold" style={`color:${axis.gray[900]}`}>Ranking de menciones en la muestra</p>
        <p class="mt-1 text-xs leading-relaxed" style={`color:${axis.gray[600]}`}>La barra muestra presencia relativa; el delta compara cada entidad contra tu marca.</p>
      </div>
      {topCompetitor && multiple && <p class="text-sm" style={`color:${axis.gray[600]}`}><span class="font-semibold" style={`color:${axis.gray[900]}`}>{topCompetitor.name}</span> tiene {multiple}× tus menciones.</p>}
    </div>
    <div class="mt-5 flex flex-col gap-4">
      {rows.map((r, index) => {
      const delta = r.deltaVsBrand ?? (r.mentions - brandMentions)
        const deltaText = r.isBrand ? 'tú' : delta > 0 ? `+${delta} vs tú` : delta < 0 ? `${delta} vs tú` : 'empatado'
        return (
        <div class={`benchmark-row data-row rounded-xl border px-3 py-3${r.isBrand ? ' is-brand' : ''}`} style={`border-color:${r.isBrand ? `${axis.accent[500]}44` : axis.gray[100]};background:${r.isBrand ? `${axis.accent[500]}08` : '#fff'}`}>
          <div class="grid gap-3 sm:grid-cols-[2.25rem_minmax(0,1fr)_auto] sm:items-center">
            <span class="benchmark-rank" style={`background:${index === 0 ? axis.gray[900] : r.isBrand ? axis.accent[500] : axis.gray[100]};color:${index === 0 || r.isBrand ? '#fff' : axis.gray[800]}`}>#{index + 1}</span>
            <div class="min-w-0">
              <div class="flex flex-wrap items-center gap-2">
                <span class="truncate text-sm font-semibold" style={`color:${r.isBrand ? axis.accent[700] : axis.gray[900]}`}>{r.name}</span>
                {r.isBrand && <span class="rounded-full px-2 py-0.5 text-[0.68rem] font-semibold" style={`background:${axis.accent[500]}18;color:${axis.accent[700]}`}>Tu marca</span>}
                {index === 0 && !r.isBrand && <span class="rounded-full px-2 py-0.5 text-[0.68rem] font-semibold" style={`background:${axis.gray[100]};color:${axis.gray[800]}`}>Líder</span>}
              </div>
              <div class="mt-2 h-2.5 w-full overflow-hidden rounded-full" style={`background:${axis.gray[100]}`}>
                <div data-bar class="h-full rounded-full" style={`width:${Math.max(4, (r.mentions / max) * 100)}%;background:${r.isBrand ? axis.accent[500] : index === 0 ? axis.gray[600] : axis.gray[400]}`}></div>
              </div>
            </div>
            <div class="flex items-baseline justify-between gap-4 sm:block sm:text-right">
              <span class="text-xl font-semibold tabular-nums" style={`color:${axis.gray[900]}`}>{r.mentions}</span>
              <p class="text-xs font-semibold tabular-nums" style={`color:${r.isBrand ? axis.accent[700] : delta > 0 ? axis.warning[700] : axis.gray[600]}`}>{deltaText}</p>
            </div>
          </div>
        </div>
        )
      })}
    </div>
  </div>
</div>

<style>
  .benchmark-brief {
    position: relative;
  }

  .benchmark-icon {
    display: inline-grid;
    flex: 0 0 auto;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border: 1px solid color-mix(in srgb, var(--benchmark-icon) 18%, #fff);
    border-radius: 999px;
    background: color-mix(in srgb, var(--benchmark-icon) 8%, #fff);
    color: var(--benchmark-icon);
  }

  .benchmark-status,
  .benchmark-metric,
  .benchmark-row {
    min-width: 0;
  }

  .benchmark-rank {
    display: inline-grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 780;
    line-height: 1;
  }
</style>
