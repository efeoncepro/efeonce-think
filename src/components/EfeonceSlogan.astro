---
// Eslogan canónico de Efeonce "Empower your Growth" (SSOT efeonce-brand.ts).
// Poppins: Empower=ExtraBold Italic (800i), your=ExtraBold (800), Growth=Black Italic (900i).
import '@fontsource/poppins/800.css'
import '@fontsource/poppins/800-italic.css'
import '@fontsource/poppins/900-italic.css'

interface Props {
  /** Color base del eslogan. Default gris de marca #848484; sobre fondo oscuro, pasar claro. */
  color?: string
  size?: string
}
const { color = '#848484', size = '1.125rem' } = Astro.props
---

<span style={`font-family:'Poppins',sans-serif;color:${color};font-size:${size};letter-spacing:-0.01em;white-space:nowrap`}>
  <span style="font-weight:800;font-style:italic">Empower</span>
  <span style="font-weight:800;font-style:normal"> your </span>
  <span style="font-weight:900;font-style:italic">Growth</span>
</span>
