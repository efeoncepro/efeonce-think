---
// LA ESCALERA — framework AEO: 5 peldaños de madurez. Cada peldaño es UNA pieza (card +
// líquido como base, sin costura). Altura del líquido = posición en la escalera; color =
// severidad. El "próximo nivel" se marca integrado. Copy lean: nombre + Be X + pregunta.
import { axis, severityMeta, LEVEL_COPY } from '@lib/report-tokens'

interface Level { id: string; axis: string; score: number | null; severity: string; status: string }
const { levels } = Astro.props as { levels: Level[] }

const ordered = [...levels].sort(
  (a, b) => Number(LEVEL_COPY[a.id]?.ordinal ?? '99') - Number(LEVEL_COPY[b.id]?.ordinal ?? '99'),
)
const nextIdx = ordered.findIndex((l) => l.severity !== 'optimo')

const liquid = (measured: boolean, sevBorder: string) =>
  measured
    ? `linear-gradient(180deg, ${sevBorder}cc 0%, ${sevBorder}30 100%)`
    : `repeating-linear-gradient(135deg, ${axis.gray[100]} 0 10px, ${axis.gray[50]} 10px 20px)`

const rungs = ordered.map((lvl, i) => {
  const copy = LEVEL_COPY[lvl.id] ?? { ordinal: '', label: lvl.id, labelEn: '', question: '' }
  const measured = lvl.status === 'measured' && lvl.score !== null
  return { lvl, copy, measured, sev: severityMeta(measured ? lvl.severity : 'sin_dato'), i, isNext: i === nextIdx }
})
---

<div class="ladder" style={`--n:${rungs.length}`}>
  {rungs.map(({ lvl, copy, measured, sev, i, isNext }) => (
    <div class={`col${isNext ? ' is-next' : ''}`}>
      <div class="card">
        {isNext && <p class="next" style={`color:${axis.accent[700]}`}>Empieza aquí</p>}
        <div class="card-top">
          <span class="ord" style={`color:${axis.gray[200]}`}>{copy.ordinal}</span>
          {measured ? (
            <span class="score" data-rung-score={Math.round(lvl.score as number)} style={`color:${axis.gray[900]}`}>{Math.round(lvl.score as number)}</span>
          ) : (
            <span class="cover" style={`background:${axis.gray[100]};color:${axis.gray[600]}`}>En cobertura</span>
          )}
        </div>
        <p class="bex" style={`color:${axis.accent[500]}`}>{copy.labelEn}</p>
        <p class="label" style={`color:${axis.gray[900]}`}>{copy.label}</p>
        <p class="q" style={`color:${axis.gray[600]}`}>{copy.question}</p>
        {measured && <span class="sev" style={`background:${sev.bg};color:${sev.fg}`}>{sev.label}</span>}
      </div>
      {/* líquido = base de la misma pieza (sin costura) */}
      <div class={`riser${measured ? ' measured' : ''}`} style={`--i:${i};background:${liquid(measured, sev.border)}`}>
        {measured && <span class="surface" style={`background:${sev.border}`}></span>}
      </div>
    </div>
  ))}
</div>

<style>
  .ladder { margin-top: 1.75rem; display: grid; grid-template-columns: repeat(var(--n), 1fr); align-items: end; gap: 0.75rem; }
  /* la PIEZA: card + líquido en un solo objeto con borde/esquinas continuas */
  .col {
    display: flex; flex-direction: column;
    border: 1px solid rgba(0,0,0,0.07); border-radius: 16px; overflow: hidden; background: #fff;
    box-shadow: 0 1px 2px rgba(0,0,0,0.04);
    transition: box-shadow 0.18s ease, transform 0.18s ease;
  }
  @media (hover: hover) { .col:hover { transform: translateY(-3px); box-shadow: 0 14px 30px -14px rgba(2,60,112,0.3); } }
  .col.is-next {
    border-color: transparent;
    box-shadow: 0 0 0 2px #0375db, 0 10px 26px -12px rgba(3,117,219,0.42);
    background: linear-gradient(180deg, rgba(3,117,219,0.06), #fff 42%);
  }
  .card { display: flex; flex-direction: column; gap: 0.12rem; padding: 1rem 1.05rem 1.15rem; }
  .next {
    display: inline-flex; align-items: center; gap: 0.28rem;
    font-size: 0.6875rem; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 0.35rem;
  }
  .next::before { content: '↑'; font-size: 0.72rem; }
  .card-top { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 0.5rem; }
  .ord { font-size: 1.9rem; font-weight: 700; font-variant-numeric: tabular-nums; line-height: 1; }
  .score { font-size: 1.9rem; font-weight: 600; font-variant-numeric: tabular-nums; line-height: 1; }
  .cover { font-size: 0.68rem; font-weight: 500; border-radius: 999px; padding: 0.2rem 0.5rem; white-space: nowrap; }
  .bex { font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; }
  .label { margin-top: 0.12rem; font-weight: 600; font-size: 0.92rem; line-height: 1.2; }
  .q { margin-top: 0.2rem; font-size: 0.76rem; line-height: 1.3; }
  .sev { align-self: flex-start; margin-top: 0.55rem; border-radius: 999px; padding: 0.12rem 0.5rem; font-size: 0.68rem; font-weight: 600; }
  /* líquido: base de la pieza; altura = peldaño; superficie = línea + onda sutil */
  .riser { position: relative; height: calc(10px + var(--i, 0) * 18px); overflow: hidden; }
  .surface { position: absolute; inset: 0 0 auto 0; height: 2px; opacity: 0.85; }
  .riser.measured::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(100deg, transparent 35%, rgba(255,255,255,0.28) 50%, transparent 65%);
    transform: translateX(-120%); animation: liquid-sheen 4.5s ease-in-out infinite;
  }
  @keyframes liquid-sheen { 0%, 60%, 100% { transform: translateX(-120%); } 80% { transform: translateX(120%); } }

  @media (max-width: 720px) {
    .ladder { grid-template-columns: 1fr; gap: 0.55rem; align-items: stretch; }
    .riser { height: 10px !important; }
  }
  @media (prefers-reduced-motion: reduce) { .riser.measured::after { animation: none; opacity: 0; } }
</style>
