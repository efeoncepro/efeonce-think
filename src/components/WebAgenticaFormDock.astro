---
import { GREENHOUSE_API_BASE } from 'astro:env/server'

/**
 * TASK-1374 — Form dock del ebook "El fin de la web" (/web-agentica).
 *
 * Embebe el `<greenhouse-form>` gobernado del ebook y, al aceptarse el submit, dispara la
 * DESCARGA GATED en pantalla usando el `download_url` que el renderer emite en el evento
 * `gh_form_submission_accepted` (handoff TASK-1375 assetDownload). Sin form completado no hay
 * download_url → no hay descarga. Luego muta a la tarjeta de agradecimiento inline (NO overlay).
 */
interface Props {
  formKey?: string
  surfaceId?: string
}

const {
  formKey = 'db1e254c-e762-41ae-a85f-50b29dc33ba5',
  surfaceId = 'fhsf-web-agentica-ebook',
} = Astro.props

const greenhouseBase = GREENHOUSE_API_BASE.replace(/\/$/, '')
const rendererSrc = `${greenhouseBase}/growth-forms/renderer-latest.js`
---

<div
  class="ebook-form-card"
  id="web-agentica-form"
  data-web-agentica-form-dock
  data-capture="web-agentica-form"
  role="region"
  aria-labelledby="web-agentica-form-title"
>
  <div class="form-workspace">
    <aside class="form-value-rail" data-capture="web-agentica-form-value" aria-label="Qué incluye la descarga">
      <p class="form-rail-kicker"><span class="form-rail-signal" aria-hidden="true"></span> Tu mapa de lectura</p>
      <p class="form-rail-title">Una guía breve para una web que ya no tiene un solo visitante.</p>
      <ol class="form-rail-list">
        <li>
          <span aria-hidden="true">01</span>
          <div><strong>Dos interfaces</strong><p>Tu experiencia y la ventana que usa un agente.</p></div>
        </li>
        <li>
          <span aria-hidden="true">02</span>
          <div><strong>Cuatro niveles</strong><p>De ser encontrado a operar como capacidad.</p></div>
        </li>
        <li>
          <span aria-hidden="true">03</span>
          <div><strong>Checklist semanal</strong><p>Una lista para transformar lectura en acción.</p></div>
        </li>
      </ol>
      <p class="form-rail-delivery"><span aria-hidden="true">↓</span> La descarga comienza al enviar.</p>
    </aside>

    <div class="form-entry">
      <div class="form-intro">
        <p class="form-eyebrow"><span aria-hidden="true">✓</span> Incluye checklist para aplicar esta semana</p>
        <h2 id="web-agentica-form-title" tabindex="-1">Descarga el ebook gratis</h2>
        <p class="form-lead">Cinco actos y un checklist para entender la web agéntica y actuar esta semana. La descarga comienza al enviar.</p>
      </div>

      <div class="form-state form-state-ready" data-form-state="ready">
        <script is:inline defer src={rendererSrc}></script>
        <greenhouse-form
          form-key={formKey}
          surface={surfaceId}
          locale="es-CL"
          color-scheme="light"
          appearance="bare"
          base-url={greenhouseBase}
        >
          <div class="governed-fallback" role="status" aria-live="polite">
            <span class="fallback-line"></span>
            <span class="fallback-line short"></span>
            <span class="fallback-line"></span>
            <p>Preparando el formulario.</p>
          </div>
        </greenhouse-form>
        <noscript>Activa JavaScript para cargar el formulario y descargar el ebook.</noscript>
      </div>
    </div>
  </div>

  <!-- Tarjeta de agradecimiento inline (reemplaza el form post-submit; NO overlay) -->
  <div
    class="form-state form-state-success"
    data-form-state="success"
    data-capture="web-agentica-form-success"
    role="status"
    aria-live="polite"
    hidden
  >
    <div class="success-primary">
      <p class="success-eyebrow"><span aria-hidden="true">✓</span> Descarga confirmada</p>
      <div class="success-mark" aria-hidden="true">
        <svg viewBox="0 0 48 48" width="48" height="48" fill="none"><circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="2" opacity="0.35"/><path d="M15 24.5l6 6 12-13" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
      <h2 id="web-agentica-success-title" tabindex="-1">Tu descarga está lista</h2>
      <p>El PDF ya se está descargando. Si necesitas abrirlo otra vez, usa el botón mientras esta página siga abierta.</p>
      <a class="redownload-cta" data-redownload href="#" hidden>Descargar el ebook otra vez <span aria-hidden="true">↗</span></a>
    </div>
    <div class="bridge">
      <p class="bridge-kicker">Tu punto de partida</p>
      <p class="bridge-title">Mide el nivel 1 de tu web agéntica</p>
      <p class="bridge-body">Descubre si ChatGPT, Perplexity y Google AI encuentran y entienden tu marca. El ebook te ayuda a avanzar desde ahí hacia acciones y capacidades.</p>
      <a class="bridge-cta" href="/brand-visibility">Medir mi visibilidad en IA <span aria-hidden="true">→</span></a>
    </div>
  </div>
</div>

<script>
  const dock = document.querySelector<HTMLElement>('[data-web-agentica-form-dock]')
  if (dock) {
    const ready = dock.querySelector('[data-form-state="ready"]') as HTMLElement | null
    const success = dock.querySelector('[data-form-state="success"]') as HTMLElement | null
    const successTitle = dock.querySelector('#web-agentica-success-title') as HTMLElement | null
    const redownload = dock.querySelector('[data-redownload]') as HTMLAnchorElement | null

    const triggerDownload = (url: string) => {
      const a = document.createElement('a')
      a.href = url
      a.rel = 'noopener'
      a.setAttribute('download', '')
      document.body.appendChild(a)
      a.click()
      a.remove()
    }

    dock.addEventListener('gh_form_submission_accepted', (event: Event) => {
      const detail = (event as CustomEvent).detail ?? {}
      const downloadUrl = typeof detail.download_url === 'string' ? detail.download_url : null

      dock.dataset.submitted = 'true'
      dock.setAttribute('aria-labelledby', 'web-agentica-success-title')
      if (ready) ready.hidden = true
      if (success) success.hidden = false
      if (downloadUrl) {
        triggerDownload(downloadUrl)
        if (redownload) {
          redownload.href = downloadUrl
          redownload.hidden = false
        }
      }
      successTitle?.focus()
    })
  }
</script>
