  }
  :global([data-surround-form-dock][data-submitted='true'] greenhouse-form .ghf-success-card__title) {
    max-width: none !important;
    font-size: 1.22rem !important;
    font-weight: 800 !important;
    letter-spacing: -.025em !important;
  }
  :global([data-surround-form-dock][data-submitted='true'] greenhouse-form .ghf-success-card__body),
  :global([data-surround-form-dock][data-submitted='true'] greenhouse-form .ghf-success-card__support),
  :global([data-surround-form-dock][data-submitted='true'] greenhouse-form .ghf-success-card__reward-body) {
    max-width: none !important;
    font-size: .86rem !important;
    line-height: 1.45 !important;
  }
  :global([data-surround-form-dock][data-submitted='true'] greenhouse-form .ghf-success-card__steps) {
    display: grid !important;
    gap: .36rem !important;
    max-width: none !important;
    margin: .1rem 0 0 !important;
    padding: 0 !important;
    list-style: none !important;
  }
  :global([data-surround-form-dock][data-submitted='true'] greenhouse-form .ghf-success-card__step) {
    position: relative !important;
    max-width: none !important;
    padding-left: 1.35rem !important;
    color: var(--text-secondary) !important;
    font-size: .82rem !important;
    line-height: 1.35 !important;
  }
  :global([data-surround-form-dock][data-submitted='true'] greenhouse-form .ghf-success-card__step::before) {
    position: absolute;
    top: .02rem;
    left: 0;
    color: var(--primary);
    content: '✓';
    font-weight: 800;
  }
  :global([data-surround-form-dock][data-submitted='true'] greenhouse-form .ghf-success-card__reward) {
    gap: .38rem !important;
    margin-top: .15rem !important;
    padding: .78rem .86rem !important;
    border-color: color-mix(in srgb, var(--primary) 22%, var(--border-subtle)) !important;
    border-left: 3px solid var(--primary) !important;
    border-radius: .7rem !important;
    background: color-mix(in srgb, var(--neutral) 76%, #fff) !important;
    text-align: left !important;
  }
  :global([data-surround-form-dock][data-submitted='true'] greenhouse-form .ghf-success-card__reward-title) {
    color: var(--text-primary) !important;
    font-family: var(--sd-display) !important;
    font-size: .94rem !important;
    font-weight: 800 !important;
