  }
  :global([data-surround-form-dock][data-submitted='true'] greenhouse-form .ghf-success-card__mark) {
    grid-column: 1 !important;
    width: 3.35rem !important;
    height: 3.35rem !important;
    margin: 0 !important;
    border: 1px solid color-mix(in srgb, var(--primary) 18%, transparent) !important;
    border-radius: .875rem !important;
    background: color-mix(in srgb, var(--primary-tonal) 84%, #fff) !important;
    box-shadow: inset 0 1px 0 rgba(255,255,255,.72), 0 .75rem 1.35rem -.9rem rgba(13,148,136,.45) !important;
  }
  :global([data-surround-form-dock][data-submitted='true'] greenhouse-form .ghf-success-card__mark-glyph) {
