  :global([data-surround-form-dock] greenhouse-form .ghf-textarea:hover) { border-color: #9fb4c8 !important; box-shadow: 0 4px 12px rgba(20,44,80,.08) !important; }
  :global([data-surround-form-dock] greenhouse-form .ghf-input:focus-visible),
  :global([data-surround-form-dock] greenhouse-form .ghf-select:focus-visible),
  :global([data-surround-form-dock] greenhouse-form .ghf-textarea:focus-visible) { outline: 2px solid var(--primary-light) !important; outline-offset: 2px !important; box-shadow: 0 0 0 4px rgba(13,148,136,.16), 0 10px 24px rgba(20,44,80,.08) !important; }
  :global([data-surround-form-dock] greenhouse-form .ghf-field:has([name="fullName"]) .ghf-input),
  :global([data-surround-form-dock] greenhouse-form .ghf-field:has([name="email"]) .ghf-input) { padding-left: 40px !important; }
