  :global([data-surround-form-dock] greenhouse-form .ghf-success-card:focus-visible) { outline: none !important; }
  :global([data-surround-form-dock] greenhouse-form .ghf-success-card::before) { display: none !important; }
  :global([data-surround-form-dock] greenhouse-form .ghf-success-card__mark) { width: 64px !important; height: 64px !important; color: var(--primary) !important; background: var(--primary-tonal) !important; animation: sd-pop .45s cubic-bezier(.2,.8,.2,1.05) both; }
  :global([data-surround-form-dock] greenhouse-form .ghf-success-card__title) { color: var(--text-primary) !important; font-family: var(--sd-display) !important; font-size: 23px !important; font-weight: 700 !important; line-height: 1.18 !important; }
  :global([data-surround-form-dock] greenhouse-form .ghf-success-card__body),
  :global([data-surround-form-dock] greenhouse-form .ghf-success-card__support),
  :global([data-surround-form-dock] greenhouse-form .ghf-success-card__reward-body) { color: var(--text-secondary) !important; font-family: var(--ghf-font) !important; font-size: 15px !important; line-height: 1.55 !important; }
  :global([data-surround-form-dock] greenhouse-form .ghf-success-card__reward) { border-color: var(--border-subtle) !important; background: var(--neutral) !important; }
  :global([data-surround-form-dock][data-submitted='true'] greenhouse-form .ghf-success-card) {
