  :global([data-surround-form-dock] greenhouse-form .ghf-field:has([data-ghf-consent]) > .ghf-help:last-child) { margin-top: -2px; text-align: center; }
  :global([data-surround-form-dock] greenhouse-form .ghf-field:has([data-ghf-consent]) > .ghf-help:last-child a) { display: inline-flex; min-height: 44px; align-items: center; color: var(--primary) !important; font-weight: 600 !important; text-decoration: underline; text-underline-offset: 3px; }
  :global([data-surround-form-dock] greenhouse-form .ghf-actions-wrap) { display: grid !important; gap: 10px !important; }
  :global([data-surround-form-dock] greenhouse-form .ghf-actions) { display: grid !important; width: 100% !important; gap: 10px !important; }
  :global([data-surround-form-dock] greenhouse-form .ghf-btn) {
    position: relative !important;
    isolation: isolate !important;
    overflow: hidden !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 100% !important;
    min-height: 46px !important;
    padding: 13px 24px !important;
    border: 0 !important;
