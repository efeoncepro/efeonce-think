  :global([data-surround-form-dock] greenhouse-form .ghf-btn:hover:not(:disabled)) { transform: translateY(-3px) !important; filter: saturate(1.16) brightness(1.06) !important; box-shadow: 0 12px 28px rgba(13,148,136,.3) !important; }
  :global([data-surround-form-dock] greenhouse-form .ghf-btn:hover:not(:disabled)::before) { opacity: 1; animation: sd-form-cta-shine .74s cubic-bezier(.25,.7,.3,1) .05s; }
  :global([data-surround-form-dock] greenhouse-form .ghf-btn:active:not(:disabled)) { transform: translateY(-1px) scale(.99) !important; }
