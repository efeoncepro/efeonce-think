---
import { GREENHOUSE_API_BASE } from 'astro:env/server'

/**
 * TASK-1387 — adaptación del dock aprobado al renderer real.
 * Mantiene la tarjeta, portada y estados inline del HTML aprobado; Growth Forms
 * conserva campos, consentimiento, Turnstile, submit, success card y URL tokenizada.
 * El host sólo abre el handoff y ofrece un reintento transitorio de descarga.
 */
interface Props {
  formKey?: string
  surfaceId?: string
}

const {
  formKey = 'e8d2bfcc-c4fe-4396-8f3b-08f5ac190409',
  surfaceId = 'fhsf-surround-discovery-ebook',
} = Astro.props
const greenhouseBase = GREENHOUSE_API_BASE.replace(/\/$/, '')
const rendererSrc = `${greenhouseBase}/growth-forms/renderer-latest.js`
---

<div id="surround-discovery-form" class="sd-form-card" data-surround-form-dock data-capture="surround-discovery-form" aria-live="polite" role="region" aria-labelledby="surround-form-card-title">
  <div class="sd-form-card__line" aria-hidden="true"></div>
  <header class="sd-form-card__header">
    <span class="sd-form-card__cover" aria-hidden="true"><img src="/surround-discovery/ebook-cover.jpeg" alt="" width="3840" height="2160" /></span>
    <div>
      <p id="surround-form-card-title">Surround Discovery™ · PDF</p>
      <span>Formulario de descarga</span>
    </div>
  </header>

  <div class="sd-form-card__body">
    <div data-form-state="ready">
      <script is:inline defer src={rendererSrc}></script>
      <greenhouse-form form-key={formKey} surface={surfaceId} locale="es-CL" color-scheme="light" appearance="bare" base-url={greenhouseBase}>
        <div class="sd-form-fallback" role="status" aria-live="polite">
          <p>Preparando el formulario</p>
          <span>Estamos cargando los campos y protecciones de Greenhouse.</span>
          <i></i><i></i><i></i><b></b>
        </div>
      </greenhouse-form>
      <noscript>Activa JavaScript para cargar el formulario y descargar el ebook.</noscript>
    </div>

    <div class="sd-form-recovery" data-form-state="recovery" hidden role="status" aria-live="polite">
      <p><strong>Descarga automática iniciada.</strong><span>Si el navegador la bloqueó, usa el respaldo mientras esta página siga abierta.</span></p>
      <a class="sd-form-download" data-redownload href="#" hidden>↓ Descargar de nuevo</a>
      <p class="sd-form-retry" data-redownload-copy hidden>El enlace de respaldo queda activo en esta sesión.</p>
    </div>

    <div class="sd-form-degraded" data-form-state="degraded" hidden role="status" aria-live="polite">
      <div class="sd-form-status-mark sd-form-status-mark--degraded" aria-hidden="true">!</div>
      <h3 id="surround-discovery-degraded-title" tabindex="-1">Tu solicitud fue recibida</h3>
      <p>La descarga automática no se pudo iniciar en este momento. Puedes recargar el formulario; no expondremos un enlace público al PDF.</p>
      <button type="button" data-retry-form>↻ Recargar el formulario</button>
    </div>
  </div>
</div>

<script>
  const dock = document.querySelector<HTMLElement>('[data-surround-form-dock]')
  if (dock) {
    const ready = dock.querySelector<HTMLElement>('[data-form-state="ready"]')
    const recovery = dock.querySelector<HTMLElement>('[data-form-state="recovery"]')
    const degraded = dock.querySelector<HTMLElement>('[data-form-state="degraded"]')
    const degradedTitle = dock.querySelector<HTMLElement>('#surround-discovery-degraded-title')
    const redownload = dock.querySelector<HTMLAnchorElement>('[data-redownload]')
    const redownloadCopy = dock.querySelector<HTMLElement>('[data-redownload-copy]')
    const retry = dock.querySelector<HTMLButtonElement>('[data-retry-form]')
    const greenhouseForm = dock.querySelector('greenhouse-form')

    const polishRendererChrome = () => {
      const privacyLink = Array.from(dock.querySelectorAll<HTMLAnchorElement>('greenhouse-form .ghf-help a'))
        .find((link) => /politica-de-privacidad/i.test(link.href))

      if (privacyLink && /^https?:\/\//i.test(privacyLink.textContent?.trim() ?? '')) {
        privacyLink.textContent = 'aviso de privacidad'
        privacyLink.setAttribute('aria-label', 'Abrir aviso de privacidad de Efeonce')
      }
    }

    const triggerDownload = (url: string) => {
      const link = document.createElement('a')
      link.href = url
      link.rel = 'noopener'
      link.setAttribute('download', '')
      document.body.appendChild(link)
      link.click()
      link.remove()
    }

    dock.addEventListener('gh_form_submission_accepted', (event: Event) => {
      const detail = (event as CustomEvent<Record<string, unknown>>).detail ?? {}
      const downloadUrl = typeof detail.download_url === 'string' && detail.download_url.length > 0 ? detail.download_url : null
      dock.dataset.submitted = 'true'

      if (downloadUrl) {
        if (recovery) recovery.hidden = false
        triggerDownload(downloadUrl)
        if (redownload) { redownload.href = downloadUrl; redownload.hidden = false }
        if (redownloadCopy) redownloadCopy.hidden = false
        window.requestAnimationFrame(() => dock.querySelector<HTMLElement>('.ghf-success-card')?.focus())
        return
      }

      if (ready) ready.hidden = true
      if (recovery) recovery.hidden = true
      if (degraded) degraded.hidden = false
      dock.setAttribute('aria-labelledby', 'surround-discovery-degraded-title')
      degradedTitle?.focus()
    })
    retry?.addEventListener('click', () => window.location.reload())
    if (greenhouseForm) {
      new MutationObserver(polishRendererChrome).observe(greenhouseForm, { childList: true, subtree: true })
      polishRendererChrome()
    }
  }
</script>

<style>
  .sd-form-card { position: relative; overflow: hidden; border: 1px solid #e3e9f0; border-radius: 1rem; background: var(--sd-white); box-shadow: 0 1px 2px rgba(16,24,40,.04), 0 .75rem 1.75rem -.5rem rgba(20,44,80,.18), 0 2.5rem 3.75rem -2rem rgba(20,44,80,.22); }
  .sd-form-card__line { position: absolute; inset: 0 0 auto; z-index: 1; height: 3px; background: linear-gradient(90deg,#3fb6bd 0%,#2b6f9e 55%,#1f4e79 100%); }
  .sd-form-card__header { display: flex; align-items: center; gap: .875rem; padding: 1rem 1.25rem; border-bottom: 1px solid var(--sd-line); background: linear-gradient(180deg,#fbfcfe,var(--sd-white)); }
  .sd-form-card__cover { display: block; flex: 0 0 auto; width: 6.5rem; aspect-ratio: 16 / 9; overflow: hidden; border-radius: .5rem; outline: 1px solid rgba(255,255,255,.65); outline-offset: -1px; box-shadow: 0 .25rem .75rem -.125rem rgba(20,44,80,.3); }
  .sd-form-card__cover img { display: block; width: 100%; height: 100%; object-fit: cover; }.sd-form-card__header p { margin: 0; color: var(--sd-ink); font-family: var(--sd-display); font-size: 1rem; font-weight: 600; line-height: 1.2; }.sd-form-card__header span { display: block; margin-top: .12rem; color: var(--sd-muted); font-size: .78rem; }.sd-form-card__body { padding: 1.375rem; }
  :global([data-surround-form-dock] greenhouse-form),
  :global([data-surround-form-dock] greenhouse-form .ghf-root),
  :global([data-surround-form-dock] greenhouse-form .ghf-scope) {
    --ghf-font: 'Geist','Geist Variable',system-ui,sans-serif;
    --ghf-accent: var(--primary);
    --ghf-accent-contrast: var(--surface);
    --ghf-fg: var(--text-primary);
    --ghf-muted: var(--text-secondary);
    --ghf-bg: transparent;
    --ghf-field-bg: var(--surface);
    --ghf-border: #d7e3ef;
    --ghf-border-strong: #9fb4c8;
    --ghf-focus: var(--primary-light);
    --ghf-radius: 8px;
    --ghf-gap: 15px;
    --ghf-field-shadow: 0 1px 2px rgba(16,24,40,.04);
    --ghf-field-shadow-focus: 0 0 0 4px rgba(13,148,136,.16), 0 10px 24px rgba(20,44,80,.08);
    --ghf-action-shadow: 0 4px 14px rgba(13,148,136,.24);
    --ghf-action-shadow-hover: 0 12px 28px rgba(13,148,136,.3);
    font-family: var(--ghf-font);
  }
  :global([data-surround-form-dock] greenhouse-form .ghf-form) { gap: 15px; }
  :global([data-surround-form-dock] greenhouse-form .ghf-fields) { display: grid !important; grid-template-columns: repeat(2,minmax(0,1fr)) !important; gap: 15px 12px !important; }
  :global([data-surround-form-dock] greenhouse-form .ghf-field) { gap: 6px !important; min-width: 0; }
  :global([data-surround-form-dock] greenhouse-form .ghf-field:has([name="fullName"])),
  :global([data-surround-form-dock] greenhouse-form .ghf-field:has([name="email"])),
  :global([data-surround-form-dock] greenhouse-form .ghf-field--full) { grid-column: 1 / -1 !important; }
  :global([data-surround-form-dock] greenhouse-form .ghf-label) { color: var(--text-primary) !important; font-family: var(--ghf-font) !important; font-size: .875rem !important; font-weight: 600 !important; line-height: 1.3 !important; }
  :global([data-surround-form-dock] greenhouse-form .ghf-required) { color: var(--primary) !important; }
  :global([data-surround-form-dock] greenhouse-form .ghf-optional) { color: var(--text-disabled) !important; font-weight: 500 !important; }
  :global([data-surround-form-dock] greenhouse-form .ghf-help) { margin: 0; color: var(--text-secondary) !important; font-family: var(--ghf-font) !important; font-size: .8125rem !important; line-height: 1.45 !important; }
