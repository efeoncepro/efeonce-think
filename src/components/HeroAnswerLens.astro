<style>
  .answer-lens {
    position: relative;
    min-width: 0;
    margin: 0;
    align-self: stretch;
    isolation: isolate;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    clip-path: inset(50%);
  }

  .answer-lens::before,
  .answer-lens::after {
    content: '';
    position: absolute;
    pointer-events: none;
    border-radius: 999px;
    z-index: -1;
  }

  .answer-lens::before {
    inset: 2% 1% 6% 8%;
    background:
      radial-gradient(circle at 50% 44%, rgba(75, 141, 255, 0.28), transparent 58%),
      radial-gradient(circle at 72% 32%, rgba(255, 179, 26, 0.13), transparent 38%);
    filter: blur(28px);
    opacity: 0.9;
  }

  .answer-lens::after {
    inset: 19% 13% 20% 20%;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 0 88px rgba(75, 141, 255, 0.14);
  }

  .answer-lens-svg {
    position: relative;
    display: block;
    width: min(100%, 680px);
    height: auto;
    margin-left: auto;
    overflow: visible;
    transform: translateX(-6%) scale(1.15);
    transform-origin: 56% 48%;
  }

  .scene-layer,
  .answer-card,
  .composer,
  .lens,
  .sparkle,
  .engine-node,
  .draw-line,
  .query-line,
  .query-dot,
  .scan-ribbon,
  .lens-scan,
  .orbit-line,
  .orbit-comet,
  .core-ring,
  .aperture-blade,
  .lens-readout,
  .lens-aura,
  .lens-caustic,
  .lens-highlight,
  .lens-rim-glint,
  .micro-star,
  .citation-dot,
  .evidence-ping,
  .spark-aura,
  .spark-core,
  .spark-diamond,
  .spark-flare,
  .spark-ray,
  .spark-secondary,
  .spark-ping,
  .composer-pulse {
    will-change: transform, opacity;
  }

  @media (max-width: 980px) {
    .answer-lens {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scene-layer,
    .answer-card,
    .composer,
    .lens,
    .sparkle,
    .engine-node,
    .draw-line,
    .query-line,
    .query-dot,
    .scan-ribbon,
    .lens-scan,
    .orbit-line,
    .orbit-comet,
    .core-ring,
    .aperture-blade,
    .lens-readout,
    .lens-aura,
    .lens-caustic,
    .lens-highlight,
    .lens-rim-glint,
    .micro-star,
    .citation-dot,
    .evidence-ping,
    .spark-aura,
    .spark-core,
    .spark-diamond,
    .spark-flare,
    .spark-ray,
    .spark-secondary,
    .spark-ping {
      animation: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  import gsap from 'gsap'

  const roots = gsap.utils.toArray<HTMLElement>('[data-answer-lens]')
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches

  roots.forEach((root) => {
    const q = gsap.utils.selector(root)
    const drawLines = q<SVGPathElement>('.draw-line')
    const queryLines = q<SVGPathElement>('.query-line')
    const orbitLines = q<SVGPathElement>('.orbit-line')

    drawLines.forEach((line) => {
      const length = line.getTotalLength()
      gsap.set(line, { strokeDasharray: length, strokeDashoffset: length })
    })
    queryLines.forEach((line) => {
      const length = line.getTotalLength()
      gsap.set(line, { strokeDasharray: length, strokeDashoffset: length })
    })

    if (reduce) {
      gsap.set(q('.scene-layer, .answer-card, .composer, .lens, .lens-readout, .sparkle, .engine-node'), { autoAlpha: 1, clearProps: 'transform' })
      gsap.set([...drawLines, ...queryLines], { strokeDashoffset: 0 })
      return
    }

    const cards = q('.answer-card')
    const composer = q('.composer')
    const promptLines = q('.prompt-line')
    const core = q('.intelligence-core')
    const lens = q('.lens')
    const lensMotion = q('.lens, .lens-readout')
    const lensReadout = q('.lens-readout')
    const lensAura = q('.lens-aura')
    const lensCaustics = q('.lens-caustic')
    const lensGlints = q('.lens-rim-glint')
    const lensHighlights = q('.lens-highlight')
    const sparkle = q('.sparkle')
    const sparkAura = q('.spark-aura')
    const sparkCore = q('.spark-core')
    const sparkDiamond = q('.spark-diamond')
    const sparkFlares = q('.spark-flare')
    const sparkRays = q('.spark-ray')
    const sparkSecondary = q('.spark-secondary')
    const engineOrbit = q('.engine-orbit')
    const engineNodes = q('.engine-node')
    const orbitComets = q('.orbit-comet')
    const scanRibbons = q('.scan-ribbon')
    const lensScan = q('.lens-scan')
    const coreRings = q('.core-ring')
    const aperture = q('.aperture')
    const stars = q('.micro-star')
    const dots = q('.citation-dot')
    const queryDots = q('.query-dot')
    const evidencePings = q('.evidence-ping')
    const sparkPing = q('.spark-ping')
    const composerPulse = q('.composer-pulse')
    const parallaxLayers = q('.scene-layer')

    gsap.set(q('.answer-card, .composer, .sparkle, .engine-node, .query-dot, .lens-readout, .evidence-ping'), { autoAlpha: 0 })
    gsap.set(core, { autoAlpha: 0, scale: 0.9, rotation: -7, svgOrigin: '386 244' })
    gsap.set(cards, { y: 24, scale: 0.96, transformOrigin: '50% 50%' })
    gsap.set(composer, { y: 18, scale: 0.985, transformOrigin: '50% 50%' })
    gsap.set(promptLines, { scaleX: 0, transformOrigin: 'left center' })
    gsap.set(lensMotion, { x: -58, y: 20, rotation: -8, scale: 0.94, svgOrigin: '398 232' })
    gsap.set(lens, { autoAlpha: 0.68 })
    gsap.set(lensCaustics, { x: -12, autoAlpha: 0.55 })
    gsap.set(lensGlints, { autoAlpha: 0.86, svgOrigin: '398 232' })
    gsap.set(lensAura, { autoAlpha: 0.62, scale: 0.92, svgOrigin: '398 232' })
    gsap.set(scanRibbons, { x: -170, autoAlpha: 0 })
    gsap.set(lensScan, { x: -118, autoAlpha: 0 })
    gsap.set(sparkle, { scale: 0.42, svgOrigin: '452 192' })
    gsap.set([...sparkAura, ...sparkCore, ...sparkDiamond, ...sparkFlares, ...sparkRays, ...sparkSecondary], { transformOrigin: '50% 50%' })
    gsap.set(engineNodes, { scale: 0.62, transformOrigin: '50% 50%' })
    gsap.set(dots, { scale: 0.3, transformOrigin: '50% 50%' })
    gsap.set(evidencePings, { scale: 0.4, transformOrigin: '50% 50%' })
    gsap.set(composerPulse, { scaleX: 0, transformOrigin: 'left center' })
    gsap.set(sparkPing, { scale: 0.5, autoAlpha: 0, svgOrigin: '452 192' })

    const intro = gsap.timeline({ defaults: { ease: 'power3.out' } })

    intro
      .to(core, { autoAlpha: 1, scale: 1, rotation: 0, duration: 0.92, ease: 'expo.out' })
      .to(composer, { autoAlpha: 1, y: 0, scale: 1, duration: 0.58 }, '<0.12')
      .to(promptLines, { scaleX: 1, duration: 0.36, stagger: 0.07 }, '<0.16')
      .to(composerPulse, { scaleX: 1, duration: 0.4, ease: 'power2.out' }, '<0.16')
      .to(queryLines, { strokeDashoffset: 0, duration: 0.8, ease: 'power2.out' }, '<0.08')
      .to(queryDots, { autoAlpha: 1, duration: 0.16, stagger: 0.06 }, '<')
      .to(queryDots, { x: (index) => [14, 56, -54][index] || 18, y: (index) => [-169, -113, -213][index] || -120, duration: 0.92, stagger: 0.06, ease: 'power2.inOut' }, '<')
      .to(queryDots, { autoAlpha: 0, duration: 0.18 }, '>-0.08')
      .fromTo(cards, { autoAlpha: 0, y: 24, scale: 0.96 }, { autoAlpha: 1, y: 0, scale: 1, duration: 0.62, stagger: { each: 0.11, from: 'center' } }, '<0.22')
      .to(engineNodes, { autoAlpha: 1, scale: 1, duration: 0.5, stagger: { each: 0.07, from: 'random' }, ease: 'back.out(1.8)' }, '<0.1')
      .to(drawLines, { strokeDashoffset: 0, duration: 0.7, stagger: 0.08, ease: 'power2.out' }, '<0.22')
      .to(lensMotion, { x: 0, y: 0, rotation: 0, scale: 1, duration: 0.96, ease: 'power3.inOut' }, '<0.08')
      .to(lens, { autoAlpha: 1, duration: 0.28 }, '<')
      .to(lensReadout, { autoAlpha: 1, duration: 0.42, ease: 'power2.out' }, '<0.28')
      .to(scanRibbons, { autoAlpha: 0.72, x: 190, duration: 1.04, ease: 'sine.inOut' }, '<0.08')
      .to(lensScan, { autoAlpha: 0.82, x: 112, duration: 0.92, ease: 'sine.inOut' }, '<0.08')
      .to(sparkle, { autoAlpha: 1, scale: 1, duration: 0.36, ease: 'back.out(2)' }, '-=0.24')
      .to(dots, { scale: 1, duration: 0.26, stagger: 0.08, ease: 'back.out(2)' }, '<0.02')
      .to(evidencePings, { autoAlpha: 1, scale: 1, duration: 0.28, stagger: 0.07, ease: 'back.out(2)' }, '<0.02')
      .to(scanRibbons, { autoAlpha: 0, duration: 0.32 }, '>-0.1')
      .to(lensScan, { autoAlpha: 0, duration: 0.28 }, '<')

    intro.eventCallback('onComplete', () => {
      gsap.to(cards, {
        y: (index) => [-7, 5, -4][index] || -5,
        duration: 2.4,
        stagger: { each: 0.16, yoyo: true, repeat: -1 },
        ease: 'sine.inOut',
        overwrite: 'auto',
      })

      gsap.to(coreRings, {
        rotation: (index) => (index ? -360 : 360),
        duration: (index) => (index ? 18 : 26),
        repeat: -1,
        ease: 'none',
        svgOrigin: '386 244',
        overwrite: 'auto',
      })

      gsap.to(orbitLines, {
        strokeDashoffset: (index) => (index ? -70 : 90),
        duration: (index) => (index ? 7.5 : 9.5),
        repeat: -1,
        ease: 'none',
        overwrite: 'auto',
      })

      gsap.to(aperture, {
        rotation: -7,
        duration: 4.8,
        yoyo: true,
        repeat: -1,
        ease: 'sine.inOut',
        svgOrigin: '386 244',
        overwrite: 'auto',
      })

      gsap.to(engineOrbit, {
        rotation: 360,
        duration: 34,
        repeat: -1,
        ease: 'none',
        svgOrigin: '386 244',
        overwrite: 'auto',
      })

      gsap.to(engineNodes, {
        rotation: -360,
        duration: 34,
        repeat: -1,
        ease: 'none',
        transformOrigin: '50% 50%',
        overwrite: 'auto',
      })

      gsap.to(orbitComets, {
        scale: 0.55,
        autoAlpha: 0.46,
        duration: 1.8,
        stagger: { each: 0.34, yoyo: true, repeat: -1 },
        ease: 'sine.inOut',
        overwrite: 'auto',
      })

      gsap.to(lensMotion, {
        x: 9,
        y: -5,
        rotation: 1.4,
        duration: 2.8,
        yoyo: true,
        repeat: -1,
        ease: 'sine.inOut',
        overwrite: 'auto',
      })

      gsap.to(lensAura, {
        scale: 1.06,
        autoAlpha: 0.36,
        duration: 2.8,
        yoyo: true,
        repeat: -1,
        ease: 'sine.inOut',
        overwrite: 'auto',
      })

      gsap.to(lensCaustics, {
        x: 10,
        autoAlpha: 0.82,
        duration: 2.65,
        stagger: { each: 0.18, yoyo: true, repeat: -1 },
        ease: 'sine.inOut',
        overwrite: 'auto',
      })

      gsap.to(lensGlints, {
        rotation: (index) => (index ? -5 : 6),
        autoAlpha: (index) => (index ? 0.38 : 0.76),
        duration: 2.4,
        stagger: { each: 0.22, yoyo: true, repeat: -1 },
        ease: 'sine.inOut',
        overwrite: 'auto',
      })

      gsap.to(lensHighlights, {
        x: 4,
        autoAlpha: 0.72,
        duration: 2.3,
        yoyo: true,
        repeat: -1,
        ease: 'sine.inOut',
        overwrite: 'auto',
      })

      gsap.to(evidencePings, {
        scale: 0.62,
        autoAlpha: 0.52,
        duration: 1.05,
        stagger: { each: 0.18, yoyo: true, repeat: -1 },
        ease: 'sine.inOut',
        overwrite: 'auto',
      })

      gsap.to(sparkle, {
        scale: 0.92,
        autoAlpha: 0.86,
        rotation: 3,
        duration: 1.55,
        yoyo: true,
        repeat: -1,
        ease: 'sine.inOut',
        overwrite: 'auto',
      })

      gsap.to(sparkRays, {
        scaleX: 0.68,
        autoAlpha: 0.64,
        duration: 1.32,
        stagger: { each: 0.08, yoyo: true, repeat: -1 },
        ease: 'sine.inOut',
        overwrite: 'auto',
      })

      gsap.to(sparkFlares, {
        scaleX: 1.22,
        autoAlpha: 0.52,
        duration: 1.48,
        stagger: { each: 0.12, yoyo: true, repeat: -1 },
        ease: 'sine.inOut',
        overwrite: 'auto',
      })

      gsap.to([...sparkAura, ...sparkDiamond], {
        scale: 0.86,
        autoAlpha: 0.58,
        duration: 1.18,
        yoyo: true,
        repeat: -1,
        ease: 'sine.inOut',
        overwrite: 'auto',
      })

      gsap.to(sparkCore, {
        scale: 0.72,
        duration: 0.92,
        yoyo: true,
        repeat: -1,
        ease: 'sine.inOut',
        overwrite: 'auto',
      })

      gsap.to(sparkSecondary, {
        y: -3,
        rotation: -8,
        duration: 1.9,
        yoyo: true,
        repeat: -1,
        ease: 'sine.inOut',
        overwrite: 'auto',
      })

      gsap.to(stars, {
        autoAlpha: 0.34,
        scale: 0.72,
        duration: 1.6,
        stagger: { each: 0.32, yoyo: true, repeat: -1 },
        ease: 'sine.inOut',
        overwrite: 'auto',
      })

      const scanLoop = gsap.timeline({ repeat: -1, repeatDelay: 1.4 })
      scanLoop
        .set(scanRibbons, { x: -170, autoAlpha: 0 })
        .set(lensScan, { x: -118, autoAlpha: 0 })
        .to(scanRibbons, { autoAlpha: 0.58, x: 190, duration: 1.05, ease: 'sine.inOut' })
        .to(lensScan, { autoAlpha: 0.66, x: 112, duration: 0.9, ease: 'sine.inOut' }, '<0.04')
        .to(scanRibbons, { autoAlpha: 0, duration: 0.3, ease: 'sine.out' })
        .to(lensScan, { autoAlpha: 0, duration: 0.24, ease: 'sine.out' }, '<')

      const queryLoop = gsap.timeline({ repeat: -1, repeatDelay: 2.2 })
      queryLoop
        .set(queryLines, { strokeDashoffset: (_index, line: SVGPathElement) => line.getTotalLength() })
        .set(queryDots, { x: 0, y: 0, autoAlpha: 0 })
        .to(queryLines, { strokeDashoffset: 0, duration: 0.72, ease: 'power2.out' })
        .to(queryDots, { autoAlpha: 1, duration: 0.14, stagger: 0.05 }, '<')
        .to(queryDots, { x: (index) => [14, 56, -54][index] || 18, y: (index) => [-169, -113, -213][index] || -120, duration: 0.82, stagger: 0.05, ease: 'power2.inOut' }, '<')
        .to(queryDots, { autoAlpha: 0, duration: 0.18 }, '>-0.05')
        .to(queryLines, { autoAlpha: 0, duration: 0.24 }, '<')
        .set(queryLines, { autoAlpha: 1 })

      gsap.to(sparkPing, {
        scale: 1.48,
        autoAlpha: 0,
        duration: 1.9,
        repeat: -1,
        repeatDelay: 2.35,
        ease: 'power2.out',
        overwrite: 'auto',
      })
    })

    if (window.matchMedia('(pointer: fine)').matches) {
      const movers = parallaxLayers.map((layer, index) => ({
        layer,
        xTo: gsap.quickTo(layer, 'x', { duration: 0.7, ease: 'power3.out' }),
        yTo: gsap.quickTo(layer, 'y', { duration: 0.7, ease: 'power3.out' }),
        depth: (index + 1) * 0.8,
      }))

      const handlePointerMove = (event: PointerEvent) => {
        const rect = root.getBoundingClientRect()
        const relX = (event.clientX - rect.left) / rect.width - 0.5
        const relY = (event.clientY - rect.top) / rect.height - 0.5

        movers.forEach(({ xTo, yTo, depth }) => {
          xTo(relX * depth * 8)
          yTo(relY * depth * 6)
        })
      }

      const handlePointerLeave = () => {
        movers.forEach(({ xTo, yTo }) => {
          xTo(0)
          yTo(0)
        })
      }

      root.addEventListener('pointermove', handlePointerMove)
      root.addEventListener('pointerleave', handlePointerLeave)
    }
  })
</script>
