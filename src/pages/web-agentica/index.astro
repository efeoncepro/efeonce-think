---
import '@fontsource/poppins/600.css'
import '@fontsource/poppins/700.css'
import BaseLayout from '@layouts/BaseLayout.astro'
import WebAgenticaFormDock from '@/components/WebAgenticaFormDock.astro'
import { axis, teal } from '@lib/report-tokens'

/**
 * TASK-1374 — Landing pública del ebook "El fin de la web" (/web-agentica).
 * Re-autoría nativa del PR #12 (NO el export estático): BaseLayout (SEO+GTM), tokens AXIS navy +
 * teal `#36c8bf`, Geist/Poppins, form gobernado + descarga gated tokenizada. Paleta Navy + Teal.
 */
const siteUrl = 'https://think.efeoncepro.com'
const landingUrl = `${siteUrl}/web-agentica`
const pageTitle = 'El fin de la web: marketing + IA | Efeonce Think'
const pageDescription =
  'Descarga gratis el ebook sobre la web agéntica: cómo la IA cambia quién encuentra tu marca y qué hacer esta semana.'

const stats = [
  { value: '−27%', label: 'Caída del tráfico orgánico interanual', source: 'HubSpot, 2026' },
  { value: '3×', label: 'El tráfico referido por IA se triplicó', source: '' },
  { value: '7×', label: 'Más ventas con integración agéntica', source: 'Cyber Week 2025' },
]

const inside = [
  'Qué es un agente de IA y por qué ya visita tu sitio',
  'AEO: cómo ser la respuesta, no solo un resultado',
  'llms.txt y las señales que la IA lee de tu marca',
  'Zero-click commerce y el flujo de venta agéntico',
  'Un checklist para aplicar esta semana',
]

const forWho = ['Dirección y C-level que deciden estrategia', 'Marketing y Growth que buscan tráfico que convierte', 'SEO y contenidos frente al cambio de la IA', 'Producto y tech que preparan el sitio']
const notForWho = ['Buscas un truco rápido de una semana', 'No te interesa cómo la IA cambia la web', 'Prefieres esperar a que "se calme"']

const faqs = [
  { q: '¿Qué es un agente de inteligencia artificial?', a: 'Un software que actúa por ti: navega, compara, decide y ejecuta tareas en la web sin que tengas que hacer clic. ChatGPT, Gemini o Claude ya operan así cuando les pides que investiguen o compren algo.' },
  { q: '¿Qué es AEO y en qué se diferencia del SEO?', a: 'AEO (Answer Engine Optimization) optimiza tu contenido para que los motores de respuesta lo citen directamente. El SEO busca posiciones en resultados; el AEO busca ser la fuente de la respuesta que la IA entrega.' },
  { q: '¿Qué es llms.txt y cómo se implementa?', a: 'Un archivo en la raíz de tu sitio que le indica a los modelos de lenguaje qué contenido pueden usar y cómo. Se implementa como un simple archivo de texto, igual que robots.txt, con las secciones clave de tu sitio.' },
  { q: '¿Qué es zero-click commerce?', a: 'Compras que se completan sin que el usuario visite tu web: el agente encuentra, compara y ejecuta la transacción por él. Requiere integración agéntica para no quedar fuera del flujo de venta.' },
  { q: '¿Cuándo los bots superaron al tráfico humano?', a: 'El 3 de junio de 2026, según datos de Cloudflare: 57.5% del tráfico de internet fue automatizado frente a un 42.5% humano — la primera vez en la historia de la red.' },
]

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': `${landingUrl}#webpage`,
    url: landingUrl,
    name: pageTitle,
    description: pageDescription,
    inLanguage: 'es-CL',
    isPartOf: { '@type': 'WebSite', url: siteUrl, name: 'Efeonce Think' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map(f => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
]
---

<BaseLayout title={pageTitle} description={pageDescription} canonical="/web-agentica" jsonLd={jsonLd}>
  <main
    class="web-agentica"
    data-capture="web-agentica-landing"
    style={`--navy:${axis.accent[900]};--navy-soft:${axis.accent[800]};--blue:${axis.accent[500]};--teal:${teal[500]};--teal-soft:${teal[400]};--teal-deep:${teal[700]};--ink:${axis.gray[900]};--muted:${axis.gray[600]};--line:${axis.gray[200]};--surface:${axis.gray[50]};`}
  >
    <!-- HERO -->
    <section class="hero" data-capture="web-agentica-hero">
      <header class="topbar">
        <a class="brand-link" href="/" aria-label="Ir a Efeonce Think">
          <img class="efeonce-mark" src="/branding/efeonce-logo-negative.svg" alt="Efeonce" />
          <span class="brand-divider" aria-hidden="true"></span>
          <img class="think-mark" src="/branding/eo-think-2.svg" alt="Think" />
        </a>
      </header>
      <div class="hero-inner">
        <p class="eyebrow">Marketing digital + IA</p>
        <h1 class="hero-title">El <span class="accent">fin</span> de la web como la conoces</h1>
        <p class="hero-lead">Tu sitio ya recibe dos tipos de visitantes: personas y agentes de IA. Este ebook te muestra cómo dejar de diseñar solo para uno.</p>
        <a class="hero-cta" href="#web-agentica-form">Descargar el ebook gratis</a>
        <p class="hero-reassurance">Sin spam. Solo el ebook y contenido que sí sirve.</p>
      </div>
    </section>

    <!-- STATS -->
    <section class="stats" data-capture="web-agentica-stats" aria-label="Lo que ya está pasando">
      {stats.map(s => (
        <div class="stat-card">
          <p class="stat-value">{s.value}</p>
          <p class="stat-label">{s.label}</p>
          {s.source ? <p class="stat-source">{s.source}</p> : null}
        </div>
      ))}
    </section>

    <!-- THESIS -->
    <section class="thesis" data-capture="web-agentica-thesis">
      <h2>Tu sitio ya tiene dos tipos de visitantes.</h2>
      <p class="thesis-sub">Solo estás diseñado para uno.</p>
    </section>

    <!-- INSIDE -->
    <section class="inside" data-capture="web-agentica-inside">
      <div class="section-head">
        <p class="kicker">Qué vas a encontrar dentro</p>
        <h2>Cinco actos para leer la nueva web</h2>
      </div>
      <ul class="inside-list">
        {inside.map(item => (
          <li><span class="tick" aria-hidden="true">→</span>{item}</li>
        ))}
      </ul>
      <p class="inside-note">Incluye checklist «Lo que haces esta semana».</p>
    </section>

    <!-- AUDIENCE -->
    <section class="audience" data-capture="web-agentica-audience">
      <div class="audience-col">
        <h3>Para quién es este ebook</h3>
        <ul>{forWho.map(x => <li><span class="tick tick-yes" aria-hidden="true">✓</span>{x}</li>)}</ul>
      </div>
      <div class="audience-col audience-col-no">
        <h3>No es para ti si…</h3>
        <ul>{notForWho.map(x => <li><span class="tick tick-no" aria-hidden="true">—</span>{x}</li>)}</ul>
      </div>
    </section>

    <!-- FORM -->
    <section class="form-section" data-capture="web-agentica-form-section">
      <WebAgenticaFormDock />
    </section>

    <!-- FAQ -->
    <section class="faq" data-capture="web-agentica-faq">
      <div class="section-head">
        <p class="kicker">Preguntas frecuentes</p>
        <h2>Lo que quizá te estás preguntando</h2>
      </div>
      <div class="faq-list">
        {faqs.map(f => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="footer" data-capture="web-agentica-footer">
      <img class="footer-mark" src="/branding/efeonce-logo-negative.svg" alt="Efeonce" />
      <p>Escrito por el equipo de Efeonce. Agencia especializada en growth con IA.</p>
    </footer>
  </main>
</BaseLayout>

<style>
  .web-agentica {
    font-family: 'Geist Variable', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    color: var(--ink);
    background: #fff;
  }
  .web-agentica h1, .web-agentica h2, .web-agentica h3, .eyebrow, .kicker, .stat-value, .hero-cta, .bridge-cta {
    font-family: 'Poppins', 'Geist Variable', sans-serif;
  }

  /* HERO */
  .hero {
    position: relative;
    background: radial-gradient(120% 90% at 50% 0%, var(--navy-soft) 0%, var(--navy) 55%, #001a33 100%);
    color: #fff;
    padding: 0 clamp(1.25rem, 5vw, 3rem) clamp(3.5rem, 8vw, 6rem);
    overflow: hidden;
  }
  .hero::after {
    content: '';
    position: absolute;
    inset: -30% -10% auto -10%;
    height: 70%;
    background: radial-gradient(60% 60% at 50% 40%, color-mix(in srgb, var(--teal) 26%, transparent) 0%, transparent 70%);
    pointer-events: none;
  }
  .topbar { display: flex; align-items: center; padding: clamp(1.25rem, 4vw, 2rem) 0; position: relative; z-index: 1; }
  .brand-link { display: inline-flex; align-items: center; gap: 12px; }
  .efeonce-mark, .think-mark { height: 26px; width: auto; }
  .brand-divider { width: 1px; height: 20px; background: rgba(255,255,255,0.3); }
  .hero-inner { position: relative; z-index: 1; max-width: 720px; margin: clamp(1.5rem, 5vw, 3rem) auto 0; text-align: center; }
  .eyebrow {
    display: inline-block; font-size: 0.8125rem; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--teal-soft); margin: 0 0 1rem;
  }
  .hero-title { font-size: clamp(2.25rem, 6vw, 4rem); font-weight: 700; line-height: 1.05; margin: 0 0 1.25rem; letter-spacing: -0.02em; }
  .hero-title .accent { color: var(--teal); }
  .hero-lead { font-size: clamp(1.0625rem, 2.4vw, 1.375rem); line-height: 1.55; color: rgba(255,255,255,0.82); margin: 0 auto 2rem; max-width: 620px; }
  .hero-cta, .bridge-cta {
    display: inline-flex; align-items: center; justify-content: center;
    background: var(--teal); color: #04222f; font-weight: 600; font-size: 1.0625rem;
    padding: 0.95rem 1.9rem; border-radius: 12px; text-decoration: none;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
    box-shadow: 0 12px 32px -12px color-mix(in srgb, var(--teal) 60%, transparent);
  }
  .hero-cta:hover, .bridge-cta:hover { transform: translateY(-2px); background: var(--teal-soft); }
  .hero-reassurance { font-size: 0.9375rem; color: rgba(255,255,255,0.6); margin: 1rem 0 0; }

  /* STATS */
  .stats { max-width: 1080px; margin: 0 auto; padding: clamp(2.5rem, 6vw, 4rem) clamp(1.25rem, 5vw, 3rem); display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  .stat-card { background: var(--surface); border: 1px solid var(--line); border-radius: 16px; padding: 1.75rem 1.5rem; text-align: center; }
  .stat-value { font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 700; color: var(--navy); margin: 0 0 0.5rem; letter-spacing: -0.02em; }
  .stat-label { font-size: 0.9375rem; line-height: 1.4; color: var(--ink); margin: 0 0 0.35rem; }
  .stat-source { font-size: 0.75rem; color: var(--muted); margin: 0; }

  /* THESIS */
  .thesis { max-width: 820px; margin: 0 auto; padding: clamp(2rem, 5vw, 3.5rem) clamp(1.25rem, 5vw, 3rem); text-align: center; }
  .thesis h2 { font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 700; color: var(--navy); margin: 0; letter-spacing: -0.02em; line-height: 1.15; }
  .thesis-sub { font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 700; color: var(--teal-deep); margin: 0.25rem 0 0; letter-spacing: -0.02em; }

  /* SECTION HEAD */
  .section-head { text-align: center; margin: 0 auto 2rem; max-width: 640px; }
  .kicker { font-size: 0.8125rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--teal-deep); margin: 0 0 0.5rem; }
  .section-head h2 { font-size: clamp(1.5rem, 3.5vw, 2.25rem); font-weight: 700; color: var(--navy); margin: 0; letter-spacing: -0.02em; }

  /* INSIDE */
  .inside { max-width: 720px; margin: 0 auto; padding: clamp(2rem, 5vw, 3.5rem) clamp(1.25rem, 5vw, 3rem); }
  .inside-list { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.75rem; }
  .inside-list li { display: flex; gap: 0.75rem; align-items: flex-start; font-size: 1.0625rem; line-height: 1.5; color: var(--ink); }
  .tick { color: var(--teal); font-weight: 700; flex-shrink: 0; }
  .inside-note { margin: 1.5rem 0 0; font-size: 0.9375rem; color: var(--muted); font-style: italic; }

  /* AUDIENCE */
  .audience { max-width: 900px; margin: 0 auto; padding: clamp(2rem, 5vw, 3.5rem) clamp(1.25rem, 5vw, 3rem); display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .audience-col { background: var(--surface); border: 1px solid var(--line); border-radius: 16px; padding: 1.75rem; }
  .audience-col-no { background: #fff; }
  .audience-col h3 { font-size: 1.1875rem; color: var(--navy); margin: 0 0 1rem; }
  .audience-col ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.6rem; }
  .audience-col li { display: flex; gap: 0.6rem; align-items: flex-start; font-size: 0.9875rem; line-height: 1.45; color: var(--ink); }
  .tick-yes { color: var(--teal-deep); } .tick-no { color: var(--muted); }

  /* FORM SECTION */
  .form-section { position: relative; background: radial-gradient(120% 100% at 50% 0%, var(--navy-soft) 0%, var(--navy) 70%, #001a33 100%); padding: clamp(3rem, 7vw, 5rem) clamp(1.25rem, 5vw, 3rem); }

  /* FAQ */
  .faq { max-width: 760px; margin: 0 auto; padding: clamp(2.5rem, 6vw, 4rem) clamp(1.25rem, 5vw, 3rem); }
  .faq-list { display: grid; gap: 0.75rem; }
  .faq-item { border: 1px solid var(--line); border-radius: 12px; padding: 0 1.25rem; background: #fff; }
  .faq-item summary { cursor: pointer; list-style: none; padding: 1.1rem 0; font-weight: 600; color: var(--navy); font-size: 1.0625rem; display: flex; justify-content: space-between; gap: 1rem; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: '+'; color: var(--teal-deep); font-size: 1.4rem; line-height: 1; flex-shrink: 0; }
  .faq-item[open] summary::after { content: '−'; }
  .faq-item p { margin: 0 0 1.1rem; color: var(--muted); line-height: 1.6; font-size: 0.9875rem; }

  /* FOOTER */
  .footer { text-align: center; padding: clamp(2.5rem, 6vw, 4rem) 1.5rem; border-top: 1px solid var(--line); }
  .footer-mark { height: 24px; width: auto; filter: brightness(0) saturate(100%); opacity: 0.7; margin: 0 0 0.75rem; }
  .footer p { color: var(--muted); font-size: 0.875rem; margin: 0; }

  @media (max-width: 720px) {
    .stats { grid-template-columns: 1fr; }
    .audience { grid-template-columns: 1fr; }
  }
</style>

<style is:global>
  /* Form dock sobre fondo navy (form-section) */
  .ebook-form-card {
    max-width: 560px; margin: 0 auto; background: #fff; border-radius: 20px;
    padding: clamp(1.5rem, 4vw, 2.5rem); box-shadow: 0 30px 80px -40px rgba(0,0,0,0.6);
  }
  .ebook-form-card .form-eyebrow { font-family: 'Poppins', sans-serif; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #1f9a92; margin: 0 0 0.35rem; }
  .ebook-form-card .form-intro h2 { font-family: 'Poppins', sans-serif; font-size: 1.5rem; color: #00284d; margin: 0 0 0.5rem; }
  .ebook-form-card .form-intro .form-lead { color: #6d6777; line-height: 1.5; margin: 0 0 1.5rem; font-size: 0.9375rem; }
  .ebook-form-card .governed-fallback { display: grid; gap: 0.6rem; }
  .ebook-form-card .fallback-line { height: 44px; border-radius: 10px; background: linear-gradient(90deg,#eee 25%,#f6f6f6 37%,#eee 63%); background-size: 400% 100%; animation: ghf-shimmer 1.4s infinite; }
  .ebook-form-card .fallback-line.short { width: 60%; }
  @keyframes ghf-shimmer { 0% { background-position: 100% 0 } 100% { background-position: 0 0 } }
  @media (prefers-reduced-motion: reduce) { .ebook-form-card .fallback-line { animation: none; } }

  .form-state-success { text-align: center; color: #1a1a2e; }
  .form-state-success .success-mark { color: #36c8bf; display: flex; justify-content: center; margin: 0 0 1rem; }
  .form-state-success h2 { font-family: 'Poppins', sans-serif; color: #00284d; margin: 0 0 0.5rem; font-size: 1.5rem; }
  .form-state-success > p { color: #6d6777; line-height: 1.55; margin: 0 auto 1.25rem; max-width: 420px; font-size: 0.9375rem; }
  .redownload-cta { display: inline-block; color: #1f9a92; font-weight: 600; text-decoration: underline; margin: 0 0 1.5rem; font-size: 0.9375rem; }
  .form-state-success .bridge { border-top: 1px solid #eaeaec; padding-top: 1.5rem; margin-top: 0.5rem; }
  .form-state-success .bridge-kicker { font-family: 'Poppins', sans-serif; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #1f9a92; margin: 0 0 0.35rem; }
  .form-state-success .bridge-title { font-family: 'Poppins', sans-serif; font-size: 1.1875rem; font-weight: 700; color: #00284d; margin: 0 0 0.4rem; }
  .form-state-success .bridge-body { color: #6d6777; line-height: 1.5; margin: 0 0 1.25rem; font-size: 0.9375rem; }
</style>
