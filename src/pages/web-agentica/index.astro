---
import '@fontsource/poppins/600.css'
import '@fontsource/poppins/700.css'
import BaseLayout from '@layouts/BaseLayout.astro'
import WebAgenticaFormDock from '@/components/WebAgenticaFormDock.astro'
import { axis, teal } from '@lib/report-tokens'

/**
 * TASK-1374 — Landing pública del ebook "El fin de la web" (/web-agentica).
 * Re-autoría FIEL al PR #12 (misma composición y narrativa): hero 2-col con el mockup del
 * ebook + secciones numeradas + 5 actos + banda de cierre. Cambia solo el mecanismo: tokens
 * AXIS navy + teal `#36c8bf` (no el naranja/DM Sans/design system foráneo del export),
 * Geist/Poppins, BaseLayout (SEO+GTM+JSON-LD), form gobernado + descarga gated tokenizada.
 */
const siteUrl = 'https://think.efeoncepro.com'
const landingUrl = `${siteUrl}/web-agentica`
const pageTitle = 'El fin de la web agéntica | Efeonce Think'
const pageDescription =
  'Descarga gratis una guía de cinco actos sobre la web agéntica: cómo pasar de ser encontrado a ser legible, accionable e intrínseco.'

const stats = [
  {
    value: '01',
    tag: 'cambio de modelo',
    label: 'De páginas que se navegan a capacidades que un agente puede leer y llamar con precisión.',
  },
  {
    value: '02',
    tag: 'interfaces',
    label: 'Tu experiencia propia y la ventana de chat del agente: hoy necesitas existir en ambas.',
  },
  {
    value: '04',
    tag: 'niveles',
    label: 'Ser encontrado, legible, accionable e intrínseco: el marco completo de la web agéntica.',
  },
]

const actos = [
  { n: 'I', title: 'El día que cruzamos la línea', description: 'Qué cambió en el tráfico y por qué ya afecta a tu presencia digital.' },
  { n: 'II', title: 'La infraestructura silenciosa', description: 'Markdown, llms.txt, WebMCP y protocolos de comercio agéntico.' },
  { n: 'III', title: 'La analogía que sí aplica', description: 'Lo que el salto a móvil enseña sobre esta nueva interfaz.' },
  { n: 'IV', title: 'Los 4 niveles donde existir', description: 'Ser encontrado, legible, accionable e intrínseco.' },
  { n: 'V', title: 'El modelo que se rompe', description: 'Zero-click commerce y el futuro de la publicidad digital.' },
]

const forWho = [
  'Lideras marketing, growth o digital y decides dónde poner la próxima inversión.',
  'Necesitas que tu negocio exista donde las personas ya delegan decisiones.',
  'Quieres entender qué ve un agente antes de recomendar, comparar o ejecutar.',
  'Tu empresa produce datos, servicios o resultados que otros flujos necesitan consumir.',
]
const notForWho = [
  'Buscas una táctica aislada sin tocar el sistema.',
  'Esperas un checklist técnico que reemplace una decisión de negocio.',
  'Tu prioridad es solo atraer clics, no participar en los flujos que siguen.',
]

const faqs = [
  { q: '¿Qué es un agente de inteligencia artificial?', a: 'Un software que actúa por ti: navega, compara, decide y ejecuta tareas en la web sin que tengas que hacer clic. ChatGPT, Gemini o Claude ya operan así cuando les pides que investiguen o compren algo.' },
  { q: '¿Cuáles son los cuatro niveles de la web agéntica?', a: 'Ser encontrado, ser legible, ser accionable y ser intrínseco. El ebook explica qué exige cada nivel: desde aparecer en una respuesta hasta exponer capacidades y datos que un agente puede consumir en el flujo del cliente.' },
  { q: '¿Por qué no basta con optimizar para búsqueda?', a: 'Porque un agente no solo busca: lee, compara y actúa. La visibilidad es el primer nivel, pero la diferencia competitiva aparece cuando tu información se entiende, tus capacidades se pueden llamar y tu trabajo se integra al flujo del cliente.' },
  { q: '¿Qué es llms.txt y cómo se implementa?', a: 'Es un archivo auxiliar en la raíz de tu sitio que ordena contenido clave para los modelos de lenguaje. El ebook lo explica como parte de volver tu presencia legible: no reemplaza una decisión de producto, datos o capacidades por sí solo.' },
  { q: '¿Qué es zero-click commerce?', a: 'Compras que se completan sin que el usuario visite tu web: el agente encuentra, compara y ejecuta la transacción por él. Requiere integración agéntica para no quedar fuera del flujo de venta.' },
  { q: '¿Qué significa que más de la mitad de las solicitudes web sean automatizadas?', a: 'Cloudflare reporta que bots y agentes ya generan más de la mitad de las solicitudes web. No significa que la web humana desaparezca: significa que tu sitio debe poder ser encontrado, entendido y usado también por sistemas automatizados.' },
]

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'WebPage', '@id': `${landingUrl}#webpage`, url: landingUrl, name: pageTitle, description: pageDescription, inLanguage: 'es-CL', isPartOf: { '@type': 'WebSite', url: siteUrl, name: 'Efeonce Think' } },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
]
---

<BaseLayout title={pageTitle} description={pageDescription} canonical="/web-agentica" ogImage="/web-agentica/ebook-hero.png" jsonLd={jsonLd}>
  <main
    class="wa"
    data-capture="web-agentica-landing"
    style={`--navy:${axis.accent[900]};--navy-2:${axis.accent[800]};--blue:${axis.accent[500]};--teal:${teal[500]};--teal-2:${teal[400]};--teal-3:${teal[300]};--teal-deep:${teal[700]};--ink:${axis.gray[900]};--muted:${axis.gray[600]};--line:${axis.gray[200]};--surface:${axis.gray[50]};`}
  >
    <!-- HERO -->
    <section class="hero" data-capture="web-agentica-hero">
      <header class="topbar">
        <a class="brand-link" href="/" aria-label="Efeonce Think"><img class="efeonce-mark" src="/branding/efeonce-logo-negative.svg" alt="Efeonce" /></a>
        <p class="research-label"><span class="research-signal" aria-hidden="true"></span> Efeonce Think · Research brief</p>
      </header>
      <div class="hero-grid">
        <div class="hero-copy">
          <p class="eyebrow"><span>Ebook gratuito</span><span class="dot" aria-hidden="true"></span><span>Web agéntica</span></p>
          <h1 class="hero-title">El fin de la <span class="accent">web</span><br />solo para humanos</h1>
          <p class="hero-lead">Cloudflare reporta que bots y agentes ya generan más de la mitad de las solicitudes web. Cinco actos para entender qué cambió — y qué hacer esta semana.</p>
          <aside class="hero-signal" aria-label="Señal de transición">
            <span class="hero-signal-index" aria-hidden="true">01</span>
            <div>
              <p class="hero-signal-kicker">Señal de transición</p>
              <p class="hero-signal-value">Más de la mitad de las solicitudes web ya son automatizadas.</p>
            </div>
            <p class="hero-signal-source">Cloudflare, 2026</p>
          </aside>
          <a class="cta cta-primary" href="#web-agentica-form">Descargar el ebook gratis <span aria-hidden="true">→</span></a>
          <p class="hero-reassurance"><span aria-hidden="true">↓</span> PDF inmediato tras enviar · contenido relacionado con baja cuando quieras.</p>
          <ul class="hero-proof" aria-label="Incluye">
            <li><strong>05</strong> actos</li>
            <li><strong>01</strong> checklist</li>
            <li><strong>04</strong> niveles</li>
          </ul>
        </div>
        <div class="hero-visual" aria-hidden="true">
          <span class="hero-visual-label hero-visual-label-human"><i></i> Interfaz humana</span>
          <span class="hero-visual-label hero-visual-label-agent"><i></i> Lectura del agente</span>
          <div class="hero-visual-art">
            <picture>
              <source
                type="image/webp"
                srcset="/web-agentica/ebook-hero-motion-base-640.webp 640w, /web-agentica/ebook-hero-motion-base-960.webp 960w, /web-agentica/ebook-hero-motion-base-1536.webp 1536w"
                sizes="(max-width: 920px) 100vw, 58vw"
              />
              <img src="/web-agentica/ebook-hero-motion-base.png" alt="" width="1536" height="1024" loading="eager" decoding="async" sizes="(max-width: 920px) 100vw, 58vw" />
            </picture>
            <svg class="hero-cursor-layer" viewBox="0 0 1536 1024" aria-hidden="true" focusable="false">
              <g class="hero-cursor-hover">
                <circle cx="880" cy="447" r="18" />
                <animate attributeName="opacity" values="0;0;.72;.72;0;0" keyTimes="0;.44;.52;.61;.70;1" dur="5.8s" begin=".7s" repeatCount="indefinite" />
                <animate attributeName="r" values="18;18;27;27;18;18" keyTimes="0;.44;.52;.61;.70;1" dur="5.8s" begin=".7s" repeatCount="indefinite" />
              </g>
              <g class="hero-cursor-pointer">
                <g class="hero-cursor-press">
                  <image href="/web-agentica/hero-cursor.png" x="-225" y="-125" width="260" height="260" />
                  <animateTransform attributeName="transform" type="scale" values="1;1;1;1;.945;.945;1;1" keyTimes="0;.59;.63;.65;.67;.71;.75;1" dur="5.8s" begin=".7s" repeatCount="indefinite" />
                </g>
                <animateTransform attributeName="transform" type="translate" values="1258 742;1258 742;1188 690;1110 632;1042 574;982 536;1006 512;1042 514;1014 522;1014 522;1128 624;1258 742" keyTimes="0;.09;.18;.29;.39;.49;.55;.59;.64;.69;.82;1" calcMode="spline" keySplines="0 0 1 1;.18 0 .55 1;.16 .34 .44 1;.18 .36 .48 1;.18 .42 .5 1;.14 .34 .42 .96;.18 .18 .64 .9;.14 .12 .55 .92;0 0 1 1;.2 0 .72 .9;0 0 1 1" dur="5.8s" begin=".7s" repeatCount="indefinite" />
                <animate attributeName="opacity" values="0;0;.9;1;1;1;1;1;.55;0;0" keyTimes="0;.09;.15;.34;.50;.60;.66;.70;.79;.86;1" dur="5.8s" begin=".7s" repeatCount="indefinite" />
              </g>
              <g class="hero-cursor-click">
                <circle cx="880" cy="447" r="12" />
                <animate attributeName="opacity" values="0;0;0;.86;.24;0;0" keyTimes="0;.60;.64;.67;.72;.78;1" dur="5.8s" begin=".7s" repeatCount="indefinite" />
                <animate attributeName="r" values="12;12;12;32;44;44;12" keyTimes="0;.60;.64;.67;.72;.78;1" dur="5.8s" begin=".7s" repeatCount="indefinite" />
              </g>
            </svg>
          </div>
        </div>
      </div>
      <nav class="brief-nav" data-brief-nav aria-label="Recorrido del ebook">
        <a href="#el-cambio">El cambio</a>
        <a href="#cinco-actos">Los 5 actos</a>
        <a href="#para-quien">Para quién</a>
        <a href="#web-agentica-form">Descargar <span aria-hidden="true">↘</span></a>
      </nav>
    </section>

    <!-- STATS -->
    <section class="stats" data-capture="web-agentica-stats" aria-label="Lo que ya está pasando" data-reveal>
      <div class="stats-intro">
        <p class="sec-label"><span class="sec-num">Señales</span> de la transición</p>
        <p>La web agéntica ya está moviendo descubrimiento, tráfico y conversión.</p>
      </div>
      {stats.map((s, index) => (
        <article class="stat-card" data-spotlight style={`--reveal-delay:${index * 70}ms`}>
          <p class="stat-value">{s.value}<span class="stat-tag">{s.tag}</span></p>
          <p class="stat-label">{s.label}</p>
        </article>
      ))}
    </section>

    <!-- 01 · EL PROBLEMA -->
    <section class="problema" id="el-cambio" data-capture="web-agentica-thesis" data-reveal>
      <p class="sec-label"><span class="sec-num">01</span> El problema</p>
      <h2>Tu sitio web ya tiene dos tipos de visitantes. <span class="accent">Solo estás diseñado para uno.</span></h2>
      <p class="problema-body">Millones de personas le piden a ChatGPT, Gemini o Claude que hagan tareas por ellos. Esos agentes no hacen clic en anuncios, no ven banners y no perdonan HTML ruidoso. Si tu presencia digital está optimizada solo para humanos, eres invisible para la mitad del tráfico que crece.</p>
      <div class="interface-lanes" aria-label="Las dos interfaces de la web agéntica">
        <article class="interface-lane interface-lane-human">
          <span class="interface-index">01</span>
          <div>
            <p class="interface-kicker">Interfaz humana</p>
            <h3>Tu experiencia propia</h3>
            <p>La navegación que las personas ven y usan directamente.</p>
          </div>
        </article>
        <div class="interface-connector" aria-hidden="true"><span></span></div>
        <article class="interface-lane interface-lane-agent">
          <span class="interface-index">02</span>
          <div>
            <p class="interface-kicker">Interfaz del agente</p>
            <h3>La ventana que decide</h3>
            <p>Donde un agente encuentra, entiende y llama tus capacidades.</p>
          </div>
        </article>
      </div>
      <p class="section-prompt">¿En qué nivel está tu empresa hoy?</p>
    </section>

    <!-- 02 · QUÉ VAS A ENCONTRAR -->
    <section class="dentro" id="cinco-actos" data-capture="web-agentica-inside" data-reveal>
      <div class="sec-head">
        <p class="sec-label"><span class="sec-num">02</span> Qué vas a encontrar dentro</p>
        <h2>Cinco actos para leer la nueva web</h2>
      </div>
      <div class="actos-journey">
        <span class="actos-rail" aria-hidden="true"><span class="actos-rail-pulse"></span></span>
        <ol class="actos" role="list">
          {actos.map((a, index) => (
            <li class="acto-card" data-spotlight>
              <div class="acto-topline">
                <span class="acto-n">{a.n}</span>
                <span class="acto-order" aria-hidden="true">{String(index + 1).padStart(2, '0')}<small>/05</small></span>
              </div>
              <p class="acto-label">Acto {a.n}</p>
              <p class="acto-title">{a.title}</p>
              <p class="acto-description">{a.description}</p>
            </li>
          ))}
        </ol>
      </div>
      <p class="checklist-chip"><span aria-hidden="true">✓</span> Incluye checklist «Lo que haces esta semana»</p>
    </section>

    <!-- 03 · PARA QUIÉN -->
    <section class="quien" id="para-quien" data-capture="web-agentica-audience" data-reveal>
      <div class="quien-head">
        <p class="sec-label center"><span class="sec-num">03</span> Para quién es este ebook</p>
        <h2>No necesitas otra táctica. Necesitas saber <span class="accent">qué parte del sistema revisar primero.</span></h2>
        <p>Esta guía está hecha para equipos que prefieren entender el cambio antes de rediseñar su presencia, sus datos o su forma de entregar valor.</p>
      </div>
      <div class="quien-grid">
        <article class="quien-card quien-yes" data-spotlight>
          <div class="quien-card-meta">
            <span class="quien-index" aria-hidden="true">01</span>
            <p>Tu punto de partida</p>
          </div>
          <h3><span class="q-icon yes" aria-hidden="true">✓</span> Es para ti si…</h3>
          <p class="quien-summary">Reconoces que la decisión ya no termina cuando alguien llega a tu sitio.</p>
          <ul>{forWho.map(x => <li><span aria-hidden="true">✓</span>{x}</li>)}</ul>
          <p class="quien-card-note"><span aria-hidden="true">→</span> El ebook te entrega un marco para decidir qué revisar antes de elegir una herramienta.</p>
        </article>
        <article class="quien-card quien-no" data-spotlight>
          <div class="quien-card-meta">
            <span class="quien-index" aria-hidden="true">02</span>
            <p>Una aclaración honesta</p>
          </div>
          <h3><span class="q-icon no" aria-hidden="true">✕</span> No es para ti todavía si…</h3>
          <p class="quien-summary">No promete un atajo. Pide mirar cómo se entrega valor más allá de la interfaz humana.</p>
          <ul>{notForWho.map(x => <li><span aria-hidden="true">✕</span>{x}</li>)}</ul>
          <p class="quien-card-note"><span aria-hidden="true">↘</span> Vuelve cuando quieras evaluar el sistema completo, no solo el siguiente ajuste.</p>
        </article>
      </div>
      <p class="quien-transition"><span aria-hidden="true">↓</span> Si te reconoces aquí, los cinco actos te dan un mapa antes de decidir qué mover esta semana.</p>
    </section>

    <!-- Autor / credencial antes de la captura -->
    <section class="autor" data-capture="web-agentica-author" data-reveal>
      <img class="autor-mark" src="/branding/efeonce-logo-negative.svg" alt="Efeonce" />
      <div>
        <p class="autor-kicker">Efeonce Think · Research brief</p>
        <p class="autor-body">Escrito por el equipo de Efeonce para ayudar a equipos de marketing, growth y digital a leer el cambio antes de decidir qué rediseñar.</p>
      </div>
    </section>

    <!-- FORM -->
    <section class="form-band" data-capture="web-agentica-form-section" data-reveal>
      <WebAgenticaFormDock />
    </section>

    <!-- 04 · FAQ -->
    <section class="faq" data-capture="web-agentica-faq" data-reveal>
      <div class="sec-head">
        <p class="sec-label"><span class="sec-num">04</span> Preguntas frecuentes</p>
        <h2>Antes de actuar, aclaremos lo esencial.</h2>
      </div>
      <div class="faq-list">
        {faqs.map((f, i) => (
          <details class="faq-item" open={i === 0}>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- Cierre -->
    <section class="cierre" data-capture="web-agentica-close" data-reveal>
      <h2>El cambio ya ocurrió. Lo que viene es la brecha entre los que lo <span class="accent">leyeron</span> y los que <span class="accent">actuaron</span>.</h2>
      <a class="cta cta-primary" href="#web-agentica-form">Descargar el ebook gratis <span aria-hidden="true">→</span></a>
    </section>

    <footer class="footer" data-capture="web-agentica-footer" data-reveal>
      <div class="footer-main">
        <div class="footer-brand">
          <a class="footer-brand-link" href="https://efeoncepro.com/" aria-label="Conocer Efeonce"><img class="footer-mark" src="/branding/efeonce-logo-negative.svg" alt="Efeonce" /></a>
          <p class="footer-kicker">Efeonce Think</p>
          <p class="footer-body">Ideas y capacidades para la web que ya están usando tus clientes.</p>
        </div>
        <nav class="footer-nav" aria-label="Explora la guía">
          <p>Explora la guía</p>
          <a href="#el-cambio">El cambio <span aria-hidden="true">↗</span></a>
          <a href="#cinco-actos">Los cinco actos <span aria-hidden="true">↗</span></a>
          <a href="#web-agentica-form">Descargar el ebook <span aria-hidden="true">↗</span></a>
        </nav>
        <div class="footer-signal">
          <span class="footer-pulse" aria-hidden="true"></span>
          <p class="footer-signal-kicker">Señal de futuro</p>
          <p>La nueva interfaz ya está abierta.</p>
        </div>
      </div>
      <div class="footer-meta">
        <p>Efeonce Group SpA · <a href="https://efeoncepro.com/politica-de-privacidad/">Privacidad</a></p>
        <a href="https://efeoncepro.com/">efeoncepro.com <span aria-hidden="true">↗</span></a>
      </div>
    </footer>
  </main>

  <script>
    const focusFormHeading = () => {
      const form = document.getElementById('web-agentica-form')
      const heading = document.getElementById('web-agentica-form-title')

      if (!form || !heading) return

      heading.focus({ preventScroll: true })
      form.scrollIntoView({
        behavior: window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth',
        block: 'start',
      })
    }

    document.querySelectorAll<HTMLAnchorElement>('a[href="#web-agentica-form"]').forEach(cta => {
      cta.addEventListener('click', event => {
        event.preventDefault()
        window.history.replaceState(null, '', '#web-agentica-form')
        focusFormHeading()
      })
    })

    if (window.location.hash === '#web-agentica-form') window.requestAnimationFrame(focusFormHeading)

    const landing = document.querySelector<HTMLElement>('.wa')
    const canAnimate = !window.matchMedia('(prefers-reduced-motion: reduce)').matches
    const briefNav = landing?.querySelector<HTMLElement>('[data-brief-nav]')

    if (landing && briefNav && canAnimate) {
      const updateBriefNav = () => {
        briefNav.classList.toggle('is-engaged', window.scrollY > 56)
      }

      landing.classList.add('has-brief-nav')
      updateBriefNav()
      window.addEventListener('scroll', updateBriefNav, { passive: true })
    }

    if (landing && canAnimate && 'IntersectionObserver' in window) {
      landing.classList.add('is-enhanced')
      const revealTargets = landing.querySelectorAll<HTMLElement>('[data-reveal]')
      const revealObserver = new IntersectionObserver(
        entries => {
          entries.forEach(entry => {
            if (!entry.isIntersecting) return
            entry.target.classList.add('is-visible')
            revealObserver.unobserve(entry.target)
          })
        },
        { rootMargin: '0px 0px -8%', threshold: 0.08 },
      )

      revealTargets.forEach(target => revealObserver.observe(target))
    }

    if (landing && canAnimate && window.matchMedia('(pointer:fine)').matches) {
      landing.querySelectorAll<HTMLElement>('[data-spotlight]').forEach(card => {
        let frame: number | undefined
        let point: { x: number; y: number } | undefined

        const paint = () => {
          if (!point) return
          card.style.setProperty('--spot-x', `${point.x}%`)
          card.style.setProperty('--spot-y', `${point.y}%`)
          frame = undefined
        }

        card.addEventListener('pointermove', event => {
          const rect = card.getBoundingClientRect()
          point = {
            x: Math.min(100, Math.max(0, ((event.clientX - rect.left) / rect.width) * 100)),
            y: Math.min(100, Math.max(0, ((event.clientY - rect.top) / rect.height) * 100)),
          }
          if (frame === undefined) frame = window.requestAnimationFrame(paint)
        })

        card.addEventListener('pointerleave', () => {
          point = undefined
          if (frame !== undefined) window.cancelAnimationFrame(frame)
          frame = undefined
          card.style.removeProperty('--spot-x')
          card.style.removeProperty('--spot-y')
        })
      })
    }
  </script>
</BaseLayout>

<style>
  .wa { font-family: 'Geist Variable', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: var(--ink); background: #fff; }
  .wa h1, .wa h2, .wa h3, .eyebrow, .sec-label, .stat-value, .cta, .acto-label, .acto-title, .autor-kicker, .checklist-chip { font-family: 'Poppins', 'Geist Variable', sans-serif; }
  .accent { color: var(--teal); }
  .wa a:focus-visible, .wa summary:focus-visible { outline: 3px solid var(--teal); outline-offset: 4px; border-radius: 4px; }
  .cta-primary { display: inline-flex; align-items: center; gap: 0.5rem; background: var(--teal); color: #04222f; font-weight: 700; font-size: 1.0625rem; padding: 0.95rem 1.9rem; border-radius: 12px; text-decoration: none; box-shadow: 0 14px 34px -14px color-mix(in srgb, var(--teal) 60%, transparent); transition: transform .15s cubic-bezier(.2,0,0,1), background .15s cubic-bezier(.2,0,0,1), box-shadow .15s cubic-bezier(.2,0,0,1); }
  .cta-primary:hover { transform: translateY(-2px); background: var(--teal-2); }
  .cta-primary:hover span { transform: translateX(3px); }
  .cta-primary:active { transform: translateY(0) scale(.985); box-shadow: 0 8px 20px -14px color-mix(in srgb, var(--teal) 70%, transparent); }
  .cta-primary span { transition: transform .15s cubic-bezier(.2,0,0,1); }

  /* HERO */
  .hero { position: relative; background: radial-gradient(130% 100% at 70% -10%, var(--navy-2) 0%, var(--navy) 52%, #001a33 100%); color: #fff; overflow: hidden; padding: 0 clamp(1.25rem, 5vw, 4rem) clamp(2.5rem, 6vw, 4.5rem); }
  .hero::before { content: ''; position: absolute; inset: 0; background-image: linear-gradient(rgba(120,176,216,.10) 1px, transparent 1px), linear-gradient(90deg, rgba(120,176,216,.10) 1px, transparent 1px); background-size: 44px 44px; -webkit-mask-image: radial-gradient(ellipse 80% 60% at 40% 30%, #000 20%, transparent 85%); mask-image: radial-gradient(ellipse 80% 60% at 40% 30%, #000 20%, transparent 85%); pointer-events: none; }
  .hero::after { content: ''; position: absolute; inset: -20% -20% auto 30%; height: 70%; background: radial-gradient(50% 55% at 60% 40%, color-mix(in srgb, var(--teal) 28%, transparent) 0%, transparent 72%); pointer-events: none; }
  .topbar { position: relative; z-index: 1; max-width: 1240px; margin: 0 auto; padding: clamp(1.25rem, 4vw, 2rem) 0; display: flex; justify-content: space-between; align-items: center; gap: 1rem; }
  .efeonce-mark { height: 26px; width: auto; }
  .research-label { display: inline-flex; align-items: center; gap: 0.45rem; margin: 0; color: rgba(255,255,255,.65); font-size: 0.75rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; }
  .research-signal { width: 7px; height: 7px; border-radius: 50%; background: var(--teal); box-shadow: 0 0 0 4px color-mix(in srgb, var(--teal) 16%, transparent); }
  .hero-grid { position: relative; z-index: 1; display: grid; grid-template-columns: .96fr 1.24fr; gap: clamp(1rem, 3vw, 2.5rem); align-items: center; max-width: 1240px; margin: 0 auto; min-height: 58vh; }
  .hero-copy { max-width: 540px; }
  .eyebrow { display: inline-flex; align-items: center; gap: 0.6rem; font-size: 0.8125rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--teal-2); margin: 0 0 1.1rem; }
  .eyebrow .dot { width: 4px; height: 4px; border-radius: 50%; background: currentColor; opacity: .6; }
  .hero-title { font-size: clamp(2.4rem, 5.5vw, 4.25rem); font-weight: 700; line-height: 1.03; margin: 0 0 1.25rem; letter-spacing: -0.025em; }
  .hero-lead { font-size: clamp(1.0625rem, 2.2vw, 1.25rem); line-height: 1.55; color: rgba(255,255,255,.8); margin: 0 0 1.5rem; }
  .hero-signal { display: grid; grid-template-columns: 2.25rem minmax(0, 1fr); gap: .7rem .8rem; align-items: start; max-width: 34rem; margin: 0 0 1.65rem; padding: .85rem 0 .9rem; border-top: 1px solid color-mix(in srgb, var(--teal) 42%, rgba(255,255,255,.18)); border-bottom: 1px solid rgba(255,255,255,.12); }
  .hero-signal-index { display: inline-flex; align-items: center; justify-content: center; width: 2.25rem; height: 2.25rem; border: 1px solid color-mix(in srgb, var(--teal) 52%, rgba(255,255,255,.18)); border-radius: 9px; color: var(--teal-2); background: color-mix(in srgb, var(--teal) 10%, rgba(255,255,255,.04)); font-family: 'Poppins', sans-serif; font-size: .6875rem; font-weight: 700; letter-spacing: .06em; }
  .hero-signal-kicker { margin: .08rem 0 .24rem; color: var(--teal-2); font-family: 'Poppins', sans-serif; font-size: .6875rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; }
  .hero-signal-value { margin: 0; color: #fff; font-size: .9375rem; font-weight: 600; line-height: 1.4; }
  .hero-signal-source { grid-column: 2; margin: -.08rem 0 0; color: rgba(255,255,255,.56); font-size: .75rem; }
  .hero-reassurance { display: flex; align-items: flex-start; gap: .45rem; font-size: .875rem; color: rgba(255,255,255,.62); margin: .9rem 0 0; line-height: 1.45; }
  .hero-reassurance > span { color: var(--teal-2); font-size: 1rem; line-height: 1.2; }
  .hero-proof { display: flex; flex-wrap: wrap; gap: .65rem 1.15rem; list-style: none; margin: .85rem 0 0; padding: .9rem 0 0; border-top: 1px solid rgba(255,255,255,.12); color: rgba(255,255,255,.65); font-size: .8125rem; }
  .hero-proof li { display: inline-flex; align-items: baseline; gap: .35rem; }
  .hero-proof strong { color: var(--teal-2); font-family: 'Poppins', 'Geist Variable', sans-serif; font-size: .75rem; letter-spacing: .06em; }
  .hero-visual { position: relative; isolation: isolate; margin: .35rem 0 -1rem; }
  .hero-visual::before { content: ''; position: absolute; inset: 8% 10%; background: radial-gradient(circle, color-mix(in srgb, var(--teal) 24%, transparent), transparent 68%); filter: blur(24px); opacity: .8; z-index: -1; }
  .hero-visual::after { content: 'AGENTIC WEB / 2026'; position: absolute; right: 4%; bottom: 2%; padding: .38rem .55rem; background: rgba(0,32,58,.82); border: 1px solid rgba(255,255,255,.16); border-radius: 7px; color: var(--teal-2); font-family: 'Poppins', 'Geist Variable', sans-serif; font-size: .625rem; font-weight: 600; letter-spacing: .1em; z-index: 2; }
  .hero-visual-label { position: absolute; z-index: 3; display: inline-flex; align-items: center; gap: .4rem; padding: .38rem .55rem; border: 1px solid color-mix(in srgb, var(--teal) 38%, rgba(255,255,255,.18)); border-radius: 7px; background: color-mix(in srgb, var(--navy) 84%, transparent); color: rgba(255,255,255,.84); font-family: 'Poppins', 'Geist Variable', sans-serif; font-size: .625rem; font-weight: 600; letter-spacing: .075em; text-transform: uppercase; box-shadow: 0 10px 24px color-mix(in srgb, var(--navy) 58%, transparent); }
  .hero-visual-label i { width: 6px; height: 6px; border-radius: 50%; background: var(--teal); box-shadow: 0 0 0 3px color-mix(in srgb, var(--teal) 18%, transparent); }
  .hero-visual-label-human { top: 18%; left: 6%; }
  .hero-visual-label-agent { right: 7%; bottom: 15%; }
  .hero-visual-art { position: relative; z-index: 1; width: 100%; max-width: 720px; margin: 0 0 0 auto; transform: translateX(-.75rem) scale(1.035); transform-origin: 45% 50%; filter: drop-shadow(0 40px 80px rgba(0,0,0,.5)); }
  .hero-visual picture, .hero-visual img { display: block; }
  .hero-visual img { width: 100%; height: auto; }
  .hero-cursor-layer { position: absolute; z-index: 2; inset: 0; display: block; width: 100%; height: 100%; overflow: visible; pointer-events: none; }
  .hero-cursor-pointer { opacity: 0; }
  .hero-cursor-hover circle { fill: color-mix(in srgb, var(--teal) 13%, transparent); stroke: color-mix(in srgb, var(--teal-2) 84%, transparent); stroke-width: 2; vector-effect: non-scaling-stroke; filter: drop-shadow(0 0 8px color-mix(in srgb, var(--teal) 42%, transparent)); }
  .hero-cursor-click circle { fill: none; stroke: var(--teal-2); stroke-width: 4; vector-effect: non-scaling-stroke; filter: drop-shadow(0 0 8px color-mix(in srgb, var(--teal) 65%, transparent)); }
  .brief-nav { position: relative; z-index: 1; display: flex; justify-content: flex-end; flex-wrap: wrap; gap: .35rem 1.1rem; max-width: 1240px; margin: 0 auto; padding-top: 1.1rem; border-top: 1px solid rgba(255,255,255,.14); }
  .brief-nav a { position: relative; color: rgba(255,255,255,.72); font-size: .8125rem; font-weight: 600; text-decoration: none; padding: .35rem 0; }
  .brief-nav a::after { content: ''; position: absolute; right: 0; bottom: 0; left: 0; height: 1px; background: var(--teal); transform: scaleX(0); transform-origin: left; transition: transform .2s cubic-bezier(.2,0,0,1); }
  .brief-nav a:hover { color: #fff; }
  .brief-nav a:hover::after { transform: scaleX(1); }
  @media (min-width: 921px) {
    .wa.has-brief-nav .brief-nav { transition: opacity .24s cubic-bezier(.2,.7,0,1), transform .24s cubic-bezier(.2,.7,0,1); }
    .wa.has-brief-nav .brief-nav:not(.is-engaged) { opacity: 0; transform: translateY(8px); }
    .wa.has-brief-nav .brief-nav:focus-within { opacity: 1; transform: translateY(0); }
  }

  /* STATS */
  .stats { max-width: 1100px; margin: 0 auto; padding: clamp(2.5rem, 6vw, 4rem) clamp(1.25rem, 5vw, 3rem); display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  .stats-intro { grid-column: 1 / -1; display: flex; align-items: end; justify-content: space-between; gap: 1.5rem; padding-bottom: .3rem; }
  .stats-intro .sec-label { margin: 0; }
  .stats-intro > p:last-child { max-width: 470px; margin: 0; color: var(--muted); font-size: .9375rem; line-height: 1.5; text-align: right; }
  .stat-card { position: relative; isolation: isolate; overflow: hidden; background: linear-gradient(145deg, #fff 0%, var(--surface) 100%); border: 1px solid var(--line); border-radius: 16px; padding: 1.75rem 1.5rem; box-shadow: 0 16px 30px -30px color-mix(in srgb, var(--navy) 55%, transparent); transition: transform .2s cubic-bezier(.2,0,0,1), border-color .2s cubic-bezier(.2,0,0,1), box-shadow .2s cubic-bezier(.2,0,0,1); }
  .stat-card::before { content: ''; position: absolute; z-index: 2; width: 62px; height: 3px; top: 0; left: 1.5rem; background: var(--teal); border-radius: 0 0 3px 3px; }
  .stat-card::after { content: ''; position: absolute; z-index: 0; inset: 0; pointer-events: none; opacity: 0; background: radial-gradient(260px circle at var(--spot-x, 50%) var(--spot-y, 50%), color-mix(in srgb, var(--teal) 20%, transparent), transparent 70%); transition: opacity .2s cubic-bezier(.2,0,0,1); }
  .stat-card > * { position: relative; z-index: 1; }
  @media (hover: hover) and (pointer: fine) { .stat-card:hover { transform: translateY(-6px); border-color: color-mix(in srgb, var(--teal) 48%, var(--line)); box-shadow: 0 28px 46px -32px color-mix(in srgb, var(--navy) 76%, transparent); } .stat-card:hover::after { opacity: 1; } }
  .stat-value { display: flex; align-items: baseline; gap: 0.5rem; font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 700; color: var(--navy); margin: 0 0 0.5rem; letter-spacing: -0.02em; }
  .stat-tag { font-size: 0.75rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--teal-deep); }
  .stat-label { font-size: 0.9375rem; line-height: 1.45; color: var(--ink); margin: 0; }
  .stat-src { color: var(--muted); text-decoration: underline; text-underline-offset: 0.15em; }

  /* SECTION LABEL */
  .sec-label { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.8125rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--teal-deep); margin: 0 0 0.75rem; }
  .sec-label.center { justify-content: center; }
  .sec-num { color: var(--teal); font-variant-numeric: tabular-nums; }
  .sec-head { text-align: center; max-width: 640px; margin: 0 auto 2.25rem; }
  .sec-head .sec-label { justify-content: center; }
  .sec-head h2 { font-size: clamp(1.6rem, 3.6vw, 2.4rem); font-weight: 700; color: var(--navy); margin: 0; letter-spacing: -0.02em; }

  /* 01 PROBLEMA (navy) */
  .problema { position: relative; isolation: isolate; overflow: hidden; background: radial-gradient(120% 100% at 50% 0%, var(--navy-2) 0%, var(--navy) 70%, #001a33 100%); color: #fff; text-align: center; padding: clamp(3rem, 7vw, 5rem) clamp(1.25rem, 5vw, 3rem); }
  .problema::before { content: ''; position: absolute; z-index: -1; inset: 0; pointer-events: none; background-image: linear-gradient(90deg, color-mix(in srgb, var(--teal) 9%, transparent) 1px, transparent 1px), linear-gradient(color-mix(in srgb, var(--teal) 7%, transparent) 1px, transparent 1px); background-size: 62px 62px; -webkit-mask-image: radial-gradient(ellipse 70% 70% at 50% 55%, #000 8%, transparent 78%); mask-image: radial-gradient(ellipse 70% 70% at 50% 55%, #000 8%, transparent 78%); }
  .problema .sec-label { justify-content: center; color: var(--teal-2); }
  .problema h2 { font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 700; margin: 0 auto 1.25rem; max-width: 760px; letter-spacing: -0.02em; line-height: 1.15; }
  .problema-body { font-size: clamp(1rem, 2.1vw, 1.1875rem); line-height: 1.6; color: rgba(255,255,255,.78); max-width: 680px; margin: 0 auto 1.5rem; }
  .interface-lanes { display: grid; grid-template-columns: minmax(0, 1fr) 58px minmax(0, 1fr); align-items: stretch; gap: 1rem; max-width: 800px; margin: 2.15rem auto 1.5rem; text-align: left; }
  .interface-lane { display: grid; grid-template-columns: auto 1fr; gap: .85rem; align-items: start; padding: 1.25rem; border: 1px solid rgba(255,255,255,.15); border-radius: 16px; background: linear-gradient(145deg, rgba(255,255,255,.10), rgba(255,255,255,.035)); box-shadow: inset 0 1px 0 rgba(255,255,255,.08); }
  .interface-lane-agent { border-color: color-mix(in srgb, var(--teal) 50%, rgba(255,255,255,.15)); background: linear-gradient(145deg, color-mix(in srgb, var(--teal) 15%, transparent), rgba(255,255,255,.035)); }
  .interface-index { display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 9px; color: var(--teal-2); background: rgba(255,255,255,.11); font-family: 'Poppins', sans-serif; font-size: .75rem; font-weight: 700; letter-spacing: .06em; }
  .interface-kicker { margin: 0 0 .25rem; color: rgba(255,255,255,.58); font-size: .6875rem; font-weight: 700; letter-spacing: .09em; text-transform: uppercase; }
  .interface-lane h3 { margin: 0 0 .35rem; color: #fff; font-size: 1rem; line-height: 1.25; }
  .interface-lane p:last-child { margin: 0; color: rgba(255,255,255,.72); font-size: .8125rem; line-height: 1.45; }
  .interface-connector { position: relative; min-height: 100%; }
  .interface-connector::before { content: ''; position: absolute; top: 50%; right: 0; left: 0; height: 1px; background: linear-gradient(90deg, rgba(255,255,255,.18), var(--teal), rgba(255,255,255,.18)); }
  .interface-connector span { position: absolute; z-index: 1; top: calc(50% - 5px); left: calc(50% - 5px); width: 10px; height: 10px; border-radius: 50%; background: var(--teal-2); box-shadow: 0 0 0 6px color-mix(in srgb, var(--teal) 18%, transparent); }
  .section-prompt { color: var(--teal-2); font-weight: 600; font-size: 1rem; margin: 0; }

  /* 02 ACTOS */
  .dentro { position: relative; isolation: isolate; max-width: 1100px; margin: 0 auto; padding: clamp(3rem, 7vw, 5rem) clamp(1.25rem, 5vw, 3rem); }
  .dentro::before { content: ''; position: absolute; z-index: -1; inset: 12% 0 6%; border-radius: 28px; pointer-events: none; background: radial-gradient(48% 48% at 50% 48%, color-mix(in srgb, var(--teal) 7%, transparent), transparent 74%); }
  .dentro .sec-head { max-width: 760px; margin-bottom: clamp(1.65rem, 3vw, 2.25rem); }
  .actos-journey { position: relative; }
  .actos-rail { position: absolute; z-index: 0; top: 2.7rem; right: 8%; left: 8%; height: 2px; overflow: hidden; border-radius: 999px; background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--teal) 48%, var(--line)) 12%, color-mix(in srgb, var(--teal) 48%, var(--line)) 88%, transparent); }
  .actos-rail-pulse { position: absolute; inset: 0; display: block; border-radius: inherit; background: linear-gradient(90deg, transparent, var(--teal-2) 16%, var(--teal) 50%, var(--teal-2) 84%, transparent); opacity: .72; scale: 0 1; transform-origin: left; }
  .actos { position: relative; z-index: 1; display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: .9rem; list-style: none; margin: 0; padding: 0; }
  .acto-card { position: relative; isolation: isolate; overflow: hidden; min-width: 0; min-height: 16.25rem; padding: 1.35rem 1.1rem 1.25rem; border: 1px solid var(--line); border-radius: 16px; background: linear-gradient(155deg, #fff 0%, color-mix(in srgb, var(--surface) 82%, #fff) 100%); box-shadow: 0 18px 32px -32px color-mix(in srgb, var(--navy) 72%, transparent); translate: 0; scale: 1; transition: translate .2s cubic-bezier(.2,0,0,1), scale .2s cubic-bezier(.2,0,0,1), border-color .2s cubic-bezier(.2,0,0,1), box-shadow .2s cubic-bezier(.2,0,0,1), background .2s cubic-bezier(.2,0,0,1); }
  .acto-card::before { content: ''; position: absolute; z-index: 2; top: 0; right: 1.1rem; left: 1.1rem; height: 3px; border-radius: 0 0 999px 999px; background: linear-gradient(90deg, var(--teal), var(--teal-2)); scale: 0 1; transform-origin: left; transition: scale .28s cubic-bezier(.2,0,0,1); }
  .acto-card::after { content: ''; position: absolute; z-index: 0; inset: 0; pointer-events: none; opacity: 0; background: radial-gradient(220px circle at var(--spot-x, 50%) var(--spot-y, 25%), color-mix(in srgb, var(--teal) 18%, transparent), transparent 72%); transition: opacity .2s cubic-bezier(.2,0,0,1); }
  .acto-card > * { position: relative; z-index: 1; }
  .acto-topline { display: flex; align-items: center; justify-content: space-between; gap: .75rem; }
  .acto-n { display: inline-flex; align-items: center; justify-content: center; width: 36px; height: 36px; border: 1px solid color-mix(in srgb, var(--teal) 24%, #fff); border-radius: 10px; background: color-mix(in srgb, var(--teal) 14%, #fff); color: var(--teal-deep); font-weight: 700; font-size: 0.9375rem; box-shadow: inset 0 1px 0 rgba(255,255,255,.72); transition: scale .2s cubic-bezier(.2,0,0,1), background .2s cubic-bezier(.2,0,0,1), color .2s cubic-bezier(.2,0,0,1); }
  .acto-order { color: color-mix(in srgb, var(--navy) 48%, #fff); font-family: 'Poppins', 'Geist Variable', sans-serif; font-size: .6875rem; font-weight: 700; letter-spacing: .07em; }
  .acto-order small { margin-left: .12rem; color: var(--muted); font-size: .625rem; font-weight: 600; }
  .acto-label { font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); margin: 0.9rem 0 0.35rem; }
  .acto-title { font-size: 0.9375rem; font-weight: 600; color: var(--navy); margin: 0; line-height: 1.3; }
  .acto-description { color: var(--muted); font-size: 0.8125rem; line-height: 1.45; margin: 0.65rem 0 0; }
  @media (hover: hover) and (pointer: fine) {
    .acto-card:hover { translate: 0 -.45rem; scale: 1.018; border-color: color-mix(in srgb, var(--teal) 50%, var(--line)); background: linear-gradient(155deg, #fff 0%, color-mix(in srgb, var(--teal) 7%, #fff) 100%); box-shadow: 0 28px 42px -30px color-mix(in srgb, var(--navy) 70%, transparent); }
    .acto-card:hover::before { scale: 1; }
    .acto-card:hover::after { opacity: 1; }
    .acto-card:hover .acto-n { scale: 1.08; background: var(--teal); color: var(--navy); }
    .acto-card:hover .acto-label { color: var(--teal-deep); }
  }
  .checklist-chip { display: inline-flex; align-items: center; gap: 0.5rem; margin: 1.75rem auto 0; padding: 0.6rem 1.1rem; background: color-mix(in srgb, var(--teal) 12%, #fff); color: var(--teal-deep); border-radius: 999px; font-size: 0.875rem; font-weight: 600; }
  .dentro > .checklist-chip { display: flex; width: fit-content; }

  /* 03 QUIÉN */
  .quien { position: relative; isolation: isolate; max-width: 1100px; margin: 0 auto; padding: clamp(3rem, 6vw, 4.5rem) clamp(1.25rem, 5vw, 3rem); }
  .quien::before { content: ''; position: absolute; z-index: -1; inset: 12% 6% 7%; border-radius: 28px; pointer-events: none; background: radial-gradient(50% 58% at 50% 50%, color-mix(in srgb, var(--teal) 8%, transparent), transparent 76%); }
  .quien-head { max-width: 760px; margin: 0 auto; text-align: center; }
  .quien-head .sec-label { justify-content: center; }
  .quien-head h2 { max-width: 710px; margin: 0 auto; color: var(--navy); font-size: clamp(1.65rem, 3.8vw, 2.45rem); font-weight: 700; letter-spacing: -.025em; line-height: 1.14; }
  .quien-head > p:last-child { max-width: 610px; margin: 1rem auto 0; color: var(--muted); font-size: 1rem; line-height: 1.6; }
  .quien-grid { display: grid; grid-template-columns: minmax(0, 1.08fr) minmax(0, .92fr); gap: 1.25rem; margin-top: clamp(1.75rem, 4vw, 2.5rem); }
  .quien-card { position: relative; isolation: isolate; display: flex; flex-direction: column; min-width: 0; min-height: 25.75rem; overflow: hidden; border: 1px solid var(--line); border-radius: 20px; padding: clamp(1.35rem, 3vw, 2rem); background: linear-gradient(145deg, #fff 0%, color-mix(in srgb, var(--surface) 72%, #fff) 100%); box-shadow: 0 20px 38px -34px color-mix(in srgb, var(--navy) 78%, transparent); container-type: inline-size; transition: translate .22s cubic-bezier(.2,0,0,1), border-color .22s cubic-bezier(.2,0,0,1), box-shadow .22s cubic-bezier(.2,0,0,1), background .22s cubic-bezier(.2,0,0,1); }
  .quien-card::before { content: ''; position: absolute; z-index: 2; top: 0; left: clamp(1.35rem, 3vw, 2rem); width: clamp(4rem, 16%, 6.5rem); height: 3px; border-radius: 0 0 999px 999px; background: var(--teal); transition: width .22s cubic-bezier(.2,0,0,1); }
