---
export const prerender = false
import BaseLayout from '@layouts/BaseLayout.astro'
import { getConceptModel } from '@lib/concept-data'
import { axis, severityMeta } from '@lib/report-tokens'

const m = await getConceptModel()
const sev = m ? severityMeta(m.overallSeverity) : severityMeta('sin_dato')
const R = 90
const CIRC = Math.PI * R
const dash = m?.overallScore ? (m.overallScore / 100) * CIRC : 0
---

<BaseLayout title="Concepto B — Navy Executive" noindex>
  {m && (
    <div class="min-h-dvh bg-white">
      {/* HERO navy dramático */}
      <header
        class="relative overflow-hidden px-6 pt-8 pb-16"
        style={`background:linear-gradient(160deg,${axis.accent[800]} 0%,${axis.accent[900]} 60%,#001a33 100%)`}
      >
        <div class="mx-auto max-w-4xl">
          <div class="flex items-center justify-between">
            <img src="/branding/efeonce-logo-negative.svg" alt="Efeonce" style="height:26px;width:auto" />
            <span class="rounded-full px-3 py-1 text-xs font-medium" style="background:rgba(255,255,255,0.12);color:rgba(255,255,255,0.85)">
              Informe de visibilidad en IA
            </span>
          </div>

          <div class="mt-12 flex flex-col items-center gap-8 sm:flex-row sm:items-center sm:justify-between">
            {/* Score glow */}
            <div class="relative shrink-0" role="img" aria-label={`Visibilidad ${m.overallScore} de 100, ${sev.label}`}>
              <svg viewBox="0 0 220 128" style="width:260px;height:150px">
                <path d="M 18 114 A 90 90 0 0 1 202 114" fill="none" stroke="rgba(255,255,255,0.14)" stroke-width="13" stroke-linecap="round" />
                <path d="M 18 114 A 90 90 0 0 1 202 114" fill="none" stroke={sev.border} stroke-width="13" stroke-linecap="round" stroke-dasharray={`${dash} ${CIRC}`} style={`filter:drop-shadow(0 0 10px ${sev.border}aa)`} />
              </svg>
              <div class="absolute inset-0 flex flex-col items-center justify-end pb-2">
                <span class="text-6xl font-semibold tabular-nums text-white">{m.overallScore}</span>
                <span class="text-xs" style="color:rgba(255,255,255,0.6)">de 100 · líderes &gt;85</span>
              </div>
            </div>
            <div class="max-w-sm text-center sm:text-left">
              <span class="inline-block rounded-full px-3 py-1 text-xs font-semibold" style={`background:${sev.border};color:white`}>{sev.label}</span>
              <h1 class="mt-4 text-3xl font-semibold tracking-tight text-balance text-white sm:text-[2rem]">{m.headlineFrame}</h1>
              <p class="mt-3 text-lg font-medium" style="color:rgba(255,255,255,0.85)">{m.organizationName}</p>
              <p class="text-sm" style="color:rgba(255,255,255,0.55)">{m.periodLabel}</p>
            </div>
          </div>
        </div>
      </header>

      {/* Ejes flotando sobre el borde */}
      <div class="mx-auto -mt-9 max-w-4xl px-6">
        <div class="grid grid-cols-2 gap-4 rounded-2xl bg-white p-5 shadow-lg ring-1" style="--tw-ring-color:rgba(0,0,0,0.05)">
          <div class="text-center">
            <p class="text-xs" style={`color:${axis.gray[600]}`}>Percepción · ¿te mencionan?</p>
            <p class="mt-1 text-2xl font-semibold tabular-nums" style={`color:${axis.gray[900]}`}>{m.perceptionScore ?? '—'}<span class="text-base font-normal" style={`color:${axis.gray[400]}`}>/100</span></p>
          </div>
          <div class="text-center">
            <p class="text-xs" style={`color:${axis.gray[600]}`}>Operabilidad · ¿te usan?</p>
            <p class="mt-1 text-2xl font-semibold" style={`color:${axis.gray[400]}`}>{m.agenticScore ?? 'En cobertura'}</p>
          </div>
        </div>
      </div>

      {/* Evidencia por motor */}
      <main class="mx-auto max-w-4xl px-6 pt-12 pb-20">
        <p class="text-sm font-semibold" style={`color:${axis.gray[900]}`}>Visibilidad por motor</p>
        <div class="mt-3 grid gap-3 sm:grid-cols-3">
          {m.engines.slice(0, 6).map((e) => (
            <div class="flex items-center gap-3 rounded-xl border px-4 py-3.5" style={`border-color:${axis.gray[100]}`}>
              {e.logo ? <img src={e.logo} alt={e.label} style="height:22px;width:22px;object-fit:contain" /> : <span class="text-lg">🔍</span>}
              <div>
                <p class="text-sm font-medium" style={`color:${axis.gray[900]}`}>{e.label}</p>
                <p class="text-xs" style={`color:${e.present > 0 ? axis.success[700] : axis.gray[400]}`}>{e.present > 0 ? `${e.present} mención${e.present === 1 ? '' : 'es'}` : 'Sin presencia'}</p>
              </div>
            </div>
          ))}
        </div>
      </main>
    </div>
  )}
</BaseLayout>
