---
export const prerender = false
import BaseLayout from '@layouts/BaseLayout.astro'
import { getConceptModel } from '@lib/concept-data'
import { axis, severityMeta } from '@lib/report-tokens'

const m = await getConceptModel()
const sev = m ? severityMeta(m.overallSeverity) : severityMeta('sin_dato')
const R = 82
const CIRC = Math.PI * R
const dash = m?.overallScore ? (m.overallScore / 100) * CIRC : 0
const targetAngle = (85 / 100) * Math.PI // marca de target 85
---

<BaseLayout title="Concepto A — Editorial Light" noindex>
  {m && (
    <div class="min-h-dvh" style={`background:${axis.gray[50]}`}>
      {/* Top bar branded */}
      <header class="mx-auto flex max-w-4xl items-center justify-between px-6 py-6">
        <img src="/branding/efeonce-logo.svg" alt="Efeonce" style="height:26px;width:auto" />
        <span class="rounded-full px-3 py-1 text-xs font-semibold" style={`background:${axis.success[100]};color:${axis.success[700]}`}>
          Público · seguro de compartir
        </span>
      </header>

      <main class="mx-auto max-w-4xl px-6 pb-20">
        {/* Hero verdict card */}
        <section class="rounded-3xl bg-white p-10 shadow-sm ring-1 sm:p-14" style="--tw-ring-color:rgba(0,0,0,0.04)">
          <p class="text-xs font-semibold tracking-[0.16em] uppercase" style={`color:${axis.accent[500]}`}>
            Informe de visibilidad en IA
          </p>
          <div class="mt-8 flex flex-col items-start gap-10 sm:flex-row sm:items-center sm:justify-between">
            <div class="max-w-md">
              <h1 class="text-2xl font-semibold tracking-tight text-balance sm:text-[1.75rem]" style={`color:${axis.gray[900]}`}>
                {m.headlineFrame}
              </h1>
              <div class="mt-4 flex items-center gap-2.5">
                <span class="text-lg font-semibold" style={`color:${axis.gray[900]}`}>{m.organizationName}</span>
                <span class="rounded-full px-2.5 py-0.5 text-xs font-semibold" style={`background:${sev.bg};color:${sev.fg}`}>{sev.label}</span>
              </div>
              <p class="mt-1 text-sm" style={`color:${axis.gray[600]}`}>{m.periodLabel}</p>
            </div>
            {/* Gauge */}
            <div class="relative shrink-0" role="img" aria-label={`Visibilidad ${m.overallScore} de 100, ${sev.label}`}>
              <svg viewBox="0 0 200 116" style="width:220px;height:128px">
                <path d="M 16 104 A 82 82 0 0 1 184 104" fill="none" stroke={axis.gray[100]} stroke-width="12" stroke-linecap="round" />
                <path d="M 16 104 A 82 82 0 0 1 184 104" fill="none" stroke={sev.border} stroke-width="12" stroke-linecap="round" stroke-dasharray={`${dash} ${CIRC}`} />
                <line x1={100 - 90 * Math.cos(targetAngle)} y1={104 - 90 * Math.sin(targetAngle)} x2={100 - 74 * Math.cos(targetAngle)} y2={104 - 74 * Math.sin(targetAngle)} stroke={axis.gray[400]} stroke-width="2" />
              </svg>
              <div class="absolute inset-0 flex flex-col items-center justify-end pb-2">
                <span class="text-5xl font-semibold tabular-nums" style={`color:${axis.gray[900]}`}>{m.overallScore}</span>
                <span class="text-xs" style={`color:${axis.gray[600]}`}>de 100 · líderes &gt;85</span>
              </div>
            </div>
          </div>
          {/* Ejes */}
          <div class="mt-10 grid grid-cols-2 gap-4 border-t pt-8" style={`border-color:${axis.gray[100]}`}>
            <div>
              <p class="text-xs" style={`color:${axis.gray[600]}`}>Percepción · ¿te mencionan?</p>
              <p class="mt-1 text-2xl font-semibold tabular-nums" style={`color:${axis.gray[900]}`}>{m.perceptionScore ?? '—'}<span class="text-base font-normal" style={`color:${axis.gray[400]}`}>/100</span></p>
            </div>
            <div>
              <p class="text-xs" style={`color:${axis.gray[600]}`}>Operabilidad · ¿te usan?</p>
              <p class="mt-1 text-2xl font-semibold" style={`color:${axis.gray[400]}`}>{m.agenticScore ?? 'En cobertura'}</p>
            </div>
          </div>
        </section>

        {/* Evidencia por motor */}
        <section class="mt-8">
          <p class="text-sm font-semibold" style={`color:${axis.gray[900]}`}>Visibilidad por motor</p>
          <div class="mt-3 grid gap-3 sm:grid-cols-3">
            {m.engines.slice(0, 6).map((e) => (
              <div class="flex items-center gap-3 rounded-2xl bg-white px-4 py-3.5 ring-1" style="--tw-ring-color:rgba(0,0,0,0.04)">
                {e.logo ? <img src={e.logo} alt={e.label} style="height:22px;width:22px;object-fit:contain" /> : <span class="text-lg">🔍</span>}
                <div>
                  <p class="text-sm font-medium" style={`color:${axis.gray[900]}`}>{e.label}</p>
                  <p class="text-xs" style={`color:${e.present > 0 ? axis.success[700] : axis.gray[400]}`}>{e.present > 0 ? `${e.present} mención${e.present === 1 ? '' : 'es'}` : 'Sin presencia'}</p>
                </div>
              </div>
            ))}
          </div>
        </section>
      </main>
    </div>
  )}
</BaseLayout>
