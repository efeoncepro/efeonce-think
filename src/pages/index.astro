---
import BaseLayout from '@layouts/BaseLayout.astro'
import { axis } from '@lib/report-tokens'
---

<BaseLayout
  title="Efeonce Think — Herramientas de visibilidad"
  description="Hub de herramientas de Efeonce para medir y mejorar tu visibilidad en la era de la IA."
>
  <main
    class="home-hero"
    data-capture="home-hero"
    style={`--axis-navy-soft:${axis.accent[800]};--axis-navy:${axis.accent[900]};`}
  >
    <img class="think-mark" src="/branding/eo-think-2.svg" alt="Efeonce Think" />
  </main>
</BaseLayout>

<style>
  .home-hero {
    display: grid;
    place-items: center;
    min-height: 100dvh;
    padding: clamp(2rem, 6vw, 5rem);
    /* Mismo degradado que el hero del report de Brand Visibility */
    background: linear-gradient(160deg, var(--axis-navy-soft) 0%, var(--axis-navy) 62%, #001a33 100%);
  }

  .think-mark {
    width: min(520px, 68vw);
    height: auto;
  }

  @media (max-width: 640px) {
    .think-mark {
      width: min(340px, 78vw);
    }
  }
</style>
