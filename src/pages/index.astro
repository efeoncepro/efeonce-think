---
import BaseLayout from '@layouts/BaseLayout.astro'
---

<BaseLayout
  title="Efeonce Think — Herramientas de visibilidad"
  description="Hub de herramientas de Efeonce para medir y mejorar tu visibilidad en la era de la IA."
>
  <main class="mx-auto flex min-h-dvh max-w-3xl flex-col items-center justify-center gap-6 px-6 text-center">
    <p class="text-sm font-medium tracking-wide text-slate-500 uppercase">Efeonce Think</p>
    <h1 class="text-4xl font-semibold text-balance sm:text-5xl">
      Herramientas de visibilidad en IA
    </h1>
    <p class="max-w-xl text-lg text-slate-600 text-pretty">
      El hub de lead magnets de Efeonce. Primera herramienta en camino: el diagnóstico de
      visibilidad de marca en IA.
    </p>
  </main>
</BaseLayout>
