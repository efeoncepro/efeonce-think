---
// SSR on-demand: el short code se resuelve server-side. En estado activo se hace `Astro.rewrite`
// a la página del token existente → el informe se renderiza bajo `/s/<code>` (la URL corta se
// conserva en el address bar) SIN duplicar el render y sin exponer el token largo al browser.
export const prerender = false

import BaseLayout from '@layouts/BaseLayout.astro'
import StatusScreen from '@/components/primitives/StatusScreen.astro'
import { resolveShortLink } from '@lib/report'

const { code } = Astro.params
const resolution = code ? await resolveShortLink(code) : ({ status: 'not_found' } as const)

// Render-in-place: reescribe a la página canónica del token sin cambiar la URL visible.
if (resolution.status === 'active') {
  return Astro.rewrite(`/brand-visibility/r/${encodeURIComponent(resolution.reportToken)}`)
}

if (resolution.status === 'not_found') Astro.response.status = 404
if (resolution.status === 'gone') Astro.response.status = 410
if (resolution.status === 'rate_limited') Astro.response.status = 429
if (resolution.status === 'error') Astro.response.status = 502
---

<BaseLayout title="Informe de visibilidad en respuestas de IA — Efeonce" noindex>
  {resolution.status === 'not_found' && <StatusScreen kind="not_found" />}

  {resolution.status === 'gone' && <StatusScreen kind="gone" />}

  {resolution.status === 'rate_limited' && <StatusScreen kind="rate_limited" />}

  {resolution.status === 'error' && <StatusScreen kind="error" />}
</BaseLayout>
