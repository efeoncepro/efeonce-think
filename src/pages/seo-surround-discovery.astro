---
import '@fontsource/poppins/600.css'
import '@fontsource/poppins/700.css'
import BaseLayout from '@layouts/BaseLayout.astro'
import SurroundDiscoveryFormDock from '@/components/SurroundDiscoveryFormDock.astro'
import { ArrowDown, ArrowRight, ArrowUpRight, Bot, Check, CirclePlay, Download, Ear, FileText, Gauge, Info, Map, MessagesSquare, RefreshCw, Search, ShoppingCart, SlidersHorizontal, Sparkles, Zap } from '@lucide/astro'
import { axis, teal } from '@lib/report-tokens'

export const prerender = true

const siteUrl = 'https://think.efeoncepro.com'
const organizationUrl = 'https://efeoncepro.com'
const landingUrl = `${siteUrl}/seo-surround-discovery`
const organizationId = `${organizationUrl}/#organization`
const websiteId = `${siteUrl}/#website`
const pageId = `${landingUrl}#webpage`
const ebookId = `${landingUrl}#ebook`
const imageId = `${landingUrl}#primaryimage`
const faqId = `${landingUrl}#faq`
const pageTitle = 'Surround Discovery™: guía para competir por descubrimiento | Efeonce Think'
const pageDescription = 'Descarga la guía gratuita Surround Discovery™ para entender SEO, AEO, video, social y marketplaces como un sistema de descubrimiento.'
const socialTitle = 'Surround Discovery™ — el mapa de la búsqueda fragmentada'
const socialDescription = 'Una guía de 61 páginas para leer SEO, AEO, video, social y marketplaces como un sistema de descubrimiento.'
const socialImageAlt = 'Portada del ebook Surround Discovery™ de Efeonce sobre fondo azul oscuro.'
const ebookImageUrl = `${landingUrl}/surround-discovery/ebook-cover.jpeg`

const surfaces = [
  { key: 'seo', title: 'SEO', question: '“¿Te encuentran cuando buscan activamente?”', description: 'La base del descubrimiento por intención: aparecer con claridad cuando alguien ya busca lo que ofreces.', cta: 'Ver enfoque SEO', icon: Search },
  { key: 'aeo', title: 'AEO', question: '“¿Los motores de IA te entienden y te citan bien?”', description: 'Presencia en motores de respuesta: que la IA explique tu propuesta con precisión, no de memoria.', cta: 'Ver enfoque AEO', icon: Bot },
  { key: 'video', title: 'Video Discovery', question: '“¿Apareces cuando tu audiencia aprende mirando?”', description: 'El video como superficie de descubrimiento, no como un formato más de campaña.', cta: undefined, icon: CirclePlay },
  { key: 'social', title: 'Social Discovery', question: '“¿Entras en las conversaciones que forman preferencia?”', description: 'Lo social y las comunidades como lugar de descubrimiento, no como métrica de vanidad.', cta: undefined, icon: MessagesSquare },
  { key: 'market', title: 'Marketplace Optimization', question: '“¿Eres visible donde comparan y compran?”', description: 'La superficie donde la demanda se captura: visibilidad en el momento exacto de decidir.', cta: undefined, icon: ShoppingCart },
] as const

const cycle = [
  { number: '01', name: 'SENSE', action: 'Escuchar la intención', description: 'Leer las señales reales de búsqueda y las preguntas detrás de cada canal.', icon: Ear },
  { number: '02', name: 'SHAPE', action: 'Construir los activos', description: 'Calibrar contenido y marca para que cada superficie tenga qué mostrar.', icon: SlidersHorizontal },
  { number: '03', name: 'SURFACE', action: 'Distribuir en el mapa', description: 'Publicar y conectar la presencia a través de las cinco superficies.', icon: Map },
  { number: '04', name: 'SOLVE', action: 'Cerrar el ciclo', description: 'SOLVE conecta el impacto de negocio con la siguiente vuelta del sistema.', icon: RefreshCw },
] as const

const relationships = [
  { title: 'AI Visibility Grader', description: 'Mide cómo te ven hoy los motores de respuesta. Es una lectura puntual de una parte del sistema (AEO), no una evaluación de las cinco superficies.', cta: 'Abrir el grader', href: '/brand-visibility', icon: Gauge },
  { title: 'Enfoque SEO', description: 'La puerta del descubrimiento por intención: cómo trabajamos la búsqueda activa dentro del sistema.', cta: 'Ver enfoque SEO', href: 'https://efeoncepro.com/loop-marketing/seo-aeo-optimizacion-ia-2025/', icon: Search },
  { title: 'Enfoque AEO', description: 'La puerta de los motores de respuesta: cómo logramos que la IA te entienda y te cite con precisión.', cta: 'Ver enfoque AEO', href: 'https://efeoncepro.com/aeo-2/', icon: Bot },
] as const

const faq = [
  { q: '¿Surround Discovery reemplaza al SEO o al AEO?', a: 'No. Los integra: SEO y AEO son dos superficies del mismo sistema. El ebook explica cómo se refuerzan entre sí junto con video, social y marketplace.' },
  { q: '¿S⁴ es una metodología nueva?', a: 'No. Es el ciclo operativo de Surround Discovery™ —SENSE, SHAPE, SURFACE y SOLVE—, no un framework independiente ni una alternativa al modelo de visibilidad en IA.' },
  { q: '¿El grader mide las cinco superficies?', a: 'No. El grader mide una parte del sistema —cómo te ven los motores de respuesta (AEO)—. El ebook es lo que explica el mapa completo de las cinco superficies.' },
  { q: '¿Qué recibo al registrarme?', a: 'El PDF de 61 páginas de Surround Discovery™, disponible para descarga inmediata tras aceptar el formulario.' },
  { q: '¿Me van a llamar o mandar spam?', a: 'Solo recibes aquello que aceptas en el formulario. El consentimiento y el tratamiento de tus datos los gobierna el formulario de Greenhouse.' },
  { q: '¿Esto garantiza mejores posiciones o citas?', a: 'No prometemos resultados. El ebook enseña el sistema y las decisiones detrás de él; los resultados dependen de cómo lo apliques en tu contexto.' },
] as const

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'Organization', '@id': organizationId, name: 'Efeonce Group SpA', alternateName: 'Efeonce', url: organizationUrl, logo: `${siteUrl}/branding/efeonce-logo.svg` },
    { '@type': 'WebSite', '@id': websiteId, name: 'Efeonce Think', url: siteUrl, inLanguage: 'es-CL', publisher: { '@id': organizationId } },
    { '@type': 'ImageObject', '@id': imageId, url: ebookImageUrl, contentUrl: ebookImageUrl, width: 3840, height: 2160, caption: socialImageAlt },
    { '@type': 'WebPage', '@id': pageId, url: landingUrl, name: pageTitle, headline: 'No compites por una posición. Compites por ser descubierto.', description: pageDescription, inLanguage: 'es-CL', isPartOf: { '@id': websiteId }, publisher: { '@id': organizationId }, primaryImageOfPage: { '@id': imageId }, about: { '@id': ebookId }, mainEntity: { '@id': ebookId } },
    { '@type': 'Book', '@id': ebookId, name: 'Surround Discovery™', alternateName: 'El mapa de la búsqueda fragmentada', description: 'Guía gratuita de Efeonce Think sobre SEO, AEO, Video Discovery, Social Discovery y Marketplace Optimization como superficies de un sistema de descubrimiento.', bookFormat: 'https://schema.org/EBook', genre: 'Research brief', inLanguage: 'es-CL', image: { '@id': imageId }, url: landingUrl, author: { '@id': organizationId }, publisher: { '@id': organizationId }, copyrightHolder: { '@id': organizationId }, isAccessibleForFree: true, audience: { '@type': 'BusinessAudience', audienceType: 'Equipos de marketing, growth y dirección' }, mainEntityOfPage: { '@id': pageId } },
    { '@type': 'FAQPage', '@id': faqId, url: `${landingUrl}#faq`, isPartOf: { '@id': pageId }, mainEntity: faq.map((item) => ({ '@type': 'Question', name: item.q, acceptedAnswer: { '@type': 'Answer', text: item.a } })) },
  ],
} as const
---

<BaseLayout title={pageTitle} description={pageDescription} canonical="/seo-surround-discovery" ogImage="/surround-discovery/ebook-cover.jpeg" ogTitle={socialTitle} ogDescription={socialDescription} ogImageAlt={socialImageAlt} jsonLd={jsonLd}>
  <a class="sd-skip" href="#main">Saltar al contenido</a>
  <div class="sd" data-capture="surround-discovery-landing" style={`--sd-navy:${axis.accent[900]};--sd-navy-2:${axis.accent[800]};--sd-blue:${axis.accent[500]};--sd-teal:${teal[500]};--sd-teal-light:${teal[300]};--sd-teal-deep:${teal[700]};--sd-teal-soft:${axis.success[100]};--sd-white:#fff;--sd-ink:${axis.gray[900]};--sd-muted:${axis.gray[600]};--sd-mist:${axis.gray[200]};--sd-line:${axis.gray[200]};--sd-surface:${axis.gray[50]};--sd-display:'Poppins','Geist Variable',sans-serif;`}>
    <header class="sd-header"><div class="sd-container sd-header__content"><a href="#main" aria-label="Efeonce, inicio"><img src="/branding/efeonce-logo.svg" alt="Efeonce" /></a><nav aria-label="Secciones"><a href="#surfaces">El sistema</a><a href="#s4">Método S⁴</a><a href="#ebook">El ebook</a><a href="#faq">Preguntas</a></nav><a class="sd-header__cta" href="#form" data-ripple><Download size={16} aria-hidden="true" /> Descargar el ebook</a></div></header>

    <main id="main">
      <section class="sd-hero" data-capture="surround-discovery-hero" aria-labelledby="surround-title"><div class="sd-hero__aura" aria-hidden="true"></div><div class="sd-container sd-hero__grid"><div><p class="sd-pill reveal" data-reveal><Map size={15} aria-hidden="true" /> El mapa de la búsqueda fragmentada</p><h1 id="surround-title" class="reveal" data-reveal data-reveal-delay="60" data-reveal-duration="750">No compites por una posición.<br /><span>Compites por ser descubierto.</span></h1><p class="sd-hero__lead reveal" data-reveal data-reveal-delay="120" data-reveal-duration="750">Tu próxima oportunidad puede empezar en Google, un motor de IA, un video, una conversación social o un marketplace. <strong>Surround Discovery™</strong> te ayuda a leer esas rutas como un sistema, no como tácticas sueltas.</p><div class="sd-hero__actions reveal" data-reveal data-reveal-delay="180" data-reveal-duration="750"><a class="sd-button sd-button--primary" href="#form" data-ripple><Download size={18} aria-hidden="true" />Descargar el ebook</a><a class="sd-button sd-button--outline" href="#surfaces" data-ripple>Ver el mapa <ArrowDown size={18} aria-hidden="true" /></a></div><p class="sd-hero__meta reveal" data-reveal data-reveal-delay="280" data-reveal-duration="800"><FileText size={16} aria-hidden="true" />Guía de 61 páginas <i aria-hidden="true"></i><Zap size={16} aria-hidden="true" />Descarga inmediata tras registro</p></div><figure class="sd-hero-map reveal" data-reveal data-parallax data-parallax-y="0.12" aria-label="Cinco superficies de descubrimiento conectadas"><div class="sd-map-ring sd-map-ring--outer"></div><div class="sd-map-ring sd-map-ring--inner"></div><div class="sd-map-wave"></div><div class="sd-map-wave sd-map-wave--late"></div><svg viewBox="0 0 100 100" aria-hidden="true"><g><line x1="50" y1="50" x2="50" y2="9" /><line x1="50" y1="50" x2="88" y2="33" /><line x1="50" y1="50" x2="79" y2="82" /><line x1="50" y1="50" x2="21" y2="82" /><line x1="50" y1="50" x2="12" y2="33" /></g></svg><div class="sd-map-core" data-halo><img src="/branding/efeonce-logo-negative.svg" alt="" /><span>Discovery</span></div>{surfaces.map((surface, index) => (<div class={`sd-hero-node sd-hero-node--${index + 1}`} data-float aria-hidden="true"><div><component is={surface.icon} size={24} /></div><span>{surface.key === 'market' ? 'Market' : surface.title === 'Video Discovery' ? 'Video' : surface.title === 'Social Discovery' ? 'Social' : surface.title}</span></div>))}</figure></div><div class="sd-hero__wave" aria-hidden="true"><svg viewBox="0 0 1440 60" preserveAspectRatio="none"><path d="M0,60 L0,28 C240,54 480,4 720,10 C960,16 1200,52 1440,26 L1440,60 Z" /></svg></div></section>

      <section class="sd-fragment section" data-capture="surround-discovery-fragmentation" aria-labelledby="frag-title"><div class="sd-container"><div class="sd-copy reveal" data-reveal><p class="sd-eyebrow"><span></span>El problema</p><h2 id="frag-title">SEO y AEO no compiten. Se quedan cortos cuando trabajan solos.</h2><p>El descubrimiento dejó de vivir en una sola caja de búsqueda. Cuando optimizas un canal aislado, resuelves una parte del recorrido y pierdes de vista el resto.</p></div><div class="sd-before-grid">{[['Optimizabas una página para un buscador.','Tu comprador pregunta en cinco lugares distintos.'],['Medías tu éxito como una posición.','El descubrimiento ya no cabe en un ranking.'],['Elegías un canal y lo trabajabas.','La intención se reparte entre todos a la vez.']].map((item, index) => (<article class="reveal" data-reveal style={`--delay:${index * 80}ms`}><span>Antes</span><p class="sd-strike">{item[0]}</p><strong>Ahora</strong><h3>{item[1]}</h3></article>))}</div></div></section>

      <section id="surfaces" class="section sd-surfaces" data-capture="surround-discovery-surfaces" aria-labelledby="surfaces-title"><div class="sd-container"><div class="sd-copy reveal" data-reveal><p class="sd-eyebrow"><span></span>El sistema</p><h2 id="surfaces-title">Cinco superficies. Una sola decisión: dónde te descubre tu mercado.</h2><p>El descubrimiento ocurre en cinco superficies conectadas. Surround Discovery las trata como un mismo sistema: cada una responde a una pregunta distinta de tu comprador, y ninguna reemplaza a las demás.</p></div><div class="sd-surface-map reveal" data-reveal aria-hidden="true"><div class="sd-surface-map__ring sd-surface-map__ring--outer"></div><div class="sd-surface-map__ring sd-surface-map__ring--inner"></div><div class="sd-surface-map__wave"></div><svg viewBox="0 0 100 100"><g><line x1="50" y1="50" x2="50" y2="10"/><line x1="50" y1="50" x2="88" y2="35"/><line x1="50" y1="50" x2="74" y2="86"/><line x1="50" y1="50" x2="26" y2="86"/><line x1="50" y1="50" x2="12" y2="35"/></g></svg><div class="sd-surface-map__core"><img src="/branding/efeonce-logo-negative.svg" alt=""/><span>Discovery</span></div>{surfaces.map((surface, index) => (<div class={`sd-surface-map__node sd-surface-map__node--${index + 1}`} data-surface-node={surface.key}><div><component is={surface.icon} size={26}/></div><span>{surface.key === 'market' ? 'Market' : surface.title === 'Video Discovery' ? 'Video' : surface.title === 'Social Discovery' ? 'Social' : surface.title}</span></div>))}</div><div class="sd-surface-cards">{surfaces.map((surface, index) => (<article class="reveal" data-reveal data-surface-card={surface.key} style={`--delay:${(index % 3) * 70}ms`}><div><span><component is={surface.icon} size={22} /></span><h3>{surface.title}</h3></div><strong>{surface.question}</strong><p>{surface.description}</p>{surface.cta && <a href="#relationship">{surface.cta}<ArrowRight size={16} aria-hidden="true" /></a>}</article>))}</div></div></section>

      <section id="s4" class="sd-cycle section" data-capture="surround-discovery-cycle" aria-labelledby="cycle-title"><div class="sd-cycle__aura" data-parallax-y="-0.1" aria-hidden="true"></div><div class="sd-container"><div class="sd-copy sd-copy--dark reveal" data-reveal><p class="sd-eyebrow"><span></span>El ciclo operativo</p><h2 id="cycle-title">Un sistema no publica y espera. Escucha, construye, distribuye y aprende.</h2><p>S⁴ es el ciclo operativo de Surround Discovery™ —no una metodología aparte—. Cuatro etapas que se retroalimentan en cada vuelta.</p></div><ol class="sd-cycle__grid">{cycle.map((step, index) => (<li class:list={['reveal', index === 3 && 'sd-cycle__solve']} data-reveal style={`--delay:${index * 90}ms;--step:${index};`}><div><span>{step.number}</span><component is={step.icon} size={26} /></div><h3>{step.name}</h3><strong>{step.action}</strong><p>{step.description}</p><i aria-hidden="true"></i></li>))}</ol><p class="sd-cycle__note reveal" data-reveal><Info size={16} aria-hidden="true" />Es un loop: como afinar el sistema, cada vuelta de SOLVE alimenta el siguiente SENSE.</p></div></section>

      <section id="relationship" class="section sd-relationship" data-capture="surround-discovery-relationships" aria-labelledby="relationship-title"><div class="sd-container"><div class="sd-copy reveal" data-reveal><p class="sd-eyebrow"><span></span>Cómo encaja lo que ya tienes</p><h2 id="relationship-title">Las herramientas ya existen. El mapa explica cómo se conectan.</h2><p>El grader y las landings de SEO y AEO son puertas especializadas dentro del mismo sistema. No son ofertas sueltas ni sustituyen al mapa completo.</p></div><div class="sd-relationship__grid">{relationships.map((item, index) => (<a class="reveal" data-reveal href={item.href} style={`--delay:${index * 80}ms`}><span><component is={item.icon} size={24}/></span><h3>{item.title}</h3><p>{item.description}</p><strong>{item.cta}<ArrowUpRight size={16} aria-hidden="true" /></strong></a>))}</div></div></section>

      <section id="ebook" class="sd-ebook section" data-capture="surround-discovery-ebook" aria-labelledby="ebook-title"><div class="sd-ebook__aura" data-parallax-y="-0.12" aria-hidden="true"></div><div class="sd-container sd-ebook__grid"><div class="sd-copy sd-copy--dark reveal" data-reveal><p class="sd-eyebrow"><span></span>El ebook</p><h2 id="ebook-title">El mapa completo,<br />en una sola guía.</h2><p>61 páginas que ordenan el sistema de descubrimiento: el problema, las cinco superficies y el ciclo S⁴, explicados para decidir dónde empieza tu presencia.</p><ol class="sd-ebook__list"><li><b>01</b>El problema del descubrimiento fragmentado</li><li><b>02</b>Las cinco superficies, una por una</li><li><b>03</b>El ciclo S⁴: SENSE, SHAPE, SURFACE y SOLVE</li><li><b>04</b>Cómo gobernar el sistema</li><li><b>05</b>Dónde se define tu posición competitiva</li></ol><div class="sd-ebook__actions"><a class="sd-button sd-button--primary" href="#form" data-ripple><Download size={18} aria-hidden="true" />Descargar el ebook</a><span><Zap size={16} aria-hidden="true" />Descarga inmediata · sin spam</span></div></div><div class="sd-book-art reveal" data-reveal data-reveal-delay="140" data-reveal-duration="850"><div class="sd-book-art__rays" aria-hidden="true"></div><div class="sd-book-art__aura" aria-hidden="true"></div><div class="sd-book-art__parallax" data-parallax-y="-0.18" aria-hidden="true"></div><div class="sd-book-art__shadow" aria-hidden="true"></div><div class="sd-book" data-parallax-y="0.16"><i></i><b></b><span></span><div><img src="/surround-discovery/ebook-cover.jpeg" alt="Portada del ebook Surround Discovery de Efeonce" width="3840" height="2160" loading="lazy" decoding="async"/></div></div><p><FileText size={16} aria-hidden="true"/>61 páginas <i></i><FileText size={16} aria-hidden="true"/>PDF <i></i><Sparkles size={16} aria-hidden="true"/>Español</p></div></div></section>

      <section id="form" class="sd-form-section section" data-capture="surround-discovery-form-section" aria-labelledby="form-title"><div class="sd-form-section__aura sd-form-section__aura--right" data-parallax data-parallax-y="-0.06" aria-hidden="true"></div><div class="sd-form-section__aura sd-form-section__aura--left" data-parallax data-parallax-y="0.05" aria-hidden="true"></div><div class="sd-container sd-form-section__grid"><div class="sd-form-rail reveal" data-reveal><p class="sd-eyebrow"><span></span>PDF · 61 páginas · Acceso inmediato</p><h2 id="form-title">Descarga tu copia ahora</h2><p>Ya viste qué hay dentro. Dinos a dónde enviarlo y obtén acceso inmediato al PDF completo.</p><div><strong>Qué pasa al enviar</strong><ol><li><b>1</b><span><em>Completas y aceptas</em>Cuatro campos. Menos de un minuto.</span></li><li><b>2</b><span><em>Descarga inmediata</em>El PDF se abre al instante, sin esperar a un correo.</span></li><li><b>3</b><span><em>Tú controlas el resto</em>Solo recibes lo que marcaste. Sin spam.</span></li></ol></div><aside><Check size={17} aria-hidden="true"/><p>Los campos, el consentimiento y la entrega los gobierna <strong>Greenhouse Growth Forms</strong>.</p></aside></div><div class="reveal" data-reveal data-reveal-delay="120"><SurroundDiscoveryFormDock /></div></div></section>

      <section id="faq" class="sd-faq section" data-capture="surround-discovery-faq" aria-labelledby="faq-title"><div class="sd-faq__wrap"><div class="reveal" data-reveal><p>Preguntas frecuentes</p><h2 id="faq-title">Antes de elegir una táctica, aclaremos el sistema.</h2></div><div class="sd-faq__items">{faq.map((item) => (<details class="reveal" data-reveal><summary>{item.q}<span aria-hidden="true">+</span></summary><p>{item.a}</p></details>))}</div></div></section>

      <section class="sd-closing" data-capture="surround-discovery-final" aria-labelledby="closing-title"><div class="sd-closing__aura" aria-hidden="true"></div><div class="sd-closing__content reveal" data-reveal><Map size={34} aria-hidden="true"/><h2 id="closing-title">El descubrimiento no ocurre en un solo lugar. Tu estrategia tampoco debería.</h2><p>Empieza con el mapa completo. El ebook te da el marco; tú decides desde dónde ordenar tu presencia.</p><a class="sd-button sd-button--primary" href="#form" data-ripple><Download size={18} aria-hidden="true"/>Descargar el ebook</a></div></section>
    </main>

    <footer class="sd-footer"><div class="sd-container"><div class="sd-footer__top"><img src="/branding/efeonce-logo-negative.svg" alt="Efeonce"/><nav aria-label="Enlaces de pie"><a href="https://efeoncepro.com/politica-de-privacidad/">Aviso de privacidad</a><a href="#form">Descargar</a></nav></div><div class="sd-footer__bottom"><p><Check size={15} aria-hidden="true"/><span><strong>Surround Discovery™</strong> y el método <strong>S⁴</strong> son marca y metodología propietarias de Efeonce. Su uso, adaptación o reproducción requiere autorización expresa.</span></p><p>© 2026 Efeonce · Todos los derechos reservados</p></div></div></footer>
  </div>
</BaseLayout>

<script>
  const root = document.querySelector<HTMLElement>('[data-capture="surround-discovery-landing"]')
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)')

  if (root) {
    const revealItems = Array.from(root.querySelectorAll<HTMLElement>('[data-reveal]'))
    const reveal = (item: HTMLElement) => { item.dataset.revealed = 'true' }
    const parallax = Array.from(root.querySelectorAll<HTMLElement>('[data-parallax-y]'))
    revealItems.forEach((item) => {
      const delay = Number.parseInt(item.getAttribute('data-reveal-delay') ?? '', 10)
      const duration = Number.parseInt(item.getAttribute('data-reveal-duration') ?? '', 10)
      if (Number.isFinite(delay)) item.style.setProperty('--delay', `${delay}ms`)
      if (Number.isFinite(duration)) item.style.setProperty('--reveal-duration', `${duration}ms`)
    })

    if (reducedMotion.matches) {
      revealItems.forEach(reveal)
    } else {
      root.dataset.motion = 'ready'
      const applyParallax = () => {
        const viewportHeight = window.innerHeight || document.documentElement.clientHeight || 1
        parallax.forEach((element) => {
          const rect = element.getBoundingClientRect()
          const distance = Math.max(-1, Math.min(1, (rect.top + rect.height / 2 - viewportHeight / 2) / viewportHeight))
          const factor = Number.parseFloat(element.getAttribute('data-parallax-y') ?? '') || 0
          element.style.setProperty('--sy', `${(distance * factor * 100).toFixed(1)}px`)
        })
      }
      const check = () => {
        const viewportHeight = window.innerHeight || document.documentElement.clientHeight || 800
        revealItems.filter((item) => !item.dataset.revealed).forEach((item) => {
          const rect = item.getBoundingClientRect()
          if (rect.top < viewportHeight * .9 && rect.bottom > -40) reveal(item)
        })
        applyParallax()
      }
      let ticking = false
      const onScroll = () => {
        if (ticking) return
        ticking = true
        window.requestAnimationFrame(() => { ticking = false; check() })
      }
      window.addEventListener('scroll', onScroll, { passive: true })
      window.addEventListener('resize', onScroll, { passive: true })
      check()
      window.setTimeout(() => revealItems.forEach(reveal), 1900)

      const constellation = root.querySelector<HTMLElement>('[data-parallax]')
      if (constellation) {
        window.addEventListener('mousemove', (event) => {
          const rect = constellation.getBoundingClientRect()
          const pointerX = Math.max(-1, Math.min(1, (event.clientX - (rect.left + rect.width / 2)) / rect.width))
          const pointerY = Math.max(-1, Math.min(1, (event.clientY - (rect.top + rect.height / 2)) / rect.height))
          constellation.style.setProperty('--px', `${(pointerX * 7).toFixed(2)}px`)
