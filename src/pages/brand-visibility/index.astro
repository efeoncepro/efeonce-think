---
import '@fontsource/poppins/600.css'
import BaseLayout from '@layouts/BaseLayout.astro'
import BrandVisibilityFormDock from '@/components/BrandVisibilityFormDock.astro'
import EfeonceSlogan from '@/components/EfeonceSlogan.astro'
import EngineAvatarGroup from '@/components/primitives/EngineAvatarGroup.astro'
import HeroAnswerLens from '@/components/HeroAnswerLens.astro'
import ReportIcon from '@/components/primitives/ReportIcon.astro'
import { buildCopyrightNotice } from '@lib/legal'
import { axis, LEVEL_COPY } from '@lib/report-tokens'
import { BadgeCheck, BookOpenText, MousePointerClick, ScanSearch, Trophy } from '@lucide/astro'

const pageTitle = 'Brand Visibility Grader | Motores de respuesta y AEO'
const pageDescription =
  'Mide cómo ChatGPT, Perplexity, Claude, Gemini y Google AI Overviews entienden, citan y recomiendan tu marca. Recibe un informe privado con acciones.'
const siteUrl = 'https://think.efeoncepro.com'
const organizationUrl = 'https://efeoncepro.com'
const landingUrl = `${siteUrl}/brand-visibility`
const organizationId = `${organizationUrl}/#organization`
const websiteId = `${siteUrl}/#website`
const webpageId = `${landingUrl}#webpage`
const serviceId = `${landingUrl}#service`
const engines = ['chatgpt', 'gemini', 'claude', 'perplexity', 'google_ai_overview']
const previewModules = [
  {
    title: 'Mapa de presencia',
    icon: 'signal',
    tone: 'presence',
    label: 'Dónde apareces',
    body: 'Identifica qué canales recuperan tu marca, con qué frecuencia y frente a qué alternativas de la categoría.',
  },
  {
    title: 'Lectura competitiva',
    icon: 'citation',
    tone: 'citation',
    label: 'Por qué te citan',
    body: 'Muestra qué fuentes sostienen la confianza, qué señales faltan y qué competidores están ganando la respuesta.',
  },
  {
    title: 'Exactitud de marca',
    icon: 'category',
    tone: 'category',
    label: 'Qué interpreta cada canal',
    body: 'Detecta si tu oferta se entiende con precisión o si el motor mezcla claims, categorías o competidores.',
  },
  {
    title: 'Prioridad de acción',
    icon: 'readiness',
    tone: 'operability',
    label: 'Qué mejorar primero',
    body: 'Ordena el siguiente movimiento: corregir presencia, estructura, narrativa, exactitud o capacidad operable.',
  },
] as const
const levels = [
  {
    key: 'found',
    signal: 'Acceso, indexación, robots y cobertura por canal.',
    diagnostic: 'Si no te encuentran, todo lo demás queda fuera de juego.',
  },
  {
    key: 'readable',
    signal: 'Estructura semántica, schema, contenido y señales legibles.',
    diagnostic: 'Si te leen con ambigüedad, completan los vacíos por ti.',
  },
  {
    key: 'correct',
    signal: 'Exactitud, claims, categoría y confusión competitiva.',
    diagnostic: 'El riesgo no es sólo no aparecer; también es que una respuesta te describa mal.',
  },
  {
    key: 'actionable',
    signal: 'Acciones, rutas claras, datos útiles y experiencia operable.',
    diagnostic: 'La próxima frontera es que un agente pueda usar tu sitio, no sólo citarlo.',
  },
  {
    key: 'intrinsic',
    signal: 'Autoridad de entidad, preferencia y share of voice sostenido.',
    diagnostic: 'Ser el default se gana con consistencia, no con un ajuste aislado.',
  },
] as const
const frameworkIcons = {
  found: ScanSearch,
  readable: BookOpenText,
  correct: BadgeCheck,
  actionable: MousePointerClick,
  intrinsic: Trophy,
} as const
const reportProofPoints = [
  {
    title: 'Privado',
    body: 'El resultado se abre en una ruta no indexable para revisión interna.',
  },
  {
    title: 'Con evidencia',
    body: 'Sólo muestra hallazgos cuando hay señales suficientes para sostenerlos.',
  },
  {
    title: 'Con siguiente paso',
    body: 'Separa diagnóstico, riesgo y acción recomendada para decidir qué corregir primero.',
  },
] as const
const reportSignals = [
  {
    label: 'Presencia',
    value: 'dónde te recuperan',
  },
  {
    label: 'Citabilidad',
    value: 'por qué te nombran',
  },
  {
    label: 'Acción',
    value: 'qué corregir primero',
  },
] as const
const brandVisibilityJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': organizationId,
      name: 'Efeonce Group SpA',
      alternateName: 'Efeonce',
      url: organizationUrl,
      logo: `${siteUrl}/branding/efeonce-logo.svg`,
    },
    {
      '@type': 'WebSite',
      '@id': websiteId,
      name: 'Efeonce Think',
      url: siteUrl,
      inLanguage: 'es-CL',
      publisher: {
        '@id': organizationId,
      },
    },
    {
      '@type': 'WebPage',
      '@id': webpageId,
      url: landingUrl,
      name: pageTitle,
      headline: 'Mide cómo los motores de respuesta entienden y recomiendan tu marca.',
      description: pageDescription,
      inLanguage: 'es-CL',
      isPartOf: {
        '@id': websiteId,
      },
      about: {
        '@id': serviceId,
      },
      mainEntity: {
        '@id': serviceId,
      },
      breadcrumb: {
        '@id': `${landingUrl}#breadcrumb`,
      },
    },
    {
      '@type': 'Service',
      '@id': serviceId,
      name: 'Brand Visibility Grader',
      serviceType: 'Análisis de visibilidad en motores de respuesta y búsqueda generativa',
      category: ['AEO', 'GEO', 'Brand visibility', 'Answer Engine Optimization'],
      description:
        'Herramienta de Efeonce Think para evaluar presencia, citabilidad, exactitud y operabilidad de una marca en motores de respuesta y superficies generativas de búsqueda.',
      provider: {
        '@id': organizationId,
      },
      audience: {
        '@type': 'BusinessAudience',
        audienceType: 'Equipos de marketing, crecimiento, dirección y estrategia digital',
      },
      potentialAction: {
        '@type': 'Action',
        name: 'Solicitar informe privado de Brand Visibility',
        target: `${landingUrl}#brand-visibility-form`,
      },
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${landingUrl}#breadcrumb`,
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Efeonce Think',
          item: siteUrl,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Brand Visibility Grader',
          item: landingUrl,
        },
      ],
    },
    {
      '@type': 'ItemList',
      '@id': `${landingUrl}#framework`,
      name: 'Framework Efeonce de visibilidad en motores de respuesta',
      itemListElement: levels.map((level, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: `${LEVEL_COPY[level.key].labelEn}: ${LEVEL_COPY[level.key].label}`,
        description: level.signal,
      })),
    },
    {
      '@type': 'ItemList',
      '@id': `${landingUrl}#report-modules`,
      name: 'Módulos del informe privado de Brand Visibility',
      itemListElement: previewModules.map((module, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: module.title,
        description: module.body,
      })),
    },
  ],
} as const
const footerCopyrightNotice = buildCopyrightNotice()
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical="/brand-visibility"
  jsonLd={brandVisibilityJsonLd}
>
  <main
    class="brand-visibility-page"
    data-capture="brand-visibility-landing"
    style={`--axis-blue:${axis.accent[500]};--axis-blue-dark:${axis.accent[700]};--axis-navy:${axis.accent[900]};--axis-navy-soft:${axis.accent[800]};--axis-success:${axis.success[500]};--axis-warning:${axis.warning[500]};--axis-gray-50:${axis.gray[50]};--axis-gray-100:${axis.gray[100]};--axis-gray-200:${axis.gray[200]};--axis-gray-600:${axis.gray[600]};--axis-gray-800:${axis.gray[800]};--axis-gray-900:${axis.gray[900]};`}
  >
    <section class="hero-shell" data-capture="brand-visibility-hero" aria-labelledby="brand-visibility-title">
      <header class="topbar" aria-label="Efeonce Think">
        <a class="brand-link" href="/" aria-label="Ir a Efeonce Think">
          <img class="efeonce-mark" src="/branding/efeonce-logo-negative.svg" alt="Efeonce" />
          <span aria-hidden="true"></span>
          <img class="think-mark" src="/branding/eo-think-2.svg" alt="Think" />
        </a>
      </header>

      <div class="hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Brand Visibility Grader</p>
          <h1 id="brand-visibility-title">
            <span>Mide cómo los motores</span>
            <span>de respuesta entienden</span>
            <span>y recomiendan</span>
            <span>tu marca.</span>
          </h1>
          <p class="hero-lead">
            Dejas tus datos en el formulario. Nuestro sistema analiza tu presencia,
            citabilidad y operabilidad en motores de respuesta y superficies generativas de búsqueda.
            Al finalizar, verás tu informe completo en pantalla.
          </p>

          <div class="engine-chips" data-capture="brand-visibility-signal-preview" aria-label="Motores de respuesta y superficies generativas analizadas">
            <p class="mini-label">Motores y superficies</p>
            <div class="engine-stack">
              <EngineAvatarGroup providers={engines} size="md" max={5} />
            </div>
          </div>
        </div>

        <HeroAnswerLens />
      </div>

      <a class="scroll-cue" href="#brand-visibility-form" data-scroll-cue aria-label="Bajar al formulario para generar el informe">
        <span class="scroll-cue-circle" aria-hidden="true"></span>
      </a>

      <BrandVisibilityFormDock />
    </section>

    <section class="framework-band" data-capture="brand-visibility-trust" aria-labelledby="framework-title">
      <div class="framework-heading">
        <p class="section-kicker framework-kicker">
          <span>Framework de</span>
          <span class="inline-efeonce-logo" role="img" aria-label="Efeonce"></span>
        </p>
        <h2 id="framework-title">La visibilidad en IA se gana capa por capa.</h2>
        <p>
          El informe ordena el diagnóstico en cinco niveles: acceso, lectura,
          exactitud, operabilidad y preferencia de marca.
        </p>
      </div>

      <ol class="framework-ladder" aria-label="Cinco niveles de visibilidad en IA, motores de respuesta y búsqueda generativa">
        {levels.map((level, index) => {
          const FrameworkIcon = frameworkIcons[level.key]

          return (
            <li>
              <div class="framework-card-body">
                <div class="framework-card-top">
                  <span class="framework-step">{LEVEL_COPY[level.key].ordinal}</span>
                  <div class="framework-card-heading">
                    <span class="framework-title-row">
                      <span class={`framework-icon framework-icon-${index + 1}`} aria-hidden="true">
                        <FrameworkIcon size={15} stroke-width={2} />
                      </span>
                      <strong>{LEVEL_COPY[level.key].labelEn}</strong>
                    </span>
                    <span class="framework-card-subtitle">{LEVEL_COPY[level.key].label}</span>
                  </div>
                </div>
                <p class="framework-question">{LEVEL_COPY[level.key].question}</p>
                <p>{level.signal}</p>
                <em>{level.diagnostic}</em>
              </div>
            </li>
          )
        })}
      </ol>

      <div class="framework-bridge" aria-label="Cómo interpreta Efeonce el framework">
        <div>
          <strong>La lectura útil no pregunta sólo si apareces.</strong>
          <p>
            Pregunta dónde se corta la cadena entre presencia, comprensión,
            exactitud y capacidad de ser citado o recomendado con confianza.
          </p>
        </div>
        <span aria-hidden="true">Found → Readable → Correct → Actionable → Intrinsic</span>
      </div>
    </section>

    <section class="preview-flow-section" data-capture="brand-visibility-report-preview" aria-labelledby="preview-title">
      <span class="capture-only" data-capture="brand-visibility-flow" aria-hidden="true"></span>
      <div class="preview-flow-grid">
        <article class="report-preview">
          <div class="section-heading">
            <div>
              <p class="section-kicker">Informe privado</p>
              <h2 id="preview-title">Del diagnóstico a la próxima acción</h2>
              <p>
                El reporte cruza presencia, citabilidad, exactitud y operabilidad
                para mostrar dónde tu marca se pierde, se confunde o puede ganar prioridad.
              </p>
            </div>
            <div class="report-signal-strip" aria-label="Señales principales del informe">
              {reportSignals.map((signal) => (
                <span>
                  <strong>{signal.label}</strong>
                  <small>{signal.value}</small>
                </span>
              ))}
            </div>
          </div>

          <div class="preview-report-layout">
            <div class="preview-module-strip">
              {previewModules.map((module) => (
                <div class="preview-module">
                  <div class="preview-module-top">
                    <span class={`preview-icon preview-icon-${module.tone}`} aria-hidden="true">
                      <ReportIcon name={module.icon} size={19} />
                    </span>
                    <small>{module.label}</small>
                  </div>
                  <h3>{module.title}</h3>
                  <p>{module.body}</p>
                </div>
              ))}
            </div>

            <div class="report-snapshot" aria-label="Vista conceptual del informe">
              <div class="snapshot-header">
                <span>Reporte privado</span>
                <strong>Brand Visibility</strong>
              </div>
              <div class="snapshot-badge-row" aria-hidden="true">
                <span>Lectura ejecutiva</span>
                <span>Señal prioritaria</span>
              </div>
              <div class="snapshot-score">
                <span class="snapshot-orbit" aria-hidden="true"></span>
                <div>
                  <small>Resultado accionable</small>
                  <strong>Presencia + precisión + siguiente paso</strong>
                </div>
              </div>
              <div class="snapshot-bars" aria-hidden="true">
                <span style="--bar-size: 78%"></span>
                <span style="--bar-size: 62%"></span>
                <span style="--bar-size: 46%"></span>
              </div>
              <div class="snapshot-notes">
                <p><strong>Primero:</strong> ubicar dónde no estás siendo recuperado ni citado.</p>
                <p><strong>Luego:</strong> corregir la señal que más limita la recomendación.</p>
              </div>
            </div>
          </div>

          <div class="report-proof-row" aria-label="Características del informe">
            {reportProofPoints.map((point) => (
              <p><strong>{point.title}.</strong> {point.body}</p>
            ))}
          </div>
        </article>
      </div>
    </section>

    <footer class="report-footer brand-visibility-footer" data-capture="brand-visibility-footer">
      <div class="report-footer-shell">
        <div class="report-footer-brand">
          <a href="https://efeoncepro.com" target="_blank" rel="noopener noreferrer" aria-label="Ir a efeoncepro.com">
            <img src="/branding/efeonce-logo-negative.svg" alt="Efeonce" style="height:28px;width:auto" />
          </a>
          <EfeonceSlogan color="rgba(255,255,255,0.64)" size="0.62rem" />
        </div>
        <div class="report-footer-column">
          <p class="report-footer-kicker">Propiedad intelectual</p>
          <p class="report-footer-strong">{footerCopyrightNotice}</p>
          <p>Todos los derechos reservados.</p>
        </div>
        <div class="report-footer-column report-footer-method">
          <p class="report-footer-kicker">Método de análisis</p>
          <p>
            Modelo propietario de Efeonce para leer presencia, citabilidad
            y posición competitiva en motores de respuesta y búsqueda generativa.
          </p>
          <a href="https://efeoncepro.com" target="_blank" rel="noopener noreferrer" class="report-footer-link">Conoce más en efeoncepro.com</a>
        </div>
        <p class="report-footer-disclaimer">
          Lectura agregada y asistida por modelos generativos. Orienta decisiones;
          no garantiza posiciones, menciones ni resultados comerciales.
        </p>
      </div>
    </footer>
  </main>
</BaseLayout>

<script is:inline>
  const scrollCue = document.querySelector('[data-scroll-cue]')
  const formDock = document.getElementById('brand-visibility-form')
  const reduceScrollMotion = window.matchMedia('(prefers-reduced-motion: reduce)')

  scrollCue?.addEventListener('click', (event) => {
    if (!(formDock instanceof HTMLElement)) return

    event.preventDefault()
    formDock.scrollIntoView({
      block: 'start',
      inline: 'nearest',
      behavior: reduceScrollMotion.matches ? 'auto' : 'smooth',
    })

    window.history?.pushState?.(null, '', '#brand-visibility-form')
  })
</script>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  .brand-visibility-page {
    --brand-form-card-radius: clamp(1rem, 1.7vw, 1.55rem);
    --brand-hero-bottom-radius: 0;
    min-height: 100vh;
    overflow-x: clip;
    background: #fff;
    color: var(--axis-gray-900);
  }

  .hero-shell {
    position: relative;
    isolation: isolate;
    overflow: visible;
    border-bottom-right-radius: var(--brand-hero-bottom-radius);
    border-bottom-left-radius: var(--brand-hero-bottom-radius);
    background: linear-gradient(160deg, var(--axis-navy-soft) 0%, var(--axis-navy) 62%, #001a33 100%);
    color: #fff;
  }

  .hero-shell::after {
    content: '';
    position: absolute;
    inset: auto 0 0;
    z-index: -1;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(76, 141, 255, 0.72), transparent);
  }

  .topbar,
  .hero-grid,
  .preview-flow-grid,
  .framework-band {
    width: min(1320px, calc(100% - 64px));
    margin-inline: auto;
  }

  .topbar {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 26px 0 0;
  }

  .brand-link {
    display: inline-grid;
    grid-template-columns: auto auto auto;
    align-items: center;
    column-gap: 0.8rem;
    color: inherit;
    text-decoration: none;
  }

  .brand-link .efeonce-mark {
    width: 150px;
    height: auto;
  }

  .brand-link > span {
    width: 1px;
    height: 2.05rem;
    background: rgba(255, 255, 255, 0.48);
  }

  .brand-link .think-mark {
    display: block;
    width: 70px;
    height: auto;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 780px) minmax(430px, 1fr);
    gap: clamp(2rem, 3vw, 3.4rem);
    align-items: center;
    padding: clamp(34px, 3vw, 52px) 0 clamp(220px, 18vw, 252px);
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    min-width: 0;
  }

  .eyebrow,
  .mini-label {
    font-size: 0.72rem;
    font-weight: 820;
    letter-spacing: 0.1em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(255, 179, 26, 0.34);
    border-radius: 999px;
    padding: 0.38rem 0.68rem;
    background: linear-gradient(180deg, #ffd166 0%, var(--axis-warning) 100%);
    color: #08203a;
    box-shadow:
      0 14px 34px -24px rgba(255, 179, 26, 0.95),
      inset 0 1px 0 rgba(255, 255, 255, 0.48);
  }

  .mini-label {
    color: rgba(255, 255, 255, 0.78);
  }

  .hero-copy h1 {
    max-width: 780px;
    margin: 1.28rem 0 0;
    color: #fff;
    font-family: 'Poppins', 'Geist Variable', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: clamp(3rem, 3.65vw, 4rem);
    font-weight: 600;
    letter-spacing: 0;
    line-height: 1.08;
    text-wrap: normal;
  }

  .hero-copy h1 span {
    display: block;
  }

  .hero-copy h1::after {
    content: '';
    display: block;
    width: 42px;
    height: 4px;
    margin-top: 1.22rem;
    border-radius: 999px;
    background: linear-gradient(90deg, #36d7c5 0%, #62f0df 100%);
    box-shadow: 0 0 22px rgba(54, 215, 197, 0.42);
  }

  .hero-lead {
    max-width: 650px;
    margin-top: 1.24rem;
    color: rgba(255, 255, 255, 0.74);
    font-size: 1.02rem;
    line-height: 1.58;
  }

  .engine-chips {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    margin-top: 1.92rem;
  }

  .engine-stack {
    display: inline-flex;
    align-items: center;
    gap: 0.86rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 999px;
    padding: 0.22rem 0.62rem 0.22rem 0.28rem;
    background: rgba(255, 255, 255, 0.048);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.07);
  }

  .engine-stack :global(.engine-avatar-group) {
    padding-block: 0;
  }

  .scroll-cue {
    position: absolute;
    inset: auto auto clamp(8rem, 10vw, 10.8rem) 50%;
    z-index: 32;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transform: translateX(-50%);
    color: #fff;
    text-decoration: none;
  }

  .scroll-cue-circle {
    position: relative;
    display: inline-grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.13), rgba(255, 255, 255, 0.055)),
      rgba(0, 40, 77, 0.28);
    box-shadow:
      0 18px 42px -28px rgba(0, 0, 0, 0.72),
      inset 0 1px 0 rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(12px);
    animation: scrollCueFloat 1.8s ease-in-out infinite;
  }

  .scroll-cue-circle::before {
    content: '';
    width: 11px;
    height: 11px;
    margin-top: -4px;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(45deg);
  }

  .scroll-cue:hover .scroll-cue-circle,
  .scroll-cue:focus-visible .scroll-cue-circle {
    border-color: rgba(54, 215, 197, 0.7);
    background:
      linear-gradient(180deg, rgba(54, 215, 197, 0.18), rgba(255, 255, 255, 0.06)),
      rgba(0, 40, 77, 0.34);
  }

  .scroll-cue:focus-visible {
    border-radius: 999px;
    outline: 2px solid rgba(54, 215, 197, 0.86);
    outline-offset: 4px;
  }

  @keyframes scrollCueFloat {
    0%, 100% {
      transform: translateY(0);
      opacity: 0.78;
    }
    50% {
      transform: translateY(7px);
      opacity: 1;
    }
  }

  .preview-icon {
    display: inline-grid;
    place-items: center;
    flex: 0 0 auto;
    width: 42px;
    height: 42px;
    border: 1px solid color-mix(in srgb, currentColor 28%, transparent);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.38)),
      color-mix(in srgb, currentColor 9%, transparent);
    color: var(--axis-success);
    box-shadow:
