---
import BaseLayout from '@layouts/BaseLayout.astro'
import BrandVisibilityFormDock from '@/components/BrandVisibilityFormDock.astro'
import EfeonceSlogan from '@/components/EfeonceSlogan.astro'
import EngineAvatarGroup from '@/components/primitives/EngineAvatarGroup.astro'
import HeroAnswerLens from '@/components/HeroAnswerLens.astro'
import ReportIcon from '@/components/primitives/ReportIcon.astro'
import { buildCopyrightNotice } from '@lib/legal'
import { axis, LEVEL_COPY } from '@lib/report-tokens'

const engines = ['chatgpt', 'gemini', 'claude', 'perplexity', 'google_ai_overview']
const previewModules = [
  {
    title: 'Presencia',
    icon: 'signal',
    tone: 'presence',
    label: 'Cobertura',
    body: 'Dónde aparece tu marca, en qué motores y con qué consistencia frente al mercado.',
  },
  {
    title: 'Citabilidad',
    icon: 'citation',
    tone: 'citation',
    label: 'Fuentes',
    body: 'Qué dominios y señales sostienen la confianza de la IA cuando recomienda opciones.',
  },
  {
    title: 'Categoría percibida',
    icon: 'category',
    tone: 'category',
    label: 'Posición',
    body: 'Cómo interpreta tu oferta, con qué competidores te compara y en qué categoría te ubica.',
  },
  {
    title: 'Operabilidad',
    icon: 'readiness',
    tone: 'operability',
    label: 'Acción',
    body: 'Si tu presencia digital está lista para ser leída, citada y usada por motores de respuesta.',
  },
] as const
const levels = [
  { key: 'found', icon: 'target', body: 'Que la IA pueda encontrarte.' },
  { key: 'readable', icon: 'read', body: 'Que la IA pueda entenderte.' },
  { key: 'correct', icon: 'validate', body: 'Que la IA pueda confiar en ti.' },
  { key: 'actionable', icon: 'act', body: 'Que la IA pueda actuar con tu info.' },
  { key: 'intrinsic', icon: 'priority', body: 'Que la IA te prefiera por defecto.' },
] as const
const footerCopyrightNotice = buildCopyrightNotice()
---

<BaseLayout
  title="Brand Visibility Grader | Efeonce Think"
  description="Solicita un análisis de Brand Visibility para ver cómo la IA entiende, cita y recomienda tu marca."
>
  <main
    class="brand-visibility-page"
    data-capture="brand-visibility-landing"
    style={`--axis-blue:${axis.accent[500]};--axis-blue-dark:${axis.accent[700]};--axis-navy:${axis.accent[900]};--axis-navy-soft:${axis.accent[800]};--axis-success:${axis.success[500]};--axis-warning:${axis.warning[500]};--axis-gray-50:${axis.gray[50]};--axis-gray-100:${axis.gray[100]};--axis-gray-200:${axis.gray[200]};--axis-gray-600:${axis.gray[600]};--axis-gray-800:${axis.gray[800]};--axis-gray-900:${axis.gray[900]};`}
  >
    <section class="hero-shell" data-capture="brand-visibility-hero" aria-labelledby="brand-visibility-title">
      <header class="topbar" aria-label="Efeonce Think">
        <a class="brand-link" href="/" aria-label="Ir a Efeonce Think">
          <img class="efeonce-mark" src="/branding/efeonce-logo-negative.svg" alt="Efeonce" />
          <span aria-hidden="true"></span>
          <img class="think-mark" src="/branding/eo-think-2.svg" alt="Think" />
        </a>
      </header>

      <div class="hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Brand Visibility Grader</p>
          <h1 id="brand-visibility-title">
            <span>Mide cómo la IA</span>
            <span>entiende y recomienda</span>
            <span>tu marca.</span>
          </h1>
          <p class="hero-lead">
            Dejas tus datos en el formulario. Nuestro sistema analiza tu presencia,
            citabilidad y operabilidad en los principales motores de IA. Al finalizar,
            verás tu informe completo en pantalla.
          </p>

          <div class="engine-chips" data-capture="brand-visibility-signal-preview" aria-label="Motores de IA analizados">
            <p class="mini-label">Motores de IA analizados</p>
            <div class="engine-stack">
              <EngineAvatarGroup providers={engines} size="md" max={5} />
            </div>
          </div>
        </div>

        <HeroAnswerLens />
      </div>

      <BrandVisibilityFormDock />
    </section>

    <section class="framework-band" data-capture="brand-visibility-trust" aria-labelledby="framework-title">
      <h2 id="framework-title">Nuestro marco de visibilidad en 5 niveles</h2>
      <ol>
        {levels.map((level, index) => (
          <li>
            <span class={`framework-icon framework-icon-${index + 1}`} aria-hidden="true">
              <ReportIcon name={level.icon} size={18} />
            </span>
            <div>
              <strong>{LEVEL_COPY[level.key].labelEn}</strong>
              <p>{level.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <section class="preview-flow-section" data-capture="brand-visibility-report-preview" aria-labelledby="preview-title">
      <span class="capture-only" data-capture="brand-visibility-flow" aria-hidden="true"></span>
      <div class="preview-flow-grid">
        <article class="report-preview">
          <div class="section-heading">
            <div>
              <p class="section-kicker">Informe privado</p>
              <h2 id="preview-title">Qué verás en tu informe</h2>
            </div>
            <p>
              Una lectura ejecutiva para entender qué ve la IA, por qué lo ve
              y qué puedes mejorar primero.
            </p>
          </div>

          <div class="preview-module-strip">
            {previewModules.map((module) => (
              <div class="preview-module">
                <div class="preview-module-top">
                  <span class={`preview-icon preview-icon-${module.tone}`} aria-hidden="true">
                    <ReportIcon name={module.icon} size={19} />
                  </span>
                  <small>{module.label}</small>
                </div>
                <h3>{module.title}</h3>
                <p>{module.body}</p>
              </div>
            ))}
          </div>

          <div class="report-proof-row" aria-label="Características del informe">
            <p><strong>Reporte privado.</strong> El resultado queda en una ruta segura para revisión interna.</p>
            <p><strong>Sin métricas decorativas.</strong> Mostramos hallazgos cuando el análisis ya tiene evidencia.</p>
            <p><strong>Accionable.</strong> Priorizamos señales que tu equipo puede convertir en mejoras concretas.</p>
          </div>
        </article>
      </div>
    </section>

    <footer class="report-footer brand-visibility-footer" data-capture="brand-visibility-footer">
      <div class="report-footer-shell">
        <div class="report-footer-brand">
          <a href="https://efeoncepro.com" target="_blank" rel="noopener noreferrer" aria-label="Ir a efeoncepro.com">
            <img src="/branding/efeonce-logo-negative.svg" alt="Efeonce" style="height:28px;width:auto" />
          </a>
          <EfeonceSlogan color="rgba(255,255,255,0.64)" size="0.62rem" />
        </div>
        <div class="report-footer-column">
          <p class="report-footer-kicker">Propiedad intelectual</p>
          <p class="report-footer-strong">{footerCopyrightNotice}</p>
          <p>Todos los derechos reservados.</p>
        </div>
        <div class="report-footer-column report-footer-method">
          <p class="report-footer-kicker">Método de análisis</p>
          <p>
            Modelo propietario de Efeonce para leer presencia, citabilidad
            y posición competitiva en motores de respuesta.
          </p>
          <a href="https://efeoncepro.com" target="_blank" rel="noopener noreferrer" class="report-footer-link">Conoce más en efeoncepro.com</a>
        </div>
        <p class="report-footer-disclaimer">
          Lectura agregada y asistida por IA. Orienta decisiones; no garantiza posiciones,
          menciones ni resultados comerciales.
        </p>
      </div>
    </footer>
  </main>
</BaseLayout>

<style>
  .brand-visibility-page {
    --brand-form-card-radius: clamp(1rem, 1.7vw, 1.55rem);
    --brand-hero-bottom-radius: 0;
    min-height: 100vh;
    overflow-x: clip;
    background: #fff;
    color: var(--axis-gray-900);
  }

  .hero-shell {
    position: relative;
    isolation: isolate;
    overflow: visible;
    border-bottom-right-radius: var(--brand-hero-bottom-radius);
    border-bottom-left-radius: var(--brand-hero-bottom-radius);
    background: linear-gradient(160deg, var(--axis-navy-soft) 0%, var(--axis-navy) 62%, #001a33 100%);
    color: #fff;
  }

  .hero-shell::after {
    content: '';
    position: absolute;
    inset: auto 0 0;
    z-index: -1;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(76, 141, 255, 0.72), transparent);
  }

  .topbar,
  .hero-grid,
  .preview-flow-grid,
  .framework-band {
    width: min(1320px, calc(100% - 64px));
    margin-inline: auto;
  }

  .topbar {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 26px 0 0;
  }

  .brand-link {
    display: inline-grid;
    grid-template-columns: auto auto auto;
    align-items: center;
    column-gap: 0.8rem;
    color: inherit;
    text-decoration: none;
  }

  .brand-link .efeonce-mark {
    width: 150px;
    height: auto;
  }

  .brand-link > span {
    width: 1px;
    height: 2.05rem;
    background: rgba(255, 255, 255, 0.48);
  }

  .brand-link .think-mark {
    display: block;
    width: 70px;
    height: auto;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 720px) minmax(500px, 1fr);
    gap: clamp(2.4rem, 4vw, 4.2rem);
    align-items: center;
    padding: clamp(34px, 3vw, 52px) 0 clamp(220px, 18vw, 252px);
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    min-width: 0;
  }

  .eyebrow,
  .mini-label {
    font-size: 0.72rem;
    font-weight: 820;
    letter-spacing: 0.1em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(255, 179, 26, 0.34);
    border-radius: 999px;
    padding: 0.38rem 0.68rem;
    background: linear-gradient(180deg, #ffd166 0%, var(--axis-warning) 100%);
    color: #08203a;
    box-shadow:
      0 14px 34px -24px rgba(255, 179, 26, 0.95),
      inset 0 1px 0 rgba(255, 255, 255, 0.48);
  }

  .mini-label {
    color: rgba(255, 255, 255, 0.78);
  }

  .hero-copy h1 {
    max-width: 720px;
    margin: 1.28rem 0 0;
    color: #fff;
    font-size: clamp(3rem, 3.65vw, 4rem);
    font-weight: 650;
    letter-spacing: 0;
    line-height: 1.04;
    text-wrap: balance;
  }

  .hero-copy h1 span {
    display: block;
  }

  .hero-copy h1::after {
    content: '';
    display: block;
    width: 42px;
    height: 4px;
    margin-top: 1.22rem;
    border-radius: 999px;
    background: linear-gradient(90deg, #36d7c5 0%, #62f0df 100%);
    box-shadow: 0 0 22px rgba(54, 215, 197, 0.42);
  }

  .hero-lead {
    max-width: 650px;
    margin-top: 1.24rem;
    color: rgba(255, 255, 255, 0.74);
    font-size: 1.02rem;
    line-height: 1.58;
  }

  .engine-chips {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    margin-top: 1.92rem;
  }

  .engine-stack {
    display: inline-flex;
    align-items: center;
    gap: 0.86rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 999px;
    padding: 0.22rem 0.62rem 0.22rem 0.28rem;
    background: rgba(255, 255, 255, 0.048);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.07);
  }

  .engine-stack :global(.engine-avatar-group) {
    padding-block: 0;
  }

  .preview-icon,
  .framework-icon {
    display: inline-grid;
    place-items: center;
    flex: 0 0 auto;
    width: 42px;
    height: 42px;
    border: 1px solid color-mix(in srgb, currentColor 28%, transparent);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.38)),
      color-mix(in srgb, currentColor 9%, transparent);
    color: var(--axis-success);
    box-shadow:
      0 16px 34px -28px currentColor,
      inset 0 1px 0 rgba(255, 255, 255, 0.8);
  }

  .preview-icon :global(svg),
  .framework-icon :global(svg) {
    filter: drop-shadow(0 6px 10px color-mix(in srgb, currentColor 20%, transparent));
  }

  .preview-icon-citation {
    color: var(--axis-warning) !important;
  }

  .preview-icon-category {
    color: #5d7cff !important;
  }

  .preview-icon-operability {
    color: #7f64ff !important;
  }

  .preview-flow-section {
    border-bottom: 1px solid var(--axis-gray-100);
    background:
      linear-gradient(180deg, #fff 0%, rgba(246, 248, 251, 0.7) 100%);
  }

  .preview-flow-grid {
    display: block;
    padding: clamp(2rem, 4vw, 3.25rem) 0 clamp(2.7rem, 5vw, 4rem);
  }

  .report-preview {
    display: grid;
    gap: 1.2rem;
    min-width: 0;
  }

  .section-heading {
    display: grid;
    grid-template-columns: minmax(0, 0.62fr) minmax(280px, 0.38fr);
    gap: clamp(1rem, 3vw, 2rem);
    align-items: end;
  }

  .section-kicker {
    margin: 0 0 0.3rem;
    color: var(--axis-blue);
    font-size: 0.72rem;
    font-weight: 820;
    letter-spacing: 0;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .section-heading h2 {
    margin: 0;
    color: var(--axis-gray-900);
    font-size: clamp(1.22rem, 1.7vw, 1.55rem);
    font-weight: 740;
    line-height: 1.25;
  }

  .section-heading > p {
    margin: 0;
    color: var(--axis-gray-600);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .preview-module-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    overflow: clip;
    border: 1px solid var(--axis-gray-100);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.9);
    box-shadow:
      0 24px 64px -56px rgba(17, 24, 39, 0.38),
      inset 0 1px 0 rgba(255, 255, 255, 0.86);
  }

  .preview-module {
    display: grid;
    align-content: start;
    gap: 0.54rem;
    min-width: 0;
    border-left: 1px solid var(--axis-gray-100);
    padding: clamp(1rem, 2vw, 1.3rem);
  }

  .preview-module:first-child {
    border-left: 0;
  }

  .preview-module-top {
    display: flex;
    align-items: center;
    gap: 0.72rem;
  }

  .preview-module small {
    color: var(--axis-gray-600);
    font-size: 0.72rem;
    font-weight: 760;
    line-height: 1.2;
  }

  .preview-module h3 {
    margin: 0;
    color: var(--axis-gray-900);
    font-size: 0.92rem;
    font-weight: 740;
    line-height: 1.22;
  }

  .preview-module p {
    margin: 0;
    color: var(--axis-gray-600);
    font-size: 0.82rem;
    line-height: 1.48;
  }

  .report-proof-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    overflow: clip;
    border: 1px solid var(--axis-gray-100);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.72);
  }

  .report-proof-row p {
    min-width: 0;
    margin: 0;
    border-left: 1px solid var(--axis-gray-100);
    padding: 0.9rem 1rem;
    color: var(--axis-gray-600);
    font-size: 0.8rem;
    line-height: 1.45;
  }

  .report-proof-row p:first-child {
    border-left: 0;
  }

  .report-proof-row strong {
    color: var(--axis-gray-900);
    font-weight: 760;
  }

  .framework-band {
    padding: var(--brand-form-dock-clearance, clamp(9rem, 12vw, 14rem)) 0 clamp(2.25rem, 4vw, 3.25rem);
  }

  .framework-band h2 {
    margin: 0;
    text-align: center;
    color: var(--axis-gray-900);
    font-size: 1.08rem;
    font-weight: 740;
  }

  .framework-band ol {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0;
    margin: 1.15rem 0 0;
    padding: 0;
    list-style: none;
  }

  .framework-band li {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.85rem;
    min-width: 0;
    border-right: 1px solid var(--axis-gray-200);
    padding: 0 1rem;
  }

  .framework-band li:last-child {
    border-right: 0;
  }

  .framework-icon {
    width: 38px;
    height: 38px;
    margin-top: 0.06rem;
  }

  .framework-icon-1 { color: var(--axis-success); }
  .framework-icon-2 { color: var(--axis-blue); }
  .framework-icon-3 { color: var(--axis-warning); }
  .framework-icon-4 { color: #7058ff; }
  .framework-icon-5 { color: var(--axis-success); }

  .framework-band strong {
    display: block;
    color: var(--axis-gray-900);
    font-size: 0.9rem;
    line-height: 1.2;
  }

  .framework-band p {
    margin: 0.34rem 0 0;
    color: var(--axis-gray-600);
    font-size: 0.78rem;
    line-height: 1.35;
  }

  .capture-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  @media (max-width: 980px) {
    .brand-visibility-page {
      --brand-form-card-radius: 1rem;
      --brand-hero-bottom-radius: 0;
    }

    .topbar,
    .hero-grid,
    .preview-flow-grid,
    .framework-band {
      width: min(100% - 32px, 720px);
    }

    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-grid {
      padding-bottom: 1.4rem;
    }

    .framework-band {
      padding-top: 1.45rem;
    }

    .preview-module-strip,
    .framework-band ol,
    .report-proof-row,
    .section-heading {
      grid-template-columns: 1fr;
    }

    .preview-module,
    .framework-band li {
      border-right: 0;
      border-left: 0;
      border-bottom: 1px solid var(--axis-gray-100);
      padding: 0.8rem 0;
    }

    .framework-band li:last-child,
    .preview-module:last-child {
      border-bottom: 0;
    }

    .preview-module {
      border-left: 0;
    }

    .report-proof-row p,
    .report-proof-row p:first-child {
      border-left: 0;
      border-top: 1px solid var(--axis-gray-100);
    }

    .report-proof-row p:first-child {
      border-top: 0;
    }
  }

  @media (max-width: 640px) {
    .topbar {
      padding-top: 18px;
      padding-bottom: 2px;
    }

    .brand-link .efeonce-mark {
      width: 82px;
    }

    .brand-link .think-mark {
      width: 42px;
    }

    .hero-grid {
      gap: 1.5rem;
      padding: 24px 0 32px;
    }

    .hero-copy h1 {
      font-size: 2.45rem;
      line-height: 1;
    }

    .hero-lead {
      font-size: 1rem;
    }

    .engine-stack {
      align-items: center;
      border-radius: 10px;
      padding: 0.44rem 0.58rem;
    }

    .engine-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.65rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      scroll-behavior: auto !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
