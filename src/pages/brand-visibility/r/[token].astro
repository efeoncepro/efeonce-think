---
// SSR on-demand: el token se resuelve server-side, nunca se expone al browser.
export const prerender = false

import BaseLayout from '@layouts/BaseLayout.astro'
import EfeonceSlogan from '@/components/EfeonceSlogan.astro'
import EngineMark from '@/components/EngineMark.astro'
import LevelLadder from '@/components/LevelLadder.astro'
import CompetitiveBenchmark from '@/components/CompetitiveBenchmark.astro'
import { fetchPublicReport } from '@lib/report'
import { axis, severityMeta } from '@lib/report-tokens'

const { token } = Astro.params
const result = token ? await fetchPublicReport(token) : ({ status: 'not_found' } as const)

if (result.status === 'not_found') Astro.response.status = 404
if (result.status === 'rate_limited') Astro.response.status = 429
if (result.status === 'ok') Astro.response.headers.set('Cache-Control', 'public, max-age=300, s-maxage=3600')

type Sev = string
interface Level { id: string; axis: string; score: number | null; severity: Sev; status: string }
interface Dimension { label: string; score: number | null; severity: Sev; explainer?: string }
interface Rec { title: string; action?: string; severity: Sev }
interface Engine { provider: string; present: number }

const ENGINE_LABEL: Record<string, string> = {
  gemini: 'Gemini', google_ai_overview: 'Google AI Overview', google_ai_mode: 'Google AI Mode',
  chatgpt: 'ChatGPT', openai: 'ChatGPT', perplexity: 'Perplexity', copilot: 'Copilot', claude: 'Claude',
}

const ok = result.status === 'ok'
const model = ok ? (result.model as Record<string, any>) : null
const header = ok ? result.header : null

const headline = model?.headline as { frame?: string } | undefined
const gate = model?.gate as { status?: string; reason?: string; nextAction?: string } | undefined
const overallScore = typeof model?.overallScore === 'number' ? Math.round(model.overallScore) : null
const overallSeverity = (model?.overallSeverity as Sev) ?? 'sin_dato'
const perceptionScore = typeof model?.perceptionAxisScore === 'number' ? Math.round(model.perceptionAxisScore) : null
const agenticScore = typeof model?.agenticAxisScore === 'number' ? Math.round(model.agenticAxisScore) : null
const levels = (model?.levels as Level[]) ?? []
const dimensions = (model?.dimensions as Dimension[]) ?? []
const primaryGap = model?.primaryGap as { title?: string; severity?: Sev } | undefined
const recommendations = (model?.recommendations as Rec[]) ?? []
const engines = (model?.engineSnapshot as Engine[]) ?? []
const disclaimer = (model?.disclaimer as string) ?? ''

const sov = model?.competitiveSov as { competitors?: { name: string; mentions: number }[]; brandMentions?: number } | undefined
const citation = model?.citationInsight as { ownDomainShare?: number | null; findingsWithCitations?: number; findingsCitingOwnDomain?: number } | undefined
const hasBenchmark = !!(sov && (sov.competitors?.length || citation?.findingsWithCitations))

const sev = severityMeta(overallSeverity)

// Gauge glow (dirección B)
const R = 90
const CIRC = Math.PI * R
const dash = overallScore ? (overallScore / 100) * CIRC : 0
---

<BaseLayout title={`Informe de visibilidad en IA${header?.organizationName ? ` — ${header.organizationName}` : ''}`} noindex>
  {
    ok && model && (
      <article>
        {/* ══ HERO NAVY ══ */}
        <header
          class="relative overflow-hidden px-6 pt-8 pb-20"
          style={`background:linear-gradient(160deg,${axis.accent[800]} 0%,${axis.accent[900]} 62%,#001a33 100%)`}
        >
          <div class="mx-auto max-w-4xl">
            <div class="flex items-center justify-between">
              <img src="/branding/efeonce-logo-negative.svg" alt="Efeonce" style="height:26px;width:auto" />
              <span class="rounded-full px-3 py-1 text-xs font-medium" style="background:rgba(255,255,255,0.12);color:rgba(255,255,255,0.85)">
                Informe de visibilidad en IA
              </span>
            </div>

            {gate?.status === 'partial' && (
              <div class="mt-8 flex items-start gap-2.5 rounded-xl px-4 py-3 text-sm" style="background:rgba(255,255,255,0.08);color:rgba(255,255,255,0.82)">
                <span aria-hidden="true">⚠️</span>
                <p><span class="font-semibold text-white">Informe parcial.</span> {gate.reason}</p>
              </div>
            )}

            <div class="mt-12 flex flex-col items-center gap-10 sm:flex-row sm:items-center sm:justify-between">
              <div class="relative shrink-0" role="img" aria-label={`Visibilidad ${overallScore ?? 'sin dato'} de 100, ${sev.label}`}>
                <svg viewBox="0 0 220 128" style="width:260px;height:150px">
                  <path d="M 18 114 A 90 90 0 0 1 202 114" fill="none" stroke="rgba(255,255,255,0.14)" stroke-width="13" stroke-linecap="round" />
                  <path d="M 18 114 A 90 90 0 0 1 202 114" fill="none" stroke={sev.border} stroke-width="13" stroke-linecap="round" stroke-dasharray={`${dash} ${CIRC}`} style={`filter:drop-shadow(0 0 10px ${sev.border}aa)`} />
                </svg>
                <div class="absolute inset-0 flex flex-col items-center justify-end pb-2">
                  <span class="text-6xl font-semibold tabular-nums text-white">{overallScore ?? '—'}</span>
                  <span class="text-xs" style="color:rgba(255,255,255,0.6)">de 100 · líderes &gt;85</span>
                </div>
              </div>
              <div class="max-w-sm text-center sm:text-left">
                <span class="inline-block rounded-full px-3 py-1 text-xs font-semibold" style={`background:${sev.border};color:white`}>{sev.label}</span>
                <h1 class="mt-4 text-3xl font-semibold tracking-tight text-balance text-white sm:text-[2rem]">{headline?.frame}</h1>
                <p class="mt-3 text-lg font-medium" style="color:rgba(255,255,255,0.9)">{header?.organizationName}</p>
                <p class="text-sm" style="color:rgba(255,255,255,0.55)">{[header?.periodLabel, header?.reportDate].filter(Boolean).join(' · ')}</p>
              </div>
            </div>
          </div>
        </header>

        {/* Ejes flotando sobre el borde */}
        <div class="mx-auto -mt-10 max-w-4xl px-6">
          <div class="grid grid-cols-2 gap-4 rounded-2xl bg-white p-5 shadow-xl ring-1" style="--tw-ring-color:rgba(0,0,0,0.05)">
            <div class="text-center">
              <p class="text-xs" style={`color:${axis.gray[600]}`}>Percepción · ¿te mencionan?</p>
              <p class="mt-1 text-2xl font-semibold tabular-nums" style={`color:${axis.gray[900]}`}>{perceptionScore ?? '—'}<span class="text-base font-normal" style={`color:${axis.gray[400]}`}>/100</span></p>
            </div>
            <div class="text-center">
              <p class="text-xs" style={`color:${axis.gray[600]}`}>Operabilidad · ¿te usan?</p>
              <p class="mt-1 text-2xl font-semibold" style={`color:${axis.gray[400]}`}>{agenticScore ?? 'En cobertura'}</p>
            </div>
          </div>
        </div>

        <main class="mx-auto max-w-4xl px-6">
          {/* ══ 01 · EVIDENCIA POR MOTOR ══ */}
          {engines.length > 0 && (
            <section class="py-14">
              <p class="text-xs font-semibold tracking-[0.14em] uppercase" style={`color:${axis.accent[500]}`}>01 · La evidencia</p>
              <h2 class="mt-1 text-2xl font-semibold tracking-tight" style={`color:${axis.gray[900]}`}>Visibilidad por motor</h2>
              <p class="mt-1.5 text-sm" style={`color:${axis.gray[600]}`}>Menciones de tu marca detectadas en cada motor de respuesta consultado.</p>
              <div class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
                {engines.map((e) => (
                  <div class="flex items-center gap-3 rounded-2xl border p-4" style={`border-color:${axis.gray[100]}`}>
                    <EngineMark provider={e.provider} label={ENGINE_LABEL[e.provider] ?? e.provider} />
                    <span class="flex-1 font-medium" style={`color:${axis.gray[900]}`}>{ENGINE_LABEL[e.provider] ?? e.provider}</span>
                    <span class="text-sm font-medium tabular-nums" style={`color:${e.present > 0 ? axis.success[700] : axis.gray[400]}`}>
                      {e.present > 0 ? `${e.present} mención${e.present === 1 ? '' : 'es'}` : 'Sin mención'}
                    </span>
                  </div>
                ))}
              </div>
            </section>
          )}

          {/* ══ 02 · BENCHMARK DE COMPETENCIA ══ */}
          {hasBenchmark && (
            <section class="border-t py-14" style={`border-color:${axis.gray[100]}`}>
              <p class="text-xs font-semibold tracking-[0.14em] uppercase" style={`color:${axis.accent[500]}`}>02 · Dónde estás parado</p>
              <h2 class="mt-1 text-2xl font-semibold tracking-tight" style={`color:${axis.gray[900]}`}>Tú frente a tu competencia</h2>
              <p class="mt-1.5 text-sm" style={`color:${axis.gray[600]}`}>Qué parte del espacio de respuesta de la IA ocupas — y cuánto te citan como fuente.</p>
              <div class="mt-5">
                <CompetitiveBenchmark
                  brandName={header?.organizationName ?? 'Tu marca'}
                  brandMentions={sov?.brandMentions ?? 0}
                  competitors={sov?.competitors ?? []}
                  ownDomainShare={citation?.ownDomainShare ?? null}
                  findingsWithCitations={citation?.findingsWithCitations ?? 0}
                  findingsCitingOwnDomain={citation?.findingsCitingOwnDomain ?? 0}
                />
              </div>
            </section>
          )}

          {/* ══ 03 · LA ESCALERA (narrativa central) ══ */}
          {levels.length > 0 && (
            <section class="border-t py-14" style={`border-color:${axis.gray[100]}`}>
              <p class="text-xs font-semibold tracking-[0.14em] uppercase" style={`color:${axis.accent[500]}`}>03 · El framework</p>
              <h2 class="mt-1 text-2xl font-semibold tracking-tight" style={`color:${axis.gray[900]}`}>La escalera de visibilidad en IA</h2>
              <p class="mt-1.5 max-w-2xl text-sm" style={`color:${axis.gray[600]}`}>
                Existir para la IA es subir cinco peldaños: que te <strong style={`color:${axis.gray[900]}`}>encuentre</strong>, te <strong style={`color:${axis.gray[900]}`}>entienda</strong>, te <strong style={`color:${axis.gray[900]}`}>represente bien</strong>, pueda <strong style={`color:${axis.gray[900]}`}>actuar</strong> y finalmente te <strong style={`color:${axis.gray[900]}`}>prefiera</strong>. Cada peldaño se apoya en el anterior — no sirve competir arriba si la base falla.
              </p>
              <LevelLadder levels={levels} />
            </section>
          )}

          {/* ══ BRECHA + MOVIMIENTO ══ */}
          {primaryGap?.title && (
            <section class="border-t py-14" style={`border-color:${axis.gray[100]}`}>
              <p class="text-xs font-semibold tracking-[0.14em] uppercase" style={`color:${axis.accent[500]}`}>04 · Qué hacer</p>
              <h2 class="mt-1 text-2xl font-semibold tracking-tight" style={`color:${axis.gray[900]}`}>Tu brecha principal</h2>
              <div class="mt-4 rounded-2xl p-6" style={`background:${severityMeta(primaryGap.severity ?? 'critico').bg};border:1px solid ${severityMeta(primaryGap.severity ?? 'critico').border}44`}>
                <span class="rounded-full bg-white px-2.5 py-0.5 text-xs font-semibold" style={`color:${severityMeta(primaryGap.severity ?? 'critico').fg}`}>{severityMeta(primaryGap.severity ?? 'critico').label}</span>
                <p class="mt-2.5 text-xl font-semibold" style={`color:${axis.gray[900]}`}>{primaryGap.title}</p>
              </div>
              {recommendations.length > 0 && (
                <div class="mt-7">
                  <h3 class="text-sm font-semibold tracking-[0.14em] uppercase" style={`color:${axis.gray[600]}`}>El movimiento recomendado</h3>
                  <ol class="mt-4 flex flex-col gap-3">
                    {recommendations.slice(0, 4).map((rec, i) => (
                      <li class="flex gap-4 rounded-2xl border p-5" style={`border-color:${axis.gray[100]}`}>
                        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-sm font-bold text-white" style={`background:${axis.accent[500]}`}>{i + 1}</span>
                        <div>
                          <p class="font-semibold" style={`color:${axis.gray[900]}`}>{rec.title}</p>
                          {rec.action && <p class="mt-1 text-sm leading-relaxed" style={`color:${axis.gray[600]}`}>{rec.action}</p>}
                        </div>
                      </li>
                    ))}
                  </ol>
                </div>
              )}
            </section>
          )}

          {/* ══ POR QUÉ OCURRE ══ */}
          {dimensions.length > 0 && (
            <section class="border-t py-14" style={`border-color:${axis.gray[100]}`}>
              <p class="text-xs font-semibold tracking-[0.14em] uppercase" style={`color:${axis.accent[500]}`}>05 · El detalle</p>
              <h2 class="mt-1 text-2xl font-semibold tracking-tight" style={`color:${axis.gray[900]}`}>Por qué ocurre</h2>
              <p class="mt-1.5 text-sm" style={`color:${axis.gray[600]}`}>Las dimensiones técnicas detrás del puntaje. No fabricamos un número cuando no hay evidencia suficiente.</p>
              <div class="mt-5 grid gap-2 sm:grid-cols-2">
                {dimensions.map((dim) => {
                  const s = severityMeta(dim.severity)
                  return (
                    <div class="flex items-start gap-3 rounded-xl border p-4" style={`border-color:${axis.gray[100]}`}>
                      <span class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full" style={`background:${s.border}`} aria-hidden="true"></span>
                      <div class="flex-1">
                        <div class="flex items-baseline justify-between gap-3">
                          <p class="font-medium" style={`color:${axis.gray[900]}`}>{dim.label}</p>
                          <span class="text-sm tabular-nums" style={`color:${axis.gray[600]}`}>{dim.score === null ? '—' : Math.round(dim.score)}</span>
                        </div>
                        {dim.explainer && <p class="mt-0.5 text-sm" style={`color:${axis.gray[600]}`}>{dim.explainer}</p>}
                      </div>
                    </div>
                  )
                })}
              </div>
            </section>
          )}
        </main>

        {/* ══ CTA DE CONVERSIÓN (navy, bookend del hero) ══ */}
        <section class="mt-6 px-6 py-16" style={`background:linear-gradient(160deg,${axis.accent[800]} 0%,${axis.accent[900]} 100%)`}>
          <div class="mx-auto max-w-2xl text-center">
            <h2 class="text-2xl font-semibold tracking-tight text-balance text-white sm:text-3xl">
              Esta brecha se cierra. Nosotros te ayudamos a cerrarla.
            </h2>
            <p class="mx-auto mt-3 max-w-lg text-pretty" style="color:rgba(255,255,255,0.75)">
              En Efeonce hacemos que las marcas sean visibles, entendibles y recomendables para la IA. Conversemos sobre tu caso.
            </p>
            <a
              href="https://efeoncepro.com"
              class="mt-7 inline-flex items-center rounded-full bg-white px-7 py-3 text-sm font-semibold transition-transform hover:-translate-y-0.5"
              style={`color:${axis.accent[800]}`}
            >
              Conversemos sobre tu visibilidad
            </a>
          </div>
        </section>

        {/* ══ FOOTER MARCA ══ */}
        <footer class="px-6 py-10" style={`background:${axis.gray[900]}`}>
          <div class="mx-auto flex max-w-4xl flex-col items-center gap-4 text-center sm:flex-row sm:justify-between sm:text-left">
            <div class="flex flex-col items-center gap-2 sm:items-start">
              <img src="/branding/efeonce-logo-negative.svg" alt="Efeonce" style="height:22px;width:auto" />
              <EfeonceSlogan color="rgba(255,255,255,0.75)" size="1rem" />
            </div>
            <div class="text-xs" style="color:rgba(255,255,255,0.5)">
              <p>Efeonce Group SpA · efeoncepro.com</p>
              <p class="mt-1 max-w-xs">{disclaimer || 'Diagnóstico agregado y público. No garantiza posiciones ni resultados.'}</p>
            </div>
          </div>
        </footer>
      </article>
    )
  }

  {result.status === 'not_found' && (
    <main role="status" class="mx-auto flex min-h-dvh max-w-md flex-col items-center justify-center gap-4 px-6 text-center">
      <div class="flex h-14 w-14 items-center justify-center rounded-full" style={`background:${axis.gray[100]}`} aria-hidden="true"><span class="text-2xl">🔗</span></div>
      <h1 class="text-2xl font-semibold" style={`color:${axis.gray[900]}`}>Este enlace no es válido o expiró</h1>
      <p style={`color:${axis.gray[600]}`}>El informe que buscas no existe o su enlace ya venció. Puedes generar uno nuevo desde el diagnóstico.</p>
      <a href="/brand-visibility" class="mt-1 inline-flex items-center rounded-lg px-4 py-2.5 text-sm font-semibold text-white hover:opacity-90" style={`background:${axis.accent[500]}`}>Hacer un diagnóstico nuevo</a>
    </main>
  )}

  {result.status === 'rate_limited' && (
    <main role="alert" class="mx-auto flex min-h-dvh max-w-md flex-col items-center justify-center gap-3 px-6 text-center">
      <h1 class="text-2xl font-semibold" style={`color:${axis.gray[900]}`}>Demasiadas solicitudes</h1>
      <p style={`color:${axis.gray[600]}`}>Recibimos muchas solicitudes desde tu conexión. Espera unos segundos y vuelve a intentar.</p>
    </main>
  )}

  {result.status === 'error' && (
    <main role="alert" class="mx-auto flex min-h-dvh max-w-md flex-col items-center justify-center gap-3 px-6 text-center">
      <h1 class="text-2xl font-semibold" style={`color:${axis.gray[900]}`}>No pudimos cargar tu informe</h1>
      <p style={`color:${axis.gray[600]}`}>Tuvimos un problema al cargar el informe. Vuelve a intentar en unos minutos.</p>
    </main>
  )}
</BaseLayout>
