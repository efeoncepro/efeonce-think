            <div class="mt-8 grid items-center gap-7 pb-2 sm:mt-12 sm:grid-cols-[0.95fr_1.05fr] sm:gap-14">
              <div class="relative mx-auto w-full max-w-[350px] sm:max-w-[390px]" role="img" aria-label={`Visibilidad ${overallScore ?? 'sin dato'} de 100, ${sev.label}`}>
