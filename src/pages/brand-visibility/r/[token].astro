              </p>
              <div class="mt-5 flex flex-wrap items-center justify-center gap-2 text-xs font-semibold sm:justify-start">
                <EngineAvatarGroup providers={sampledProviders} size="sm" max={5} />
                <span class="inline-flex items-center gap-2 rounded-full px-3 py-2" style="background:rgba(255,255,255,0.1);color:rgba(255,255,255,0.82);border:1px solid rgba(255,255,255,0.14)">
