---
// SSR on-demand: el token se resuelve server-side, nunca se expone al browser.
export const prerender = false

import BaseLayout from '@layouts/BaseLayout.astro'
import StatusScreen from '@/components/primitives/StatusScreen.astro'
import { GREENHOUSE_API_BASE } from 'astro:env/server'
import EfeonceSlogan from '@/components/EfeonceSlogan.astro'
import EngineMark from '@/components/EngineMark.astro'
import EngineAvatarGroup from '@/components/primitives/EngineAvatarGroup.astro'
import ReportIcon from '@/components/primitives/ReportIcon.astro'
import MaturityLadder from '@/components/primitives/MaturityLadder.astro'
import CompetitiveBenchmark from '@/components/CompetitiveBenchmark.astro'
import GrowthCtaDock from '@/components/GrowthCtaDock.astro'
import { fetchPublicReport } from '@lib/report'
import { buildCopyrightNotice } from '@lib/legal'
import { axis, severityMeta, LEVEL_COPY } from '@lib/report-tokens'
import type { LadderRung } from '@lib/primitives/ladder'

const { token } = Astro.params
const result = token ? await fetchPublicReport(token) : ({ status: 'not_found' } as const)

if (result.status === 'not_found') Astro.response.status = 404
if (result.status === 'rate_limited') Astro.response.status = 429
if (result.status === 'ok') Astro.response.headers.set('Cache-Control', 'public, max-age=300, s-maxage=3600')

type Sev = string
interface Level { id: string; axis: string; score: number | null; severity: Sev; status: string }
interface Dimension { label: string; score: number | null; severity: Sev; explainer?: string }
interface Rec { title: string; action?: string; severity: Sev }
interface Engine { provider: string; present: number | null; resolved: number | null }
interface SourceDomain { domain: string; count: number; engines?: string[]; classification?: string }
interface CitationSourceBreakdown { domains?: SourceDomain[]; totalCitations?: number; uniqueDomains?: number; reason?: string | null }
interface CategorySummary {
  status?: string
  categories?: { nodeId: string; level: string; label?: { es?: string; en?: string } | string; count: number }[]
  totalSignals?: number
  unmappedCount?: number
  ambiguousCount?: number
}
interface ReadinessAxis {
  axis: string
  overallScore: number | null
  severity: Sev
  coverage?: { probed: number; measured: number }
  dimensions?: { key: string; label: string; score: number | null; severity: Sev; status: string }[]
}
interface Readiness { scoreVersion?: string; structural?: ReadinessAxis; agentic?: ReadinessAxis }
interface SentimentSummary {
  positive?: number
  neutral?: number
  negative?: number
  mixed?: number
  evaluated?: number
  net?: 'positivo' | 'neutral' | 'negativo' | 'mixto' | 'sin_dato' | string
}
interface EngineCoverageProvider {
  providerId: string
  displayId: string
  label: string
  resolved: number | null
  present: number | null
  mentionRate: number | null
  status: string
}
interface ViewFacts {
  engineCoverage?: {
    providers?: EngineCoverageProvider[]
    summary?: {
      roster?: number
      sampled?: number
      resolved?: number
      present?: number
      shareOfModel?: number | null
      strongestDisplayId?: string | null
      weakestMeasuredDisplayId?: string | null
    }
  }
  citationTotals?: {
    totalCitations?: number
    uniqueDomains?: number
    ownDomainShare?: number | null
    ownDomain?: number | null
    competitor?: number | null
    thirdParty?: number | null
    ugc?: number | null
  }
  competitiveBenchmark?: {
    totalMentions?: number
    brandShare?: number | null
    brandRank?: number | null
    leaderName?: string | null
    leaderMentions?: number | null
    leaderGap?: number | null
    nextGap?: number | null
    leaderMultiple?: number | null
    rows?: { name: string; mentions: number; rank: number; isBrand: boolean; deltaVsBrand: number; sharePct: number | null }[]
  }
  sentimentFacts?: SentimentSummary
  readinessSummary?: {
    structuralScore?: number | null
    agenticScore?: number | null
    actionGap?: number | null
    structuralCoverage?: { measured: number; probed: number } | null
    agenticCoverage?: { measured: number; probed: number } | null
  }
  dimensionHighlights?: {
    strengths?: { key: string; label: string; score: number }[]
    critical?: { key: string; label: string; score: number }[]
    unmeasured?: { key: string; label: string }[]
  }
  shareFacts?: {
    reportUrl?: string | null
    graderUrl?: string
    scoreText?: string
    shareOfModelText?: string
    citabilityText?: string
    providersText?: string
  }
}

const ENGINE_LABEL: Record<string, string> = {
  gemini: 'Gemini', google_ai_overview: 'Google AI Overview', google_ai_mode: 'Google AI Mode',
  chatgpt: 'ChatGPT', openai: 'ChatGPT', perplexity: 'Perplexity', copilot: 'Copilot', claude: 'Claude',
}

const ok = result.status === 'ok'
const model = ok ? (result.model as Record<string, any>) : null
const viewFacts = (model?.viewFacts as ViewFacts | undefined) ?? null
const publicReport = ok ? (result.report as Record<string, any> | null | undefined) : null
const header = ok ? result.header : null
const organizationName = header?.organizationName ?? 'tu marca'
const reportDisplayId =
  (ok && typeof result.runPublicId === 'string' && result.runPublicId.trim())
    ? result.runPublicId.trim()
    : token === 'mock-token'
      ? 'EO-GRUN-1329'
      : null

const headline = model?.headline as { frame?: string } | undefined
const gate = model?.gate as { status?: string; reason?: string; nextAction?: string } | undefined
const overallScore = typeof model?.overallScore === 'number' ? Math.round(model.overallScore) : null
const overallSeverity = (model?.overallSeverity as Sev) ?? 'sin_dato'
const perceptionScore = typeof model?.perceptionAxisScore === 'number' ? Math.round(model.perceptionAxisScore) : null
const agenticScore = typeof model?.agenticAxisScore === 'number' ? Math.round(model.agenticAxisScore) : null
const levels = (model?.levels as Level[]) ?? []
const dimensions = (model?.dimensions as Dimension[]) ?? []
const primaryGap = model?.primaryGap as { title?: string; severity?: Sev } | undefined
const recommendations = (model?.recommendations as Rec[]) ?? []

// Adapter: modelo del grader (Level[] + LEVEL_COPY) → contrato de la primitiva MaturityLadder.
// Ordena 01→N y marca el primer peldaño no-óptimo como "tu próximo nivel".
const orderedLevels = [...levels].sort(
  (a, b) => Number(LEVEL_COPY[a.id]?.ordinal ?? '99') - Number(LEVEL_COPY[b.id]?.ordinal ?? '99'),
)
const nextLevelIdx = orderedLevels.findIndex((l) => l.severity !== 'optimo')
const ladderRungs: LadderRung[] = orderedLevels.map((lvl, i) => {
  const copy = LEVEL_COPY[lvl.id] ?? { ordinal: '', label: lvl.id, labelEn: '', tier: '', result: '', desc: '', question: '' }
  const measured = lvl.status === 'measured' && lvl.score !== null
  return {
    ordinal: copy.ordinal,
    eyebrow: copy.labelEn,
    label: copy.label,
    caption: copy.question,
    score: measured ? (lvl.score as number) : null,
    severity: lvl.severity,
    isNext: i === nextLevelIdx,
  }
})
const coverageLevelCount = orderedLevels.filter((lvl) => lvl.status !== 'measured' || lvl.score === null).length
const engines = (model?.engineSnapshot as Engine[]) ?? []
const provenance = model?.provenance as { providersSampled?: string[]; promptCount?: number; asOfDate?: string; scoreVersion?: string; promptPackVersion?: string } | undefined
const sourceBreakdown = (model?.citationSourceBreakdown as CitationSourceBreakdown | undefined) ?? null
const topSourceDomains = (sourceBreakdown?.domains ?? []).slice(0, 6)
const categorySummary = (model?.categoryTaxonomySummary as CategorySummary | undefined) ?? null
const rawCategoryStatus = typeof categorySummary?.status === 'string' ? categorySummary.status : 'unknown'
const normalizeSignalCount = (value: unknown) => {
  if (typeof value !== 'number' || !Number.isFinite(value)) return 0
  return Math.max(0, Math.floor(value))
}
const rawCategoryRows = Array.isArray(categorySummary?.categories) ? categorySummary.categories : []
const categoryRows =
  rawCategoryStatus === 'mapped'
    ? rawCategoryRows
        .map((cat) => ({ ...cat, count: normalizeSignalCount(cat.count) }))
        .filter((cat) => cat.count > 0)
        .slice(0, 5)
    : []
const categorySignalRowsTotal = categoryRows.reduce((sum, cat) => sum + cat.count, 0)
const categorySignalTotalFromPayload = normalizeSignalCount(categorySummary?.totalSignals)
const categorySignalTotal = categorySignalTotalFromPayload > 0 ? categorySignalTotalFromPayload : categorySignalRowsTotal
const categoryStatus = rawCategoryStatus === 'mapped' && categoryRows.length === 0 ? 'unknown' : rawCategoryStatus
const readiness = (model?.readiness as Readiness | null | undefined) ?? null
const readinessAxes = [readiness?.agentic, readiness?.structural].filter((axis): axis is ReadinessAxis => !!axis)
const sentimentFromPayload = (model?.sentimentSummary ?? publicReport?.sentimentSummary) as SentimentSummary | undefined
const sentiment =
  viewFacts?.sentimentFacts ??
  sentimentFromPayload ??
  (token === 'mock-token'
    ? ({ positive: 13, neutral: 7, mixed: 3, negative: 2, evaluated: 25, net: 'positivo' } satisfies SentimentSummary)
    : ({ positive: 0, neutral: 0, negative: 0, mixed: 0, evaluated: 0, net: 'sin_dato' } satisfies SentimentSummary))
const disclaimer = (model?.disclaimer as string) ?? ''

const normalizeProvider = (provider: string) => {
  if (provider === 'openai') return 'chatgpt'
  if (provider === 'anthropic') return 'claude'
  return provider
}
const engineCoverageProviders = viewFacts?.engineCoverage?.providers ?? null
const allEngines = engineCoverageProviders
  ? engineCoverageProviders.map((engine) => ({
      provider: engine.displayId,
      label: engine.label,
      present: engine.present,
      resolved: engine.resolved,
      mentionRate: engine.mentionRate,
      status: engine.status,
    }))
  : engines.map((engine) => ({ provider: normalizeProvider(engine.provider), label: ENGINE_LABEL[normalizeProvider(engine.provider)] ?? engine.provider, present: engine.present, resolved: engine.resolved, mentionRate: engine.resolved ? Math.round(((engine.present ?? 0) / engine.resolved) * 100) : null, status: engine.resolved === null ? 'not_sampled' : engine.resolved === 0 ? 'no_response' : (engine.present ?? 0) > 0 ? 'measured_with_mentions' : 'measured_without_mentions' }))

const sov = model?.competitiveSov as { competitors?: { name: string; mentions: number }[]; brandMentions?: number } | undefined
const citation = model?.citationInsight as { ownDomainShare?: number | null; findingsWithCitations?: number; findingsCitingOwnDomain?: number } | undefined
const benchmarkFacts = viewFacts?.competitiveBenchmark ?? null
const citationTotals = viewFacts?.citationTotals ?? null
const hasBenchmark = !!(benchmarkFacts?.rows?.length || (sov && (sov.competitors?.length || citation?.findingsWithCitations)))

// Radar de dimensiones (solo medidas; sin_dato NO se plotea como 0 — honestidad dataviz).
// Nombres cortos para que las etiquetas del radar no se encimen.
const RADAR_SHORT: Record<string, string> = {
  'AI Visibility': 'Visibilidad', 'Entity Clarity': 'Claridad', 'Category Ownership': 'Categoría',
  'Competitive Share of Voice': 'SoV', 'Citation Quality': 'Citabilidad',
  'Message Alignment': 'Mensaje', 'Revenue Intent Coverage': 'Intención',
}
const DIMENSION_LABEL: Record<string, string> = {
  'AI Visibility': 'Visibilidad en IA',
  'Entity Clarity': 'Claridad de entidad',
  'Category Ownership': 'Dominio de categoría',
  'Competitive Share of Voice': 'Share of Voice (SoV)',
  'Citation Quality': 'Citabilidad',
  'Message Alignment': 'Alineación del mensaje',
  'Revenue Intent Coverage': 'Cobertura de intención comercial',
}
const dimensionLabel = (label: string) => DIMENSION_LABEL[label] ?? label
const radarDims = dimensions.filter((d) => d.score !== null).map((d) => ({ name: RADAR_SHORT[d.label] ?? d.label, score: Math.round(d.score as number) }))
const hasRadar = radarDims.length >= 3

const sev = severityMeta(overallSeverity)
const categoryLabel = (label: NonNullable<CategorySummary['categories']>[number]['label']) =>
  typeof label === 'string' ? label : label?.es ?? label?.en ?? 'Categoría detectada'
const CATEGORY_LEVEL_COPY: Record<string, { label: string; helper: string }> = {
  industry: {
    label: 'Industria',
    helper: 'Marco amplio donde la IA ubica el negocio.',
  },
  sector: {
    label: 'Sector competitivo',
    helper: 'Espacio donde la IA suele comparar a la marca.',
  },
  product_service_category: {
    label: 'Categoría de oferta',
    helper: 'Producto, servicio o línea de solución reconocida.',
  },
  use_case: {
    label: 'Caso de uso',
    helper: 'Problema o situación para la que la IA asocia la marca.',
  },
  buyer_persona: {
    label: 'Comprador asociado',
    helper: 'Perfil de comprador o usuario que aparece en la lectura.',
  },
  market: {
    label: 'Mercado',
    helper: 'Ámbito geográfico o segmento donde se interpreta la marca.',
  },
}
const categoryLevelCopy = (level?: string) =>
  CATEGORY_LEVEL_COPY[level ?? ''] ?? {
    label: 'Señal de categoría',
    helper: 'Lectura agrupada desde respuestas y fuentes citadas.',
  }
type CategoryVisualIcon = 'domain' | 'sourceMap' | 'category' | 'target' | 'market' | 'buyer' | 'sample'
const CATEGORY_LEVEL_VISUAL: Record<string, { icon: CategoryVisualIcon; bg: string; fg: string }> = {
  industry: { icon: 'domain', bg: axis.gray[100], fg: axis.gray[800] },
  sector: { icon: 'sourceMap', bg: axis.accent[500] + '14', fg: axis.accent[700] },
  product_service_category: { icon: 'category', bg: axis.success[100], fg: axis.success[700] },
  use_case: { icon: 'target', bg: axis.warning[100], fg: axis.warning[700] },
  buyer_persona: { icon: 'buyer', bg: axis.gray[100], fg: axis.gray[800] },
  market: { icon: 'market', bg: axis.accent[500] + '14', fg: axis.accent[700] },
}
const categoryLevelVisual = (level?: string) =>
  CATEGORY_LEVEL_VISUAL[level ?? ''] ?? { icon: 'sample' as const, bg: axis.gray[100], fg: axis.gray[800] }
const CATEGORY_STATUS_COPY: Record<string, { label: string; title: string; helper: string; tone: { bg: string; fg: string } }> = {
  mapped: {
    label: 'Categoría medida',
    title: 'La IA ya deja una lectura de categoría publicable',
    helper: 'El diagnóstico encontró lecturas de categoría suficientes para explicar cómo los motores encuadran la marca.',
    tone: { bg: axis.success[100], fg: axis.success[700] },
  },
  unknown: {
    label: 'En cobertura',
    title: 'Este corte no trae categoría medible',
    helper: 'El diagnóstico no recibió señales verificables de industria, sector, oferta, mercado o comprador para este run. No inferimos una etiqueta desde la industria declarada, el sitio o la estrategia.',
    tone: { bg: axis.gray[100], fg: axis.gray[600] },
  },
  needs_review: {
    label: 'Revisión requerida',
    title: 'Hay señales, pero no son publicables todavía',
    helper: 'El diagnóstico detectó señales de categoría que no alcanzan una clasificación confiable. Se muestran como cobertura, no como diagnóstico.',
    tone: { bg: axis.warning[100], fg: axis.warning[700] },
  },
}
const categoryStatusCopy = CATEGORY_STATUS_COPY[categoryStatus] ?? CATEGORY_STATUS_COPY.unknown
const CATEGORY_COVERAGE_LENSES = [
  {
    title: 'Industria y sector',
    helper: 'Dónde ubican los motores a la marca dentro del mercado amplio y competitivo.',
    levels: 'Industria · Sector',
  },
  {
    title: 'Oferta y caso de uso',
    helper: 'Qué producto, servicio o problema asocian con la marca cuando la mencionan.',
    levels: 'Oferta · Caso de uso',
  },
  {
    title: 'Mercado y comprador',
    helper: 'Para qué mercado o perfil de comprador aparece la marca en la lectura.',
    levels: 'Mercado · Comprador',
  },
]
const primaryCategory = categoryRows[0] ?? null
const primaryCategoryName = primaryCategory ? categoryLabel(primaryCategory.label) : 'Categoría en revisión'
const primaryCategoryLevel = categoryLevelCopy(primaryCategory?.level)
const categorySignalLabel = (count: number) => `${count} señal${count === 1 ? '' : 'es'}`
const showCategorySection = Boolean(categorySummary)
const categoryReviewSignalCount =
  normalizeSignalCount(categorySummary?.ambiguousCount) + normalizeSignalCount(categorySummary?.unmappedCount)
const sourceClassLabel: Record<string, string> = {
  own_domain: 'Sitio propio',
  competitor: 'Competidor',
  third_party: 'Tercero',
  ugc: 'UGC/comunidad'
}
const sourceClassTone = (classification?: string) => {
  switch (classification) {
    case 'own_domain':
      return { bg: axis.success[100], fg: axis.success[700] }
    case 'competitor':
      return { bg: axis.error[100], fg: axis.error[700] }
    case 'ugc':
      return { bg: axis.warning[100], fg: axis.warning[700] }
    default:
      return { bg: axis.gray[100], fg: axis.gray[800] }
  }
}

const findDimension = (label: string) => dimensions.find((d) => d.label === label)
const entityClarity = findDimension('Entity Clarity')
const categoryOwnership = findDimension('Category Ownership')
const citationQuality = findDimension('Citation Quality')
const strongDimensions = viewFacts?.dimensionHighlights?.strengths ?? dimensions
  .filter((d) => d.score !== null && d.severity === 'optimo')
  .map((d) => ({ ...d, score: Math.round(d.score as number) }))
const criticalDimensions = viewFacts?.dimensionHighlights?.critical ?? dimensions
  .filter((d) => d.score !== null && d.severity === 'critico')
  .map((d) => ({ ...d, score: Math.round(d.score as number) }))
const unmeasuredDimensions = viewFacts?.dimensionHighlights?.unmeasured ?? dimensions.filter((d) => d.score === null)
const partialReason =
  gate?.status === 'partial'
    ? 'Puntaje calculado con los motores que respondieron; la capacidad de acción sigue en revisión.'
    : null

const resolvedTotal = viewFacts?.engineCoverage?.summary?.resolved ?? allEngines.reduce((sum, engine) => sum + (engine.resolved ?? 0), 0)
const presentTotal = viewFacts?.engineCoverage?.summary?.present ?? allEngines.reduce((sum, engine) => sum + (engine.present ?? 0), 0)
const measuredEngineCount = viewFacts?.engineCoverage?.summary?.sampled ?? allEngines.filter((engine) => engine.resolved !== null).length
const engineRosterCount = viewFacts?.engineCoverage?.summary?.roster ?? allEngines.length
const engineEvidenceRate = viewFacts?.engineCoverage?.summary?.shareOfModel ?? (resolvedTotal > 0 ? Math.round((presentTotal / resolvedTotal) * 100) : null)
const ownDomainCitations = citationTotals?.ownDomain ?? topSourceDomains
  .filter((source) => source.classification === 'own_domain')
  .reduce((sum, source) => sum + source.count, 0)
const totalCitations = citationTotals?.totalCitations ?? sourceBreakdown?.totalCitations ?? topSourceDomains.reduce((sum, source) => sum + source.count, 0)
const ownDomainSharePct = citationTotals?.ownDomainShare ?? (totalCitations > 0 ? Math.round((ownDomainCitations / totalCitations) * 100) : null)
const dependencyRiskInCoverage = citationTotals && (citationTotals.thirdParty === null || citationTotals.competitor === null || citationTotals.ugc === null)
const thirdPartyCitationCount = (citationTotals?.thirdParty ?? null) === null && (citationTotals?.ugc ?? null) === null
  ? topSourceDomains
      .filter((source) => source.classification === 'third_party' || source.classification === 'ugc')
      .reduce((sum, source) => sum + source.count, 0)
  : (citationTotals?.thirdParty ?? 0) + (citationTotals?.ugc ?? 0)
const competitorCitationCount = citationTotals?.competitor ?? topSourceDomains
  .filter((source) => source.classification === 'competitor')
  .reduce((sum, source) => sum + source.count, 0)
const agenticCoverageText = viewFacts?.readinessSummary?.agenticCoverage
  ? `${viewFacts.readinessSummary.agenticCoverage.measured}/${viewFacts.readinessSummary.agenticCoverage.probed}`
  : readiness?.agentic?.coverage
  ? `${readiness.agentic.coverage.measured}/${readiness.agentic.coverage.probed}`
  : '—'
const agenticReadiness = readiness?.agentic ?? readinessAxes.find((readinessAxis) => readinessAxis.axis === 'agentic')
const structuralReadiness = readiness?.structural ?? readinessAxes.find((readinessAxis) => readinessAxis.axis === 'structural')
const agenticReadinessScore = viewFacts?.readinessSummary?.agenticScore ?? agenticReadiness?.overallScore ?? null
const structuralReadinessScore = viewFacts?.readinessSummary?.structuralScore ?? structuralReadiness?.overallScore ?? null
const readinessActionGap = viewFacts?.readinessSummary?.actionGap ?? (
  agenticReadinessScore !== null && structuralReadinessScore !== null
    ? Math.round(structuralReadinessScore - agenticReadinessScore)
    : null
)
const agenticReadinessMeta = severityMeta(agenticReadiness?.severity ?? 'sin_dato')
const structuralReadinessMeta = severityMeta(structuralReadiness?.severity ?? 'sin_dato')
const agenticCoverage = viewFacts?.readinessSummary?.agenticCoverage ?? agenticReadiness?.coverage ?? null
const structuralCoverage = viewFacts?.readinessSummary?.structuralCoverage ?? structuralReadiness?.coverage ?? null
const agenticCoverageLabel = agenticCoverage ? `${agenticCoverage.measured}/${agenticCoverage.probed}` : '—'
const structuralCoverageLabel = structuralCoverage ? `${structuralCoverage.measured}/${structuralCoverage.probed}` : '—'
const readinessGapLabel =
  readinessActionGap === null
    ? 'Brecha en cobertura'
    : readinessActionGap > 0
      ? `Brecha de acción: -${readinessActionGap} pts`
      : readinessActionGap < 0
        ? `Acción sobre base: +${Math.abs(readinessActionGap)} pts`
        : 'Base y acción alineadas'
const readinessGapTone =
  readinessActionGap === null
    ? { bg: axis.gray[100], fg: axis.gray[600], border: axis.gray[200] }
    : readinessActionGap >= 20
      ? { bg: axis.warning[100], fg: axis.warning[700], border: axis.warning[500] }
      : readinessActionGap > 0
        ? { bg: axis.gray[100], fg: axis.accent[700], border: axis.accent[500] }
        : { bg: axis.success[100], fg: axis.success[700], border: axis.success[500] }
const readinessFlow = [
  {
    label: 'Leer el sitio',
    value: structuralReadinessScore !== null ? `${structuralReadinessScore}/100` : 'En cobertura',
    detail: 'La base técnica permite interpretar estructura y contenido.',
    color: structuralReadinessMeta.border,
    icon: 'read',
  },
  {
    label: 'Validar evidencia',
    value: agenticCoverageLabel,
    detail: 'Pruebas con señal medible para que un agente pueda avanzar.',
    color: axis.accent[500],
    icon: 'validate',
  },
  {
    label: 'Ejecutar acción',
    value: agenticReadinessScore !== null ? `${agenticReadinessScore}/100` : 'En cobertura',
    detail: 'Rutas y señales para que un agente avance una tarea.',
    color: agenticReadinessMeta.border,
    icon: 'act',
  },
] as const
const sentimentCounts = {
  positive: Math.max(0, sentiment?.positive ?? 0),
  neutral: Math.max(0, sentiment?.neutral ?? 0),
  mixed: Math.max(0, sentiment?.mixed ?? 0),
  negative: Math.max(0, sentiment?.negative ?? 0),
}
const sentimentEvaluated = Math.max(
  0,
  sentiment?.evaluated ?? sentimentCounts.positive + sentimentCounts.neutral + sentimentCounts.mixed + sentimentCounts.negative,
)
const sentimentNet = (sentiment?.net ?? 'sin_dato') as NonNullable<SentimentSummary['net']>
const hasSentiment = sentimentEvaluated > 0 && sentimentNet !== 'sin_dato'
const sentimentSegments = [
  { key: 'positive', label: 'Favorables', short: '+', count: sentimentCounts.positive, color: axis.success[500], bg: axis.success[100] },
  { key: 'neutral', label: 'Neutrales', short: '=', count: sentimentCounts.neutral, color: axis.gray[600], bg: axis.gray[100] },
  { key: 'mixed', label: 'Mixtas', short: '±', count: sentimentCounts.mixed, color: axis.warning[500], bg: axis.warning[100] },
  { key: 'negative', label: 'Negativas', short: '−', count: sentimentCounts.negative, color: axis.error[500], bg: axis.error[100] },
] as const
const sentimentPct = (count: number) => sentimentEvaluated > 0 ? Math.round((count / sentimentEvaluated) * 100) : 0
const sentimentNetCopy: Record<string, { label: string; eyebrow: string; title: string; helper: string; color: string; bg: string }> = {
  positivo: {
    label: 'Positivo',
    eyebrow: 'Señal favorable',
    title: 'La IA tiende a hablar bien de la marca cuando la menciona.',
    helper: 'Hay más menciones favorables que negativas en la muestra calificada.',
    color: axis.success[700],
    bg: axis.success[100],
  },
  neutral: {
    label: 'Neutral',
    eyebrow: 'Señal descriptiva',
    title: 'La IA describe la marca sin una preferencia clara.',
    helper: 'La oportunidad está en convertir presencia neutral en preferencia y recomendación.',
    color: axis.gray[800],
    bg: axis.gray[100],
  },
  mixto: {
    label: 'Mixto',
    eyebrow: 'Señal dividida',
    title: 'La narrativa combina señales favorables, neutras o negativas.',
    helper: 'Conviene alinear fuentes, claims y casos para reducir ambigüedad.',
    color: axis.warning[700],
    bg: axis.warning[100],
  },
  negativo: {
    label: 'Negativo',
    eyebrow: 'Riesgo narrativo',
    title: 'La IA está asociando la marca a señales desfavorables.',
    helper: 'Prioriza corrección de fuentes, reputación y contenido que desambigue el posicionamiento.',
    color: axis.error[700],
    bg: axis.error[100],
  },
  sin_dato: {
    label: 'Sin dato',
    eyebrow: 'Sin muestra suficiente',
    title: 'No hubo menciones calificables para medir tono con confianza.',
    helper: 'Este estado no es negativo: significa que falta muestra evaluable.',
    color: axis.gray[600],
    bg: axis.gray[100],
  },
}
const sentimentRead = sentimentNetCopy[sentimentNet] ?? sentimentNetCopy.sin_dato
const sentimentMentionLabel = sentimentEvaluated === 1 ? 'mención' : 'menciones'
const sentimentConicStops = hasSentiment
  ? (() => {
      let cursor = 0
      return sentimentSegments
        .filter((segment) => segment.count > 0)
        .map((segment) => {
          const next = cursor + (segment.count / sentimentEvaluated) * 100
          const stop = `${segment.color} ${cursor.toFixed(2)}% ${next.toFixed(2)}%`
          cursor = next
          return stop
        })
        .join(', ')
    })()
  : `${axis.gray[100]} 0% 100%`
const sampledProviders = [...allEngines.map((engine) => engine.provider), ...(provenance?.providersSampled ?? [])]
  .map(normalizeProvider)
  .filter((provider, index, list) => provider && list.indexOf(provider) === index)
const strongestEngine = viewFacts?.engineCoverage?.summary?.strongestDisplayId
  ? allEngines.find((engine) => engine.provider === viewFacts.engineCoverage?.summary?.strongestDisplayId)
  : [...allEngines].filter((engine) => typeof engine.present === 'number' && (engine.present ?? 0) > 0).sort((a, b) => (b.present ?? 0) - (a.present ?? 0))[0]
const weakestEngine = viewFacts?.engineCoverage?.summary?.weakestMeasuredDisplayId
  ? allEngines.find((engine) => engine.provider === viewFacts.engineCoverage?.summary?.weakestMeasuredDisplayId)
  : [...allEngines].filter((engine) => typeof engine.resolved === 'number').sort((a, b) => (a.present ?? 0) - (b.present ?? 0))[0]

// Gauge glow (dirección B)
const R = 90
const CIRC = Math.PI * R
const dash = overallScore ? (overallScore / 100) * CIRC : 0
const shareTitle = `Brand Visibility Snapshot — ${organizationName}`
const shareSummary =
  viewFacts?.shareFacts
    ? `${viewFacts.shareFacts.scoreText}, ${viewFacts.shareFacts.shareOfModelText} y ${viewFacts.shareFacts.citabilityText}`
    : overallScore !== null
    ? `score ${overallScore}/100, Share of Model IA ${engineEvidenceRate ?? '—'}% y citabilidad propia ${ownDomainSharePct ?? '—'}%`
    : `Snapshot público de visibilidad IA para ${organizationName}`
const shareProvidersText = viewFacts?.shareFacts?.providersText ?? 'ChatGPT · Gemini · Claude · Perplexity · Google AI Overview'
const shareMessageTemplate = `Medí la visibilidad de mi marca en ${shareProvidersText} con el Brand Visibility Grader de Efeonce. Mi snapshot dio ${shareSummary}. Mira el informe: {{reportUrl}}. Haz el tuyo aquí: {{graderUrl}}`
const conversionLandingUrl = `${viewFacts?.shareFacts?.graderUrl ?? 'https://efeoncepro.com/aeo-2/'}?utm_source=think_report&utm_medium=owned_report&utm_campaign=ai_visibility_report&utm_content=bottom_primary_cta`
const shareReportUrl = viewFacts?.shareFacts?.reportUrl ?? null
const shareGraderUrl = viewFacts?.shareFacts?.graderUrl ?? 'https://efeoncepro.com/aeo-2/'
const meetingUrl = 'https://meetings.hubspot.com/efeoncepro/agenda-discovery?utm_source=think_report&utm_medium=owned_report&utm_campaign=ai_visibility_report&utm_content=bottom_meeting_cta'
const greenhouseApiBase = (GREENHOUSE_API_BASE || 'https://greenhouse.efeoncepro.com').replace(/\/+$/, '')
const pdfDownloadUrl = token ? `${greenhouseApiBase}/api/public/growth/ai-visibility/report/${encodeURIComponent(token)}/pdf` : null
const footerCopyrightNotice = buildCopyrightNotice()
const sectionNumbers = Object.fromEntries(
  [
    ['engine', allEngines.length > 0],
    ['benchmark', hasBenchmark],
    ['sentiment', Boolean(sentiment)],
    ['sources', topSourceDomains.length > 0 || Boolean(sourceBreakdown?.reason)],
    ['readiness', readinessAxes.some((readinessAxis) => readinessAxis.overallScore !== null)],
    ['category', showCategorySection],
    ['ladder', levels.length > 0],
    ['recommendations', Boolean(primaryGap?.title)],
    ['dimensions', dimensions.length > 0],
  ]
    .filter(([, active]) => active)
    .map(([key], index) => [key, String(index + 1).padStart(2, '0')]),
) as Record<string, string>
