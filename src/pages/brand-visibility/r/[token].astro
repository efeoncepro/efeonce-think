            </div>

            <div class="rounded-2xl p-4 shadow-2xl sm:p-5" style="background:rgba(255,255,255,0.96);border:1px solid rgba(255,255,255,0.28);box-shadow:0 24px 70px rgba(0,0,0,0.22)">
              <p class="eyebrow-sub" style={`color:${axis.accent[500]}`}>Elige cómo avanzar</p>
              <h3 class="mt-2 text-xl font-semibold text-balance" style={`color:${axis.gray[900]}`}>Mide primero. Actúa con foco después.</h3>
              <p class="mt-2 text-sm leading-relaxed" style={`color:${axis.gray[600]}`}>
                Haz tu diagnóstico completo o agenda una sesión para convertir estas brechas en prioridades comerciales, contenido y señales de autoridad.
              </p>
              <div class="mt-5 grid gap-3">
                <a
                  href={conversionLandingUrl}
                  class="press inline-flex items-center justify-center gap-2 rounded-full px-5 py-3 text-sm font-semibold text-white"
                  style={`background:${axis.accent[500]};box-shadow:0 14px 34px rgba(0,122,255,0.24)`}
                >
                  Hacer mi diagnóstico AEO
                  <span aria-hidden="true">→</span>
                </a>
                <a
                  href={meetingUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="press inline-flex items-center justify-center gap-2 rounded-full px-5 py-3 text-sm font-semibold"
                  style={`color:${axis.accent[800]};background:#fff;border:1px solid ${axis.gray[200]}`}
                >
                  <ReportIcon name="calendar" size={16} />
                  Agendar reunión
                </a>
              </div>
              <p class="mt-4 hidden text-center text-xs leading-relaxed sm:block" style={`color:${axis.gray[600]}`}>
                Sin costo inicial · sin compromiso · pensado para equipos que quieren ganar visibilidad en motores de respuesta.
              </p>
            </div>
          </div>
        </section>

        {/* ══ FOOTER MARCA ══ */}
        <footer class="report-footer">
          <div class="report-footer-shell">
            <div class="report-footer-brand">
              <a href="https://efeoncepro.com" target="_blank" rel="noopener noreferrer" aria-label="Ir a efeoncepro.com">
                <img src="/branding/efeonce-logo-negative.svg" alt="Efeonce" style="height:28px;width:auto" />
              </a>
              <EfeonceSlogan color="rgba(255,255,255,0.64)" size="0.62rem" />
            </div>
            <div class="report-footer-column">
              <p class="report-footer-kicker">Propiedad intelectual</p>
              <p class="report-footer-strong">{footerCopyrightNotice}</p>
              <p>Todos los derechos reservados.</p>
            </div>
            <div class="report-footer-column report-footer-method">
              <p class="report-footer-kicker">Método de análisis</p>
              <p>
                Modelo propietario de Efeonce para leer presencia, citabilidad
                y posición competitiva en motores de respuesta.
              </p>
              <a href="https://efeoncepro.com" target="_blank" rel="noopener noreferrer" class="report-footer-link">Conoce más en efeoncepro.com</a>
            </div>
            <p class="report-footer-disclaimer">
              {disclaimer || 'Lectura agregada y asistida por IA. Orienta decisiones; no garantiza posiciones, menciones ni resultados comerciales.'}
            </p>
          </div>
        </footer>
      </article>
    )
  }

  {result.status === 'not_found' && <StatusScreen kind="not_found" />}

  {result.status === 'rate_limited' && <StatusScreen kind="rate_limited" />}

  {result.status === 'error' && <StatusScreen kind="error" />}

  <script>
    import gsap from 'gsap'
    import * as echarts from 'echarts/core'
    import { RadarChart } from 'echarts/charts'
    import { TooltipComponent } from 'echarts/components'
    import { CanvasRenderer } from 'echarts/renderers'

    echarts.use([RadarChart, TooltipComponent, CanvasRenderer])

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    const arrivedFromAnalysisLoader = (() => {
      try {
        const raw = window.sessionStorage.getItem('brandVisibilityReportArrival')
        if (!raw) return false
        window.sessionStorage.removeItem('brandVisibilityReportArrival')
        const payload = JSON.parse(raw) as { source?: string; at?: number }
        return payload.source === 'analysis-loader' && typeof payload.at === 'number' && Date.now() - payload.at < 30000
      } catch {
        return false
      }
    })()

    const closeSentimentInfo = () => {
      document.querySelectorAll<HTMLElement>('.sentiment-info-wrap.is-open').forEach((wrap) => {
        wrap.classList.remove('is-open')
        wrap.querySelector<HTMLButtonElement>('.sentiment-info-trigger')?.setAttribute('aria-expanded', 'false')
      })
    }

    document.querySelectorAll<HTMLElement>('.sentiment-info-wrap').forEach((wrap) => {
      const trigger = wrap.querySelector<HTMLButtonElement>('.sentiment-info-trigger')
      if (!trigger) return

      trigger.addEventListener('click', (event) => {
        event.stopPropagation()
        const shouldOpen = !wrap.classList.contains('is-open')
        closeSentimentInfo()
        wrap.classList.toggle('is-open', shouldOpen)
        trigger.setAttribute('aria-expanded', String(shouldOpen))
      })
    })

    document.addEventListener('click', (event) => {
      const target = event.target
      if (!(target instanceof Node) || !document.querySelector('.sentiment-info-wrap')?.contains(target)) {
        closeSentimentInfo()
      }
    })

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeSentimentInfo()
    })

    const copyToClipboard = async (value: string) => {
      if (!navigator.clipboard?.writeText) {
        throw new Error('Clipboard API unavailable')
      }

      await navigator.clipboard.writeText(value)
    }

    document.querySelectorAll<HTMLElement>('[data-capture="report-share"]').forEach((panel) => {
      const title = panel.dataset.shareTitle || document.title
      const template = panel.dataset.shareTemplate || ''
      const trigger = panel.querySelector<HTMLButtonElement>('[data-share-toggle]')
      const sharePanel = panel.querySelector<HTMLElement>('[data-share-panel]')
      const close = panel.querySelector<HTMLButtonElement>('[data-share-close]')
      const preview = panel.querySelector<HTMLElement>('[data-share-message-preview]')
      const shortLink = panel.querySelector<HTMLElement>('[data-share-short-link]')
      const feedback = panel.querySelector<HTMLElement>('[data-share-feedback]')
      const setFeedback = (message: string) => {
        if (feedback) feedback.textContent = message
      }
      const reportShortUrl = () => {
        if (panel.dataset.shareReportUrl) return panel.dataset.shareReportUrl
        const pathParts = window.location.pathname.split('/').filter(Boolean)
        const token = pathParts[pathParts.length - 1]
        return token ? new URL(`/r/${encodeURIComponent(token)}`, window.location.href).toString() : window.location.href
      }
      const graderUrl = () => panel.dataset.shareGraderUrl || new URL('/brand-visibility', window.location.href).toString()
      const displayUrl = (value: string) => value.replace(/^https?:\/\//, '').replace(/\/$/, '')
      const buildMessage = () => template
        .replace('{{reportUrl}}', reportShortUrl())
        .replace('{{graderUrl}}', graderUrl())
      const buildDisplayMessage = () => template
        .replace('{{reportUrl}}', displayUrl(reportShortUrl()))
        .replace('{{graderUrl}}', displayUrl(graderUrl()))
      const syncGeneratedMessage = () => {
        if (preview) preview.textContent = buildDisplayMessage()
        if (shortLink) {
          shortLink.hidden = false
          shortLink.textContent = `Enlace corto generado: ${displayUrl(reportShortUrl())}`
        }
        return buildMessage()
      }
      const nativeText = () => template
        .replace('{{reportUrl}}', 'el enlace corto del informe')
        .replace('{{graderUrl}}', 'el Brand Visibility Grader')
      const setOpen = (nextOpen: boolean) => {
        if (!trigger || !sharePanel) return

        trigger.setAttribute('aria-expanded', String(nextOpen))

        if (nextOpen) {
          syncGeneratedMessage()
          sharePanel.hidden = false
          sharePanel.removeAttribute('aria-hidden')
          requestAnimationFrame(() => {
            sharePanel.classList.add('is-open')
            sharePanel.focus({ preventScroll: true })
          })
          return
        }

        sharePanel.classList.remove('is-open')
        sharePanel.setAttribute('aria-hidden', 'true')
        window.setTimeout(() => {
          if (!sharePanel.classList.contains('is-open')) sharePanel.hidden = true
        }, reduce ? 0 : 190)
        trigger.focus({ preventScroll: true })
      }

      trigger?.addEventListener('click', (event) => {
        event.stopPropagation()
        const isOpen = trigger.getAttribute('aria-expanded') === 'true'
        setOpen(!isOpen)
      })

      close?.addEventListener('click', () => setOpen(false))

      document.addEventListener('click', (event) => {
        if (!sharePanel || sharePanel.hidden) return
        const target = event.target
        if (target instanceof Node && !panel.contains(target)) setOpen(false)
      })

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && sharePanel && !sharePanel.hidden) setOpen(false)
      })

      panel.querySelectorAll<HTMLButtonElement>('[data-share-action]').forEach((button) => {
        button.addEventListener('click', async () => {
          const action = button.dataset.shareAction

          try {
            if (action === 'native' && navigator.share) {
              await navigator.share({
                title,
                text: nativeText(),
                url: reportShortUrl(),
              })
              setFeedback('Informe listo para compartir desde tu navegador.')
              return
            }

            if (action === 'copy-link') {
              await copyToClipboard(reportShortUrl())
              setFeedback('Enlace corto copiado.')
              return
            }

            await copyToClipboard(syncGeneratedMessage())
            setFeedback(action === 'native' ? 'Mensaje copiado; tu navegador no abrió el panel de compartir.' : 'Mensaje copiado.')
          } catch {
            setFeedback('No pudimos copiar automáticamente. Usa el texto sugerido en la tarjeta.')
          }
        })
      })
    })

    // ── ECharts radar de dimensiones (chart signature animado) ──
    const radarEl = document.getElementById('dims-radar')
    if (radarEl) {
      const dims = JSON.parse(radarEl.dataset.dims || '[]') as { name: string; score: number }[]
      if (dims.length >= 3) {
        const chart = echarts.init(radarEl)
        chart.setOption({
          tooltip: {},
          radar: {
            indicator: dims.map((d) => ({ name: d.name, max: 100 })),
            radius: '62%',
            center: ['50%', '54%'],
            axisName: { color: '#6d6777', fontSize: 10.5, fontWeight: 500 },
            splitLine: { lineStyle: { color: '#eaeaec' } },
            splitArea: { areaStyle: { color: ['#ffffff', '#f7f7f8'] } },
            axisLine: { lineStyle: { color: '#eaeaec' } },
          },
          series: [
            {
              type: 'radar',
              data: [{ value: dims.map((d) => d.score), name: 'Tu marca' }],
              symbolSize: 5,
              areaStyle: { color: 'rgba(3,117,219,0.15)' },
              lineStyle: { color: '#0375db', width: 2 },
              itemStyle: { color: '#0375db' },
              animationDuration: reduce ? 0 : 900,
            },
          ],
        })
        window.addEventListener('resize', () => chart.resize())
      }
    }

    if (!reduce) {
      if (arrivedFromAnalysisLoader) {
        const reportHero = document.querySelector<HTMLElement>('[data-capture="report-hero"]')
        const readinessPanel = document.querySelector<HTMLElement>('[data-capture="report-readiness"]')
        const firstSection = document.querySelector<HTMLElement>('[data-capture="report-method"]')
        const arrival = gsap.timeline({ defaults: { ease: 'power3.out' } })

        if (reportHero) {
          arrival.fromTo(
            reportHero,
            { autoAlpha: 0, y: 18, scale: 0.992 },
            { autoAlpha: 1, y: 0, scale: 1, duration: 0.62, clearProps: 'opacity,visibility,transform' },
            0,
          )
        }

        if (readinessPanel) {
          arrival.fromTo(
            readinessPanel,
            { autoAlpha: 0, y: 24, scale: 0.985 },
            { autoAlpha: 1, y: 0, scale: 1, duration: 0.58, clearProps: 'opacity,visibility,transform' },
            0.22,
          )
        }

        if (firstSection) {
          arrival.fromTo(
            firstSection,
            { autoAlpha: 0, y: 18 },
            { autoAlpha: 1, y: 0, duration: 0.5, clearProps: 'opacity,visibility,transform' },
            0.34,
          )
        }
      }

      // ── count-up (score + eje percepción) ──
      document.querySelectorAll<HTMLElement>('[data-countup]').forEach((el) => {
        const target = parseFloat(el.dataset.countup || '')
        if (isNaN(target)) return
        const o = { v: 0 }
        gsap.to(o, { v: target, duration: 1.1, ease: 'power2.out', onUpdate: () => { el.textContent = String(Math.round(o.v)) } })
      })
      // ── gauge: el arco se dibuja ──
      const arc = document.getElementById('gauge-arc')
      if (arc) {
        const dash = parseFloat(arc.dataset.dash || '0')
        const circ = parseFloat(arc.dataset.circ || '0')
        gsap.fromTo(arc, { attr: { 'stroke-dasharray': `0 ${circ}` } }, { attr: { 'stroke-dasharray': `${dash} ${circ}` }, duration: 1.3, ease: 'power2.out' })
      }

      // ── barras que se llenan (ejes + Share of Model) ── (seguro: fin = ancho real)
      document.querySelectorAll<HTMLElement>('[data-bar]').forEach((el) => {
        gsap.from(el, { width: 0, duration: 1, ease: 'power2.out', delay: 0.2 })
      })

      // ── Sentimiento: entrada rica + microinteracción del balance ──
      document.querySelectorAll<HTMLElement>('.sentiment-panel').forEach((panel) => {
        const orb = panel.querySelector<HTMLElement>('.sentiment-orb')
        const core = panel.querySelector<HTMLElement>('.sentiment-orb-core')
        const pill = panel.querySelector<HTMLElement>('.sentiment-pill')
        const headline = panel.querySelector<HTMLElement>('.sentiment-copy h3')
        const summary = panel.querySelector<HTMLElement>('.sentiment-summary-line')
        const segments = gsap.utils.toArray<HTMLElement>(panel.querySelectorAll('.sentiment-stack-segment'))
        const stats = gsap.utils.toArray<HTMLElement>(panel.querySelectorAll('.sentiment-stat'))

        const tl = gsap.timeline({ defaults: { ease: 'power2.out' } })
        if (orb) {
          tl.fromTo(orb, { scale: 0.92, rotate: -8, opacity: 0 }, { scale: 1, rotate: 0, opacity: 1, duration: 0.7 }, 0)
        }
        if (core) tl.from(core, { y: 8, opacity: 0, duration: 0.45 }, 0.16)
        tl.from([pill, headline, summary].filter(Boolean), { y: 10, opacity: 0, duration: 0.46, stagger: 0.07 }, 0.12)
        if (segments.length) {
          tl.fromTo(segments, { scaleX: 0 }, { scaleX: 1, duration: 0.72, stagger: 0.08, ease: 'power3.out' }, 0.32)
        }
        if (stats.length) {
          tl.from(stats, { y: 14, opacity: 0, duration: 0.42, stagger: 0.055 }, 0.5)
        }

        if (orb) {
          const enter = () => gsap.to(orb, { y: -4, rotate: 2.2, scale: 1.018, duration: 0.22, ease: 'sine.out', overwrite: 'auto' })
          const leave = () => gsap.to(orb, { y: 0, rotate: 0, scale: 1, duration: 0.32, ease: 'elastic.out(1, 0.55)', overwrite: 'auto' })
          orb.addEventListener('pointerenter', enter)
          orb.addEventListener('pointerleave', leave)
          orb.addEventListener('focusin', enter)
          orb.addEventListener('focusout', leave)
        }
      })

      // (La escalera anima su propia entrada — motion self-contained en la primitiva MaturityLadder.)

      // ── reveal on-scroll sutil de cada sección (progresivo: contenido visible por defecto) ──
      const sections = gsap.utils.toArray<HTMLElement>('main section')
      if (sections.length) {
        const shown = new Set<HTMLElement>()
        const reveal = (s: HTMLElement) => {
          if (shown.has(s)) return
          shown.add(s)
          gsap.from(s, { opacity: 0, y: 18, duration: 0.5, ease: 'power2.out', immediateRender: false })
        }
        const sio = new IntersectionObserver((entries) => {
          entries.forEach((e) => { if (e.isIntersecting) { reveal(e.target as HTMLElement); sio.unobserve(e.target) } })
        }, { threshold: 0.12 })
        sections.forEach((s) => sio.observe(s))
        // fail-safe global: si algo falla, todo visible a los 4s (nunca en blanco)
        window.setTimeout(() => sections.forEach((s) => { if (!shown.has(s)) gsap.set(s, { clearProps: 'opacity,transform' }) }), 4000)
      }
    }
  </script>
</BaseLayout>
