                  <path d="M 18 114 A 90 90 0 0 1 202 114" fill="none" stroke="rgba(255,255,255,0.14)" stroke-width="15" stroke-linecap="round" />
                  <path d="M 18 114 A 90 90 0 0 1 202 114" fill="none" stroke={sev.border} stroke-width="23" stroke-linecap="round" stroke-dasharray={`${dash} ${CIRC}`} opacity="0.18" />
                  <path id="gauge-arc" data-dash={dash} data-circ={CIRC} d="M 18 114 A 90 90 0 0 1 202 114" fill="none" stroke={sev.border} stroke-width="15" stroke-linecap="round" stroke-dasharray={`${dash} ${CIRC}`} />
