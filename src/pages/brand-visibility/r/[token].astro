---
// SSR on-demand: el token se resuelve server-side, nunca se expone al browser.
export const prerender = false

import BaseLayout from '@layouts/BaseLayout.astro'
import EfeonceSlogan from '@/components/EfeonceSlogan.astro'
import EngineMark from '@/components/EngineMark.astro'
import MaturityLadder from '@/components/primitives/MaturityLadder.astro'
import CompetitiveBenchmark from '@/components/CompetitiveBenchmark.astro'
import { fetchPublicReport } from '@lib/report'
import { axis, severityMeta, LEVEL_COPY } from '@lib/report-tokens'
import type { LadderRung } from '@lib/primitives/ladder'

const { token } = Astro.params
const result = token ? await fetchPublicReport(token) : ({ status: 'not_found' } as const)

if (result.status === 'not_found') Astro.response.status = 404
if (result.status === 'rate_limited') Astro.response.status = 429
if (result.status === 'ok') Astro.response.headers.set('Cache-Control', 'public, max-age=300, s-maxage=3600')

type Sev = string
interface Level { id: string; axis: string; score: number | null; severity: Sev; status: string }
interface Dimension { label: string; score: number | null; severity: Sev; explainer?: string }
interface Rec { title: string; action?: string; severity: Sev }
interface Engine { provider: string; present: number }

const ENGINE_LABEL: Record<string, string> = {
  gemini: 'Gemini', google_ai_overview: 'Google AI Overview', google_ai_mode: 'Google AI Mode',
  chatgpt: 'ChatGPT', openai: 'ChatGPT', perplexity: 'Perplexity', copilot: 'Copilot', claude: 'Claude',
}

const ok = result.status === 'ok'
const model = ok ? (result.model as Record<string, any>) : null
const header = ok ? result.header : null
const organizationName = header?.organizationName ?? 'tu marca'

const headline = model?.headline as { frame?: string } | undefined
const gate = model?.gate as { status?: string; reason?: string; nextAction?: string } | undefined
const overallScore = typeof model?.overallScore === 'number' ? Math.round(model.overallScore) : null
const overallSeverity = (model?.overallSeverity as Sev) ?? 'sin_dato'
const perceptionScore = typeof model?.perceptionAxisScore === 'number' ? Math.round(model.perceptionAxisScore) : null
const agenticScore = typeof model?.agenticAxisScore === 'number' ? Math.round(model.agenticAxisScore) : null
const levels = (model?.levels as Level[]) ?? []
const dimensions = (model?.dimensions as Dimension[]) ?? []
const primaryGap = model?.primaryGap as { title?: string; severity?: Sev } | undefined
const recommendations = (model?.recommendations as Rec[]) ?? []

// Adapter: modelo del grader (Level[] + LEVEL_COPY) → contrato de la primitiva MaturityLadder.
// Ordena 01→N y marca el primer peldaño no-óptimo como "tu próximo nivel".
const orderedLevels = [...levels].sort(
  (a, b) => Number(LEVEL_COPY[a.id]?.ordinal ?? '99') - Number(LEVEL_COPY[b.id]?.ordinal ?? '99'),
)
const nextLevelIdx = orderedLevels.findIndex((l) => l.severity !== 'optimo')
const ladderRungs: LadderRung[] = orderedLevels.map((lvl, i) => {
  const copy = LEVEL_COPY[lvl.id] ?? { ordinal: '', label: lvl.id, labelEn: '', tier: '', result: '', desc: '', question: '' }
  const measured = lvl.status === 'measured' && lvl.score !== null
  return {
    ordinal: copy.ordinal,
    eyebrow: copy.labelEn,
    label: copy.label,
    caption: copy.question,
    score: measured ? (lvl.score as number) : null,
    severity: lvl.severity,
    isNext: i === nextLevelIdx,
  }
})
const coverageLevelCount = orderedLevels.filter((lvl) => lvl.status !== 'measured' || lvl.score === null).length
const engines = (model?.engineSnapshot as Engine[]) ?? []
const disclaimer = (model?.disclaimer as string) ?? ''

// Roster canónico de motores: siempre mostramos los 5 principales (incl. Claude). Los que
// no vinieron en el snapshot de este análisis se marcan "Sin datos" (honesto, consistente
// con el banner de informe parcial) — distinto de "Sin mención" (consultado, 0 menciones).
const ENGINE_ROSTER = ['gemini', 'chatgpt', 'claude', 'perplexity', 'google_ai_overview']
const findEngine = (p: string) => engines.find((e) => e.provider === p || (p === 'chatgpt' && e.provider === 'openai'))
const rosterEngines = ENGINE_ROSTER.map((p) => {
  const f = findEngine(p)
  return { provider: p, present: f ? f.present : null }
})
const extraEngines = engines
  .filter((e) => !ENGINE_ROSTER.includes(e.provider) && e.provider !== 'openai')
  .map((e) => ({ provider: e.provider, present: e.present }))
const allEngines = [...rosterEngines, ...extraEngines]

const sov = model?.competitiveSov as { competitors?: { name: string; mentions: number }[]; brandMentions?: number } | undefined
const citation = model?.citationInsight as { ownDomainShare?: number | null; findingsWithCitations?: number; findingsCitingOwnDomain?: number } | undefined
const hasBenchmark = !!(sov && (sov.competitors?.length || citation?.findingsWithCitations))

// Radar de dimensiones (solo medidas; sin_dato NO se plotea como 0 — honestidad dataviz).
// Nombres cortos para que las etiquetas del radar no se encimen.
const RADAR_SHORT: Record<string, string> = {
  'AI Visibility': 'Visibilidad', 'Entity Clarity': 'Claridad', 'Category Ownership': 'Categoría',
  'Competitive Share of Voice': 'Share of Voice', 'Citation Quality': 'Citas',
  'Message Alignment': 'Mensaje', 'Revenue Intent Coverage': 'Intención',
}
const radarDims = dimensions.filter((d) => d.score !== null).map((d) => ({ name: RADAR_SHORT[d.label] ?? d.label, score: Math.round(d.score as number) }))
const hasRadar = radarDims.length >= 3

const sev = severityMeta(overallSeverity)

const findDimension = (label: string) => dimensions.find((d) => d.label === label)
const entityClarity = findDimension('Entity Clarity')
const categoryOwnership = findDimension('Category Ownership')
const citationQuality = findDimension('Citation Quality')
const strongDimensions = dimensions
  .filter((d) => d.score !== null && d.severity === 'optimo')
  .map((d) => ({ ...d, score: Math.round(d.score as number) }))
const criticalDimensions = dimensions
  .filter((d) => d.score !== null && d.severity === 'critico')
  .map((d) => ({ ...d, score: Math.round(d.score as number) }))
const unmeasuredDimensions = dimensions.filter((d) => d.score === null)
const partialReason =
  gate?.status === 'partial'
    ? 'Score basado en motores que respondieron; operabilidad sigue en cobertura.'
    : null

// Gauge glow (dirección B)
const R = 90
const CIRC = Math.PI * R
const dash = overallScore ? (overallScore / 100) * CIRC : 0
---

<BaseLayout
  title={`Informe de visibilidad en IA${header?.organizationName ? ` — ${header.organizationName}` : ''}`}
  description={`Diagnóstico de la visibilidad de ${header?.organizationName ?? 'tu marca'} en los motores de IA — qué tan visible, entendible y recomendable eres para ChatGPT, Gemini, Perplexity y más.`}
  noindex
>
  {
    ok && model && (
      <article>
        {/* ══ HERO NAVY ══ */}
        <header
          class="relative overflow-hidden px-6 pt-6 pb-14 sm:pt-8 sm:pb-20"
          style={`background:linear-gradient(160deg,${axis.accent[800]} 0%,${axis.accent[900]} 62%,#001a33 100%)`}
        >
          <div class="relative mx-auto max-w-7xl">
            <div class="flex items-center justify-between gap-4">
              <img src="/branding/efeonce-logo-negative.svg" alt="Efeonce" style="height:34px;width:auto" />
              <span class="rounded-full px-3.5 py-1.5 text-xs font-medium" style="background:rgba(255,255,255,0.12);color:rgba(255,255,255,0.88)">
                Informe de visibilidad en IA
              </span>
            </div>

            {gate?.status === 'partial' && (
              <div class="mt-8 grid gap-2 rounded-xl px-4 py-3 text-sm sm:grid-cols-[auto_1fr_auto]" style="background:rgba(255,255,255,0.08);color:rgba(255,255,255,0.82)">
                <span aria-hidden="true">⚠️</span>
                <p><span class="font-semibold text-white">Informe parcial.</span> Algunos motores no respondieron — te mostramos solo lo que sí pudimos medir.</p>
                <span class="rounded-full px-2.5 py-0.5 text-xs font-semibold" style="background:rgba(255,255,255,0.11);color:rgba(255,255,255,0.86)">
                  Operabilidad en cobertura
                </span>
              </div>
            )}

            <div class="mt-8 grid items-center gap-7 pb-2 sm:mt-12 sm:grid-cols-[0.9fr_1.1fr] sm:gap-14">
              <div class="relative mx-auto w-full max-w-[300px] sm:max-w-none" role="img" aria-label={`Visibilidad ${overallScore ?? 'sin dato'} de 100, ${sev.label}`}>
                <svg viewBox="0 0 220 128" class="mx-auto" style="width:min(260px,70vw);height:auto">
                  <path d="M 18 114 A 90 90 0 0 1 202 114" fill="none" stroke="rgba(255,255,255,0.14)" stroke-width="13" stroke-linecap="round" />
                  <path id="gauge-arc" data-dash={dash} data-circ={CIRC} d="M 18 114 A 90 90 0 0 1 202 114" fill="none" stroke={sev.border} stroke-width="13" stroke-linecap="round" stroke-dasharray={`${dash} ${CIRC}`} style={`filter:drop-shadow(0 0 10px ${sev.border}aa)`} />
                </svg>
                <div class="absolute inset-0 flex flex-col items-center justify-end pb-2">
                  <span class="text-5xl font-semibold tabular-nums text-white sm:text-6xl" data-countup={overallScore ?? ''}>{overallScore ?? '—'}</span>
                  <span class="text-xs" style="color:rgba(255,255,255,0.6)">de 100 · líderes &gt;85</span>
                </div>
              </div>
              <div class="text-center sm:text-left">
                <span class="inline-block rounded-full px-3 py-1 text-xs font-semibold" style={`background:${sev.border};color:white`}>{sev.label}</span>
                <h1 class="mt-4 text-[2rem] font-semibold text-balance text-white sm:text-[2.4rem]" style="line-height:1.1">{headline?.frame}</h1>
                <p class="mt-3 text-lg font-medium" style="color:rgba(255,255,255,0.9)">{header?.organizationName}</p>
                <p class="text-sm" style="color:rgba(255,255,255,0.55)">{[header?.periodLabel, header?.reportDate].filter(Boolean).join(' · ')}</p>
                <div class="mt-5 text-left">
                  {primaryGap?.title && <p class="text-sm leading-relaxed" style="color:rgba(255,255,255,0.82)">Brecha principal: <span class="font-semibold text-white">{primaryGap.title}</span></p>}
                  <div class="mt-3 flex flex-wrap gap-2">
                    {typeof entityClarity?.score === 'number' && (
                      <span class="rounded-full px-2.5 py-1 text-xs font-semibold" style="background:rgba(255,255,255,0.12);color:rgba(255,255,255,0.88)">
                        Claridad {Math.round(entityClarity.score)}/100
                      </span>
                    )}
                    {typeof categoryOwnership?.score === 'number' && (
                      <span class="rounded-full px-2.5 py-1 text-xs font-semibold" style="background:rgba(255,255,255,0.12);color:rgba(255,255,255,0.88)">
                        Categoría {Math.round(categoryOwnership.score)}/100
                      </span>
                    )}
                    {typeof citationQuality?.score === 'number' && (
                      <span class="rounded-full px-2.5 py-1 text-xs font-semibold" style="background:rgba(255,255,255,0.12);color:rgba(255,255,255,0.88)">
                        Citas {Math.round(citationQuality.score)}/100
                      </span>
                    )}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </header>

        {/* Ejes: card que aterriza sobre la costura del hero */}
        <div class="relative z-10 mx-auto -mt-9 max-w-7xl px-6">
          <div class="report-panel grid overflow-hidden rounded-2xl bg-white shadow-xl ring-1 sm:grid-cols-2" style="--tw-ring-color:rgba(0,0,0,0.06)">
            <div class="p-5 sm:p-6">
              <div class="flex items-center justify-between gap-3">
                <p class="text-xs font-medium" style={`color:${axis.gray[600]}`}>Percepción medida · ¿te mencionan?</p>
                <span class="rounded-full px-2 py-0.5 text-[0.68rem] font-semibold" style={`background:${axis.accent[500]}16;color:${axis.accent[700]}`}>Medido</span>
              </div>
              <div class="mt-1.5 flex items-baseline gap-1">
                <span class="text-3xl font-semibold tabular-nums" style={`color:${axis.gray[900]}`} data-countup={perceptionScore ?? ''}>{perceptionScore ?? '—'}</span>
                <span class="text-base" style={`color:${axis.gray[400]}`}>/100</span>
              </div>
              <div class="mt-2.5 h-1.5 w-full overflow-hidden rounded-full" style={`background:${axis.gray[100]}`}>
                <div data-bar class="h-full rounded-full" style={`width:${perceptionScore ?? 0}%;background:${axis.accent[500]}`}></div>
              </div>
            </div>
            <div class="border-t p-5 sm:border-t-0 sm:border-l sm:p-6" style={`border-color:${axis.gray[100]}`}>
              <div class="flex items-center justify-between gap-3">
                <p class="text-xs font-medium" style={`color:${axis.gray[600]}`}>Operabilidad · ¿te pueden usar?</p>
                <span class="rounded-full px-2 py-0.5 text-[0.68rem] font-semibold" style={`background:${axis.gray[100]};color:${axis.gray[600]}`}>{agenticScore !== null ? 'Medido' : 'Cobertura'}</span>
              </div>
              {agenticScore !== null ? (
                <>
                  <div class="mt-1.5 flex items-baseline gap-1">
                    <span class="text-3xl font-semibold tabular-nums" style={`color:${axis.gray[900]}`}>{agenticScore}</span>
                    <span class="text-base" style={`color:${axis.gray[400]}`}>/100</span>
                  </div>
                  <div class="mt-2.5 h-1.5 w-full overflow-hidden rounded-full" style={`background:${axis.gray[100]}`}>
                    <div data-bar class="h-full rounded-full" style={`width:${agenticScore}%;background:${axis.accent[500]}`}></div>
                  </div>
                </>
              ) : (
                <>
                  <p class="mt-1.5 text-2xl font-semibold" style={`color:${axis.gray[400]}`}>En cobertura</p>
                  <p class="mt-1.5 text-xs" style={`color:${axis.gray[400]}`}>Aún no medido en este análisis parcial.</p>
                </>
              )}
            </div>
          </div>
          {partialReason && <p class="mt-3 text-center text-xs" style={`color:${axis.gray[600]}`}>{partialReason}</p>}
        </div>

        <main class="mx-auto max-w-7xl px-6">
          {/* ══ 01 · EVIDENCIA POR MOTOR ══ */}
          {engines.length > 0 && (
            <section class="py-16" data-capture="report-engine-visibility">
              <p class="eyebrow" style={`color:${axis.accent[500]}`}>01 · Cobertura capturada</p>
              <h2 class="section-title" style={`color:${axis.gray[900]}`}>Qué motores mencionan a {organizationName}</h2>
              <p class="section-lead" style={`color:${axis.gray[600]}`}>Separamos menciones reales, ausencia de mención y motores sin respuesta. Así el diagnóstico no confunde una consulta sin resultado con una medición que aún está en cobertura.</p>
              <div class="report-panel mt-6 overflow-hidden rounded-2xl border bg-white" style={`border-color:${axis.gray[100]}`}>
                <div class="hidden grid-cols-[1.35fr_0.85fr_1.2fr] border-b px-5 py-3 text-xs font-semibold uppercase tracking-[0.08em] sm:grid" style={`border-color:${axis.gray[100]};color:${axis.gray[600]}`}>
                  <span>Motor</span>
                  <span class="text-right">Menciones</span>
                  <span class="text-right">Estado</span>
                </div>
                <ul role="list">
                  {allEngines.map((e) => {
                    const label = ENGINE_LABEL[e.provider] ?? e.provider
                    const stateText = e.present === null ? 'Sin datos' : e.present > 0 ? 'Mención detectada' : 'Sin mención'
                    const mentionText = e.present === null ? '—' : String(e.present)
                    const stateBg = e.present === null ? axis.gray[50] : e.present > 0 ? axis.success[100] : axis.gray[100]
                    const stateColor = e.present === null ? axis.gray[600] : e.present > 0 ? axis.success[700] : axis.gray[600]
                    return (
                      <li class="data-row grid gap-3 border-b px-5 py-4 last:border-b-0 sm:grid-cols-[1.35fr_0.85fr_1.2fr] sm:items-center" style={`border-color:${axis.gray[100]}`}>
                        <div class="flex items-center gap-3">
                          <EngineMark provider={e.provider} label={label} />
                          <span class="font-semibold" style={`color:${axis.gray[900]}`}>{label}</span>
                        </div>
                        <div class="flex items-baseline justify-between gap-3 sm:block sm:text-right">
                          <span class="text-xs font-semibold uppercase tracking-[0.08em] sm:hidden" style={`color:${axis.gray[600]}`}>Menciones</span>
                          <span class="text-sm font-semibold tabular-nums" style={`color:${e.present && e.present > 0 ? axis.success[700] : axis.gray[600]}`}>{mentionText}</span>
                        </div>
                        <div class="flex justify-between gap-3 sm:justify-end">
                          <span class="text-xs font-semibold uppercase tracking-[0.08em] sm:hidden" style={`color:${axis.gray[600]}`}>Estado</span>
                          <span class="rounded-full px-2.5 py-1 text-xs font-semibold" style={`background:${stateBg};color:${stateColor}`}>{stateText}</span>
                        </div>
                      </li>
                    )
                  })}
                </ul>
              </div>
            </section>
          )}

          {/* ══ 02 · BENCHMARK DE COMPETENCIA ══ */}
          {hasBenchmark && (
            <section class="border-t py-16" style={`border-color:${axis.gray[100]}`}>
              <p class="eyebrow" style={`color:${axis.accent[500]}`}>02 · Posición competitiva</p>
              <h2 class="section-title" style={`color:${axis.gray[900]}`}>Share of voice frente al líder detectado</h2>
              <p class="section-lead" style={`color:${axis.gray[600]}`}>Contrasta las menciones de {organizationName} con las entidades competidoras y separa dos señales distintas: aparecer en la respuesta y ser citado como fuente.</p>
              <div class="mt-5">
                <CompetitiveBenchmark
                  brandName={organizationName}
                  brandMentions={sov?.brandMentions ?? 0}
                  competitors={sov?.competitors ?? []}
                  ownDomainShare={citation?.ownDomainShare ?? null}
                  findingsWithCitations={citation?.findingsWithCitations ?? 0}
                  findingsCitingOwnDomain={citation?.findingsCitingOwnDomain ?? 0}
                />
              </div>
            </section>
          )}

          {/* ══ 03 · LA ESCALERA (narrativa central) ══ */}
          {levels.length > 0 && (
            <section class="border-t py-16" style={`border-color:${axis.gray[100]}`}>
              <p class="eyebrow" style={`color:${axis.accent[500]}`}>03 · Marco de madurez</p>
              <h2 class="section-title" style={`color:${axis.gray[900]}`}>La escalera de visibilidad en IA</h2>
              <p class="section-lead max-w-3xl" style={`color:${axis.gray[600]}`}>
                El diagnóstico se ordena en cinco niveles acumulativos: <strong style={`color:${axis.gray[900]}`}>Be Found</strong>, <strong style={`color:${axis.gray[900]}`}>Readable</strong>, <strong style={`color:${axis.gray[900]}`}>Correct</strong>, <strong style={`color:${axis.gray[900]}`}>Actionable</strong> e <strong style={`color:${axis.gray[900]}`}>Intrinsic</strong>. El primer peldaño pendiente marca dónde destrabar avance antes de intentar optimizar niveles superiores.
              </p>
              {coverageLevelCount > 0 && (
                <p class="mt-3 max-w-2xl rounded-2xl border bg-white p-4 text-sm leading-relaxed" style={`border-color:${axis.gray[100]};color:${axis.gray[600]}`}>
                  Lectura parcial: {coverageLevelCount} peldaño{coverageLevelCount === 1 ? '' : 's'} en cobertura. Esos peldaños no se tratan como cero ni entran como evidencia medida.
                </p>
              )}
              <MaturityLadder rungs={ladderRungs} />
            </section>
          )}

          {/* ══ BRECHA + MOVIMIENTO ══ */}
          {primaryGap?.title && (
            <section class="deferred-report-section border-t py-16" data-capture="report-recommendations" style={`border-color:${axis.gray[100]}`}>
              <p class="eyebrow" style={`color:${axis.accent[500]}`}>04 · Prioridad operativa</p>
              <h2 class="section-title" style={`color:${axis.gray[900]}`}>La brecha que más limita el avance</h2>
              <p class="section-lead" style={`color:${axis.gray[600]}`}>El siguiente paso se ordena desde la brecha principal del modelo: primero corregir el bloqueo de base, después expandir cobertura y autoridad.</p>
              <div class="report-panel mt-4 overflow-hidden rounded-2xl border bg-white" style={`border-color:${severityMeta(primaryGap.severity ?? 'critico').border}66`}>
                <div class="p-5 sm:p-6" style={`border-left:4px solid ${severityMeta(primaryGap.severity ?? 'critico').border};background:${severityMeta(primaryGap.severity ?? 'critico').bg}`}>
                  <span class="rounded-full bg-white px-2.5 py-0.5 text-xs font-semibold" style={`color:${severityMeta(primaryGap.severity ?? 'critico').fg}`}>Prioridad · {severityMeta(primaryGap.severity ?? 'critico').label}</span>
                  <p class="mt-2 text-xl font-semibold" style={`color:${axis.gray[900]}`}>{primaryGap.title}</p>
                  <p class="mt-1 text-sm" style={`color:${axis.gray[600]}`}>Es el foco de mayor impacto dentro de este diagnóstico.</p>
                </div>
              </div>
              {recommendations.length > 0 && (
                <div class="mt-7">
                  <h3 class="eyebrow-sub" style={`color:${axis.gray[600]}`}>Secuencia recomendada</h3>
                  <ol class="report-panel mt-4 overflow-hidden rounded-2xl border bg-white" style={`border-color:${axis.gray[100]}`}>
                    {recommendations.slice(0, 4).map((rec, i) => (
                      <li class="data-row grid grid-cols-[2.3rem_1fr] gap-4 border-b p-5 last:border-b-0" style={`border-color:${axis.gray[100]}`}>
                        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-sm font-bold text-white" style={`background:${axis.accent[500]}`} aria-hidden="true">{i + 1}</span>
                        <div class="max-w-[72ch]">
                          <p class="font-semibold leading-snug" style={`color:${axis.gray[900]}`}>{rec.title}</p>
                          {rec.action && <p class="mt-1.5 text-sm leading-relaxed" style={`color:${axis.gray[600]}`}>{rec.action}</p>}
                        </div>
                      </li>
                    ))}
                  </ol>
                </div>
              )}
            </section>
          )}

          {/* ══ POR QUÉ OCURRE ══ */}
          {dimensions.length > 0 && (
            <section class="deferred-report-section border-t py-16" data-capture="report-dimension-detail" style={`border-color:${axis.gray[100]}`}>
              <p class="eyebrow" style={`color:${axis.accent[500]}`}>05 · Diagnóstico técnico</p>
              <h2 id="s-detalle" class="section-title" style={`color:${axis.gray[900]}`}>Qué explica el puntaje</h2>
              <p class="section-lead" style={`color:${axis.gray[600]}`}>Resumen de fortalezas, brechas críticas y dimensiones sin evidencia suficiente. Los campos sin dato se mantienen fuera del cálculo visual.</p>
              {(strongDimensions.length > 0 || criticalDimensions.length > 0 || unmeasuredDimensions.length > 0) && (
                <div class="report-panel mt-5 overflow-hidden rounded-2xl border bg-white sm:grid sm:grid-cols-3" style={`border-color:${axis.gray[100]}`}>
                  {strongDimensions.length > 0 && (
                    <div class="border-b p-4 sm:border-b-0 sm:border-r" style={`border-color:${axis.gray[100]}`}>
                      <p class="text-xs font-semibold uppercase tracking-[0.12em]" style={`color:${axis.success[700]}`}>Fortalezas</p>
                      <p class="mt-2 text-sm leading-relaxed" style={`color:${axis.gray[600]}`}>{strongDimensions.map((d) => `${d.label} ${d.score}`).join(' · ')}</p>
                    </div>
                  )}
                  {criticalDimensions.length > 0 && (
                    <div class="border-b p-4 sm:border-b-0 sm:border-r" style={`border-color:${axis.gray[100]}`}>
                      <p class="text-xs font-semibold uppercase tracking-[0.12em]" style={`color:${axis.error[700]}`}>Brechas críticas</p>
                      <p class="mt-2 text-sm leading-relaxed" style={`color:${axis.gray[600]}`}>{criticalDimensions.map((d) => `${d.label} ${d.score}`).join(' · ')}</p>
                    </div>
                  )}
                  {unmeasuredDimensions.length > 0 && (
                    <div class="p-4">
                      <p class="text-xs font-semibold uppercase tracking-[0.12em]" style={`color:${axis.gray[600]}`}>Sin evidencia suficiente</p>
                      <p class="mt-2 text-sm leading-relaxed" style={`color:${axis.gray[600]}`}>{unmeasuredDimensions.map((d) => d.label).join(' · ')}</p>
                    </div>
                  )}
                </div>
              )}
              <div class="mt-5 grid gap-5 lg:grid-cols-[1fr_1.25fr] lg:items-start">
                {hasRadar && (
                  <figure class="report-panel rounded-2xl border p-4" style={`border-color:${axis.gray[100]}`}>
                    <div id="dims-radar" data-dims={JSON.stringify(radarDims)} style="width:100%;height:300px"></div>
                    <figcaption class="mt-2 text-xs leading-relaxed" style={`color:${axis.gray[600]}`}>
                      Radar de dimensiones medidas; las dimensiones sin dato no se grafican como cero.
                    </figcaption>
                  </figure>
                )}
                <div class="report-panel overflow-hidden rounded-2xl border bg-white" style={`border-color:${axis.gray[100]}`}>
                  <div class="hidden grid-cols-[1.35fr_0.45fr_0.72fr_1.5fr] gap-4 border-b px-5 py-3 text-xs font-semibold uppercase tracking-[0.08em] lg:grid" style={`border-color:${axis.gray[100]};color:${axis.gray[600]}`}>
                    <span>Dimensión</span>
                    <span class="text-right">Score</span>
                    <span>Estado</span>
                    <span>Pregunta</span>
                  </div>
                  <div>
                {dimensions.map((dim) => {
                  const s = severityMeta(dim.severity)
                  return (
                    <div class="data-row grid gap-3 border-b px-5 py-4 last:border-b-0 lg:grid-cols-[1.35fr_0.45fr_0.72fr_1.5fr] lg:items-start lg:gap-4" style={`border-color:${axis.gray[100]};border-left:3px solid ${dim.score === null ? axis.gray[200] : s.border}`}>
                      <p class="font-semibold leading-snug" style={`color:${axis.gray[900]}`}>{dim.label}</p>
                      <div class="flex items-center justify-between gap-3 lg:block lg:text-right">
                        <span class="text-xs font-semibold uppercase tracking-[0.08em] lg:hidden" style={`color:${axis.gray[600]}`}>Score</span>
                        <span class="text-xl font-semibold tabular-nums leading-none" style={`color:${dim.score === null ? axis.gray[400] : axis.gray[900]}`}>{dim.score === null ? '—' : Math.round(dim.score)}</span>
                      </div>
                      <div>
                        <span class="inline-block rounded-full px-2 py-0.5 text-xs font-semibold" style={`background:${s.bg};color:${s.fg}`}>{s.label}</span>
                      </div>
                      {dim.explainer && <p class="text-sm leading-relaxed" style={`color:${axis.gray[600]}`}>{dim.explainer}</p>}
                    </div>
                  )
                })}
                  </div>
                </div>
              </div>
            </section>
          )}
        </main>

        {/* ══ CTA DE CONVERSIÓN (navy, bookend del hero) ══ */}
        <section class="mt-6 px-6 py-10 sm:py-11" style={`background:linear-gradient(160deg,${axis.accent[800]} 0%,${axis.accent[900]} 100%);border-top:1px solid rgba(255,255,255,0.08)`}>
          <div class="mx-auto flex max-w-7xl flex-col gap-6 text-center sm:flex-row sm:items-center sm:justify-between sm:text-left">
            <div class="max-w-2xl">
              <p class="eyebrow-sub" style="color:rgba(255,255,255,0.58)">Siguiente paso</p>
              <h2 class="mt-2 text-2xl font-semibold text-balance text-white sm:text-[1.85rem]" style="line-height:1.2">
                Convierte este diagnóstico en avance medible
              </h2>
              <p class="mt-2 max-w-xl text-sm leading-relaxed text-pretty" style="color:rgba(255,255,255,0.72)">
                Transforma la brecha priorizada en un plan de mejoras, medición y contenido para que la IA te encuentre, te entienda y te recomiende con más consistencia.
              </p>
            </div>
            <a
              href="https://efeoncepro.com"
              class="press inline-flex items-center justify-center gap-2 rounded-full bg-white px-6 py-3 text-sm font-semibold sm:shrink-0"
              style={`color:${axis.accent[800]}`}
            >
              Revisar el plan de visibilidad
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </section>

        {/* ══ FOOTER MARCA ══ */}
        <footer class="px-6 py-7" style="background:#1a1b1e;border-top:1px solid rgba(255,255,255,0.05)">
          <div class="mx-auto flex max-w-7xl flex-col items-center gap-4 text-center sm:flex-row sm:justify-between sm:text-left">
            <div class="flex flex-col items-center gap-2 sm:items-start">
              <img src="/branding/efeonce-logo-negative.svg" alt="Efeonce" style="height:28px;width:auto" />
              <EfeonceSlogan color="rgba(255,255,255,0.64)" size="0.62rem" />
            </div>
            <div class="text-xs leading-relaxed" style="color:rgba(255,255,255,0.46)">
              <p>Efeonce Group SpA · efeoncepro.com</p>
              <p class="mt-1 max-w-md">{disclaimer || 'Diagnóstico agregado y público. No garantiza posiciones ni resultados.'}</p>
            </div>
          </div>
        </footer>
      </article>
    )
  }

  {result.status === 'not_found' && (
    <main role="status" class="mx-auto flex min-h-dvh max-w-md flex-col items-center justify-center gap-4 px-6 text-center">
      <div class="flex h-14 w-14 items-center justify-center rounded-full" style={`background:${axis.gray[100]}`} aria-hidden="true"><span class="text-2xl">🔗</span></div>
      <h1 class="text-2xl font-semibold" style={`color:${axis.gray[900]}`}>Este enlace no es válido o expiró</h1>
      <p style={`color:${axis.gray[600]}`}>El informe que buscas no existe o su enlace ya venció. Puedes generar uno nuevo desde el diagnóstico.</p>
      <a href="/brand-visibility" class="mt-1 inline-flex items-center rounded-lg px-4 py-2.5 text-sm font-semibold text-white hover:opacity-90" style={`background:${axis.accent[500]}`}>Hacer un diagnóstico nuevo</a>
    </main>
  )}

  {result.status === 'rate_limited' && (
    <main role="alert" class="mx-auto flex min-h-dvh max-w-md flex-col items-center justify-center gap-3 px-6 text-center">
      <h1 class="text-2xl font-semibold" style={`color:${axis.gray[900]}`}>Demasiadas solicitudes</h1>
      <p style={`color:${axis.gray[600]}`}>Recibimos muchas solicitudes desde tu conexión. Espera unos segundos y vuelve a intentar.</p>
    </main>
  )}

  {result.status === 'error' && (
    <main role="alert" class="mx-auto flex min-h-dvh max-w-md flex-col items-center justify-center gap-3 px-6 text-center">
      <h1 class="text-2xl font-semibold" style={`color:${axis.gray[900]}`}>No pudimos cargar tu informe</h1>
      <p style={`color:${axis.gray[600]}`}>Tuvimos un problema al cargar el informe. Vuelve a intentar en unos minutos.</p>
    </main>
  )}

  <script>
    import gsap from 'gsap'
    import * as echarts from 'echarts/core'
    import { RadarChart } from 'echarts/charts'
    import { TooltipComponent } from 'echarts/components'
    import { CanvasRenderer } from 'echarts/renderers'

    echarts.use([RadarChart, TooltipComponent, CanvasRenderer])

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    // ── ECharts radar de dimensiones (chart signature animado) ──
    const radarEl = document.getElementById('dims-radar')
    if (radarEl) {
      const dims = JSON.parse(radarEl.dataset.dims || '[]') as { name: string; score: number }[]
      if (dims.length >= 3) {
        const chart = echarts.init(radarEl)
        chart.setOption({
          tooltip: {},
          radar: {
            indicator: dims.map((d) => ({ name: d.name, max: 100 })),
            radius: '62%',
            center: ['50%', '54%'],
            axisName: { color: '#6d6777', fontSize: 10.5, fontWeight: 500 },
            splitLine: { lineStyle: { color: '#eaeaec' } },
            splitArea: { areaStyle: { color: ['#ffffff', '#f7f7f8'] } },
            axisLine: { lineStyle: { color: '#eaeaec' } },
          },
          series: [
            {
              type: 'radar',
              data: [{ value: dims.map((d) => d.score), name: 'Tu marca' }],
              symbolSize: 5,
              areaStyle: { color: 'rgba(3,117,219,0.15)' },
              lineStyle: { color: '#0375db', width: 2 },
              itemStyle: { color: '#0375db' },
              animationDuration: reduce ? 0 : 900,
            },
          ],
        })
        window.addEventListener('resize', () => chart.resize())
      }
    }

    if (!reduce) {
      // ── count-up (score + eje percepción) ──
      document.querySelectorAll<HTMLElement>('[data-countup]').forEach((el) => {
        const target = parseFloat(el.dataset.countup || '')
        if (isNaN(target)) return
        const o = { v: 0 }
        gsap.to(o, { v: target, duration: 1.1, ease: 'power2.out', onUpdate: () => { el.textContent = String(Math.round(o.v)) } })
      })
      // ── gauge: el arco se dibuja ──
      const arc = document.getElementById('gauge-arc')
      if (arc) {
        const dash = parseFloat(arc.dataset.dash || '0')
        const circ = parseFloat(arc.dataset.circ || '0')
        gsap.fromTo(arc, { attr: { 'stroke-dasharray': `0 ${circ}` } }, { attr: { 'stroke-dasharray': `${dash} ${circ}` }, duration: 1.3, ease: 'power2.out' })
      }

      // ── barras que se llenan (ejes + Share of Voice) ── (seguro: fin = ancho real)
      document.querySelectorAll<HTMLElement>('[data-bar]').forEach((el) => {
        gsap.from(el, { width: 0, duration: 1, ease: 'power2.out', delay: 0.2 })
      })

      // (La escalera anima su propia entrada — motion self-contained en la primitiva MaturityLadder.)

      // ── reveal on-scroll sutil de cada sección (progresivo: contenido visible por defecto) ──
      const sections = gsap.utils.toArray<HTMLElement>('main section')
      if (sections.length) {
        const shown = new Set<HTMLElement>()
        const reveal = (s: HTMLElement) => {
          if (shown.has(s)) return
          shown.add(s)
          gsap.from(s, { opacity: 0, y: 18, duration: 0.5, ease: 'power2.out', immediateRender: false })
        }
        const sio = new IntersectionObserver((entries) => {
          entries.forEach((e) => { if (e.isIntersecting) { reveal(e.target as HTMLElement); sio.unobserve(e.target) } })
        }, { threshold: 0.12 })
        sections.forEach((s) => sio.observe(s))
        // fail-safe global: si algo falla, todo visible a los 4s (nunca en blanco)
        window.setTimeout(() => sections.forEach((s) => { if (!shown.has(s)) gsap.set(s, { clearProps: 'opacity,transform' }) }), 4000)
      }
    }
  </script>
</BaseLayout>
