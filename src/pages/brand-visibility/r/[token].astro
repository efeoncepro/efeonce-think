                  <EngineAvatarGroup providers={sampledProviders} size="sm" />
                </div>
              </div>
              <div>
                <p class="inline-section-label" style={`color:${axis.gray[600]}`}><ReportIcon name="calendar" size={15} />Corte de evidencia</p>
                <p class="mt-1 text-xl font-semibold" style={`color:${axis.gray[900]}`}>{header?.reportDate ?? '—'}</p>
                <p class="mt-1 text-xs" style={`color:${axis.gray[600]}`}>snapshot público seguro</p>
              </div>
              </div>
            </div>
          </section>

          {/* ══ 01 · EVIDENCIA POR MOTOR ══ */}
          {allEngines.length > 0 && (
            <section class="py-16" data-capture="report-engine-coverage">
              <p class="eyebrow" style={`color:${axis.accent[500]}`}>{sectionNumbers.engine} · Cobertura capturada</p>
              <h2 class="section-title" style={`color:${axis.gray[900]}`}>Share of Model (SoM) por motor</h2>
              <p class="section-lead" style={`color:${axis.gray[600]}`}>El SoM muestra qué tan presente está tu marca en cada motor evaluado: menciones sobre respuestas resueltas, sin mezclar respuestas no disponibles. Así ves qué modelo ya te reconoce y dónde la señal todavía se pierde.</p>
              <div class="mt-5 grid gap-3 sm:grid-cols-3">
                <div class="report-card rounded-2xl border bg-white p-4" style={`border-color:${axis.gray[100]}`}>
                  <p class="eyebrow-sub" style={`color:${axis.gray[600]}`}>Menciones</p>
                  <p class="mt-1 text-2xl font-semibold tabular-nums" style={`color:${axis.gray[900]}`}>{presentTotal}</p>
                  <p class="mt-1 text-xs" style={`color:${axis.gray[600]}`}>sobre {resolvedTotal || '—'} respuestas resueltas</p>
                </div>
                <div class="report-card rounded-2xl border bg-white p-4" style={`border-color:${axis.gray[100]}`}>
                  <p class="eyebrow-sub" style={`color:${axis.gray[600]}`}>SoM capturado</p>
                  <p class="mt-1 text-2xl font-semibold tabular-nums" style={`color:${axis.gray[900]}`}>{engineEvidenceRate ?? '—'}{engineEvidenceRate !== null && <span class="text-sm" style={`color:${axis.gray[400]}`}>%</span>}</p>
                  <p class="mt-1 text-xs" style={`color:${axis.gray[600]}`}>presencia agregada en respuestas resueltas</p>
                </div>
                <div class="report-card rounded-2xl border bg-white p-4" style={`border-color:${axis.gray[100]}`}>
                  <p class="eyebrow-sub" style={`color:${axis.gray[600]}`}>Motores con evidencia</p>
                  <p class="mt-1 text-2xl font-semibold tabular-nums" style={`color:${axis.gray[900]}`}>{measuredEngineCount}/{engineRosterCount}</p>
                  <p class="mt-1 text-xs" style={`color:${axis.gray[600]}`}>motores con respuesta evaluable</p>
                </div>
              </div>
              <div class="report-panel mt-6 overflow-hidden rounded-2xl border bg-white" style={`border-color:${axis.gray[100]}`}>
                <div class="hidden grid-cols-[1.1fr_0.72fr_1.35fr_1fr] gap-4 border-b px-5 py-3 text-xs font-semibold uppercase tracking-[0.08em] md:grid" style={`border-color:${axis.gray[100]};color:${axis.gray[600]}`}>
                  <span>Motor</span>
                  <span class="text-right">Menciones</span>
                  <span>Cobertura</span>
                  <span class="text-right">Estado</span>
                </div>
                <ul role="list">
                  {allEngines.map((e) => {
                    const label = e.label ?? ENGINE_LABEL[e.provider] ?? e.provider
                    const presentCount = e.present ?? 0
                    const resolvedCount = e.resolved ?? 0
                    const rowRate = resolvedCount > 0 ? Math.round((presentCount / resolvedCount) * 100) : null
                    const stateText = e.resolved === null ? 'Sin datos' : e.resolved === 0 ? 'Sin respuestas evaluables' : presentCount > 0 ? 'Mención detectada' : 'Sin mención'
                    const mentionText = e.resolved === null ? '—' : `${presentCount}/${e.resolved}`
                    const stateBg = e.resolved === null || e.resolved === 0 ? axis.gray[50] : presentCount > 0 ? axis.success[100] : axis.gray[100]
                    const stateColor = e.resolved === null || e.resolved === 0 ? axis.gray[600] : presentCount > 0 ? axis.success[700] : axis.gray[600]
                    return (
                      <li class="engine-row data-row grid gap-3 border-b px-5 py-4 last:border-b-0 md:grid-cols-[1.1fr_0.72fr_1.35fr_1fr] md:items-center" style={`border-color:${axis.gray[100]}`}>
                        <div class="flex items-center gap-3">
                          <EngineMark provider={e.provider} label={label} />
                          <span class="font-semibold" style={`color:${axis.gray[900]}`}>{label}</span>
                        </div>
                        <div class="flex items-baseline justify-between gap-3 md:block md:text-right">
                          <span class="text-xs font-semibold uppercase tracking-[0.08em] md:hidden" style={`color:${axis.gray[600]}`}>Menciones</span>
                          <span class="text-sm font-semibold tabular-nums" style={`color:${e.present && e.present > 0 ? axis.success[700] : axis.gray[600]}`}>{mentionText}</span>
                        </div>
                        <div class="min-w-0">
                          <div class="flex items-center justify-between gap-3 md:hidden">
                            <span class="text-xs font-semibold uppercase tracking-[0.08em]" style={`color:${axis.gray[600]}`}>Cobertura</span>
                            <span class="text-xs font-semibold tabular-nums" style={`color:${axis.gray[600]}`}>{rowRate ?? '—'}{rowRate !== null ? '%' : ''}</span>
                          </div>
                          <div class="mt-1 h-2 overflow-hidden rounded-full md:mt-0" style={`background:${axis.gray[100]}`}>
                            <div data-bar class="h-full rounded-full" style={`width:${rowRate ?? 0}%;background:${rowRate === null ? axis.gray[200] : rowRate > 0 ? axis.accent[500] : axis.gray[200]}`}></div>
                          </div>
                        </div>
                        <div class="flex justify-between gap-3 md:justify-end">
                          <span class="text-xs font-semibold uppercase tracking-[0.08em] md:hidden" style={`color:${axis.gray[600]}`}>Estado</span>
                          <span class="rounded-full px-2.5 py-1 text-xs font-semibold" style={`background:${stateBg};color:${stateColor}`}>{stateText}</span>
                        </div>
                      </li>
                    )
                  })}
                </ul>
              </div>
            </section>
          )}

          {/* ══ 02 · BENCHMARK DE COMPETENCIA ══ */}
          {hasBenchmark && (
            <section class="border-t py-16" style={`border-color:${axis.gray[100]}`}>
              <p class="eyebrow" style={`color:${axis.accent[500]}`}>{sectionNumbers.benchmark} · Posición competitiva</p>
              <h2 class="section-title" style={`color:${axis.gray[900]}`}>Share of Voice (SoV): tu cuota de conversación en IA</h2>
              <p class="section-lead" style={`color:${axis.gray[600]}`}>Después de medir en qué motores apareces, comparamos cuánto espacio ocupa tu marca frente al set competitivo: quién lidera, qué tan lejos estás y cuánta de esa visibilidad se sostiene con tu propio sitio.</p>
              <div class="mt-5">
                <CompetitiveBenchmark
                  brandName={organizationName}
                  brandMentions={sov?.brandMentions ?? 0}
                  competitors={sov?.competitors ?? []}
                  ownDomainShare={citation?.ownDomainShare ?? null}
                  findingsWithCitations={citation?.findingsWithCitations ?? 0}
                  findingsCitingOwnDomain={citation?.findingsCitingOwnDomain ?? 0}
                  benchmark={benchmarkFacts}
                />
              </div>
            </section>
          )}

          {/* ══ 03 · TONO DE MENCIÓN ══ */}
          {sentiment && (
            <section class="border-t py-16" data-capture="report-sentiment" style={`border-color:${axis.gray[100]}`}>
              <p class="eyebrow" style={`color:${axis.accent[500]}`}>{sectionNumbers.sentiment} · Tono de mención</p>
              <h2 class="section-title" style={`color:${axis.gray[900]}`}>Cómo te describen los motores cuando apareces</h2>
              <p class="section-lead" style={`color:${axis.gray[600]}`}>No basta con aparecer: importa el sentiment con que la IA habla de la marca. Mostramos el tono como agregado público, sin exponer respuestas crudas.</p>

              <div class="sentiment-panel report-panel mt-6 overflow-hidden rounded-2xl border bg-white" style={`border-color:${axis.gray[100]}`}>
                <div class="sentiment-info-wrap">
                  <button
                    class="sentiment-info-trigger"
                    type="button"
                    aria-label="Cómo se calcula el tono de mención"
                    aria-describedby="sentiment-tooltip"
                    aria-expanded="false"
                  >
                    i
                  </button>
                  <span class="sentiment-info-tip" id="sentiment-tooltip" role="tooltip">
                    <span class="sentiment-info-title">Qué mide este bloque</span>
                    <span>Clasifica las menciones evaluables hacia la marca como favorables, neutrales, mixtas o negativas. Es un agregado público: no muestra prompts, respuestas crudas ni URLs completas.</span>
                    <span class="sentiment-info-note">Si no hay menciones calificables, el bloque queda sin dato.</span>
                  </span>
                </div>
                <div class="sentiment-hero p-5 sm:p-6 lg:p-7">
                    <div class="sentiment-orb" style={`--sentiment-conic:conic-gradient(${sentimentConicStops});--sentiment-bg:${sentimentRead.bg};--sentiment-color:${sentimentRead.color}`} role="img" aria-label={`Sentimiento ${sentimentRead.label}; ${sentimentEvaluated} ${sentimentMentionLabel} calificadas`}>
                      <div class="sentiment-orb-core">
                        <span class="sentiment-orb-kicker">{hasSentiment ? 'Saldo' : 'Estado'}</span>
                        <strong>{sentimentRead.label}</strong>
                        <span>{sentimentEvaluated} {sentimentMentionLabel}</span>
                      </div>
                    </div>

                  <div class="sentiment-copy">
                    <span class="sentiment-pill" style={`background:${sentimentRead.bg};color:${sentimentRead.color}`}>{sentimentRead.eyebrow}</span>
                    <h3 style={`color:${axis.gray[900]}`}>{sentimentRead.title}</h3>
                    <p style={`color:${axis.gray[600]}`}>{sentimentRead.helper}</p>
                    <div class="sentiment-summary-line" style={`color:${axis.gray[600]}`}>
                      <span>{sentimentCounts.positive} favorables</span>
                      <span>{sentimentCounts.neutral} neutrales</span>
                      <span>{sentimentCounts.mixed} mixtas</span>
                      <span>{sentimentCounts.negative} negativas</span>
                    </div>
                  </div>
                </div>

                <div class="sentiment-breakdown border-t p-5 sm:p-6" style={`border-color:${axis.gray[100]}`}>
                  <div class="sentiment-stack" aria-hidden="true">
                    {sentimentSegments.map((segment) => (
                      <span
                        class={`sentiment-stack-segment sentiment-stack-${segment.key}`}
                        style={`--segment-width:${hasSentiment ? Math.max(segment.count > 0 ? 5 : 0, sentimentPct(segment.count)) : 0}%;--segment-color:${segment.color}`}
                      ></span>
                    ))}
                  </div>
                  <div class="mt-4 grid gap-3 md:grid-cols-4">
                    {sentimentSegments.map((segment) => (
                      <div class="sentiment-stat rounded-2xl border bg-white p-4" style={`border-color:${axis.gray[100]}`}>
                        <span class="sentiment-stat-mark" style={`background:${segment.bg};color:${segment.color}`}>{segment.short}</span>
                        <p class="mt-3 text-2xl font-semibold tabular-nums" style={`color:${axis.gray[900]}`}>{segment.count}</p>
                        <p class="mt-1 text-xs font-semibold uppercase tracking-[0.1em]" style={`color:${axis.gray[600]}`}>{segment.label}</p>
                        <p class="mt-1 text-xs" style={`color:${axis.gray[600]}`}>{sentimentPct(segment.count)}% de la muestra calificada</p>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </section>
          )}

          {/* ══ 04 · FUENTES CITADAS ══ */}
          {(topSourceDomains.length > 0 || sourceBreakdown?.reason) && (
            <section class="border-t py-16" data-capture="report-source-evidence" style={`border-color:${axis.gray[100]}`}>
              <p class="eyebrow" style={`color:${axis.accent[500]}`}>{sectionNumbers.sources} · Fuentes citadas</p>
              <h2 class="section-title" style={`color:${axis.gray[900]}`}>Mapa de citabilidad: quién alimenta la respuesta</h2>
              <p class="section-lead" style={`color:${axis.gray[600]}`}>En AEO/GEO, no solo importa que te nombren: importa qué fuentes cita la IA para sostener la respuesta. Mostramos dominios agregados, no URLs completas ni texto crudo de proveedores.</p>
              {topSourceDomains.length > 0 ? (
                <div class="report-panel mt-6 overflow-hidden rounded-2xl border bg-white" style={`border-color:${axis.gray[100]}`}>
                  <div class="grid gap-4 border-b p-5 sm:grid-cols-4" style={`border-color:${axis.gray[100]}`}>
                    <div>
                      <p class="inline-section-label" style={`color:${axis.gray[600]}`}><ReportIcon name="citation" size={15} />Citas totales</p>
                      <p class="mt-1 text-2xl font-semibold tabular-nums" style={`color:${axis.gray[900]}`}>{sourceBreakdown?.totalCitations ?? '—'}</p>
                    </div>
                    <div>
                      <p class="inline-section-label" style={`color:${axis.gray[600]}`}><ReportIcon name="domain" size={15} />Dominios únicos</p>
                      <p class="mt-1 text-2xl font-semibold tabular-nums" style={`color:${axis.gray[900]}`}>{sourceBreakdown?.uniqueDomains ?? topSourceDomains.length}</p>
                    </div>
                    <div>
                      <p class="inline-section-label" style={`color:${axis.gray[600]}`}><ReportIcon name="sourceMap" size={15} />Citabilidad propia</p>
                      <p class="mt-1 text-2xl font-semibold tabular-nums" style={`color:${axis.gray[900]}`}>{ownDomainSharePct ?? '—'}{ownDomainSharePct !== null && <span class="text-sm" style={`color:${axis.gray[400]}`}>%</span>}</p>
                    </div>
                    <div>
                      <p class="inline-section-label" style={`color:${axis.gray[600]}`}><ReportIcon name="dependency" size={15} />Riesgo de dependencia</p>
                      <p class="mt-1 text-sm leading-relaxed" style={`color:${axis.gray[600]}`}>
                        {dependencyRiskInCoverage ? 'Riesgo de dependencia: en cobertura' : `${thirdPartyCitationCount} citas de terceros · ${competitorCitationCount} de competidores.`}
                      </p>
                    </div>
                  </div>
                  <div class="source-header hidden border-b px-5 py-3 text-xs font-semibold uppercase tracking-[0.08em] lg:grid" style={`border-color:${axis.gray[100]};color:${axis.gray[600]}`}>
                    <span>Dominio</span>
                    <span>Citas capturadas</span>
                    <span>Motores</span>
                    <span class="text-right">Tipo</span>
                  </div>
                  <ul role="list">
                    {topSourceDomains.map((source) => {
                      const tone = sourceClassTone(source.classification)
                      const citationShare = totalCitations > 0 ? Math.round((source.count / totalCitations) * 100) : 0
                      const sourceEngineProviders = (source.engines ?? [])
                        .map(normalizeProvider)
                        .filter((provider, index, list) => provider && list.indexOf(provider) === index)
                      return (
                        <li class="source-row data-row grid gap-5 border-b px-5 py-5 last:border-b-0 lg:grid-cols-[minmax(12rem,0.95fr)_minmax(20rem,1.12fr)_minmax(8rem,0.52fr)_minmax(8rem,auto)] lg:items-center" style={`border-color:${axis.gray[100]}`}>
                          <div class="min-w-0">
                            <p class="truncate font-semibold" style={`color:${axis.gray[900]}`}>{source.domain}</p>
                            <p class="mt-1 text-xs tabular-nums lg:hidden" style={`color:${axis.gray[600]}`}>{source.count} citas capturadas</p>
                          </div>
                          <div class="source-share min-w-0">
                            <p class="text-sm font-semibold tabular-nums" style={`color:${axis.gray[900]}`}>{source.count} de {totalCitations || '—'} <span class="font-medium" style={`color:${axis.gray[600]}`}>· {citationShare}% de las citas</span></p>
                            <div class="source-bar-track mt-2 h-2.5 overflow-hidden rounded-full" style={`background:${axis.gray[100]}`}>
                              <div data-bar class="h-full rounded-full" style={`width:${citationShare}%;background:${tone.fg}`}></div>
                            </div>
                          </div>
                          <div class="source-engines min-w-0">
                            <span class="text-xs font-semibold uppercase tracking-[0.08em] lg:hidden" style={`color:${axis.gray[600]}`}>Motores</span>
                            <div class="mt-2 lg:mt-0">
                              {sourceEngineProviders.length > 0 ? (
                                <EngineAvatarGroup providers={sourceEngineProviders} size="sm" max={4} />
                              ) : (
                                <span class="text-sm" style={`color:${axis.gray[600]}`}>Motor no especificado</span>
                              )}
                            </div>
                          </div>
                          <p class="source-class flex justify-start lg:justify-end">
                            <span class="rounded-full px-2.5 py-1 text-xs font-semibold" style={`background:${tone.bg};color:${tone.fg}`}>{sourceClassLabel[source.classification ?? ''] ?? 'Fuente'}</span>
                          </p>
                        </li>
                      )
                    })}
                  </ul>
                </div>
              ) : (
                <div class="report-panel mt-6 rounded-2xl border bg-white p-5" style={`border-color:${axis.gray[100]}`}>
                  <p class="font-semibold" style={`color:${axis.gray[900]}`}>Sin evidencia suficiente</p>
                  <p class="mt-1 text-sm" style={`color:${axis.gray[600]}`}>Este diagnóstico no trae citas evaluables para mostrar dominios de fuente.</p>
                </div>
              )}
            </section>
          )}

          {/* ══ 05 · OPERABILIDAD ══ */}
          {readinessAxes.some((readinessAxis) => readinessAxis.overallScore !== null) && (
            <section class="border-t py-16" data-capture="report-readiness-detail" style={`border-color:${axis.gray[100]}`}>
              <p class="eyebrow" style={`color:${axis.accent[500]}`}>{sectionNumbers.readiness} · Operabilidad del sitio</p>
              <h2 class="section-title" style={`color:${axis.gray[900]}`}>Operabilidad: que el agente pueda actuar, no solo citar</h2>
              <p class="section-lead" style={`color:${axis.gray[600]}`}>Esta lectura separa presencia de capacidad de acción: aparecer en una respuesta no significa que un agente pueda usar tu sitio para avanzar una compra, contacto o validación.</p>
              <div class="readiness-diagnostic report-panel mt-6 overflow-hidden rounded-2xl border bg-white" style={`border-color:${axis.gray[100]}`}>
                <div class="readiness-diagnostic-main p-5 sm:p-6 lg:p-7">
                  <div class="flex flex-wrap items-start justify-between gap-3">
                    <div>
                      <p class="eyebrow-sub" style={`color:${axis.gray[600]}`}>Brecha de acción</p>
                      <h3 class="mt-2 text-2xl font-semibold leading-tight sm:text-3xl" style={`color:${axis.gray[900]}`}>El sitio se puede leer; todavía le cuesta ejecutar</h3>
                    </div>
                    <span class="rounded-full px-3 py-1 text-xs font-semibold" style={`background:${readinessGapTone.bg};color:${readinessGapTone.fg}`}>{readinessGapLabel}</span>
                  </div>

                  <p class="mt-3 max-w-2xl text-sm leading-relaxed sm:text-base" style={`color:${axis.gray[600]}`}>
                    La base técnica muestra señales razonables, pero la capacidad de acción queda más baja: faltan señales o rutas más claras para que un motor pase de entender el sitio a completar una acción.
                  </p>

                  <div class="readiness-flow mt-6" aria-label="Ruta de operabilidad para agentes">
                    {readinessFlow.map((step, index) => (
                      <div class="readiness-flow-step" style={`--step-color:${step.color}`}>
                        <span class="readiness-flow-index">
                          <ReportIcon name={step.icon} size={15} />
                          <span class="sr-only">Paso {index + 1}</span>
                        </span>
                        <div>
                          <p class="font-semibold" style={`color:${axis.gray[900]}`}>{step.label}</p>
                          <p class="mt-1 text-xl font-semibold tabular-nums" style={`color:${axis.gray[900]}`}>{step.value}</p>
                          <p class="mt-1 text-xs leading-relaxed" style={`color:${axis.gray[600]}`}>{step.detail}</p>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>

                <aside class="readiness-diagnostic-aside border-t p-5 sm:p-6 lg:border-l lg:border-t-0" style={`border-color:${axis.gray[100]}`}>
                  <div class="readiness-metric-card" style={`--metric-color:${agenticReadinessMeta.border};--metric-bg:${agenticReadinessMeta.bg}`}>
                    <div class="flex items-start justify-between gap-3">
                      <div>
                        <p class="eyebrow-sub" style={`color:${axis.gray[600]}`}>Capacidad de acción</p>
                        <p class="mt-1 text-4xl font-semibold tabular-nums" style={`color:${axis.gray[900]}`}>{agenticReadinessScore ?? '—'}<span class="text-base" style={`color:${axis.gray[400]}`}>/100</span></p>
                      </div>
                      <span class="rounded-full px-2.5 py-1 text-xs font-semibold" style={`background:${agenticReadinessMeta.bg};color:${agenticReadinessMeta.fg}`}>{agenticReadinessMeta.label}</span>
                    </div>
                    <p class="mt-3 text-sm" style={`color:${axis.gray[600]}`}>{agenticCoverageLabel} pruebas con evidencia medible.</p>
                    <div class="mt-4 h-2 overflow-hidden rounded-full" style={`background:${axis.gray[100]}`}>
                      <div data-bar class="h-full rounded-full" style={`width:${agenticReadinessScore ?? 0}%;background:${agenticReadinessMeta.border}`}></div>
                    </div>
                  </div>

                  <div class="readiness-metric-card mt-4" style={`--metric-color:${structuralReadinessMeta.border};--metric-bg:${structuralReadinessMeta.bg}`}>
                    <div class="flex items-start justify-between gap-3">
                      <div>
                        <p class="eyebrow-sub" style={`color:${axis.gray[600]}`}>Base técnica</p>
                        <p class="mt-1 text-3xl font-semibold tabular-nums" style={`color:${axis.gray[900]}`}>{structuralReadinessScore ?? '—'}<span class="text-base" style={`color:${axis.gray[400]}`}>/100</span></p>
                      </div>
                      <span class="rounded-full px-2.5 py-1 text-xs font-semibold" style={`background:${structuralReadinessMeta.bg};color:${structuralReadinessMeta.fg}`}>{structuralReadinessMeta.label}</span>
                    </div>
                    <p class="mt-3 text-sm" style={`color:${axis.gray[600]}`}>{structuralCoverageLabel} pruebas con evidencia medible.</p>
                    <div class="mt-4 h-2 overflow-hidden rounded-full" style={`background:${axis.gray[100]}`}>
                      <div data-bar class="h-full rounded-full" style={`width:${structuralReadinessScore ?? 0}%;background:${structuralReadinessMeta.border}`}></div>
                    </div>
                  </div>
                </aside>
              </div>
            </section>
          )}

          {/* ══ 06 · CATEGORÍA PERCIBIDA ══ */}
          {showCategorySection && (
            <section
              class="border-t py-16"
              data-capture="report-category-association"
              data-category-status={categoryStatus}
              style={`border-color:${axis.gray[100]}`}
            >
              <p class="eyebrow" style={`color:${axis.accent[500]}`}>{sectionNumbers.category} · Categoría percibida</p>
              <h2 class="section-title" style={`color:${axis.gray[900]}`}>Qué entiende la IA sobre tu categoría</h2>
              <p class="section-lead" style={`color:${axis.gray[600]}`}>
                Esta lectura revisa si los motores alcanzan a ubicar la marca por industria, sector, oferta, caso de uso, mercado o comprador. Si el run no trae señales suficientes, el informe lo declara como cobertura y no inventa narrativa.
              </p>
              {categoryRows.length > 0 ? (
                <div class="report-panel mt-6 overflow-hidden rounded-2xl border bg-white" data-capture="report-category-mapped" style={`border-color:${axis.gray[100]}`}>
                  <div class="grid lg:grid-cols-[1.05fr_0.95fr]">
                    <div class="p-5 sm:p-6 lg:p-7" style={`background:linear-gradient(135deg, ${axis.gray[50]}, #fff 72%)`}>
                      <span class="inline-flex items-center gap-2 rounded-full px-3 py-1 text-xs font-semibold bg-white" style={`color:${axis.accent[700]};border:1px solid ${axis.gray[100]}`}>
                        <ReportIcon name="engines" size={14} />
                        Lectura principal
                      </span>
                      <h3 class="mt-4 text-2xl font-semibold leading-tight sm:text-3xl" style={`color:${axis.gray[900]}`}>{primaryCategoryName}</h3>
                      <p class="mt-3 max-w-2xl text-sm leading-relaxed sm:text-base" style={`color:${axis.gray[600]}`}>
                        Los motores tienden a encuadrar la marca en este territorio. Eso influye en qué búsquedas apareces, contra quién te comparan y qué autoridad esperan ver antes de recomendarte.
                      </p>
                      <div class="mt-5 flex flex-wrap gap-2">
                        <span class="rounded-full px-3 py-1 text-xs font-semibold" style={`background:${axis.gray[100]};color:${axis.accent[700]}`}>{primaryCategory ? categorySignalLabel(primaryCategory.count) : 'Señal pendiente'}</span>
                        <span class="rounded-full px-3 py-1 text-xs font-semibold" style={`background:${axis.gray[100]};color:${axis.gray[800]}`}>{primaryCategoryLevel.label}</span>
                        <span class="rounded-full px-3 py-1 text-xs font-semibold" style={`background:${axis.gray[50]};color:${axis.gray[800]}`}>{categorySignalTotal || categoryRows.length} señales totales</span>
                      </div>
                    </div>

                    <div class="border-t p-5 sm:p-6 lg:border-l lg:border-t-0 lg:p-7" style={`border-color:${axis.gray[100]}`}>
                      <p class="eyebrow-sub" style={`color:${axis.gray[600]}`}>Qué significa</p>
                      <div class="mt-4 space-y-4">
                        <div class="flex gap-3">
                          <span class="report-icon-badge mt-0.5" style={`--icon-color:${axis.success[700]}`}><ReportIcon name="signal" size={15} /></span>
                          <p class="text-sm leading-relaxed" style={`color:${axis.gray[600]}`}><strong style={`color:${axis.gray[900]}`}>Si coincide con tu estrategia,</strong> conviene reforzar esa asociación con fuentes propias, casos y páginas que usen el mismo lenguaje.</p>
                        </div>
                        <div class="flex gap-3">
                          <span class="report-icon-badge mt-0.5" style={`--icon-color:${axis.warning[700]}`}><ReportIcon name="priority" size={15} /></span>
                          <p class="text-sm leading-relaxed" style={`color:${axis.gray[600]}`}><strong style={`color:${axis.gray[900]}`}>Si no coincide,</strong> la IA puede estar activando comparaciones equivocadas o dejando fuera la oferta que más quieres posicionar.</p>
                        </div>
                      </div>
                    </div>
                  </div>

