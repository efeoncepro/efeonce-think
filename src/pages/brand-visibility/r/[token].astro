          class="mt-8 px-6 pt-11 pb-28 sm:py-14"
          style={`background:linear-gradient(155deg,${axis.accent[800]} 0%,${axis.accent[900]} 66%,#06233b 100%);border-top:1px solid rgba(255,255,255,0.08)`}
        >
          <div class="mx-auto grid max-w-7xl gap-7 lg:grid-cols-[minmax(0,1.08fr)_minmax(20rem,0.62fr)] lg:items-center">
            <div class="max-w-3xl text-center sm:text-left">
              <p class="eyebrow-sub" style="color:rgba(255,255,255,0.62)">Siguiente paso</p>
              <h2 class="mt-2 text-3xl font-semibold text-balance text-white sm:text-[2.25rem]" style="line-height:1.08">
