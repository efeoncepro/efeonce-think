                                <div data-bar class="h-full rounded-full" style={`width:${barWidth}%;background:${axis.accent[500]}`}></div>
                              </div>
                            )}
                          </li>
                        )
                      })}
                    </ul>
                  </div>
                </div>
              ) : (
