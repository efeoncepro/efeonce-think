              </div>

              <div class="grid gap-4 border-t p-5 sm:grid-cols-3 sm:p-6" style={`border-color:${axis.gray[100]}`}>
                <div>
                <p class="inline-section-label" style={`color:${axis.gray[600]}`}><ReportIcon name="sample" size={15} />Muestra del diagnóstico</p>
                <p class="mt-1 text-xl font-semibold tabular-nums" style={`color:${axis.gray[900]}`}>{provenance?.promptCount ?? '—'}</p>
                <p class="mt-1 text-xs" style={`color:${axis.gray[600]}`}>prompts evaluados</p>
              </div>
              <div>
                <p class="inline-section-label" style={`color:${axis.gray[600]}`}><ReportIcon name="engines" size={15} />Motores muestreados</p>
