  }
  .g-aside strong {
    color: var(--muted); font-size: var(--t-over); font-weight: var(--w-label);
    letter-spacing: 0.08em; text-transform: uppercase;
  }
  .g-next {
    display: flex; gap: 1rem; align-items: center; justify-content: space-between;
    padding: 1rem 1.15rem; background: var(--navy);
    color: var(--ink-d); border-radius: var(--g-card-radius); text-decoration: none;
    border: 1px solid var(--navy-3);
    transition: transform var(--dur) var(--ease), background-color var(--dur) var(--ease);
  }
  .g-next:hover {
    background: var(--navy-3); transform: translateX(3px);
  }
  .g-next:focus-visible { outline: 2px solid var(--blue); outline-offset: 3px; }
  @media (max-width: 640px) {
    .g-serp-h { display: grid; }
    .g-serp-badge { justify-self: start; }
    .g-list li { grid-template-columns: 1.4rem minmax(0, 1fr); gap: 0.55rem; align-items: start; }
    .g-kind { grid-column: 2; justify-self: start; white-space: normal; line-height: 1.25; }
    .g-diagnosis p,
    .g-aside { grid-template-columns: 1fr; gap: 0.35rem; }
  }

  /* ══════════ ② EL ARTÍCULO ══════════ */
  .read-stage {
    position: relative;
    isolation: isolate;
    width: min(100%, 64rem);
    margin-inline: auto;
    padding-block: clamp(0.75rem, 1.8vw, 1.35rem) 1rem;
  }
  @media (max-width: 720px) {
    .read-stage {
      width: 100%;
      padding-block-start: 0.95rem;
    }
  }

  .xr[data-step='articulo'] main.xr-wrap {
    padding-bottom: clamp(2rem, 5vw, 3.5rem);
  }
  .xr[data-step='articulo'] .xr-next {
    position: fixed;
    left: 0.75rem;
    right: 0.75rem;
    bottom: max(1rem, env(safe-area-inset-bottom));
    z-index: 30;
    width: auto;
    margin: 0;
    padding: 0;
    pointer-events: none;
    transition: opacity var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .xr[data-step='articulo'] .xr-next a {
    pointer-events: auto;
    width: min(100%, 30rem);
    max-width: none;
    margin-inline: auto;
    min-height: 4.35rem;
    padding: 0.85rem 1rem 0.85rem 1.15rem;
    border-radius: 10px;
    border: 1px solid var(--navy-3);
    box-shadow:
      0 22px 60px color-mix(in srgb, var(--navy) 20%, transparent),
      0 1px 0 rgb(255 255 255 / 0.12) inset;
  }
  .xr[data-step='articulo'] .xr-next a:hover {
    transform: translateY(-2px);
  }
  .xr[data-step='articulo'] .xr-next-l {
    letter-spacing: 0.12em;
  }
  .xr[data-step='articulo'] .xr-next-t {
    font-size: clamp(1.02rem, 1.45vw, 1.22rem);
    line-height: 1.18;
    text-wrap: balance;
  }
  .xr-next-t-short {
    display: none;
  }
  .xr[data-step='articulo'] .xr-next-arrow {
    width: 2rem;
    height: 2rem;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: color-mix(in srgb, var(--blue-up) 12%, transparent);
  }
  @media (min-width: 1280px) {
    .xr[data-step='articulo'] .xr-next {
      left: calc(50% + 32rem + 1rem);
      right: auto;
      bottom: clamp(1rem, 2vw, 1.5rem);
      width: min(12rem, calc(50vw - 32rem - 2rem));
    }
    .xr[data-step='articulo'] .xr-next a {
      width: 100%;
      min-height: 4rem;
      margin-inline: 0;
      padding: 0.72rem 0.65rem 0.72rem 0.8rem;
      gap: 0.55rem;
    }
    .xr[data-step='articulo'] .xr-next-l {
      font-size: 0.58rem;
      letter-spacing: 0.1em;
    }
    .xr[data-step='articulo'] .xr-next-l-prefix {
      display: none;
    }
    .xr[data-step='articulo'] .xr-next-t-full {
      display: none;
    }
    .xr[data-step='articulo'] .xr-next-t-short {
      display: block;
      font-size: 1rem;
      line-height: 1.08;
    }
    .xr[data-step='articulo'] .xr-next-arrow {
      width: 1.8rem;
      height: 1.8rem;
    }
  }
  @media (min-width: 1280px) and (max-width: 1439px) {
    .xr[data-step='articulo'] .xr-next a {
      justify-content: center;
      gap: 0.45rem;
    }
    .xr[data-step='articulo'] .xr-next-l {
      text-align: center;
      line-height: 1.2;
    }
    .xr[data-step='articulo'] .xr-next-t-short {
      display: none;
    }
  }
  @media (max-width: 720px) {
    .xr[data-step='articulo'] main.xr-wrap {
      padding-bottom: calc(5.75rem + env(safe-area-inset-bottom));
    }
    .xr[data-step='articulo'] .xr-next {
      left: 0.75rem;
      right: 0.75rem;
      bottom: calc(0.75rem + env(safe-area-inset-bottom));
      width: auto;
    }
    .xr[data-step='articulo'] .xr-next a {
      width: 100%;
      max-width: none;
      justify-content: space-between;
      min-height: 3.45rem;
      padding: 0.55rem 0.7rem 0.55rem 0.85rem;
      border-radius: 10px;
    }
    .xr[data-step='articulo'] .xr-next-l {
      font-size: 0.6rem;
      letter-spacing: 0.11em;
    }
    .xr[data-step='articulo'] .xr-next-t {
      font-size: 0.9rem;
      line-height: 1.18;
    }
    .xr[data-step='articulo'] .xr-next-arrow {
      width: 1.55rem;
      height: 1.55rem;
    }
  }
  .xr[data-step='articulo'][data-next-state='done'] .xr-next {
    opacity: 0;
    transform: translateY(0.65rem);
    pointer-events: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .xr[data-step='articulo'] .xr-next a:hover {
      transform: none;
    }
  }

  /* ══════════ ③ LA RADIOGRAFÍA ══════════ */
  /* EL MARCO DE LA ③. La pantalla que carga toda la revelación no puede abrir con una instrucción:
     abre con el ARGUMENTO. Y si alguien entra por deep-link desde el deck, acá se defiende sola. */
  .r-head {
    max-width: 74ch;
    margin: 0 0 clamp(0.9rem, 1.6vw, 1.25rem);
    padding-top: clamp(1.35rem, 3vw, 2.4rem);
  }
  .r-h1 {
    font-family: Poppins, system-ui, sans-serif; font-size: var(--t-sect); font-weight: var(--w-display);
    line-height: 1.16; letter-spacing: 0; color: var(--ink); margin-top: 0.3rem; max-width: 32ch; text-wrap: balance;
  }
  .r-h1 em { font-style: italic; color: var(--blue); }
  .r-thesis { margin-top: 0.65rem; font-size: var(--t-body); line-height: 1.58; color: var(--ink-3); max-width: 64ch; }

  .r-hint { padding-top: 0.45rem; font-size: var(--t-meta); color: var(--muted); }
  .hint-d { display: none; }
  @media (hover: hover) and (pointer: fine) { .hint-d { display: block; } .hint-m { display: none; } }
  @media (max-width: 720px) { .hint-d { display: none; } .hint-m { display: block; } }
      /* EN MÓVIL, LA ③ ES UNA LECTURA INTERROGABLE.
     Poner el instrumento primero convertía la radiografía en una capa de máquina antes de que el
     evaluador viera qué iba a tocar. El trabajo educativo de la pantalla no es enseñar teoría AEO:
     es dejar que el comprador toque un bloque visible y vea qué produce.

     Con JS, el instrumento espera cerrado y sube como hoja inferior al acoplar. Sin JS, queda después
     del artículo como contenido estático: la pieza no promete interacción, pero sigue siendo legible. */
  .split { display: grid; grid-template-columns: 1fr; gap: 1.25rem; min-width: 0; padding-top: 0.65rem; }
  @media (max-width: 1079px) {
    .xr[data-js='on'] .split > :global(.inst) { display: none; }
    .xr[data-js='on'][data-sheet='open'] .split > :global(.inst) { display: block; }
  }
  @media (min-width: 1080px) {
    .r-head {
      display: grid;
      grid-template-columns: minmax(0, 0.95fr) minmax(20rem, 0.78fr);
      column-gap: clamp(2rem, 4vw, 4.5rem);
      align-items: end;
      max-width: min(100%, 88rem);
    }
    .r-head .g-kick,
    .r-h1 {
      grid-column: 1;
    }
    .r-thesis {
      grid-column: 2;
      grid-row: 1 / span 2;
      align-self: end;
      margin-top: 0;
      padding-bottom: 0.1rem;
      font-size: 1rem;
      line-height: 1.62;
    }
    .split { grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr); align-items: start; }
    .split :global(.inst) {
      position: sticky; top: 6rem; max-height: calc(100vh - 7.2rem); overflow-y: auto;
      view-transition-name: xr-inst; /* el instrumento LLEGA desde la derecha, no aparece */
    }
  }

  @media (max-width: 720px) {
    .r-head {
      padding-top: clamp(1rem, 5vw, 1.5rem);
      margin-bottom: 0.9rem;
    }
    .r-h1 {
      font-size: clamp(1.58rem, 6.2vw, 1.9rem);
      line-height: 1.12;
    }
    .r-thesis {
      font-size: 1rem;
      line-height: 1.54;
    }
  }

  /* ══════════ ④ DÓNDE MÁS VIVE ══════════ */
  .at-intro { margin-top: 1rem; font-size: 1.125rem; line-height: 1.65; color: var(--ink-2); max-width: 68ch; }
  .at-lineage {
    margin-top: 1.35rem; padding: 0.75rem; border: 1px solid var(--line);
    border-radius: 14px; background: color-mix(in srgb, var(--blue-up) 5%, white);
    display: grid; gap: 0.55rem; align-items: center;
  }
  .at-lineage-source {
    padding: 0.65rem 0.75rem; border-radius: 10px; background: #fff;
    border: 1px solid color-mix(in srgb, var(--line) 82%, transparent);
  }
  .at-lineage-source span,
  .at-lineage-bridge {
    display: block; font-size: var(--t-over); font-weight: var(--w-label);
    letter-spacing: 0; text-transform: uppercase; color: var(--muted);
  }
  .at-lineage-source-k {
    display: flex; align-items: center; gap: 0.35rem;
  }
  .at-lineage-source-k svg { flex: 0 0 auto; color: var(--blue-up); }
  .at-lineage-source strong {
    display: block; margin-top: 0.2rem; font-size: var(--t-meta);
    line-height: 1.35; color: var(--ink); font-weight: var(--w-label);
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .at-lineage-bridge { text-align: center; color: var(--blue-up); }
  .at-lineage-list {
    list-style: none; display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 0.4rem; min-width: 0;
  }
  .at-lineage-list li {
    min-width: 0; padding: 0.55rem 0.6rem; border-radius: 10px;
    background: var(--navy); color: var(--ink-d); border: 1px solid var(--navy-3);
  }
  .at-lineage-list li[data-artifact='social'] {
    background: color-mix(in srgb, var(--client) 11%, var(--navy));
    border-color: color-mix(in srgb, var(--client) 42%, var(--navy-3));
  }
  .at-lineage-list span {
    display: flex; align-items: center; gap: 0.35rem; font-family: Poppins, system-ui, sans-serif;
    font-size: 0.78rem; line-height: 1.2; font-weight: var(--w-display); color: #fff;
  }
  .at-channel-icon {
    width: 1.25rem; height: 1.25rem; border-radius: 999px;
    display: inline-grid; place-items: center; flex: 0 0 auto;
    background: color-mix(in srgb, var(--blue-up) 16%, var(--navy-2));
    color: var(--blue-up); font-style: normal;
  }
  .at-lineage-list li[data-artifact='social'] .at-channel-icon {
    background: color-mix(in srgb, var(--client) 18%, var(--navy-2));
    color: #fff;
  }
  .at-lineage-list small {
    display: none; margin-top: 0.2rem; font-size: 0.75rem;
    line-height: 1.35; color: var(--dim-d);
  }
  .at-grid { display: grid; grid-template-columns: 1fr; gap: 1.25rem; margin-top: 1.35rem; align-items: start; }
  @media (max-width: 979px) {
    .atom[data-featured='true'] { order: -1; }
  }
  @media (min-width: 980px) {
    .at-lineage { grid-template-columns: minmax(0, 1fr) auto minmax(0, 2.1fr); padding: 0.95rem; gap: 0.75rem; }
    .at-lineage-source { padding: 0.8rem 0.9rem; }
    .at-lineage-source strong { display: block; overflow: visible; }
    .at-lineage-list { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .at-lineage-list li { padding: 0.7rem 0.8rem; }
    .at-lineage-list span { font-size: var(--t-meta); line-height: 1.35; }
    .at-lineage-list small { display: block; }
    .at-grid { grid-template-columns: minmax(0, 1fr) minmax(0, 1.35fr) minmax(0, 1fr); }
    .atom[data-featured='true'] { transform: translateY(-0.35rem); }
  }

  .atom {
    background: var(--navy); color: var(--ink-d); border: 1px solid var(--navy-3);
    border-radius: 14px; padding: 1.2rem; min-width: 0; position: relative;
    outline: 2px solid transparent; scroll-margin-top: 5rem;
  }
  .atom[data-featured='true'] {
    border-color: color-mix(in srgb, var(--client) 42%, var(--navy-3));
    background: color-mix(in srgb, var(--client) 10%, var(--navy));
    box-shadow: 0 18px 40px color-mix(in srgb, var(--navy) 18%, transparent);
  }
  .atom:focus-visible { outline: 2px solid var(--blue-up); }
  .atom-h { display: flex; align-items: flex-start; gap: 0.65rem; margin-bottom: 0.9rem; }
  .atom-icon {
    width: 2rem; height: 2rem; border-radius: 999px; display: inline-grid; place-items: center;
    flex: 0 0 auto; color: var(--blue-up);
    background: color-mix(in srgb, var(--blue-up) 12%, var(--navy-2));
    border: 1px solid color-mix(in srgb, var(--blue-up) 26%, var(--navy-3));
  }
  .atom[data-artifact='social'] .atom-icon {
    color: #fff; background: color-mix(in srgb, var(--client) 22%, var(--navy-2));
    border-color: color-mix(in srgb, var(--client) 38%, var(--navy-3));
  }
  .atom-title { min-width: 0; display: grid; gap: 0.25rem; }
  .atom-k {
    display: block;
    font-family: Poppins, system-ui, sans-serif; font-size: var(--t-node);
    font-weight: var(--w-display); color: #fff;
  }
  /* La LÍNEA DE SANGRE: de qué bloque del artículo nació. No son entregables sueltos. */
  .atom-from { font-size: var(--t-meta); color: var(--blue-up); }
  .atom-artifact { margin-top: 1rem; min-width: 0; }
  .atom-proof {
    margin-top: 1rem; padding: 0.85rem 0.9rem; border-radius: 12px;
    background: color-mix(in srgb, var(--blue-up) 7%, var(--navy-2));
    border: 1px solid color-mix(in srgb, var(--blue-up) 20%, var(--navy-3));
    display: grid; gap: 0.55rem;
  }
  .atom-section-label {
    display: block; font-size: var(--t-over); font-weight: var(--w-label);
    letter-spacing: 0.08em; text-transform: uppercase; color: var(--blue-up);
  }
  .atom-stat {
    display: grid; grid-template-columns: auto minmax(0, 1fr); gap: 0.7rem;
    align-items: start; margin: 0; color: var(--ink-d);
  }
  .atom-stat strong {
    font-family: Poppins, system-ui, sans-serif; font-size: 2.05rem; font-weight: var(--w-display);
    line-height: 0.95; color: #fff; font-variant-numeric: tabular-nums; letter-spacing: 0;
  }
  .atom-stat span {
    display: block; font-size: var(--t-meta); font-weight: var(--w-body-dark);
    line-height: 1.45; color: var(--ink-d); letter-spacing: 0;
  }
  /* La fuente de la cifra. Sobre navy el texto sube un paso (--w-body-dark): el mismo peso
     sobre oscuro se rasteriza más fino. Misma voz, distinto sustrato. */
  .atom-cite {
    display: block; padding-top: 0.55rem; border-top: 1px solid color-mix(in srgb, var(--line-d) 58%, transparent);
    font-size: 0.75rem; line-height: 1.45; color: var(--dim-d);
    font-style: normal; font-weight: var(--w-body-dark);
  }
  /* Las cuatro fotos reales, con su alt. El argumento de las imágenes deja de estar solo AFIRMADO. */
  .atom-imgs { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.65rem; list-style: none; }
  .atom-imgs img {
    width: 100%; aspect-ratio: 1 / 0.78; object-fit: cover; border-radius: 8px; display: block;
  }
  .atom-alt {
    margin-top: 0.32rem; font-size: 0.66rem; line-height: 1.35; color: var(--dim-d);
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
  }
  .atom-alt span {
    display: inline-block; margin-right: 0.3rem; padding: 0.05rem 0.3rem; border-radius: 3px;
    background: var(--navy-3); color: var(--blue-up); font-family: ui-monospace, monospace;
  }

  .atom-rationale {
    margin-top: 0.85rem; padding-left: 0.85rem;
    border-left: 2px solid color-mix(in srgb, var(--blue-up) 42%, var(--navy-3));
  }
  .atom-rationale p {
    margin-top: 0.35rem; font-size: var(--t-meta); line-height: 1.6; color: var(--dim-d);
  }

  /* La pieza social, renderizada. Es un mockup del entregable.
     `position: relative` NO es cosmético: `.pc-brand` es absolute, y sin este ancla se
     colgaba del `.atom` (el único ancestro posicionado) — la marca de SKY terminaba abajo
     del todo, encima de NUESTRA nota de honestidad, como si SKY la firmara. */
  .post-card {
    position: relative;
    padding: 1.1rem; border-radius: 12px;
    background: linear-gradient(160deg, color-mix(in srgb, var(--client) 90%, black), color-mix(in srgb, var(--client) 55%, black));
    color: #fff; aspect-ratio: 4 / 5; display: flex; flex-direction: column; justify-content: center; gap: 0.6rem;
  }
  .atom[data-featured='true'] .post-card { padding: 1.35rem; }
  .atom[data-featured='true'] .pc-body { font-size: 1.25rem; }
  @media (min-width: 980px) { .atom[data-featured='true'] .pc-body { font-size: 1.55rem; } }
  .pc-hook { font-size: var(--t-meta); font-weight: var(--w-label); text-transform: uppercase; letter-spacing: 0.06em; opacity: 0.85; }
  .pc-body { font-family: Poppins, system-ui, sans-serif; font-size: 1.25rem; font-weight: var(--w-display); line-height: 1.3; text-wrap: balance; }
  .pc-cta { font-size: var(--t-meta); opacity: 0.9; }
  .pc-brand {
    position: absolute; right: 1.9rem; bottom: 1.9rem; font-family: Poppins, system-ui, sans-serif;
    font-weight: var(--w-display); font-size: 0.8125rem; letter-spacing: 0.06em; opacity: 0.75;
  }
  .video-artifact {
    margin: 0; display: grid; gap: 0.7rem;
  }
  .video-frame {
    position: relative; overflow: hidden; border-radius: 12px; background: var(--navy-sunk);
    border: 1px solid color-mix(in srgb, var(--blue-up) 24%, var(--navy-3));
  }
  .video-frame img,
  .video-frame video {
    width: 100%; aspect-ratio: 16 / 9; object-fit: cover; display: block; filter: saturate(1.08) contrast(1.02);
  }
  .video-frame video { background: var(--navy-sunk); }
  .video-disclosure {
    position: absolute; top: 0.65rem; left: 0.65rem; z-index: 1;
    display: inline-flex; align-items: center; padding: 0.25rem 0.45rem; border-radius: 999px;
    background: color-mix(in srgb, var(--navy-sunk) 72%, transparent);
    border: 1px solid color-mix(in srgb, #fff 22%, transparent);
    color: #fff; font-size: 0.66rem; line-height: 1; font-weight: var(--w-label);
  }
  .video-caption {
    position: absolute; inset: auto 0 0; padding: 2.4rem 0.85rem 0.8rem;
    background: linear-gradient(180deg, transparent, color-mix(in srgb, var(--navy-sunk) 92%, transparent));
  }
  .video-caption span {
    display: block; font-size: 0.68rem; font-weight: var(--w-label);
    letter-spacing: 0; text-transform: uppercase; color: var(--blue-up);
  }
  .video-caption strong {
    display: block; margin-top: 0.2rem; font-family: Poppins, system-ui, sans-serif;
    font-size: 1rem; line-height: 1.25; color: #fff;
  }
  .reel-artifact {
    display: grid; grid-template-columns: minmax(7.5rem, 0.48fr) minmax(0, 1fr); gap: 0.8rem; align-items: center;
    padding: 0.7rem; border-radius: 12px;
    background: color-mix(in srgb, var(--blue-up) 7%, var(--navy-2));
    border: 1px solid color-mix(in srgb, var(--blue-up) 22%, var(--navy-3));
  }
  .reel-phone {
    position: relative; overflow: hidden; width: 100%; max-width: 10.25rem; justify-self: center;
    border-radius: 13px; background: var(--navy-sunk);
    border: 1px solid color-mix(in srgb, #fff 15%, transparent);
    box-shadow: 0 18px 40px color-mix(in srgb, #000 24%, transparent);
  }
  .reel-preview {
    display: block; width: 100%; aspect-ratio: 9 / 16; object-fit: cover;
    background: var(--navy-sunk); filter: saturate(1.05) contrast(1.02);
  }
  .reel-copy { min-width: 0; }
  .reel-copy span {
    display: block; font-size: var(--t-over); font-weight: var(--w-label);
    letter-spacing: 0; text-transform: uppercase; color: var(--blue-up);
  }
