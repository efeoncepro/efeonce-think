---
import { Image } from 'astro:assets'
import { getCollection } from 'astro:content'
import { FileText, Images, MessagesSquare, Play } from '@lucide/astro'
import BaseLayout from '@layouts/BaseLayout.astro'
import EfeonceSlogan from '@/components/EfeonceSlogan.astro'
import Article from '@/components/aeo-xray/Article.astro'
import Instrument from '@/components/aeo-xray/Instrument.astro'
// Los pesos de display de la pieza. SIN estos imports la ruta solo hereda los del slogan
// (800/900i, que son de la marca) y el algoritmo de matching CSS resuelve TODO 600/700 a 800:
// los titulares salían ExtraBold sin que el CSS lo pidiera. Un @font-face que falta no falla: sustituye.
import '@fontsource/poppins/500.css'
import '@fontsource/poppins/600.css'
import '@styles/aeo-xray.css'

/**
 * Radiografía AEO — el FLOW. TASK-1410 (greenhouse-eo).
 *
 * CUATRO PANTALLAS, cada una con UN trabajo. Estaba todo en una sola, y el síntoma era que
 * el artículo «se veía plano»: nunca tuvo espacio para ser LEÍDO, porque un panel le comía el
 * 46% de la pantalla. Le pusimos tipografía editorial a un contenedor que no lo era.
 *
 *   ① El hueco       — el SERP real. Wikipedia, Instagram, TripAdvisor. Y SKY no está.
 *   ② El artículo    — a ancho completo, sin nada al lado. Acá por fin respira.
 *   ③ La radiografía — el split con el acoplamiento. Funciona 10× mejor porque el evaluador
 *                      YA leyó el artículo: la revelación aterriza en vez de competir.
 *   ④ Dónde más vive — la atomización. Cada átomo es una SUPERFICIE MÁS donde el motor de
 *                      respuesta puede encontrar al cliente.
 *
 * ⚠️ INVARIANTE #1: el JSON-LD se muestra como TEXTO ESCAPADO, nunca como marcado activo.
 * Esta página NO le pasa `jsonLd` a BaseLayout. Ver Instrument.astro.
 */

export const prerender = true

export async function getStaticPaths() {
  const samples = await getCollection('aeoXray')

  return samples.flatMap(sample =>
    sample.data.flow.map(s => ({
      // URL = `<slug legible>-<token>`: el slug porque el evaluador lee la URL antes que el H1;
      // el token porque sin él la muestra de un cliente es adivinable desde la de otro.
      params: { slug: `${sample.id}-${sample.data.token}`, step: s.step || undefined },
      props: { sample, step: s.step },
    })),
  )
}

const { sample, step } = Astro.props
const d = sample.data
const { ui, machine, evidence, meta, client, flow, gap, atoms, thesis } = d
const headlineFacts = evidence.facts.filter(f => f.headline)

const base = `/muestras/${sample.id}-${d.token}`
const i = flow.findIndex(s => s.step === step)
const cur = flow[i]
const next = flow[i + 1]
const href = (s: string) => (s ? `${base}/${s}` : base)

/** El par pintado desde el HTML: sin JS, la pieza sigue argumentando. */
/**
 * 🔴 EL MOTOR NO PUEDE CONOCER UN `coupleId` DEL CLIENTE.
 *
 * Antes esto era `const HERO = 'capsule-main'` — una cadena de SKY escrita en el motor, y repetida
 * DOS veces más dentro del `<script>` del cliente. Sostenía dos invariantes: el par héroe pintado
 * desde el HTML (*sin JS, la pieza sigue argumentando*) y la salida del enfoque. Un payload que
 * llamara a su cápsula `capsule-hero` llegaba **sin `data-on`** y no fallaba nada: simplemente el
 * argumento zero-JS desaparecía en silencio. El acoplamiento más barato de romper y el más caro de
 * detectar.
 *
 * Ahora el héroe se DERIVA del payload: la primera cápsula de respuesta acoplable del artículo. Y
 * viaja al script por `data-hero`, no por una constante — así el JS deja de conocer al cliente.
 */
const coupleIdOf = (b: (typeof d.article.blocks)[number]): string =>
  'coupleId' in b && typeof b.coupleId === 'string' ? b.coupleId : ''

const HERO =
  d.article.blocks.filter(b => b.type === 'answer-capsule').map(coupleIdOf).find(Boolean) ??
  d.article.blocks.map(coupleIdOf).find(Boolean) ??
  ''

/**
 * Cuántos datos de máquina produce cada bloque — alimenta el chip direccional («→ 3 datos»).
 * Sin el número, el hover te dice QUE hay algo al otro lado, pero no CUÁNTO ni hacia dónde.
 */
const produces = new Map<string, number>()
const bump = (id: string) => produces.set(id, (produces.get(id) ?? 0) + 1)
machine.seo.forEach(x => bump(x.coupleId))
machine.og.forEach(x => bump(x.coupleId))
machine.craft.forEach(x => bump(x.coupleId))
machine.jsonld.forEach(x => bump(x.coupleId))
machine.alts.forEach(x => bump(x.coupleId))
machine.headings.tree.forEach(x => bump(x.coupleId))
bump(machine.headings.coupleId)
evidence.facts.forEach(x => bump(x.coupleId))
evidence.fanOut.items.forEach(x => bump(x.coveredBy))

/* Las fotos del artículo — las mismas, con su alt. El átomo de imágenes las EXHIBE en vez de
   limitarse a argumentar sobre ellas. */
const imageBlocks = d.article.blocks.filter(
  (b): b is Extract<typeof b, { type: 'image' | 'hero-image' }> =>
    b.type === 'image' || b.type === 'hero-image',
)

const codeRecord = (code: unknown): Record<string, unknown> =>
  code && typeof code === 'object' ? (code as Record<string, unknown>) : {}

const codeField = (code: unknown, key: string): string => {
  const value = codeRecord(code)[key]
  return typeof value === 'string' ? value : ''
}

const deliverableValue = (atom: (typeof atoms)[number], pattern: RegExp): string =>
  atom.deliverable.find(x => pattern.test(x.k))?.v ?? ''

const artifactKind = (atom: (typeof atoms)[number]) => {
  const type = codeField(atom.code, '@type')

  if (atom.post) return 'social'
  if (atom.showsImages) return 'images'
  if (type === 'VideoObject') return 'video'

  return 'asset'
}

const asText = (code: unknown) =>
  JSON.stringify({ '@context': 'https://schema.org', ...(code as object) }, null, 2)

const titles: Record<string, string> = {
  '': `${meta.instrument} — el hueco`,
  articulo: `${meta.instrument} — el artículo`,
  radiografia: `${meta.instrument} — la radiografía`,
  atomizacion: `${meta.instrument} — dónde más vive`,
}
---

<BaseLayout
  title={`${titles[step ?? ''] ?? meta.instrument} · muestra de Efeonce para ${meta.sampleFor}`}
  description="Muestra de trabajo de Efeonce: un artículo, su capa de máquina y dónde más vive."
  noindex={true}
>
  {/* `data-hero` es el puente: el héroe se DERIVA del payload y viaja al script por el DOM, no por
      una constante. Así el JS del acoplamiento deja de conocer un `coupleId` del cliente. */}
  <div class="xr" data-testid="xray-root" data-step={step || 'hueco'} data-hero={HERO} style={`--client:${client.accent};--client-font:${client.font.family};--w-client-title:${client.font.titleWeight};--w-client-body:${client.font.bodyWeight}`}>
    <!-- ══ CHROME EFEONCE — la marca es dueña del marco, no un pie de página ══ -->
    <header class="xr-chrome" data-testid="disclaimer">
      <div class="xr-wrap xr-chrome-in">
        {/* LOCKUP, no isotipo. El isotipo solo comunica a quien YA conoce la marca —
            y el comité que abre esto no la conoce. El logotipo dice QUIÉN; el nombre de
            la herramienta, QUÉ. El separador impide que se lean como una sola cosa. */}
        <a class="xr-brand" href={base}>
          <img
            class="xr-logo"
            src="/branding/efeonce-logo-negative.svg"
            alt="Efeonce"
            width="102"
            height="24"
          />
          <span class="xr-brand-sep" aria-hidden="true"></span>
          <span class="xr-brand-t">{meta.instrument}</span>
        </a>
        <p class="xr-rotulo">
          <strong>{ui.disclaimerLabel}</strong>
          <span>{ui.disclaimerBody}</span>
        </p>
      </div>
    </header>

    <!-- El RIEL. Su trabajo no es navegar: es AVISAR que el recorrido tiene más pantallas. -->
    <nav class="xr-rail" aria-label="Recorrido de la muestra">
      <div class="xr-wrap xr-rail-in">
        {flow.map((s, n) => (
          <a
            class="xr-step"
            href={href(s.step)}
            aria-current={n === i ? 'step' : undefined}
          >
            {/* Número, nunca ✓. El ✓ afirmaba «ya lo viste» a quien entró por deep-link desde el
                deck y NO lo vio: historia inventada, y apagaba el scent que lo mandaría a leer el
                artículo primero — que es la lectura de la que depende la ③. El estado activo lo
                comunica `aria-current` + el realce, que es lo honesto. */}
            <span class="xr-step-n">{n + 1}</span>
            {s.label}
          </a>
        ))}
      </div>
    </nav>

    <main class="xr-wrap">
      {/* ══════════ ① EL HUECO ══════════ */}
      {!step && (
        <section class="gap" data-capture="aeo-xray-gap">
          <header class="g-head">
            <p class="g-kick">{gap.kicker}</p>
            <h1 class="g-h1">{gap.headline}</h1>
            {gap.lead && <p class="g-lead">{gap.lead}</p>}
          </header>

          <div class="g-kpis" aria-label="Resumen del diagnóstico">
            {headlineFacts.map((k, n) => (
              <div class:list={['g-kpi', { 'g-kpi-hit': n === headlineFacts.length - 1 }]}>
                <p class="g-kpi-l">{k.label}</p>
                <p class="g-kpi-n">{k.big}</p>
                <p class="g-kpi-u">{k.bigUnit}</p>
                <cite>{k.source} · {k.asOf}</cite>
              </div>
            ))}
          </div>

          <div class="g-grid">
            <div class="g-serp" data-capture="aeo-xray-gap-serp">
              <div class="g-serp-h">
                <div>
                  <p class="g-panel-k">Evidencia SERP</p>
                  <h2 class="g-serp-t">{gap.serpTitle}</h2>
                </div>
                {gap.serpBadge && <span class="g-serp-badge">{gap.serpBadge}</span>}
              </div>
              {gap.serpSummary && <p class="g-serp-s">{gap.serpSummary}</p>}
              <ol class="g-list">
                {gap.serp.map(r => (
                  <li>
                    <span class="g-pos">{r.pos}</span>
                    <span class="g-dom">{r.domain}</span>
                    <span class="g-kind">{r.kind}</span>
                  </li>
                ))}
              </ol>
              <p class="g-note">{gap.serpNote}</p>
            </div>

            <div class="g-side">
              <article class="g-punch" data-capture="aeo-xray-gap-diagnosis">
                {gap.diagnosisLabel && <p class="g-panel-k g-panel-k--dark">{gap.diagnosisLabel}</p>}
                <h2 class="g-punch-t">{gap.punch}</h2>
                <div class="g-diagnosis">
                  <p>
                    <strong>Qué muestra el SERP</strong>
                    <span>{gap.punchNote}</span>
                  </p>
                  {gap.punchWhy && (
                    <p>
                      <strong>Por qué importa</strong>
                      <span>{gap.punchWhy}</span>
                    </p>
                  )}
                  {gap.punchOpportunity && (
                    <p>
                      <strong>Dónde atacar</strong>
                      <span>{gap.punchOpportunity}</span>
                    </p>
                  )}
                </div>
              </article>
              <aside class="g-aside">
                {gap.asideLabel && <strong>{gap.asideLabel}</strong>}
                <span>{gap.aside}</span>
              </aside>
              {next && (
                <a class="g-next" href={href(next.step)}>
                  <span>
                    <span class="xr-next-l">{ui.flowNext}: paso {i + 2} {ui.flowOf} {flow.length}</span>
                    <span class="xr-next-t">{cur.next}</span>
                  </span>
                  <span class="xr-next-arrow" aria-hidden="true">→</span>
                </a>
              )}
            </div>
          </div>
        </section>
      )}

      {/* ══════════ ② EL ARTÍCULO — a ancho completo. Acá por fin se LEE. ══════════ */}
      {step === 'articulo' && (
        <div class="read-stage" data-capture="aeo-xray-article-read">
          <Article d={d} />
        </div>
      )}

      {/* ══════════ ③ LA RADIOGRAFÍA — el split con el acoplamiento ══════════ */}
      {step === 'radiografia' && (
        <>
          {/* 🔴 LA PANTALLA QUE CARGA TODO EL ARGUMENTO ERA LA ÚNICA SIN TITULAR.
              La ① tiene kicker + H1 + punch. La ④ tiene kicker + H1 + intro. La ③ abría directo con
              el hint —«pase el cursor y verá…»—, que dice CÓMO SE USA y nunca POR QUÉ IMPORTA. Doble
              golpe: para quien recorre en orden, la revelación llegaba sin enunciar; y para quien
              entra por DEEP-LINK desde el deck (caso de primera clase, la propia arquitectura lo
              promueve) era una pantalla partida sin contexto. No se defendía sola.

              Y la ironía: el payload YA TENÍA `thesis` (el schema lo obliga, `min(40)`) y
              `ui.thesisLabel`… y el motor NO LOS RENDERIZABA EN NINGUNA PARTE. Prosa obligatoria que
              nadie veía. */}
          <header class="r-head">
            <p class="g-kick">{ui.thesisLabel}</p>
            <h1 class="r-h1">
              El schema solo marca contenido <em>visible</em>. La máquina lee lo que el artículo dice.
            </h1>
            <p class="r-thesis">{thesis}</p>
          </header>
          <p class="r-hint hint-d" hidden data-hint>{ui.hintDesktop}</p>
          <p class="r-hint hint-m" hidden data-hint data-testid="hint-m">{ui.hintMobile}</p>
          <div class="split">
            <Article d={d} coupled produces={produces} hero={HERO} />
            <Instrument d={d} hero={HERO} />
          </div>
        </>
      )}

      {/* ══════════ ④ DÓNDE MÁS VIVE — la atomización ══════════ */}
      {step === 'atomizacion' && (
        <section class="at">
          <p class="g-kick">La distribución</p>
          <h1 class="at-h1">Este artículo no vive solo en una URL</h1>
          <p class="at-intro">{d.atomsIntro}</p>

          <div class="at-lineage" aria-label="Línea de sangre de la distribución">
            <div class="at-lineage-source">
              <span class="at-lineage-source-k"><FileText size={16} aria-hidden="true" />Artículo original</span>
              <strong>{meta.sampleTitle}</strong>
            </div>
            <div class="at-lineage-bridge" aria-hidden="true">se convierte en</div>
            <ul class="at-lineage-list">
              {atoms.map(a => (
                <li data-artifact={artifactKind(a)}>
                  <span>
                    <i class="at-channel-icon" aria-hidden="true">
                      {artifactKind(a) === 'video' && <Play size={15} />}
                      {artifactKind(a) === 'social' && <MessagesSquare size={15} />}
                      {artifactKind(a) === 'images' && <Images size={15} />}
                    </i>
                    {a.kind}
                  </span>
                  <small>{a.bornFrom}</small>
                </li>
              ))}
            </ul>
          </div>

          <div class="at-grid">
            {atoms.map(a => (
              <article class="atom" data-artifact={artifactKind(a)} data-featured={a.post ? 'true' : undefined} data-couple-target={a.coupleId} tabindex="0">
                <div class="atom-h">
                  <span class="atom-icon" aria-hidden="true">
                    {artifactKind(a) === 'video' && <Play size={18} />}
                    {artifactKind(a) === 'social' && <MessagesSquare size={18} />}
                    {artifactKind(a) === 'images' && <Images size={18} />}
                  </span>
                  <span class="atom-title">
                    <span class="atom-k">{a.kind}</span>
                    <span class="atom-from">{a.bornFrom}</span>
                  </span>
                </div>

                <div class="atom-artifact">
                  {artifactKind(a) === 'video' && imageBlocks[0] && (
                    <figure class="video-artifact">
                      <div class="video-frame">
                        {a.video ? (
                          <>
                            <video class="video-preview" src={a.video.src} poster={a.video.poster} muted playsinline loop autoplay preload="metadata" aria-label={a.video.alt}></video>
                            {a.video.disclosure && <span class="video-disclosure">{a.video.disclosure}</span>}
                          </>
                        ) : (
                          <Image src={imageBlocks[0].src} alt={imageBlocks[0].alt} widths={[360, 720]} sizes="420px" format="avif" quality={70} loading="lazy" />
                        )}
                        <div class="video-caption">
                          <span>{a.video?.label || deliverableValue(a, /duraci/i) || 'Video recuperable'}</span>
                          <strong>{codeField(a.code, 'name') || a.kind}</strong>
                        </div>
                      </div>
                      {a.reel && (
                        <div class="reel-artifact" data-capture="atom-video-reel">
                          <div class="reel-phone">
                            <video class="reel-preview" src={a.reel.src} poster={a.reel.poster} muted playsinline loop autoplay preload="metadata" aria-label={a.reel.alt}></video>
                            {a.reel.disclosure && <span class="video-disclosure">{a.reel.disclosure}</span>}
                          </div>
                          <div class="reel-copy">
                            <span>{a.reel.label || 'Reel vertical 9:16'}</span>
                            <strong>{a.reel.title || 'Reel vertical'}</strong>
                            {a.reel.description && <p>{a.reel.description}</p>}
                          </div>
                        </div>
                      )}
                      <div class="video-script">
                        <span>Guion + transcripción</span>
                        <p>{deliverableValue(a, /guion/i) || codeField(a.code, 'description')}</p>
                      </div>
                    </figure>
                  )}

                  {/* La pieza social se RENDERIZA. Es un mockup del entregable, como todo el resto. */}
                  {a.post && (
                    <div class="post-card">
                      <p class="pc-hook">{a.post.hook}</p>
                      <p class="pc-body">{a.post.body}</p>
                      <p class="pc-cta">{a.post.cta}</p>
                      <span class="pc-brand">{client.name}</span>
                    </div>
                  )}

                  {/* 🔴 ASIMETRÍA DE PRUEBA: el átomo de video ESPECIFICA el entregable y el social lo
                      RENDERIZA — pero el de imágenes, cuyo argumento textual es «un alt que dice
                      "paisaje" no sirve para nada; uno que dice "las agujas de roca del Cerro Castillo
                      nevadas sobre un lago" hace que esa foto se recupere», NO MOSTRABA NI UNA FOTO NI
                      UN ALT. Dos átomos demostraban y uno solo afirmaba — en la pieza cuya regla entera
                      es demostrar. Y de paso dejaba un hueco blanco de ~600px en la lámina de cierre.
                      Ahora enseña las cuatro fotos reales con su alt: el argumento se ve. */}
                  {a.showsImages && (
                    <ul class="atom-imgs">
                      {imageBlocks.map(img => (
                        <li>
                          <Image src={img.src} alt={img.alt} widths={[180, 360]} sizes="180px" format="avif" quality={65} loading="lazy" />
                          <p class="atom-alt"><span>alt</span> “{img.alt}”</p>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>

                <div class="atom-proof">
                  {/* La cifra va CON su fuente. La ④ afirmaba tres números sin una sola cita
                      mientras la ① y la ③ citaban todo — en la pieza cuya tesis es el rigor.
                      Sin fuente y sin fecha, una cifra es una opinión con números. */}
                  <span class="atom-section-label">Evidencia</span>
                  <p class="atom-stat"><strong>{a.stat}</strong> <span>{a.statNote}</span></p>
                  <cite class="atom-cite">{a.source} · {a.asOf}</cite>
                </div>

                <div class="atom-rationale">
                  <span class="atom-section-label">Criterio</span>
                  <p>{a.why}</p>
                </div>

                <div class="atom-spec">
                  <span class="atom-section-label">Entregable</span>
                  <dl class="atom-d">
                    {a.deliverable.map(x => (
                      <div class="atom-spec-row">
                        <dt>{x.k}</dt>
                        <dd>{x.v}</dd>
                      </div>
                    ))}
                  </dl>
                </div>

                {a.code && (
                  <details class="atom-code">
                    <summary>Ver los datos estructurados</summary>
                    <pre role="region" tabindex="0" aria-label={`Datos estructurados: ${a.kind}`}><code>{asText(a.code)}</code></pre>
                  </details>
                )}

                {/* Lo que la muestra NO puede fingir. Decirlo suma; simularlo la destruye. */}
                <div class="atom-hon" role="note">
                  <span>Nota de honestidad</span>
                  <p>{a.honesty}</p>
                </div>
              </article>
            ))}
          </div>

          {/* 🔴 EL RECORRIDO MORÍA ACÁ. Cuatro pantallas construyendo tensión y la soltaba en el
              vacío: la última línea era un párrafo con un borde encima, y después el footer. Un
              comité que termina convencido y SIN NADA QUE HACER con esa convicción se queda
              exactamente donde estaba — y el competidor de fondo es la indecisión.

              El cierre hace dos cosas que la pieza prometía y no entregaba:
              1. Cierra el arco contra la ① (el hueco → la disciplina que lo tapa).
              2. Le da al evaluador la HERRAMIENTA para verificarlo con sus propias manos. La
                 arquitectura dice, textual, que esto es «una prueba que el comité puede verificar
                 por su cuenta» — y en ninguna pantalla se le decía CÓMO. Convertir un claim en una
                 comprobación que hace él mismo es lo que le da el argumento que va a repetir en la
                 reunión interna. Hoy le pedíamos fe donde podíamos darle prueba. */}
          <footer class="at-end">
            <p class="at-close">{ui.closing}</p>

            <div class="verify">
              <p class="verify-t">{ui.verifyTitle}</p>
              <ol class="verify-l">
                {ui.verifySteps.map(v => (
                  <li>
                    <strong>{v.what}</strong>
                    <span>{v.how}</span>
                  </li>
                ))}
              </ol>
              {/* ⚠️ EL VALIDADOR IMPORTA. Schema.org valida ESTRUCTURA. El Rich Results Test de
                  Google reportaría el `FAQPage` como «detectado pero NO elegible para resultado
                  enriquecido» — que es exactamente el autogol del invariante 6, con el evaluador
                  de testigo. Es la herramienta correcta por la MISMA razón por la que la pieza no
                  promete la cajita. */}
              <p class="verify-n">{ui.verifyNote}</p>
            </div>
          </footer>
        </section>
      )}

      {next && step && (
        <div class="xr-next">
          <a href={href(next.step)} aria-label={`${ui.flowNext}: paso ${i + 2} ${ui.flowOf} ${flow.length}. ${cur.next}`}>
            <span>
              <span class="xr-next-l"><span class="xr-next-l-prefix">{ui.flowNext}: </span>paso {i + 2} {ui.flowOf} {flow.length}</span>
              <span class="xr-next-t xr-next-t-full">{cur.next}</span>
              <span class="xr-next-t xr-next-t-short">{next.label}</span>
            </span>
            <span class="xr-next-arrow" aria-hidden="true">→</span>
          </a>
        </div>
      )}

      <footer class="xr-foot">
        <EfeonceSlogan />
      </footer>
    </main>
  </div>
</BaseLayout>

<script>
  /**
   * En móvil el riel es horizontal. Si alguien entra por deep-link a la ④, el paso activo
   * no puede quedar fuera de la primera mirada: el riel debe decir "estás acá".
   */
  const activeXrayStep = document.querySelector<HTMLElement>('.xr-step[aria-current="step"]')

  if (activeXrayStep && window.matchMedia('(max-width: 719px)').matches) {
    requestAnimationFrame(() => {
      activeXrayStep.scrollIntoView({ block: 'nearest', inline: 'center' })
    })
  }
</script>

{step === 'articulo' && (
  <script>
    /**
     * El CTA acompaña la lectura, no el footer. Mientras queda artículo por leer flota
     * como rail lateral; cuando el final real del artículo entra en la mirada, se retira.
     */
    const articleRoot = document.querySelector<HTMLElement>('[data-testid="xray-root"][data-step="articulo"]')
    const articleStage = articleRoot?.querySelector<HTMLElement>('.read-stage')
    const nextAction = articleRoot?.querySelector<HTMLElement>('.xr-next')

    if (articleRoot && articleStage && nextAction) {
      let nextRaf = 0

      const updateNextState = () => {
        nextRaf = 0

        const stage = articleStage.getBoundingClientRect()
        const action = nextAction.getBoundingClientRect()
        const endLine = window.innerHeight - Math.max(112, action.height + 56)

        articleRoot.dataset.nextState = stage.bottom <= endLine ? 'done' : 'floating'
      }

      const queueNextState = () => {
        if (nextRaf) return
        nextRaf = window.requestAnimationFrame(updateNextState)
      }

      updateNextState()
      window.addEventListener('scroll', queueNextState, { passive: true })
      window.addEventListener('resize', queueNextState)
    }
  </script>
)}

{step === 'radiografia' && (
  <script>
    /**
     * Acoplamiento asimétrico artículo ↔ instrumento. CERO React: el contenido es estático;
     * hidratarlo para conmutar un resaltado sería over-hydration. Esto solo mueve `data-on`;
     * el CSS hace el resto. Sin JS, el par héroe ya viene pintado desde el HTML.
     */
    const root = document.querySelector<HTMLElement>('[data-testid="xray-root"]')
    /* El héroe llega por el DOM, DERIVADO del payload. El script no conoce al cliente. */
    const HERO = root?.dataset.hero ?? ''

    /* 🔴 PRIMERA LÍNEA: recién ahora la página puede prometer un acoplamiento.
       Todas las afordancias (cursor, punto, botón de sonda, chip) cuelgan de `[data-js]`. Sin JS
       el artículo se lee entero y la capa de máquina se lee apilada abajo — pero NADA promete una
       interacción que no existe. La lección ya estaba aprendida para el hint; faltaba el resto. */
    if (root) root.dataset.js = 'on'
    const live = document.querySelector<HTMLElement>('[data-testid="live"]')

    // El hint promete que el hover produce algo. Sin JS no produce nada: solo aparece con JS.
    document.querySelectorAll<HTMLElement>('[data-hint]').forEach(el => el.removeAttribute('hidden'))

    if (root) {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
      const inst = root.querySelector<HTMLElement>('.inst')
      const focusNote = root.querySelector<HTMLElement>('[data-testid="focus-note"]')
      /* El destino seguro del foco cuando el panel colapsa bajo él, y el ancla del focus-return
         al salir del enfoque. Es `tabindex="-1"`: alcanzable por script, nunca por Tab. */
      const instTitle = root.querySelector<HTMLElement>('#in-t')
      const showAll = root.querySelector<HTMLButtonElement>('[data-show-all]')
      let pinned: string | null = null

      /** MÓVIL: el instrumento espera fuera de la lectura. Sube como hoja al acoplar. */
      const sheet = () => window.matchMedia('(max-width: 1079px)').matches
      let opener: HTMLElement | null = null
      const closeSheet = () => {
        root.dataset.sheet = ''
        opener?.focus()
        opener = null
      }
      root.querySelector('[data-close-sheet]')?.addEventListener('click', closeSheet)

      /**
       * SALIR DEL ENFOQUE → volver al MAPA. Una sola puerta, usada por el botón y por Escape.
       *
       * El foco se mueve EXPLÍCITAMENTE al título del instrumento. Antes el botón se ocultaba al
       * activarse (solo existía en modo enfoque), así que el foco caía al inicio del documento y el
       * usuario de teclado quedaba perdido en una página de 9.000px — el mismo bug que el botón vino
       * a arreglar, ahora en la salida. Hoy el botón NO desaparece: queda `disabled` en su sitio.
       */
      const exitFocus = () => {
        pinned = null
        paint(HERO, false)
        if (showAll) showAll.disabled = true
        instTitle?.focus({ preventScroll: true })
        if (live) live.textContent = 'Capa completa: el instrumento vuelve a mostrarse entero.'
      }

      showAll?.addEventListener('click', exitFocus)

      /**
       * `collapse` separa los DOS MODOS del instrumento:
       *
       *  · MAPA (collapse=false) — el estado de llegada. El panel entero, agrupado por familia, con
       *    el acoplamiento héroe ya resaltado. Es el argumento de masa: «miren TODO lo que hay que
       *    poner para que una máquina cite esto». Si el panel se colapsara también al cargar, ese
       *    argumento no existiría nunca: el evaluador aterrizaría viendo tres tarjetas sueltas.
       *
       *  · ENFOQUE (collapse=true) — cuando el evaluador INTERROGA un bloque. El panel se reduce a
       *    lo que ese bloque produce y nada más.
       *
       * Primero ves la máquina entera. Después la apuntas.
       */
      const paint = (id: string | null, collapse = true) => {
        if (inst) inst.dataset.focus = id && collapse ? 'true' : ''
        if (sheet() && id) root.dataset.sheet = 'open'

        root.querySelectorAll<HTMLElement>('[data-couple],[data-couple-target]').forEach(el => {
          const mine = el.dataset.couple ?? el.dataset.coupleTarget
          const on = Boolean(id) && mine === id

          if (on) {
            el.dataset.on = 'true'
            el.setAttribute('aria-current', 'true')
          } else {
            delete el.dataset.on
            el.removeAttribute('aria-current')
          }

          /* El botón de sonda DICE si la capa de su bloque está desplegada en el panel. Sin esto,
             el lector de pantalla no sabe que el bloque controla algo remoto — ni si está activo. */
          if (el.dataset.couple) el.querySelector('[data-probe]')?.setAttribute('aria-expanded', String(on))
        })
        /**
         * EL INSTRUMENTO ENFOCA (no solo atenúa).
         *
         * El panel está ordenado POR FAMILIA (Metadatos · Datos estructurados · Estructura ·
         * Evidencia), pero al tocar un bloque la pregunta es «¿qué produce ESTO?» — una consulta
         * POR PRODUCTOR contra un layout POR FAMILIA. Los datos de un bloque nunca son contiguos.
         *
         * Antes solo atenuábamos y scrolleábamos al PRIMER match. Medido: de 51 datos prometidos
         * por los chips, 44 NO se veían nunca. El `h1` prometía 11 y mostraba 0. El primero en el
         * DOM suele ser el más aburrido («tu H2 está en la lista de H2») y el argumento de verdad
         * —«nadie en ese resultado resuelve la llegada»— quedaba 1.000px abajo, invisible.
         * Un chip que promete «4 datos» y muestra uno MIENTE, y en la pieza cuya tesis es el rigor
         * eso es lo más caro que puede pasar.
         *
         * Ahora el panel COLAPSA a lo que ese bloque produce y nada más: los N datos quedan
         * apilados arriba, sin cacería. En reposo vuelve a ser el mapa completo.
         */
        const body = inst?.querySelector<HTMLElement>('.in-body')
        body?.querySelectorAll<HTMLElement>('[data-hide]').forEach(el => delete el.dataset.hide)

        if (!id) {
          if (focusNote) focusNote.textContent = ''
          if (live) live.textContent = ''
          if (inst) inst.dataset.more = ''

          return
        }

        const target = root.querySelector<HTMLElement>(`[data-couple-target="${id}"]`)
        if (!target) return
        target.querySelector('details')?.setAttribute('open', '')

        /* En modo MAPA se resalta y se acabó: no se colapsa, no se scrollea, no se anuncia cuenta. */
        if (!collapse) {
          if (focusNote) focusNote.textContent = ''
          if (inst) inst.dataset.more = ''

          return
        }

        if (body) {
          /* Se conserva: cada nodo activo, su cadena de ancestros (para no romper el contenedor
             que lo envuelve) y todo lo que cuelga de él (el dato es el nodo ENTERO). */
          const keep = new Set<Element>()

          body.querySelectorAll<HTMLElement>('[data-on]').forEach(on => {
            for (let el: Element | null = on; el && el !== body; el = el.parentElement) keep.add(el)
            on.querySelectorAll('*').forEach(d => keep.add(d))
          })

          /* 🔴 NUNCA OCULTAR BAJO EL FOCO. `display:none` saca el nodo del árbol de accesibilidad Y
             del orden de tabulación: si el elemento activo queda dentro de lo que vamos a colapsar,
             el foco cae al `<body>` y el usuario aparece al inicio de una página de 9.000px sin
             entender qué pasó. Se lo movemos ANTES, al header del instrumento, que es el sitio
             correcto: es donde acaba de aparecer la cuenta («Lo que produce este bloque · 4 datos»). */
          const active = document.activeElement

          if (active instanceof HTMLElement && body.contains(active) && !keep.has(active)) {
            instTitle?.focus({ preventScroll: true })
          }

          /* Se colapsa: los rótulos de familia, los nodos de otros bloques, las filas del árbol
             que no son ésta y las preguntas del fan-out que este bloque no cubre. */
          body
            .querySelectorAll<HTMLElement>(':scope > *, .kpi, .t3wrap > *, .hn, .fan li')
            .forEach(el => {
              if (!keep.has(el)) el.dataset.hide = 'true'
            })

          /* 🔴 EL ORDEN IMPORTA TANTO COMO LA VISIBILIDAD.
             Se arregló QUÉ se ve; faltaba QUÉ SE LEE PRIMERO. Los nodos supervivientes quedaban en
             orden del DOM = orden de FAMILIA (craft → jsonld → seo → estructura → evidencia AL
             FINAL). Al interrogar un H2, lo primero que leía el comité era «cada H2 es una
             sub-pregunta del FAN-OUT… el motor recupera PASAJES, no páginas» — jerga pura. Y los dos
             nodos que de verdad ARGUMENTAN («cero aerolíneas en ese resultado», «Balmaceda es el
             ángulo que solo SKY tiene», ambos con fuente) iban 2.º y 3.º.

             El `tier` existe en el payload (1 = mueve un número del diagnóstico) y en modo enfoque no
             se usaba. Para quien no sabe SEO, la PRIMERA frase decide si sigue o se desconecta.

             Se ordenan los HIJOS DIRECTOS del panel (un `.hn` anidado no se puede reordenar solo):
             cada uno toma el mejor rango que sobrevive dentro suyo.

             ⚠️ Y el `tier` SOLO no alcanza: la evidencia y el árbol de encabezados son AMBOS tier 2,
             así que ordenar por tier los dejaba igual. El tier mide la importancia en la CAPA DE
             MÁQUINA; lo que decide si el comité sigue leyendo es otra cosa. Para quien no sabe SEO,
             la EVIDENCIA es el argumento («cero aerolíneas en ese resultado», «Balmaceda es el
             ángulo que solo SKY tiene»): va primero, siempre. Después el tier. */
          const rank = (el: Element) => {
            if (el.matches('.fct, .kpi') || el.querySelector('.fct, .kpi')) return 0
            const t = /\bt([123])\b/.exec(el.className)?.[1]

            return t ? Number(t) : 2
          }

          body.querySelectorAll<HTMLElement>(':scope > *').forEach(child => {
            if (child.dataset.hide) return
            const own = child.matches('[data-on]') ? rank(child) : 9
            const inner = [...child.querySelectorAll('[data-on]')].map(n => rank(n.parentElement ?? n))
            const best = Math.min(own, ...(inner.length ? inner : [9]))

            child.style.order = String(best === 9 ? 2 : best)
          })
        }

        /* Con el panel ya colapsado, los N datos empiezan arriba: se vuelve al tope en vez de
           perseguir un nodo. Y el header pegajoso deja de poder taparlo (WCAG 2.2 AA 2.4.11). */
        const pane = target.closest<HTMLElement>('.inst')
        pane?.scrollTo({ top: 0, behavior: reduce ? 'auto' : 'smooth' })

        const all = root.querySelectorAll(`[data-couple-target="${id}"]`).length
        const cuenta = `${all} ${all === 1 ? 'dato' : 'datos'}`

        /* El H1 produce ONCE datos y en pantalla caben cuatro. Si la pila enfocada desborda, hay que
           DECIRLO: si no, el header promete once y el ojo ve cuatro — que es la misma mentira que
           vinimos a arreglar, sólo que más chica. */
        requestAnimationFrame(() => {
          if (!inst || !pane) return
          inst.dataset.more = pane.scrollHeight > pane.clientHeight + 4 ? 'true' : ''
        })

        /* El comprador no tiene por qué saber SEO: se le dice en palabras, no solo con un realce. */
        if (focusNote) focusNote.textContent = `Lo que produce este bloque · ${cuenta}`
        if (showAll) showAll.disabled = false

        /* El anuncio tiene que ser HONESTO: si el resto de la capa se colapsó, hay que decirlo — y
           decir cómo volver. Antes anunciaba «4 datos. Primero: X» y dejaba al usuario de lector de
           pantalla creyendo que el panel seguía entero. */
        if (live) {
          const name = target.querySelector('.nd-l,.sch-t,.kpi-u')?.textContent?.trim()

          live.textContent =
            `Enfocado: ${cuenta}${name ? `. Primero: ${name}` : ''}. ` +
            'El resto de la capa está colapsada. Botón «Ver toda la capa» para volver.'
        }
      }

      const hit = (e: Event) =>
        (e.target as HTMLElement).closest<HTMLElement>('[data-couple],[data-couple-target]')

      /**
       * Modalidad de entrada. Sin esto, el mouse QUIETO le roba el acoplamiento al teclado: al
       * enfocar con Tab la página scrollea, los elementos pasan bajo el cursor inmóvil y
       * disparan `mouseover` fantasma que repinta encima de lo que el teclado seleccionó.
       */
      let keyboard = false
      root.addEventListener('mousemove', () => { keyboard = false }, { passive: true })
      document.addEventListener('keydown', e => {
        if (e.key === 'Tab' || e.key.startsWith('Arrow')) keyboard = true
      })

      /**
       * 🔴 EL INSTRUMENTO NO PUEDE REPINTARSE DESDE SÍ MISMO.
       *
       * Antes, `enter()` escuchaba sobre `[data-couple]` Y `[data-couple-target]` — o sea, los DOS
       * lados del split. Con el modo enfoque (que colapsa con `display:none` todo lo que el bloque
       * no produce), eso volvía el panel inusable con teclado:
       *
       *   1. El usuario tabula al primer nodo del instrumento.
       *   2. `focusin` → `paint(ese nodo)` → el 90% del panel se pone `display:none`.
       *   3. Tab: ya no queda nada enfocable dentro → SALE del instrumento.
       *
       * El evaluador con teclado NUNCA podía recorrer la capa de máquina: se le deshacía cada vez
       * que la tocaba. Y con mouse pasaba la variante fea: abrías un «Ver el código», movías el
       * cursor a otro bloque, y el elemento enfocado desaparecía → el foco caía al `<body>`.
       *
       * El acoplamiento nace en el ARTÍCULO y viaja al instrumento. Nunca al revés.
       */
      const enter = (e: Event) => {
        const el = hit(e)
        if (!el || pinned) return
        if (e.type === 'mouseover' && keyboard) return
        // Solo el lado del artículo dispara el acoplamiento. El panel se lee, no se repinta.
        if (!el.dataset.couple) return
        paint(el.dataset.couple)
      }

      root.addEventListener('mouseover', enter)
      root.addEventListener('focusin', enter)
      root.addEventListener('click', e => {
        const el = hit(e)
        if (!el) return
        const id = el.dataset.couple ?? el.dataset.coupleTarget ?? null
        if (sheet() && el.dataset.couple) opener = el
        pinned = pinned === id ? null : id
        paint(pinned ?? id)
      })
      document.addEventListener('keydown', e => {
        if (e.key !== 'Escape') return
        if (root.dataset.sheet === 'open') { closeSheet(); return }
        pinned = null
        /* Escape devuelve al MAPA (el panel entero), no a otro enfoque: es la salida del
           instrumento, y sin ella —al no haber `mouseout`, el acoplamiento es pegajoso a
           propósito— no habría forma de volver a ver la máquina completa sin recargar. */
        exitFocus()
      })
    }
  </script>
)}

