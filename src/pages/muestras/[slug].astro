  .faq .a { font-size: 1rem; line-height: 1.65; color: #4a5c6e; margin-top: 0.35rem; max-width: 62ch; }

  .lnks { margin-top: 0.2rem; }
  .lnks li { font-size: 1rem; margin: 0.5rem 0; line-height: 1.5; }
  .lnks a { color: var(--client); text-decoration: underline; text-underline-offset: 2px; font-weight: 500; }
  .lnks em { color: var(--muted); font-style: normal; font-size: 0.8125rem; }
  .srcs { border-top: 1px solid var(--line); margin-top: 2rem; padding-top: 1.1rem; }
  .srcs ul { padding-left: 1rem; list-style: disc; }
  .srcs li { font-size: 0.875rem; margin: 0.35rem 0; line-height: 1.5; }
  .srcs a { color: var(--muted); text-decoration: underline; }

  /* ══════ INSTRUMENTO — navy Efeonce ══════ */
  .inst { background: var(--navy); color: var(--ink-d); border: 1px solid var(--navy-3); }
  .in-head {
    display: flex; justify-content: space-between; align-items: center; gap: 1rem;
    padding: 0.9rem 1.1rem; border-bottom: 1px solid var(--line-d); background: var(--navy-2);
    border-radius: 12px 12px 0 0; position: sticky; top: 0; z-index: 2;
  }
  .in-head h2 { font-size: var(--t-body); font-weight: 600; }
  .in-live { font-size: var(--t-over); color: var(--dim-d); text-align: right; }

  /* Visible SOLO para lectores de pantalla. Le da voz al chip direccional, que es `content`
