  .sch-m {
    font-size: var(--t-over); font-weight: 700; color: var(--navy);
    background: var(--blue-up); padding: 0.12rem 0.45rem; border-radius: 999px; white-space: nowrap;
  }
  .sch pre {
    margin-top: 0.6rem; padding: 0.65rem; background: #04101d; color: #cfe3f5;
    border: 1px solid var(--line-d); border-radius: 7px;
    font-size: 0.6875rem; line-height: 1.55; overflow-x: auto; max-height: 20rem; max-width: 100%;
  }

  .hn { font-size: var(--t-meta); padding: 0.2rem 0.3rem; border-radius: 4px; outline: 2px solid transparent;
        transition: outline-color var(--dur) var(--ease), background-color var(--dur) var(--ease); }
  .hn.l2 { padding-left: 1.15rem; }
  .lv { display: inline-block; min-width: 1.7rem; font-weight: 700; color: var(--blue-up); font-size: 0.625rem; }

  .fct-v { font-size: var(--t-node); font-weight: 700; color: var(--blue-up); margin: 0.15rem 0; font-variant-numeric: tabular-nums; }
  .fct cite { display: block; margin-top: 0.4rem; font-size: 0.75rem; color: var(--dim-d); font-style: normal; }
