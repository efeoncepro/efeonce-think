  }
  .cap p { font-size: var(--a-lead); line-height: 1.6; color: #1e2f3f; max-width: 58ch; font-weight: 450; }
  .cap-t {
    display: block; margin-bottom: 0.4rem; font-size: var(--t-over); font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--client);
  }

  /* La CITA DESTACADA: rompe el muro de texto y es el pasaje que un motor puede extraer entero. */
  .pull {
    margin-block: 2rem; padding: 0.2rem 0 0.2rem 1.4rem;
    border-left: 4px solid var(--client);
  }
  .pull p {
    font-family: Poppins, system-ui, sans-serif;
    font-size: 1.4375rem; line-height: 1.35; font-weight: 500; letter-spacing: -0.01em;
    color: var(--ink); max-width: 30ch; text-wrap: balance;
  }

  .blk-t {
    font-family: Poppins, system-ui, sans-serif; font-weight: 600;
    font-size: 1.1875rem; margin-bottom: 0.7rem; letter-spacing: -0.01em;
  }

  /* La tabla tiene presencia editorial, no de planilla. */
  .tw { overflow-x: auto; max-width: 100%; border: 1px solid var(--line); border-radius: 10px; }
  table { width: 100%; min-width: 32rem; border-collapse: collapse; font-size: 0.9375rem; }
  caption { text-align: left; font-family: Poppins, system-ui, sans-serif; font-weight: 600;
            font-size: 1.1875rem; padding-bottom: 0.7rem; letter-spacing: -0.01em; }
  th, td { border-bottom: 1px solid var(--line); padding: 0.75rem 0.9rem; text-align: left; vertical-align: top; line-height: 1.5; }
