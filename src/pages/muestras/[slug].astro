  .grp em { font-style: normal; font-weight: 500; color: var(--dim-d); letter-spacing: 0.04em; text-transform: none; }
  .warn {
    font-size: var(--t-meta); line-height: 1.5; color: #ffd166;
    background: color-mix(in srgb, #ffd166 10%, var(--navy-2));
