  /* La FIRMA: categoría, autor, fecha, lectura. Es lo que el BlogPosting declara — y el
     schema solo puede marcar contenido VISIBLE. Sin esto, la muestra se contradice. */
  .head-blk { padding-top: 0.25rem; }
  .cat {
    font-size: var(--t-over); font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--client); margin-bottom: 0.6rem;
  }
  .p-h1 {
    font-family: Poppins, system-ui, sans-serif;
    font-size: var(--a-h1); font-weight: 600; line-height: 1.12; letter-spacing: -0.02em;
