---
import { getCollection } from 'astro:content'
import BaseLayout from '@layouts/BaseLayout.astro'
import EfeonceSlogan from '@/components/EfeonceSlogan.astro'

/**
 * Radiografía AEO — muestra de trabajo "artículo + su capa de máquina".
 * TASK-1410 (greenhouse-eo). Ver docs/ui/wireframes/TASK-1410-aeo-article-xray.md
 *
 * ⚠️ INVARIANTE #1 — El JSON-LD del artículo se renderiza como TEXTO ESCAPADO.
 * NUNCA dentro de un <script type="application/ld+json">, y esta página NO le pasa
 * `jsonLd` a BaseLayout. Emitirlo declararía, en NUESTRO dominio, que Efeonce publicó
 * un artículo del cliente: un dato estructurado falso, ingerible por crawlers, justo en
 * la pieza cuya tesis es el rigor técnico. `verify-aeo-xray.mjs` falla si aparece uno.
 *
 * ── LA DIRECCIÓN DE ARTE: la pieza es un INSTRUMENTO, y tiene que parecerlo. ──
 *
 * DOS ZONAS DE MARCA, y la separación es el diseño:
 *   · Izquierda = la muestra del CLIENTE. Fondo claro, su acento. Es el espécimen.
 *   · Derecha + todo el chrome = el INSTRUMENTO de Efeonce. Navy + azul. Es la máquina
 *     que lo lee.
 * Eso hace tres cosas de una: pone la marca Efeonce donde corresponde (el análisis es
 * NUESTRO, no puede hablar en el color del cliente), vuelve los dos lados inconfundibles
 * —así el ojo siempre sabe dónde está— y refuerza el disclaimer sin decir una palabra:
 * se VE que el artefacto del cliente está contenido dentro de nuestro instrumento.
 *
 * EL ACOPLAMIENTO ES ASIMÉTRICO. La fuente susurra, el destino grita. Si los dos gritan
 * igual, el ojo no sabe cuál es la causa y cuál el efecto — que era exactamente el bug.
 */

export const prerender = true

export async function getStaticPaths() {
  const samples = await getCollection('aeoXray')

  /** URL = `<slug legible>-<token>`. El slug porque el evaluador lee la URL antes que el H1;
   *  el token porque sin él la muestra de un cliente es adivinable desde la de otro. */
  return samples.map(sample => ({
    params: { slug: `${sample.id}-${sample.data.token}` },
    props: { sample },
  }))
}

const { sample } = Astro.props
const d = sample.data
const { ui, machine, evidence, article, client, meta } = d

/** El par que viene pintado desde el HTML: ES el frame que va a la lámina del deck.
 *  Tiene que verse COMPLETO en el pliegue, a los dos lados. */
const HERO = 'capsule-main'

type Block = (typeof article.blocks)[number]
type ImageBlock = Extract<Block, { type: 'image' | 'hero-image' }>
const isImage = (b: Block): b is ImageBlock => b.type === 'image' || b.type === 'hero-image'
const images = article.blocks.filter(isImage)

/**
 * Cuántos datos de máquina produce cada bloque del artículo.
 * Es lo que alimenta el chip direccional («→ 3 datos»): sin un número, el hover te dice
 * QUE hay algo al otro lado, pero no CUÁNTO ni hacia dónde mirar.
 */
const produces = new Map<string, number>()
const bump = (id: string) => produces.set(id, (produces.get(id) ?? 0) + 1)
machine.seo.forEach(x => bump(x.coupleId))
machine.og.forEach(x => bump(x.coupleId))
machine.craft.forEach(x => bump(x.coupleId))
machine.jsonld.forEach(x => bump(x.coupleId))
machine.alts.forEach(x => bump(x.coupleId))
machine.headings.tree.forEach(x => bump(x.coupleId))
// El contenedor del árbol de encabezados TAMBIÉN es un destino (se enciende entero).
// Sin contarlo, el chip decía 9 y el lector de pantalla anunciaba 10.
bump(machine.headings.coupleId)
// La evidencia y el fan-out también son destinos: si se encienden, se cuentan.
// Contarlos de menos hace que el chip prometa menos de lo que entrega.
evidence.facts.forEach(x => bump(x.coupleId))
evidence.fanOut.items.forEach(x => bump(x.coveredBy))

const kpis = evidence.facts.filter(f => f.headline)
const details = evidence.facts.filter(f => !f.headline)

/**
 * La FIRMA del artículo (categoría · autor · fecha · tiempo de lectura).
 *
 * No es adorno: es una corrección. El `BlogPosting` declara `author`, `datePublished` y
 * `articleSection`, y el schema SOLO puede marcar contenido VISIBLE (marcar contenido oculto
 * es violación de política de Google). Sin la firma en la página, la muestra estaría
 * violando su propia tesis. Que además le dé al artículo el aire de un post publicado —
 * en vez de un bloque de texto — es la consecuencia, no el motivo.
 */
const words = article.blocks.reduce((n, b) => {
  const t =
    'text' in b ? b.text
    : b.type === 'faq' ? b.items.map(i => `${i.q} ${i.a}`).join(' ')
    : b.type === 'ordered-list' ? b.items.join(' ')
    : b.type === 'table' ? b.rows.flat().join(' ')
    : ''

  return n + t.split(/\s+/).filter(Boolean).length
}, 0)
const readMin = Math.max(1, Math.round(words / 200))
const published = new Date(`${article.publishedAt}T12:00:00Z`).toLocaleDateString('es-CL', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
  timeZone: 'UTC',
})

/** Escapa el JSON-LD para mostrarlo como TEXTO. Jamás `set:html`. */
const asText = (code: unknown) =>
  JSON.stringify({ '@context': 'https://schema.org', ...(code as object) }, null, 2)
---

<BaseLayout
  title={`${meta.instrument} — muestra de Efeonce para ${meta.sampleFor}`}
  description="Muestra de trabajo de Efeonce: un artículo y su capa de máquina, lado a lado."
  noindex={true}
>
  <div class="xr" data-testid="xray-root" style={`--client:${client.accent}`}>
    <!-- ══ CHROME EFEONCE — la marca es dueña del instrumento, no un pie de página ══ -->
    <header class="chrome" data-testid="disclaimer">
      <div class="chrome-in">
        <div class="brand">
          <img src="/branding/efeonce-isotipo-negative.svg" alt="Efeonce" width="26" height="26" />
          <span class="brand-t">{meta.instrument}</span>
        </div>
        <p class="rotulo">
          <strong>{ui.disclaimerLabel}</strong>
          <span>{ui.disclaimerBody}</span>
        </p>
      </div>
    </header>

    <!-- ══ LEDE — la página se llama por lo que ES. El título del artículo vive en su panel. ══ -->
    <section class="lede">
      <p class="over">{meta.kicker}</p>
      <h1>{meta.instrument} <em>· muestra para {meta.sampleFor}</em></h1>
      <div class="thesis">
        <p class="thesis-l">{ui.thesisLabel}</p>
        <p class="thesis-b">{d.thesis}</p>
      </div>
      <p class="hint hint-d" hidden data-hint>{ui.hintDesktop}</p>
      <p class="hint hint-m" hidden data-hint data-testid="hint-m">{ui.hintMobile}</p>
    </section>

    <div class="split">
      <!-- ══════ ESPÉCIMEN — la marca del CLIENTE vive acá dentro, y solo acá ══════ -->
      <section class="specimen" aria-labelledby="sp-t">
        <div class="sp-head">
          <div>
            <h2 id="sp-t">{ui.paneArticleTitle}</h2>
            <p>{ui.paneArticleSubtitle}</p>
          </div>
          {/* La URL propuesta, en su contexto. Es el mismo valor que el panel declara como
              canónica: verlo acá es la mitad de la correspondencia. */}
          <span class="urlbar" title={article.proposedUrl}>
            <span class="lock" aria-hidden="true">🔒</span>
            <span class="url">{article.proposedUrl.replace('https://', '')}</span>
          </span>
        </div>

        <article class="post">
          {article.blocks.map(b => {
            if (!('coupleId' in b)) {
              if (b.type === 'paragraph') return <p class="para">{b.text}</p>

              return null
            }

            const on = b.coupleId === HERO ? true : undefined
            const n = produces.get(b.coupleId) ?? 0
            const attrs = {
              'data-couple': b.coupleId,
              'data-on': on,
              'data-n': n > 0 ? `${n} ${n === 1 ? ui.producesLabelOne : ui.producesLabel}` : undefined,
              tabindex: 0,
            }

            if (isImage(b))
              return (
                <figure class={`blk fig ${b.type === 'hero-image' ? 'hero' : ''}`} {...attrs}>
                  <span class="sr">{ui.srProduces.replace('{n}', String(n))}</span>
                  <img src={b.src} alt={b.alt} loading={b.type === 'hero-image' ? 'eager' : 'lazy'} />
                  <div class="fig-m">
                    {b.caption && <figcaption>{b.caption}</figcaption>}
                    <p class="credit">
                      Foto: {b.credit.author} · <a href={b.credit.url} rel="nofollow noopener">{b.credit.license}</a>
                    </p>
                  </div>
                </figure>
              )

            /* El H1 arrastra la FIRMA. El BlogPosting declara author/datePublished/articleSection,
               y el schema SOLO puede marcar contenido visible: sin firma, la muestra violaría su
               propia tesis. Que además haga que el artículo se lea como un post publicado —y no
               como un bloque de texto— es la consecuencia. */
            if (b.type === 'h1')
              return (
                <div class="blk head-blk" {...attrs}>
                  <span class="sr">{ui.srProduces.replace('{n}', String(n))}</span>
                  <p class="cat">{article.category}</p>
                  <h3 class="p-h1">{b.text}</h3>
                  <p class="byline">
                    {ui.bylineBy} <b>{article.author}</b>
                    <span class="dot" aria-hidden="true">·</span>
                    <time datetime={article.publishedAt}>{published}</time>
                    <span class="dot" aria-hidden="true">·</span>
                    {readMin} {ui.readTime}
                  </p>
                </div>
              )
            if (b.type === 'h2')
              return (
                <div class="blk" {...attrs}>
                  <h4 class="p-h2">{b.text}</h4>
                  <span class="sr">{ui.srProduces.replace('{n}', String(n))}</span>
                </div>
              )
            if (b.type === 'answer-capsule')
              return (
                <div class="blk cap" {...attrs}>
                  <span class="cap-t">Respuesta directa</span>
                  <p>{b.text}</p>
                  <span class="sr">{ui.srProduces.replace('{n}', String(n))}</span>
                </div>
              )
            if (b.type === 'pull-quote')
              return (
                <blockquote class="blk pull" {...attrs}>
                  <p>{b.text}</p>
                  <span class="sr">{ui.srProduces.replace('{n}', String(n))}</span>
                </blockquote>
              )
            if (b.type === 'sources')
              return (
                <div class="blk srcs" {...attrs}>
                  <p class="blk-t">{b.title}</p>
                  <ul>{b.items.map(i => <li><a href={i.href} rel="nofollow noopener">{i.text}</a></li>)}</ul>
                  <span class="sr">{ui.srProduces.replace('{n}', String(n))}</span>
                </div>
              )
            if (b.type === 'table')
              return (
                <div class="blk" {...attrs}>
                  <span class="sr">{ui.srProduces.replace('{n}', String(n))}</span>
                  <div class="tw">
                    <table>
                      <caption>{b.caption}</caption>
                      <thead><tr>{b.headers.map(h => <th scope="col">{h}</th>)}</tr></thead>
                      <tbody>{b.rows.map(r => <tr>{r.map(c => <td>{c}</td>)}</tr>)}</tbody>
                    </table>
                  </div>
                </div>
              )
            if (b.type === 'ordered-list')
              return (
                <div class="blk" {...attrs}>
                  <p class="blk-t">{b.title}</p>
                  <ol>{b.items.map(i => <li>{i}</li>)}</ol>
                  <span class="sr">{ui.srProduces.replace('{n}', String(n))}</span>
                </div>
              )
            if (b.type === 'faq')
              return (
                <div class="blk faq" {...attrs}>
                  <p class="blk-t">{b.title}</p>
                  {b.items.map(i => (
                    <div class="qa">
                      <p class="q">{i.q}</p>
                      <p class="a">{i.a}</p>
                    </div>
                  ))}
                </div>
              )
            if (b.type === 'internal-links')
              return (
                <div class="blk" {...attrs}>
                  <p class="blk-t">{b.title}</p>
                  <ul class="lnks">
                    {b.items.map(i => (
                      <li>
                        <a href={i.href} rel="nofollow noopener">{i.text}</a>
                        {i.note && <em> — {i.note}</em>}
                      </li>
                    ))}
                  </ul>
                </div>
              )

            return null
          })}
        </article>
      </section>

      <!-- ══════ INSTRUMENTO — navy Efeonce. Nuestro análisis habla con NUESTRA voz. ══════ -->
      <aside class="inst" aria-labelledby="in-t">
        <div class="in-head">
          <h2 id="in-t">{ui.instrumentTitle}</h2>
          <p class="in-live" role="status" aria-live="polite" data-testid="live"></p>
        </div>

        <div class="in-body">
          <!-- La evidencia ABRE el instrumento. Es el argumento, no el apéndice. -->
          <div class="kpis" data-testid="kpis">
            {kpis.map(k => (
              <div class="kpi" data-couple-target={k.coupleId} tabindex="0">
                <p class="kpi-n">{k.big}</p>
                <p class="kpi-u">{k.bigUnit}</p>
                <cite class="kpi-s">{k.source} · {k.asOf}</cite>
              </div>
            ))}
          </div>

          <!-- Nivel 1 primero: lo que mueve un número del diagnóstico. -->
          <p class="grp">Cómo está escrito</p>
          {machine.craft.map(c => (
            <div class={`nd t${c.tier}`} data-couple-target={c.coupleId} data-on={c.coupleId === HERO ? true : undefined} tabindex="0">
              {c.stat && (
                <p class="stat">{c.stat} <span>{c.statNote}</span></p>
              )}
              <p class="nd-l">{c.label} <em>· {c.detail}</em></p>
              <p class="why"><b>{ui.whyLabel}:</b> {c.why}</p>
            </div>
          ))}

          <p class="grp">Datos estructurados <em>· se muestran como texto</em></p>
          <p class="warn">{ui.schemaNote}</p>
          {/*
            El ARGUMENTO (el stat + el para qué) va siempre visible; el CÓDIGO va colapsado.
            Con el JSON desplegado por defecto el panel se volvía un muro de código y el
            argumento —que es lo que el comité recuerda— quedaba enterrado bajo su propia prueba.
          */}
          {machine.jsonld.map(n => (
            <div class={`nd t${n.tier} sch`} data-couple-target={n.coupleId} tabindex="0">
              <div class="sch-h">
                <span class="sch-t">{n.type}</span>
                <span class="sch-m">{n.metric}</span>
              </div>
              {n.stat && <p class="stat"><span class="stat-fix">arregla</span>{n.stat} <span>{n.statNote}</span></p>}
              {n.tier < 3 && <p class="why"><b>{ui.whyLabel}:</b> {n.why}</p>}
              <details>
                <summary>Ver el código</summary>
                <pre role="region" tabindex="0" aria-label={`Datos estructurados: ${n.type}`}><code>{asText(n.code)}</code></pre>
              </details>
            </div>
          ))}

          <p class="grp">Metadatos</p>
          {machine.seo.map(s => (
            <div class={`nd t${s.tier}`} data-couple-target={s.coupleId} tabindex="0">
              <p class="nd-l">{s.label} {s.detail && <em>· {s.detail}</em>}</p>
              <p class="nd-v">{s.value}</p>
              {s.tier < 3 && <p class="why"><b>{ui.whyLabel}:</b> {s.why}</p>}
            </div>
          ))}
          <div class="t3wrap">
            {machine.og.map(o => (
              <div class="nd t3" data-couple-target={o.coupleId} tabindex="0">
                <p class="nd-l">{o.label}</p>
                <p class="nd-v mono">{o.value}</p>
              </div>
            ))}
          </div>

          <p class="grp">Estructura</p>
          <div class="nd t2" data-couple-target={machine.headings.coupleId} tabindex="0">
            {machine.headings.tree.map(h => (
              <p class={`hn l${h.level}`} data-couple-target={h.coupleId} tabindex="0">
                <span class="lv">H{h.level}</span> {h.text}
              </p>
            ))}
            <p class="why"><b>{ui.whyLabel}:</b> {machine.headings.why}</p>
          </div>
          {machine.alts.map(a => (
            <div class="nd t2" data-couple-target={a.coupleId} tabindex="0">
              <p class="nd-v">“{a.alt}”</p>
              <p class="why"><b>{ui.whyLabel}:</b> {a.why}</p>
            </div>
          ))}

          <p class="grp">La evidencia <em>· por qué existe este artículo</em></p>
          {details.map(f => (
            <div class="nd t2 fct" data-couple-target={f.coupleId} tabindex="0">
              <p class="nd-l">{f.label}</p>
              <p class="fct-v">{f.value}</p>
              <p class="why">{f.note}</p>
              <cite>{ui.sourceLabel}: {f.source} · {f.asOf}</cite>
            </div>
          ))}
          <div class="nd t2">
            <p class="nd-l">{evidence.fanOut.title}</p>
            <p class="why">{evidence.fanOut.note}</p>
            <ul class="fan">
              {evidence.fanOut.items.map(i => (
                <li data-couple-target={i.coveredBy} tabindex="0">
                  <span class="ok" aria-hidden="true">{i.covered ? '✓' : '—'}</span>{i.q}
                </li>
              ))}
            </ul>
          </div>
          <p class="hon">{evidence.honesty}</p>
        </div>
      </aside>
    </div>

    <!-- ══ Licencias: es la demostración del requisito, no una nota al pie ══ -->
    <footer class="lic" data-testid="licenses">
      <p class="grp dark">{ui.licenseTitle}</p>
      <ul>
        {images.map(i => (
          <li>
            <span class="lic-a">{i.alt}</span>
            <span class="lic-c">{i.credit.author} · <a href={i.credit.url} rel="nofollow noopener">{i.credit.license}</a></span>
          </li>
        ))}
      </ul>
      <p class="lic-n">Todas las imágenes tienen licencia verificable y crédito visible. Ninguna fue generada con IA.</p>
      <p class="closing">{ui.closing}</p>
      <div class="slogan"><EfeonceSlogan /></div>
    </footer>
  </div>
</BaseLayout>

<script>
  /**
   * Acoplamiento asimétrico artículo ↔ instrumento.
   *
   * Cero React: el contenido es estático; hidratarlo para conmutar un resaltado sería
   * over-hydration. Esto solo mueve `data-on`; el CSS hace todo lo demás. Sin JS, el par
   * héroe ya viene pintado desde el HTML y la pieza sigue argumentando.
   */
  // El hint promete que el hover produce algo. Sin JS no produce nada: solo se muestra
  // cuando el JS realmente cargó. El copy no puede prometer lo que la página no va a cumplir.
  document.querySelectorAll<HTMLElement>('[data-hint]').forEach(el => el.removeAttribute('hidden'))

  const root = document.querySelector<HTMLElement>('[data-testid="xray-root"]')
  const live = document.querySelector<HTMLElement>('[data-testid="live"]')
  if (root) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    let pinned: string | null = null

    const inst = root.querySelector<HTMLElement>('.inst')

    const paint = (id: string | null) => {
      // Con un solo destino basta el resaltado. Pero el H1 enciende NUEVE nodos repartidos por
      // todo el panel: ves uno y los otros ocho quedan fuera de vista. Atenuar lo no-acoplado
      // hace que lo encendido resalte aunque esté disperso — y le dice al ojo cuántos hay.
      if (inst) inst.dataset.focus = id ? 'true' : ''

      root.querySelectorAll<HTMLElement>('[data-couple],[data-couple-target]').forEach(el => {
        const mine = el.dataset.couple ?? el.dataset.coupleTarget
        if (id && mine === id) {
          el.dataset.on = 'true'
          el.setAttribute('aria-current', 'true')
        } else {
          delete el.dataset.on
          el.removeAttribute('aria-current')
        }
      })
      if (!id) return

      const target = root.querySelector<HTMLElement>(`[data-couple-target="${id}"]`)
      if (!target) return
      target.querySelector('details')?.setAttribute('open', '')

      /**
       * Scrollea SOLO el panel, nunca la página. `scrollIntoView` no sirve: mueve todos los
       * ancestros scrolleables, y arrastrar la página bajo el cursor mientras alguien lee es
       * desorientador. Movemos el scrollTop del instrumento a mano.
       */
      const pane = target.closest<HTMLElement>('.inst')
      if (pane && pane.scrollHeight > pane.clientHeight) {
        /**
         * El encabezado del instrumento es `position: sticky`. Si scrolleamos el nodo al
         * borde del panel, el header lo TAPA — y el usuario ve medio número cortado sin
         * entender qué se le está señalando. Es WCAG 2.2 AA 2.4.11 (Focus Not Obscured),
         * el fallo más común de los dashboards modernos.
         * El tope real no es el borde del panel: es el borde de abajo del header pegajoso.
         */
        const head = pane.querySelector<HTMLElement>('.in-head')
        const safeTop = (head?.offsetHeight ?? 0) + 12
        const t = target.getBoundingClientRect()
        const p = pane.getBoundingClientRect()
        const top = t.top - p.top
        const bottom = t.bottom - p.top

        if (top < safeTop || bottom > pane.clientHeight - 12) {
          pane.scrollTo({
            top: pane.scrollTop + top - safeTop,
            behavior: reduce ? 'auto' : 'smooth',
          })
        }
      }
      if (live) {
        const all = root.querySelectorAll(`[data-couple-target="${id}"]`).length
        const name = target.querySelector('.nd-l,.sch-t,.kpi-u')?.textContent?.trim()
        live.textContent = name
          ? `${all} ${all === 1 ? 'dato resaltado' : 'datos resaltados'}. Primero: ${name}`
          : ''
      }
    }

    const hit = (e: Event) =>
      (e.target as HTMLElement).closest<HTMLElement>('[data-couple],[data-couple-target]')

    /**
     * Modalidad de entrada. Sin esto, el mouse QUIETO le roba el acoplamiento al teclado:
     * al enfocar con Tab la página scrollea, los elementos pasan por debajo del cursor
     * inmóvil y disparan `mouseover`, que repinta encima de lo que el teclado acababa de
     * seleccionar. Un usuario que navega con teclado y dejó el mouse apoyado en cualquier
     * parte no puede conducir la pieza. Lo cazó el assert 12 del verify.
     */
    let keyboard = false
    root.addEventListener('mousemove', () => { keyboard = false }, { passive: true })
    document.addEventListener('keydown', e => {
      if (e.key === 'Tab' || e.key.startsWith('Arrow')) keyboard = true
    })

    const enter = (e: Event) => {
      const el = hit(e)
      if (!el || pinned) return
      if (e.type === 'mouseover' && keyboard) return
      paint(el.dataset.couple ?? el.dataset.coupleTarget ?? null)
    }

    root.addEventListener('mouseover', enter)
    root.addEventListener('focusin', enter)
    root.addEventListener('click', e => {
      const el = hit(e)
      if (!el) return
      const id = el.dataset.couple ?? el.dataset.coupleTarget ?? null
      pinned = pinned === id ? null : id
      paint(pinned ?? id)
    })
    document.addEventListener('keydown', e => {
      if (e.key !== 'Escape') return
      pinned = null
      paint('capsule-main')
    })
  }
</script>

<style>
  /* ════════════════════════════════════════════════════════════════════════
     TOKENS
     Marca Efeonce (navy + azul) = el instrumento. `--client` = el espécimen.
     El azul de marca (#0375db) NO alcanza 4.5:1 sobre el navy, así que el texto
     sobre oscuro usa la versión levantada. El HEX de marca nunca va inline.
     ════════════════════════════════════════════════════════════════════════ */
  .xr {
    --navy: #001a33;
    --navy-2: #08203a;
    --navy-3: #0e2c4b;
    --line-d: #1b3c5e;
    --blue: #0375db;
    --blue-up: #58aef5;      /* texto/borde sobre navy */
    --ink-d: #e9f0f7;        /* texto principal sobre navy */
    --dim-d: #9db4cb;        /* texto secundario sobre navy (≥4.5:1) */

    --ink: #0d1b2a;
    --muted: #5a6b7d;
    --line: #e2e8f0;
    --tint-c: color-mix(in srgb, var(--client) 7%, white);

    /* Escala: base 16 × 1.25. La anterior eran 6 tamaños dentro de 4px — no era escala. */
    --t-over: 0.6875rem;   /* 11 — solo eyebrows, con tracking */
    --t-meta: 0.8125rem;   /* 13 */
    --t-body: 1rem;        /* 16 — el piso */
    --t-node: 1.25rem;     /* 20 */
    --t-sect: 1.5625rem;   /* 25 */
    --t-page: 1.9375rem;   /* 31 */
    --t-stat: 2.5rem;      /* 40 — el número es el héroe */

    --dur: 140ms;
    --ease: cubic-bezier(0.2, 0, 0, 1);

    color: var(--ink);
    font-size: var(--t-body);
  }

  /* ── Chrome Efeonce ─────────────────────────────────────────────────── */
  .chrome { position: sticky; top: 0; z-index: 30; background: var(--navy); color: var(--ink-d); }
  .chrome-in {
    max-width: 1560px; margin: 0 auto; padding: 0.6rem 1.25rem;
    display: flex; gap: 1.25rem; align-items: center; flex-wrap: wrap;
  }
  .brand { display: flex; gap: 0.55rem; align-items: center; flex-shrink: 0; }
  .brand img { display: block; }
  .brand-t {
    font-family: Poppins, system-ui, sans-serif; font-weight: 600;
    font-size: var(--t-meta); letter-spacing: 0.01em;
  }
  .rotulo {
    display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: baseline;
    font-size: var(--t-meta); line-height: 1.45;
    padding-left: 1.25rem; border-left: 1px solid var(--line-d);
  }
  .rotulo strong { color: #fff; white-space: nowrap; }
  .rotulo span { color: var(--dim-d); }

  /* ── Lede ───────────────────────────────────────────────────────────── */
  .xr > .lede,
  .xr > .split,
  .xr > .lic { max-width: 1560px; margin-inline: auto; padding-inline: 1.25rem; }
  .lede { padding-top: 1.75rem; padding-bottom: 1.25rem; max-width: min(1560px, 82ch + 2.5rem); }
  .over {
    font-size: var(--t-over); font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--muted);
  }
  .lede h1 {
    margin-top: 0.5rem; font-family: Poppins, system-ui, sans-serif;
    font-size: var(--t-page); font-weight: 600; line-height: 1.15; letter-spacing: -0.01em;
  }
  .lede h1 em { font-style: normal; font-weight: 400; color: var(--muted); }
  .thesis {
    margin-top: 1rem; padding: 0.9rem 1.1rem;
    background: var(--navy); color: var(--ink-d); border-radius: 8px;
    border-left: 3px solid var(--blue-up);
  }
  .thesis-l {
    font-size: var(--t-over); font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--blue-up);
  }
  .thesis-b { margin-top: 0.4rem; font-size: var(--t-body); line-height: 1.6; max-width: 78ch; }
  .hint { margin-top: 0.8rem; font-size: var(--t-meta); color: var(--muted); }
  .hint-d { display: none; }
  @media (hover: hover) and (pointer: fine) { .hint-d { display: block; } .hint-m { display: none; } }

  /* ── Split ──────────────────────────────────────────────────────────── */
  .split { display: grid; grid-template-columns: 1fr; gap: 1.25rem; min-width: 0; }
  @media (min-width: 1080px) {
    .split { grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr); align-items: start; }
    .inst { position: sticky; top: 3.4rem; max-height: calc(100vh - 4.6rem); overflow-y: auto; }
  }
  .specimen, .inst { min-width: 0; border-radius: 12px; }

  /* ══════ ESPÉCIMEN — claro, con el acento del CLIENTE ══════ */
  .specimen { background: #fff; border: 1px solid var(--line); }
  .sp-head {
    display: flex; justify-content: space-between; align-items: center; gap: 1rem;
    padding: 0.9rem 1.1rem; border-bottom: 1px solid var(--line); background: #fbfcfd;
    border-radius: 12px 12px 0 0;
  }
  .sp-head h2 { font-size: var(--t-body); font-weight: 600; }
  .sp-head p { font-size: var(--t-meta); color: var(--muted); }
  .urlbar {
    display: flex; gap: 0.4rem; align-items: center; min-width: 0; max-width: 22rem;
    font-size: var(--t-meta); color: var(--muted);
    background: #eef2f6; border: 1px solid var(--line);
    padding: 0.3rem 0.7rem; border-radius: 999px;
  }
  .lock { font-size: 0.625rem; opacity: 0.6; }
  .url { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  /* ══════════════════════════════════════════════════════════════════════════
     EL ESPÉCIMEN ES EDITORIAL, NO PRODUCT UI.
     Es un mockup de un blog real: cuerpo 18px / interlineado 1.7 / medida 62-66ch /
     imágenes que respiran / ritmo vertical con aire antes de cada H2.
     La V2 le aplicó densidad de producto (16px, márgenes de 0.45rem) y por eso se veía
     plano: le estábamos mostrando al comité un wireframe del contenido, no el contenido.
     ══════════════════════════════════════════════════════════════════════════ */
  .specimen { --a-body: 1.125rem; --a-lead: 1.25rem; --a-h1: 2.25rem; --a-h2: 1.5rem; }
  .post { padding: 0 0 1.5rem; }
  .post > .para,
  .post > .srcs { margin-inline: 1.75rem; }
  @media (max-width: 640px) { .post > .para, .post > .srcs { margin-inline: 1.15rem; } }

  /* ── EL LADO FUENTE DEL ACOPLAMIENTO ──
     La fuente SUSURRA: tinte + barra lateral, sin outline. Ya la estás tocando; no necesita
     llamarte. El que grita es el destino. */
  .blk {
    position: relative; padding: 0.5rem 0.75rem; border-radius: 8px; cursor: pointer;
    border-left: 3px solid transparent;
    transition: background-color var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  .post > .blk:not(.fig) { margin-inline: 1rem; }
  @media (max-width: 640px) { .post > .blk:not(.fig) { margin-inline: 0.4rem; } }
  .blk.fig { padding: 0; border-left: 0; }
  .blk:focus-visible { outline: 2px solid var(--ink); outline-offset: 2px; }
  .blk[data-on] { background: var(--tint-c); border-left-color: var(--client); }
  .blk.fig[data-on] { background: transparent; box-shadow: inset 0 0 0 3px var(--client); }

  /* AFORDANCIA EN REPOSO: un punto en el borde derecho dice "esto se conecta con algo allá".
     Sin ella, nada avisa que el artículo es interactivo. */
  .blk[data-n]::before {
    content: ''; position: absolute; right: 0.4rem; top: 50%; translate: 0 -50%;
    width: 5px; height: 5px; border-radius: 999px;
    background: color-mix(in srgb, var(--client) 45%, transparent);
    transition: opacity var(--dur) var(--ease), scale var(--dur) var(--ease);
    z-index: 2;
  }
  .blk[data-n]:hover::before { scale: 1.4; }
  .blk[data-on][data-n]::before { opacity: 0; }

  /* EL CHIP DIRECCIONAL: apunta al destino y dice CUÁNTO hay al otro lado.
     Apilado no hay canaleta que cruzar, así que apunta hacia abajo y vive adentro. */
  .blk[data-n]::after {
    content: '↓ ' attr(data-n);
    position: absolute; right: 0.25rem; top: 50%; translate: 0 -50%;
    font-size: var(--t-over); font-weight: 700; letter-spacing: 0.02em;
    color: #fff; background: var(--navy);
    padding: 0.2rem 0.5rem; border-radius: 999px; white-space: nowrap;
