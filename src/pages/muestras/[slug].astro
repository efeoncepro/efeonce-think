  .fig-m { padding: 0.55rem 1.75rem 0; }
  figcaption { font-size: 0.9375rem; line-height: 1.5; color: #4a5c6e; }
  .credit { margin-top: 0.25rem; font-size: 0.75rem; color: #7c8fa3; }
