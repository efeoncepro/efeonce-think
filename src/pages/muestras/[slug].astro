  /* Ritmo editorial: mucho aire ANTES de cada H2, poco después. El ojo agrupa por proximidad. */
  .p-h2 {
    margin-top: 2.25rem; font-family: Poppins, system-ui, sans-serif;
    font-size: var(--a-h2); font-weight: 600; line-height: 1.25; letter-spacing: -0.01em;
