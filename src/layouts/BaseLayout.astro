---
import '@fontsource-variable/geist'
import '@styles/global.css'

interface Props {
  title: string
  description?: string
  /** El informe per-lead es noindex (ADR §SEO); las landings de herramientas SÍ se indexan. */
  noindex?: boolean
}

const { title, description, noindex = false } = Astro.props
---

<!doctype html>
<html lang="es-CL">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Open Graph / Twitter — para unfurl bonito al compartir el link (NO afecta noindex) */}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Efeonce" />
    <meta property="og:locale" content="es_CL" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
  </head>
  <body class="min-h-dvh bg-white text-slate-900 antialiased" style="font-family:'Geist Variable',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif">
    <slot />
  </body>
</html>
