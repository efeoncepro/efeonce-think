---
import '@fontsource-variable/geist'
import '@styles/global.css'

interface Props {
  title: string
  description?: string
  /** El informe per-lead es noindex (ADR §SEO); las landings de herramientas SÍ se indexan. */
  noindex?: boolean
  canonical?: string
  ogImage?: string
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]
}

const { title, description, noindex = false, canonical, ogImage, jsonLd } = Astro.props
const site = Astro.site ?? new URL('https://think.efeoncepro.com')
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, site).toString()
const absoluteOgImage = ogImage ? new URL(ogImage, site).toString() : undefined
const jsonLdItems = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : []
const safeJsonLd = (value: Record<string, unknown>) => JSON.stringify(value).replace(/</g, '\\u003c')
---

<!doctype html>
<html lang="es-CL">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {/* Google Tag Manager — medición unificada con efeoncepro.com (misma propiedad GA4, container GTM-NGHPGRLZ).
        El page_view lo dispara un GA4 Config gateado por hostname dentro del container; los forms `<greenhouse-form>`
        emiten `gh_form_submission_accepted` → el tag genérico `generate_lead`. Doc: greenhouse-eo docs/reference/measurement-gtm-ga4. */}
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-NGHPGRLZ');
    </script>

    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large'} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#138760" />

    {/* Open Graph / Twitter — para unfurl bonito al compartir el link (NO afecta noindex) */}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Efeonce Think" />
    <meta property="og:locale" content="es_CL" />
    {absoluteOgImage && <meta property="og:image" content={absoluteOgImage} />}
    {absoluteOgImage && <meta property="og:image:alt" content={title} />}
    <meta name="twitter:card" content={absoluteOgImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {absoluteOgImage && <meta name="twitter:image" content={absoluteOgImage} />}
    {jsonLdItems.map((item) => <script type="application/ld+json" set:html={safeJsonLd(item)} is:inline />)}
    <slot name="head" />
  </head>
  <body class="min-h-dvh bg-white text-slate-900 antialiased" style="font-family:'Geist Variable',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif">
    {/* Google Tag Manager (noscript) */}
    <noscript is:inline><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NGHPGRLZ" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <slot />
  </body>
</html>
